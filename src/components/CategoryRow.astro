---
import VideoCard from './VideoCard.astro';

interface Video {
  videoId: string;
  title: string;
  duracion?: string;
  views?: number;
  slug: string;
}

interface Props {
  title: string;
  href?: string;
  videos: Video[];
  cardWidth?: string;
}
const { title, href, videos, cardWidth = '260px' } = Astro.props;
if (videos.length === 0) return;
---

<section class="nrow">
  <div class="nrow-header">
    <h2 class="nrow-title">
      {href
        ? <a href={href} class="nrow-title-link">{title}<span class="nrow-arrow">›</span></a>
        : title
      }
    </h2>
    {href && <a href={href} class="nrow-see-all" aria-label={`Ver todos los vídeos de ${title}`}>Ver todos <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>}
  </div>
  <div class="nrow-scroll">
    {videos.map(v => (
      <VideoCard videoId={v.videoId} title={v.title} duracion={v.duracion} views={v.views} slug={v.slug} width={cardWidth} />
    ))}
  </div>
</section>

<style>
  .nrow {
    padding: 1.5rem 0 0.5rem;
  }

  .nrow-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    gap: 1rem;
  }

  .nrow-title {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .nrow-title-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: inherit;
    transition: color 0.15s;
  }

  .nrow-title-link:hover { color: var(--accent); }
  .nrow-title-link:hover .nrow-arrow { opacity: 1; transform: translateX(2px); }

  .nrow-arrow {
    font-size: 1.2rem;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    line-height: 1;
  }

  .nrow-see-all {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-2);
    white-space: nowrap;
    transition: color 0.15s;
    flex-shrink: 0;
  }

  .nrow-see-all:hover { color: var(--accent); }

  .nrow-scroll {
    display: flex;
    gap: 6px;
    overflow-x: auto;
    padding-bottom: 12px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .nrow-scroll::-webkit-scrollbar { display: none; }
  .nrow-scroll > * { scroll-snap-align: start; }
</style>
