---
import VideoCard from './VideoCard.astro';

interface Video {
  videoId: string;
  title: string;
  duracion?: string;
  views?: number;
  slug: string;
}

interface Props {
  title: string;
  href: string;
  videos: Video[];
}
const { title, href, videos } = Astro.props;
---

<section class="cat-row">
  <div class="row-header">
    <h2 class="row-label">{title}</h2>
    <a href={href} class="row-more">
      Ver todos
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
  <div class="row-scroll">
    {videos.map(v => (
      <VideoCard
        videoId={v.videoId}
        title={v.title}
        duracion={v.duracion}
        views={v.views}
        slug={v.slug}
        width="260px"
      />
    ))}
  </div>
</section>

<style>
  .cat-row {
    padding: 1.75rem 0;
  }

  .row-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.1rem;
  }

  .row-label {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .row-more {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-2);
    white-space: nowrap;
    transition: color 0.15s;
  }

  .row-more:hover {
    color: var(--accent);
  }
</style>
