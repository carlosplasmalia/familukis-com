---
import VideoCard from './VideoCard.astro';

interface Video {
  videoId: string;
  title: string;
  duracion?: string;
  views?: number;
  slug: string;
}

interface Props {
  title: string;
  href: string;
  videos: Video[];
  accent?: boolean;
}
const { title, href, videos, accent = false } = Astro.props;
---

<section class={`cat-row${accent ? ' cat-row--accent' : ''}`}>
  <div class="cat-row-header">
    <h2 class="cat-row-title">
      {accent && <span class="accent-dot"></span>}
      {title}
    </h2>
    <a href={href} class="cat-row-link">
      Ver todos
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
  <div class="row-scroll">
    {videos.map(v => (
      <VideoCard
        videoId={v.videoId}
        title={v.title}
        duracion={v.duracion}
        views={v.views}
        slug={v.slug}
        size="md"
      />
    ))}
  </div>
</section>

<style>
  .cat-row {
    padding: 2rem 0;
  }

  .cat-row--accent {
    background: linear-gradient(135deg, rgba(255,107,0,0.06) 0%, transparent 60%);
    border-radius: var(--radius-lg);
    padding: 2rem 1.5rem;
    margin: 0 -1.5rem;
  }

  .cat-row-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .cat-row-title {
    font-size: 1.2rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .accent-dot {
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .cat-row-link {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .cat-row-link:hover {
    color: var(--accent);
  }
</style>
