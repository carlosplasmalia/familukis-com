---
const BREVO_URL = "https://9ab7b963.sibforms.com/serve/MUIFADIlif981oRL3CO9RsJ6MZRoDBPdav1100emuwGi9FhnJl6m939M2xMOAUZi33VCaYBEKvLr7fbtkPSVJBn-nvwDuD-UFrdNC7hUEm4makNYhhPrRV3DBZX8ZJT2LzrpYPyjj2sMnzWzDz2-bXnSAJqEl9nR8lf-lx2zv-AAVGhkrwd8u4qplqS3f7i2LK2IAuhfuFwZKQimAg==";
---

<section class="lead-section">
  <div class="lead-inner">

    <div class="lead-copy">
      <span class="lead-tag">Gratis</span>
      <h2>50 Retos Divertidos para Hacer en Casa</h2>
      <p>
        Descarga la guía con los mejores retos Familukis: fáciles de preparar,
        sin comprar nada especial. Perfectos para cualquier tarde en familia.
      </p>
      <ul class="lead-bullets">
        <li>✓ 50 retos listos para usar</li>
        <li>✓ Para todas las edades</li>
        <li>✓ Sin spam — solo planes Familukis</li>
      </ul>
    </div>

    <div class="lead-form-wrap">
      <iframe
        src={BREVO_URL}
        frameborder="0"
        scrolling="no"
        allowfullscreen
        class="lead-iframe"
        title="Suscríbete para recibir la guía gratis"
        loading="lazy"
      ></iframe>
    </div>

  </div>
</section>

<style>
  .lead-section {
    margin: 2rem 0;
    background: linear-gradient(135deg, #1a0a0a 0%, #1f1212 50%, #141414 100%);
    border-top: 1px solid rgba(229,9,20,0.2);
    border-bottom: 1px solid rgba(229,9,20,0.2);
    padding: 3rem 2rem;
  }

  .lead-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .lead-tag {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 10px;
    border-radius: 3px;
    margin-bottom: 0.75rem;
  }

  .lead-copy h2 {
    font-size: clamp(1.35rem, 2.5vw, 1.9rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .lead-copy p {
    color: var(--text-2);
    font-size: 0.92rem;
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .lead-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .lead-bullets li {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
  }

  /* Iframe wrapper — fondo blanco porque el form de Brevo es blanco */
  .lead-form-wrap {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  .lead-iframe {
    width: 100%;
    height: 280px;
    display: block;
    border: none;
  }

  @media (max-width: 800px) {
    .lead-inner {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .lead-section { padding: 2.5rem 1.25rem; }
    .lead-iframe { height: 300px; }
  }
</style>
