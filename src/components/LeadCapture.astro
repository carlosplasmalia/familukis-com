---
const BREVO_ACTION = "https://9ab7b963.sibforms.com/serve/MUIFADIlif981oRL3CO9RsJ6MZRoDBPdav1100emuwGi9FhnJl6m939M2xMOAUZi33VCaYBEKvLr7fbtkPSVJBn-nvwDuD-UFrdNC7hUEm4makNYhhPrRV3DBZX8ZJT2LzrpYPyjj2sMnzWzDz2-bXnSAJqEl9nR8lf-lx2zv-AAVGhkrwd8u4qplqS3f7i2LK2IAuhfuFwZKQimAg==";
---

<section class="lead-section">
  <div class="lead-inner">

    <div class="lead-copy">
      <span class="lead-tag">Gratis</span>
      <h2>50 Retos Divertidos para Hacer en Casa</h2>
      <p>
        Descarga la guía con los mejores retos Familukis: fáciles de preparar,
        sin comprar nada especial. Perfectos para cualquier tarde en familia.
      </p>
      <ul class="lead-bullets">
        <li>✓ 50 retos listos para usar</li>
        <li>✓ Para todas las edades</li>
        <li>✓ Sin spam — solo planes Familukis</li>
      </ul>
    </div>

    <div class="lead-form-wrap">
      <div id="lead-ready">
        <p class="lead-form-title">Recíbela en tu correo</p>
        <form
          id="lead-form"
          action={BREVO_ACTION}
          method="POST"
          class="lead-form"
        >
          <input
            type="email"
            name="EMAIL"
            placeholder="tu@email.com"
            required
            autocomplete="email"
            class="lead-input"
          />
          <input type="hidden" name="locale" value="es" />
          <input type="hidden" name="html_type" value="simple" />
          <button type="submit" class="lead-btn">
            Quiero mi guía gratis →
          </button>
        </form>
        <p class="lead-legal">Sin spam. Cancela cuando quieras.</p>
      </div>

      <div id="lead-thanks" hidden>
        <p class="thanks-icon">📬</p>
        <p class="thanks-title">¡Listo! Revisa tu correo</p>
        <p class="thanks-sub">
          En unos minutos recibirás el enlace para descargar los 50 Retos Familukis.
          Si no aparece, mira la carpeta de spam.
        </p>
      </div>
    </div>

  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Enviando...';

      try {
        await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          mode: 'no-cors',
        });
      } catch {}

      document.getElementById('lead-ready')!.hidden = true;
      document.getElementById('lead-thanks')!.hidden = false;
    });
  }
</script>

<style>
  .lead-section {
    margin: 2rem 0;
    background: linear-gradient(135deg, #1a0a0a 0%, #1f1212 50%, #141414 100%);
    border-top: 1px solid rgba(229,9,20,0.2);
    border-bottom: 1px solid rgba(229,9,20,0.2);
    padding: 3rem 2rem;
  }

  .lead-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .lead-tag {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 10px;
    border-radius: 3px;
    margin-bottom: 0.75rem;
  }

  .lead-copy h2 {
    font-size: clamp(1.35rem, 2.5vw, 1.9rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .lead-copy p {
    color: var(--text-2);
    font-size: 0.92rem;
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .lead-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .lead-bullets li {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
  }

  .lead-form-wrap {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(229,9,20,0.25);
    border-radius: 12px;
    padding: 2rem 1.75rem;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .lead-form-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 1rem;
  }

  .lead-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .lead-input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    color: #fff;
    font-size: 0.92rem;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .lead-input::placeholder { color: rgba(255,255,255,0.35); }
  .lead-input:focus { border-color: var(--accent); }

  .lead-btn {
    width: 100%;
    padding: 0.8rem 1rem;
    background: var(--accent);
    color: #fff;
    font-size: 0.92rem;
    font-weight: 700;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .lead-btn:hover { opacity: 0.88; }
  .lead-btn:disabled { opacity: 0.6; cursor: default; }

  .lead-legal {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.3);
    margin: 0.75rem 0 0;
    text-align: center;
  }

  /* Estado de gracias */
  #lead-thanks {
    text-align: center;
    padding: 1rem 0;
  }
  .thanks-icon { font-size: 2.5rem; margin: 0 0 0.5rem; }
  .thanks-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.5rem;
  }
  .thanks-sub {
    font-size: 0.85rem;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 800px) {
    .lead-inner {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .lead-section { padding: 2.5rem 1.25rem; }
  }
</style>
