---
const BREVO_ACTION = "https://9ab7b963.sibforms.com/serve/MUIFADIlif981oRL3CO9RsJ6MZRoDBPdav1100emuwGi9FhnJl6m939M2xMOAUZi33VCaYBEKvLr7fbtkPSVJBn-nvwDuD-UFrdNC7hUEm4makNYhhPrRV3DBZX8ZJT2LzrpYPyjj2sMnzWzDz2-bXnSAJqEl9nR8lf-lx2zv-AAVGhkrwd8u4qplqS3f7i2LK2IAuhfuFwZKQimAg==";
---

<section class="lead-section">
  <div class="lead-inner">

    <div class="lead-copy">
      <span class="lead-tag">Únete gratis</span>
      <h2>Forma parte del Club Familukis</h2>
      <p>
        Apúntate y te enviamos de regalo la guía con los
        <strong>50 Retos Divertidos para Hacer en Casa</strong> — sin comprar nada,
        sin preparar nada. Solo pasar un buen rato en familia.
      </p>
      <ul class="lead-bullets">
        <li>✓ Guía de 50 retos gratis al apuntarte</li>
        <li>✓ Planes, novedades y sorpresas Familukis</li>
        <li>✓ Sin spam — cuando quieras te vas</li>
      </ul>
    </div>

    <div class="lead-form-wrap">
      <div id="lead-ready">
        <p class="lead-form-title">Tu correo y listo 👇</p>
        <form
          id="lead-form"
          action={BREVO_ACTION}
          method="POST"
          target="brevo-hidden"
          class="lead-form"
        >
          <input
            type="email"
            name="EMAIL"
            placeholder="tu@email.com"
            required
            autocomplete="email"
            class="lead-input"
          />
          <input type="hidden" name="locale" value="es" />
          <input type="hidden" name="html_type" value="simple" />
          <label class="lead-check-label">
            <input type="checkbox" name="OPT_IN" required class="lead-check" />
            <span>
              Acepto la <a href="/privacidad" target="_blank" class="lead-link">política de privacidad</a>
              y consiento recibir comunicaciones de Familukis.
            </span>
          </label>
          <button type="submit" class="lead-btn">
            Unirme al Club y recibir los 50 Retos →
          </button>
        </form>
        <p class="lead-legal">Sin spam. Cancela cuando quieras.</p>
      </div>

      <iframe name="brevo-hidden" style="display:none;width:0;height:0;border:0" aria-hidden="true" title=""></iframe>

      <div id="lead-thanks" hidden>
        <p class="thanks-icon">📬</p>
        <p class="thanks-title">¡Bienvenido al Club Familukis!</p>
        <p class="thanks-sub">
          En unos minutos recibirás tu guía de 50 Retos en el correo.
          Si no aparece, mira la carpeta de spam.
        </p>
      </div>
    </div>

  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', () => {
      const btn = form.querySelector('button') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Enviando...';
      // El form hace POST real a Brevo en el iframe oculto.
      // Mostramos éxito tras 1.5s, tiempo suficiente para que Brevo responda.
      setTimeout(() => {
        document.getElementById('lead-ready')!.hidden = true;
        document.getElementById('lead-thanks')!.hidden = false;
      }, 1500);
    });
  }
</script>

<style>
  .lead-section {
    margin: 2rem 0;
    background: linear-gradient(135deg, #1a0a0a 0%, #1f1212 50%, #141414 100%);
    border-top: 1px solid rgba(229,9,20,0.2);
    border-bottom: 1px solid rgba(229,9,20,0.2);
    padding: 3rem 2rem;
  }

  .lead-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .lead-tag {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 10px;
    border-radius: 3px;
    margin-bottom: 0.75rem;
  }

  .lead-copy h2 {
    font-size: clamp(1.35rem, 2.5vw, 1.9rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .lead-copy p {
    color: var(--text-2);
    font-size: 0.92rem;
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .lead-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .lead-bullets li {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
  }

  .lead-form-wrap {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(229,9,20,0.25);
    border-radius: 12px;
    padding: 2rem 1.75rem;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .lead-form-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 1rem;
  }

  .lead-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .lead-input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    color: #fff;
    font-size: 0.92rem;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .lead-input::placeholder { color: rgba(255,255,255,0.35); }
  .lead-input:focus { border-color: var(--accent); }

  .lead-btn {
    width: 100%;
    padding: 0.8rem 1rem;
    background: var(--accent);
    color: #fff;
    font-size: 0.92rem;
    font-weight: 700;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .lead-btn:hover { opacity: 0.88; }
  .lead-btn:disabled { opacity: 0.6; cursor: default; }

  .lead-check-label {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.45;
    cursor: pointer;
  }

  .lead-check {
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--accent);
    width: 15px;
    height: 15px;
    cursor: pointer;
  }

  .lead-link {
    color: rgba(255,255,255,0.75);
    text-decoration: underline;
    transition: color 0.15s;
  }
  .lead-link:hover { color: var(--accent); }

  .lead-legal {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.3);
    margin: 0.75rem 0 0;
    text-align: center;
  }

  /* Estado de gracias */
  #lead-thanks {
    text-align: center;
    padding: 1rem 0;
  }
  .thanks-icon { font-size: 2.5rem; margin: 0 0 0.5rem; }
  .thanks-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.5rem;
  }
  .thanks-sub {
    font-size: 0.85rem;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 800px) {
    .lead-inner {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .lead-section { padding: 2.5rem 1.25rem; }
  }
</style>
