---
interface Product {
  title: string;
  badge: string;
  image: string;
  url: string;
}

interface Props {
  title?: string;
  products: Product[];
}

const { title = 'Nuestra tienda', products } = Astro.props;
---

<section class="prod-section">
  <div class="prod-head">
    <h2 class="prod-title">{title}</h2>
    <span class="prod-ad">Publicidad</span>
  </div>

  <div class="prod-track">
    {products.map(p => (
      <a
        href={p.url}
        class="prod-card"
        target="_blank"
        rel="nofollow sponsored noopener"
        aria-label={`Ver ${p.title} en Amazon`}
      >
        <div class="prod-img-wrap">
          <img src={p.image} alt={p.title} loading="lazy" decoding="async" />
        </div>
        <div class="prod-info">
          <span class="prod-badge">{p.badge}</span>
          <p class="prod-name">{p.title}</p>
          <span class="prod-cta">Ver en Amazon ↗</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .prod-section {
    padding: 0.5rem 0 2rem;
  }

  .prod-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 2rem;
    max-width: 1300px;
    margin: 0 auto 0.75rem;
  }

  .prod-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
  }

  .prod-ad {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.3);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 3px;
    padding: 2px 6px;
  }

  .prod-track {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.25rem 2rem 1rem;
    max-width: 1300px;
    margin: 0 auto;
  }
  .prod-track::-webkit-scrollbar { display: none; }

  .prod-card {
    flex-shrink: 0;
    width: 175px;
    scroll-snap-align: start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
  }

  .prod-card:hover {
    border-color: var(--border-2);
    transform: translateY(-3px);
  }

  .prod-img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #fff;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .prod-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 8px;
  }

  .prod-info {
    padding: 0.7rem 0.75rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .prod-badge {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--accent);
  }

  .prod-name {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .prod-cta {
    font-size: 0.72rem;
    font-weight: 600;
    color: #FF9900;
    margin-top: 0.2rem;
  }

  @media (max-width: 640px) {
    .prod-head { padding: 0 1.25rem; }
    .prod-track { padding: 0.25rem 1.25rem 1rem; }
    .prod-card { width: 155px; }
  }
</style>
