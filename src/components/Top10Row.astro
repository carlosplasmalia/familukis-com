---
interface Item {
  rank: number;
  videoId: string;
  slug: string;
  title: string;
  cover: string; /* ruta /covers/topN-xxx.jpg */
}

interface Props {
  title?: string;
  items: Item[];
}

const { title = 'Para los más nostálgicos', items } = Astro.props;
---

<section class="top10-section">
  <h2 class="top10-title">{title}</h2>

  <div class="top10-track">
    {items.map(item => (
      <a href={`/videos/${item.slug}`} class="top10-item" aria-label={item.title}>
        <span class="top10-num" aria-hidden="true">{item.rank}</span>
        <div class="top10-card">
          <img
            src={item.cover}
            alt={item.title}
            loading="lazy"
            decoding="async"
          />
          <div class="top10-overlay">
            <p class="top10-label">{item.title}</p>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .top10-section {
    padding: 1.5rem 0 2rem;
  }

  .top10-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
    padding: 0 2rem;
    max-width: 1300px;
    margin-left: auto;
    margin-right: auto;
  }

  .top10-track {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.5rem 2rem 1.5rem;
    max-width: 1300px;
    margin: 0 auto;
  }
  .top10-track::-webkit-scrollbar { display: none; }

  .top10-item {
    display: flex;
    align-items: flex-end;
    flex-shrink: 0;
    scroll-snap-align: start;
    text-decoration: none;
    cursor: pointer;
  }

  .top10-num {
    font-size: clamp(120px, 14vw, 180px);
    font-weight: 900;
    line-height: 1;
    /* outlined like Netflix */
    color: #141414;
    -webkit-text-stroke: 5px rgba(255,255,255,0.45);
    paint-order: stroke fill;
    flex-shrink: 0;
    width: clamp(80px, 9vw, 120px);
    text-align: right;
    user-select: none;
    letter-spacing: -0.04em;
  }

  .top10-card {
    position: relative;
    width: clamp(130px, 15vw, 185px);
    flex-shrink: 0;
    margin-left: clamp(-28px, -3.5vw, -18px);
    border-radius: 6px;
    overflow: hidden;
    transition: transform 0.22s ease;
    z-index: 1;
  }

  .top10-item:hover .top10-card {
    transform: scale(1.06);
  }

  .top10-card img {
    display: block;
    width: 100%;
    aspect-ratio: 2/3;
    object-fit: cover;
  }

  .top10-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.2s;
    display: flex;
    align-items: flex-end;
    padding: 0.6rem;
  }

  .top10-item:hover .top10-overlay {
    opacity: 1;
  }

  .top10-label {
    font-size: 0.72rem;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .top10-title { padding: 0 1.25rem; }
    .top10-track  { padding: 0.5rem 1.25rem 1.5rem; }
    .top10-num {
      font-size: 80px;
      width: 58px;
      -webkit-text-stroke: 3px rgba(255,255,255,0.5);
    }
    .top10-card {
      width: 108px;
      margin-left: -12px;
    }
  }
</style>
