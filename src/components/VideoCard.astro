---
interface Props {
  videoId: string;
  title: string;
  duracion?: string;
  views?: number;
  slug: string;
  width?: string;
}
const { videoId, title, duracion, views, slug, width = '260px' } = Astro.props;

const thumb = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;

function fv(n: number) {
  if (n >= 1_000_000) return `${(n/1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${Math.round(n/1_000)}K`;
  return String(n);
}
---

<a href={`/videos/${slug}`} class="ncard" style={`--w:${width}`}>
  <div class="ncard-thumb">
    <img src={thumb} alt={title} loading="lazy" decoding="async" width="480" height="270" />
    {duracion && <span class="nduration">{duracion}</span>}
    <div class="ncard-hover">
      <div class="nplay">
        <svg viewBox="0 0 24 24" fill="white" width="28" height="28"><path d="M8 5v14l11-7z"/></svg>
      </div>
      <div class="ncard-info">
        {views && views > 0 && <span class="nviews">{fv(views)} vistas</span>}
      </div>
    </div>
  </div>
  <p class="ncard-title">{title}</p>
</a>

<style>
  .ncard {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: var(--w);
    flex-shrink: 0;
    cursor: pointer;
  }

  .ncard-thumb {
    position: relative;
    aspect-ratio: 16/9;
    border-radius: 4px;
    overflow: hidden;
    background: #1f1f1f;
  }

  .ncard-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
    display: block;
  }

  .ncard:hover .ncard-thumb img {
    transform: scale(1.08);
  }

  .nduration {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: rgba(0,0,0,0.85);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 3px;
  }

  .ncard-hover {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.25s;
  }

  .ncard:hover .ncard-hover {
    opacity: 1;
  }

  .nplay {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(4px);
    transition: transform 0.2s, background 0.2s;
    margin-bottom: auto;
    margin-top: auto;
  }

  .ncard:hover .nplay {
    transform: scale(1.1);
    background: rgba(229,9,20,0.85);
    border-color: transparent;
  }

  .ncard-info {
    width: 100%;
    padding: 0 8px 8px;
  }

  .nviews {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
  }

  .ncard-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.15s;
  }

  .ncard:hover .ncard-title {
    color: #fff;
  }
</style>
