<script is:inline src="https://www.dwin2.com/pub.2956549.min.js" defer></script>

</body>
</html>

<style>
  #nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(8, 8, 8, 0.88);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-inner {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1.15rem;
    color: #e50914;
    flex-shrink: 0;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 0;
    flex: 1;
  }

  .nav-links a {
    color: rgba(255,255,255,0.6);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.4rem 0.85rem;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .nav-links a:hover {
    color: #fff;
    background: rgba(255,255,255,0.07);
  }


  /* Hamburger — hidden on desktop */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    order: -1;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.2s;
    transform-origin: center;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile menu panel — always in DOM, hidden via visibility+opacity */
  #mobile-menu {
    position: fixed;
    top: 64px;
    left: 0; right: 0;
    z-index: 99;
    background: rgba(10,10,10,0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    visibility: hidden;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0s linear 0.2s;
    pointer-events: none;
  }
  #mobile-menu.open {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0s linear 0s;
    pointer-events: auto;
  }
  #mobile-menu nav {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 1.5rem 1.5rem;
  }
  #mobile-menu nav a {
    color: rgba(255,255,255,0.75);
    font-size: 1.05rem;
    font-weight: 500;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    transition: color 0.15s;
  }
  #mobile-menu nav a:last-child { border-bottom: none; }
  #mobile-menu nav a:active { color: #e50914; }

  @media (max-width: 800px) {
    .nav-links { display: none; }
    .nav-inner { gap: 0.5rem; justify-content: space-between; }
    .logo-icon { display: none; }
    .hamburger { display: flex; }
  }

  /* FOOTER */
  #footer {
    margin-top: 6rem;
    border-top: 1px solid rgba(255,255,255,0.07);
    background: #080808;
  }

  .footer-inner {
    max-width: 1300px;
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: #e50914;
    letter-spacing: -0.03em;
    margin-bottom: 0.25rem;
  }

  .footer-brand p {
    color: rgba(255,255,255,0.35);
    font-size: 0.875rem;
    line-height: 1.65;
    max-width: 38ch;
  }

  .footer-col h3 {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.3);
    margin-bottom: 0.4rem;
  }

  .footer-col a {
    color: rgba(255,255,255,0.5);
    font-size: 0.875rem;
    transition: color 0.15s;
  }

  .footer-col a:hover { color: #e50914; }

  .footer-bottom {
    max-width: 1300px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .footer-bottom p {
    color: rgba(255,255,255,0.25);
    font-size: 0.8rem;
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.6rem;
  }
  .footer-legal a {
    color: rgba(255,255,255,0.2);
    font-size: 0.78rem;
    transition: color 0.15s;
  }
  .footer-legal a:hover { color: rgba(255,255,255,0.5); }

  @media (max-width: 800px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 500px) {
    .footer-inner { grid-template-columns: 1fr; }
  }

  /* PWA Install Banner */
  #pwa-banner {
    position: fixed;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    width: calc(100% - 2rem);
    max-width: 480px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.6);
    padding: 1rem;
    animation: pwa-slide-up 0.3s ease;
  }
  #pwa-banner[hidden] { display: none; }
  @keyframes pwa-slide-up {
    from { opacity: 0; transform: translateX(-50%) translateY(20px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }
  .pwa-banner-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .pwa-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .pwa-text strong {
    color: #fff;
    font-size: 0.95rem;
  }
  .pwa-text span {
    color: rgba(255,255,255,0.5);
    font-size: 0.8rem;
  }
  .pwa-btn-install {
    background: #e50914;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.45rem 1rem;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .pwa-btn-install:hover { background: #cc0812; }
  .pwa-btn-dismiss {
    background: none;
    border: none;
    color: rgba(255,255,255,0.3);
    font-size: 1rem;
    cursor: pointer;
    padding: 0.25rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .pwa-btn-dismiss:hover { color: rgba(255,255,255,0.7); }
</style>
