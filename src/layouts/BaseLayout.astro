        "https://www.youtube.com/@LosFamilukis",
        "https://www.youtube.com/c/losfamilukis",
        "https://www.instagram.com/losfamilukis",
        "https://www.tiktok.com/@losfamilukis"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "availableLanguage": "Spanish"
      }
    }
  ])} />

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#e50914" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Familukis" />
  <slot name="head" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RXVK4TC0NP"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RXVK4TC0NP');
  </script>

  <script is:inline src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer></script>
  <script is:inline>
    window.OneSignalDeferred = window.OneSignalDeferred || [];
    OneSignalDeferred.push(async function(OneSignal) {
      await OneSignal.init({
        appId: "e527ef87-2f89-4058-a8e9-101d9b5e9800",
        safari_web_id: "web.onesignal.auto.00b75e31-4d41-4106-ab79-a5c68121f393",
        notifyButton: {
          enable: true,
        },
        promptOptions: {
          slidedown: {
            prompts: [{
              type: "push",
              autoPrompt: true,
              text: {
                actionMessage: "¿Quieres enterarte antes que nadie de nuestros nuevos vídeos?",
                acceptButton: "¡Sí, avísame!",
                cancelButton: "Ahora no",
