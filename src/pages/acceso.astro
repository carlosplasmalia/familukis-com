<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Familukis — Acceso exclusivo</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- Open Graph: miniatura premium al compartir el link -->
  <meta property="og:title" content="Familukis — Acceso exclusivo a nuestros vídeos" />
  <meta property="og:description" content="Entra a ver todos nuestros vídeos exclusivos. Solo para Familukis." />
  <meta property="og:image" content="https://familukis.com/og-acceso.jpg" />
  <meta property="og:image:width" content="2720" />
  <meta property="og:image:height" content="1360" />
  <meta property="og:url" content="https://familukis.com/acceso" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://familukis.com/og-acceso.jpg" />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RXVK4TC0NP"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RXVK4TC0NP');
  </script>
</head>
<body>

  <div id="screen" class="hidden">
    <svg width="48" height="48" viewBox="0 0 32 32" fill="none">
      <rect width="32" height="32" rx="8" fill="#e50914"/>
      <text x="16" y="22" text-anchor="middle" fill="white" font-size="16" font-weight="800" font-family="system-ui">F</text>
    </svg>
    <h1>Familukis</h1>
    <p>Ver todos los vídeos exclusivos</p>
    <button id="btn">Abrir web</button>
  </div>

</body>
</html>

<script>
  const DEFAULT = 'https://familukis.com?utm_source=instagram&utm_medium=dm&utm_campaign=acceso_comentarios';
  // Hash (#) tiene prioridad — Instagram no lo elimina. Query param (?url=) como fallback.
  const paramUrl = window.location.hash.slice(1) || new URLSearchParams(window.location.search).get('url');
  const DEST = paramUrl || DEFAULT;

  const isAmazon = /amzn\.to|amazon\.(es|com|co\.uk|de|fr|it)/.test(DEST);

  const ua = navigator.userAgent;
  const isInstagram = /Instagram/.test(ua);
  const isAndroid   = /Android/.test(ua);
  const isIOS       = /iPhone|iPad|iPod/.test(ua);

  if (isAmazon) {
    document.getElementById('btn').textContent = 'Abrir en Amazon';
  }

  if (!isInstagram) {
    window.location.replace(DEST);
  } else {
    document.getElementById('screen').classList.remove('hidden');

    if (isAndroid) {
      // Amazon app primero; si no instalada, Chrome como fallback
      const pkg = isAmazon ? 'com.amazon.mShop.android.shopping' : 'com.android.chrome';
      window.location.href =
        'intent://' + DEST.replace(/^https?:\/\//, '') +
        '#Intent;scheme=https;package=' + pkg + ';S.browser_fallback_url=' +
        encodeURIComponent(DEST) + ';end';
    } else if (isIOS) {
      if (isAmazon) {
        // Scheme nativo de la app de Amazon en iOS
        window.location.href = 'amzn://' + DEST.replace(/^https?:\/\//, '');
        setTimeout(() => {
          window.location.href = DEST.replace('https://', 'x-safari-https://');
        }, 700);
      } else {
        window.location.href = 'googlechrome://' + DEST.replace(/^https?:\/\//, '');
        setTimeout(() => {
          window.location.href = DEST.replace('https://', 'x-safari-https://');
        }, 600);
      }
    }

    document.getElementById('btn').addEventListener('click', () => {
      if (isAndroid) {
        const pkg = isAmazon ? 'com.amazon.mShop.android.shopping' : 'com.android.chrome';
        window.location.href =
          'intent://' + DEST.replace(/^https?:\/\//, '') +
          '#Intent;scheme=https;package=' + pkg + ';S.browser_fallback_url=' +
          encodeURIComponent(DEST) + ';end';
      } else if (isIOS && isAmazon) {
        window.location.href = 'amzn://' + DEST.replace(/^https?:\/\//, '');
        setTimeout(() => { window.location.href = DEST.replace('https://', 'x-safari-https://'); }, 700);
      } else {
        const w = window.open(DEST, '_blank', 'noreferrer');
        if (!w || w.closed) {
          window.location.href = isIOS ? DEST.replace('https://', 'x-safari-https://') : DEST;
        }
      }
    });
  }
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #080808;
    color: #fff;
    font-family: system-ui, -apple-system, sans-serif;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem;
    text-align: center;
    animation: up 0.3s ease;
  }
  #screen.hidden { display: none; }

  @keyframes up {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: none; }
  }

  h1 {
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #e50914;
  }

  p {
    color: rgba(255,255,255,0.45);
    font-size: 0.95rem;
  }

  #btn {
    margin-top: 0.5rem;
    background: #e50914;
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    width: 100%;
    max-width: 280px;
    transition: background 0.15s, transform 0.1s;
  }
  #btn:active { background: #b8060f; transform: scale(0.97); }
</style>
