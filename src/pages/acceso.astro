---
const DEST = 'https://familukis.com?utm_source=instagram&utm_medium=dm&utm_campaign=acceso_comentarios';
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Familukis — Ver vídeos</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RXVK4TC0NP"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RXVK4TC0NP');
  </script>
</head>
<body>

  <!-- Estado inicial: copiando -->
  <div id="state-copying" class="screen">
    <svg class="spinner" viewBox="0 0 50 50"><circle cx="25" cy="25" r="20" fill="none" stroke-width="4"/></svg>
    <p>Un momento…</p>
  </div>

  <!-- Estado: enlace copiado con éxito -->
  <div id="state-copied" class="screen" style="display:none">
    <div class="icon-wrap success">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </div>
    <h1>¡Enlace copiado!</h1>
    <p class="sub">Ahora abre <strong>Safari</strong> o <strong>Chrome</strong>,<br>pégalo en la barra de arriba y pulsa ir.</p>
    <div class="url-box">
      <span class="url-text">familukis.com</span>
      <button id="btn-copy-again" class="btn-copy">Copiar de nuevo</button>
    </div>
    <p class="hint">El enlace ya está en tu portapapeles</p>
  </div>

  <!-- Estado: portapapeles bloqueado (fallback) -->
  <div id="state-manual" class="screen" style="display:none">
    <div class="logo-wrap">
      <svg width="36" height="36" viewBox="0 0 32 32" fill="none">
        <rect width="32" height="32" rx="8" fill="#e50914"/>
        <text x="16" y="22" text-anchor="middle" fill="white" font-size="16" font-weight="800" font-family="system-ui">F</text>
      </svg>
      <span>Familukis</span>
    </div>
    <h1>Un paso más</h1>
    <p class="sub">Copia este enlace, ábrelo en Safari o Chrome</p>
    <div class="url-box">
      <span class="url-text">familukis.com</span>
      <button id="btn-copy-manual" class="btn-copy">Copiar</button>
    </div>
    <p id="copy-feedback" class="copy-ok" style="opacity:0">¡Copiado!</p>
  </div>

</body>
</html>

<script define:vars={{ DEST }}>
  const isInstagram = /Instagram/.test(navigator.userAgent);
  const isAndroid   = /Android/.test(navigator.userAgent);
  const isIOS       = /iPhone|iPad|iPod/.test(navigator.userAgent);

  function show(id) {
    ['state-copying','state-copied','state-manual'].forEach(s =>
      document.getElementById(s).style.display = s === id ? 'flex' : 'none'
    );
  }

  async function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      await navigator.clipboard.writeText(text);
      return;
    }
    // Fallback para WebViews más restrictivos
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:0;left:0;opacity:0';
    document.body.appendChild(ta);
    ta.focus(); ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
  }

  async function init() {
    if (!isInstagram) {
      // Navegador normal: redirige directo sin mostrar nada
      window.location.replace(DEST);
      return;
    }

    // Intentos automáticos de apertura externa (sin bloquear UI)
    if (isAndroid) {
      setTimeout(() => {
        window.location.href =
          'intent://' + DEST.replace(/^https?:\/\//, '') +
          '#Intent;scheme=https;package=com.android.chrome;end';
      }, 300);
    } else if (isIOS) {
      setTimeout(() => {
        window.location.href = DEST.replace('https://', 'x-safari-https://');
      }, 300);
    }

    // Copiar enlace al portapapeles automáticamente
    try {
      await copyToClipboard(DEST);
      show('state-copied');
    } catch(e) {
      show('state-manual');
    }
  }

  init();

  // Botón "Copiar de nuevo"
  document.getElementById('btn-copy-again').addEventListener('click', async () => {
    await copyToClipboard(DEST);
    const btn = document.getElementById('btn-copy-again');
    btn.textContent = '¡Copiado!';
    setTimeout(() => btn.textContent = 'Copiar de nuevo', 2000);
  });

  // Botón copiar manual
  document.getElementById('btn-copy-manual').addEventListener('click', async () => {
    await copyToClipboard(DEST);
    const fb = document.getElementById('copy-feedback');
    fb.style.opacity = '1';
    setTimeout(() => fb.style.opacity = '0', 2000);
  });
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #080808;
    color: #fff;
    font-family: system-ui, -apple-system, sans-serif;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .screen {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.2rem;
    max-width: 320px;
    width: 100%;
    animation: fadeIn 0.25s ease;
  }
  @keyframes fadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }

  /* Spinner */
  .spinner {
    width: 40px; height: 40px;
    animation: spin 0.9s linear infinite;
  }
  .spinner circle {
    stroke: #e50914;
    stroke-linecap: round;
    stroke-dasharray: 90,150;
    stroke-dashoffset: -35;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Icono check */
  .icon-wrap {
    width: 64px; height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.25rem;
  }
  .icon-wrap.success { background: #16a34a; }

  /* Logo */
  .logo-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 1.1rem;
    color: #e50914;
  }

  h1 {
    font-size: 1.65rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .sub {
    color: rgba(255,255,255,0.5);
    font-size: 0.95rem;
    line-height: 1.65;
  }
  .sub strong { color: #fff; }

  /* Caja URL */
  .url-box {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    padding: 0.9rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    width: 100%;
  }

  .url-text {
    font-family: monospace;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.7);
    text-align: left;
  }

  .btn-copy {
    background: #e50914;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 0.45rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s;
  }
  .btn-copy:active { background: #b8060f; }

  .hint {
    color: rgba(255,255,255,0.22);
    font-size: 0.78rem;
  }

  .copy-ok {
    color: #4ade80;
    font-size: 0.85rem;
    font-weight: 600;
    transition: opacity 0.3s;
  }

  #state-copying p {
    color: rgba(255,255,255,0.35);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }
</style>
