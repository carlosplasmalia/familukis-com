---
// Página puente para DMs de Instagram
// Detecta el WebView de Instagram y fuerza apertura en navegador externo
// UTM tracking: utm_source=instagram&utm_medium=dm&utm_campaign=acceso_comentarios
const DEST = 'https://familukis.com?utm_source=instagram&utm_medium=dm&utm_campaign=acceso_comentarios';
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Familukis — Ver vídeos exclusivos</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RXVK4TC0NP"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RXVK4TC0NP');
  </script>
</head>
<body>

  <div id="screen-loading" aria-hidden="true">
    <svg class="spinner" viewBox="0 0 50 50"><circle cx="25" cy="25" r="20" fill="none" stroke-width="4"/></svg>
  </div>

  <div id="screen-instagram" style="display:none" role="main">
    <div class="logo-wrap">
      <svg width="52" height="52" viewBox="0 0 32 32" fill="none">
        <rect width="32" height="32" rx="8" fill="#e50914"/>
        <text x="16" y="22" text-anchor="middle" fill="white" font-size="16" font-weight="800" font-family="system-ui">F</text>
      </svg>
      <span>Familukis</span>
    </div>

    <h1>¡Hola, Familuki!</h1>
    <p class="sub">Todos nuestros vídeos exclusivos te esperan.<br>Toca el botón para abrirlos en tu navegador.</p>

    <a id="cta" href={DEST} target="_blank" rel="noreferrer noopener">
      Ver todos los vídeos
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
    </a>

    <p class="hint">Se abrirá en Safari o Chrome</p>
  </div>

</body>
</html>

<script define:vars={{ DEST }}>
  const isInstagram = /Instagram/.test(navigator.userAgent);

  if (isInstagram) {
    document.getElementById('screen-loading').style.display = 'none';
    document.getElementById('screen-instagram').style.display = 'flex';

    // Intentar apertura externa automática en Android
    if (/Android/.test(navigator.userAgent)) {
      const intent = `intent://${DEST.replace(/^https?:\/\//, '')}#Intent;scheme=https;package=com.android.chrome;end`;
      try { window.location.replace(intent); } catch(e) {}
    }
  } else {
    window.location.replace(DEST);
  }
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #080808;
    color: #fff;
    font-family: system-ui, -apple-system, sans-serif;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  #screen-loading {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .spinner {
    width: 42px; height: 42px;
    animation: spin 0.9s linear infinite;
  }
  .spinner circle {
    stroke: #e50914;
    stroke-linecap: round;
    stroke-dasharray: 90, 150;
    stroke-dashoffset: -35;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  #screen-instagram {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    max-width: 360px;
    animation: fadeIn 0.3s ease;
  }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

  .logo-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1.3rem;
    color: #e50914;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .sub {
    color: rgba(255,255,255,0.55);
    font-size: 1rem;
    line-height: 1.6;
  }

  #cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #e50914;
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: background 0.15s, transform 0.1s;
    width: 100%;
    justify-content: center;
  }
  #cta:active { background: #b8060f; transform: scale(0.98); }

  .hint {
    color: rgba(255,255,255,0.25);
    font-size: 0.8rem;
  }
</style>
