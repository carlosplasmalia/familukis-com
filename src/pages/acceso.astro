---
const DEST = 'https://familukis.com?utm_source=instagram&utm_medium=dm&utm_campaign=acceso_comentarios';
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Familukis — Ver vídeos exclusivos</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RXVK4TC0NP"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RXVK4TC0NP');
  </script>
</head>
<body>

  <div id="screen-loading">
    <svg class="spinner" viewBox="0 0 50 50"><circle cx="25" cy="25" r="20" fill="none" stroke-width="4"/></svg>
  </div>

  <!-- Pantalla para navegador normal: nunca se ve (redirige automático) -->
  <div id="screen-normal" style="display:none"></div>

  <!-- Pantalla para Instagram WebView -->
  <div id="screen-instagram" style="display:none" role="main">
    <div class="logo-wrap">
      <svg width="44" height="44" viewBox="0 0 32 32" fill="none">
        <rect width="32" height="32" rx="8" fill="#e50914"/>
        <text x="16" y="22" text-anchor="middle" fill="white" font-size="16" font-weight="800" font-family="system-ui">F</text>
      </svg>
      <span>Familukis</span>
    </div>

    <h1>¡Ya casi estás!</h1>
    <p class="sub">Instagram no deja abrir la web correctamente.<br>Sigue estos 2 pasos:</p>

    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-text">
          Toca los <strong>tres puntos ···</strong><br>
          <span class="dim">(arriba a la derecha de esta pantalla)</span>
        </div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-text">
          Selecciona <strong>"Abrir en Safari"</strong><br>
          <span class="dim">o "Abrir en Chrome"</span>
        </div>
      </div>
    </div>

    <div class="divider">o si prefieres</div>

    <a id="cta" href={DEST}>
      Copia este enlace
    </a>
    <p class="url-text">familukis.com</p>

    <p class="hint">Una vez fuera de Instagram podrás ver todos los vídeos</p>
  </div>

</body>
</html>

<script define:vars={{ DEST }}>
  const ua = navigator.userAgent;
  const isInstagram = /Instagram/.test(ua);
  const isAndroid = /Android/.test(ua);
  const isIOS = /iPhone|iPad|iPod/.test(ua);

  function show(id) {
    document.getElementById('screen-loading').style.display = 'none';
    document.getElementById(id).style.display = 'flex';
  }

  if (!isInstagram) {
    // Navegador normal: redirige directo
    window.location.replace(DEST);
    return;
  }

  // Estamos en Instagram WebView
  show('screen-instagram');

  // Intentos automáticos de bypass (en paralelo, sin bloquear la UI)
  setTimeout(() => {
    if (isAndroid) {
      // Android: intent a Chrome
      window.location.href =
        'intent://' + DEST.replace(/^https?:\/\//, '') +
        '#Intent;scheme=https;package=com.android.chrome;end';
    } else if (isIOS) {
      // iOS: esquema x-safari (abre Safari directamente si el usuario no ha bloqueado)
      window.location.href = DEST.replace('https://', 'x-safari-https://');
    }
  }, 400);
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #080808;
    color: #fff;
    font-family: system-ui, -apple-system, sans-serif;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  #screen-loading {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .spinner {
    width: 42px; height: 42px;
    animation: spin 0.9s linear infinite;
  }
  .spinner circle {
    stroke: #e50914;
    stroke-linecap: round;
    stroke-dasharray: 90, 150;
    stroke-dashoffset: -35;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  #screen-instagram {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.1rem;
    max-width: 340px;
    width: 100%;
    animation: fadeIn 0.3s ease;
  }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

  .logo-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1.2rem;
    color: #e50914;
    margin-bottom: 0.25rem;
  }

  h1 {
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .sub {
    color: rgba(255,255,255,0.5);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .steps {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    text-align: left;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .step-num {
    background: #e50914;
    color: #fff;
    font-weight: 800;
    font-size: 0.9rem;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .step-text {
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .step-text strong { color: #fff; }
  .dim { color: rgba(255,255,255,0.35); font-size: 0.85rem; }

  .divider {
    color: rgba(255,255,255,0.2);
    font-size: 0.8rem;
    position: relative;
    width: 100%;
    text-align: center;
  }
  .divider::before, .divider::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 35%;
    height: 1px;
    background: rgba(255,255,255,0.1);
  }
  .divider::before { left: 0; }
  .divider::after { right: 0; }

  #cta {
    display: block;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.85rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    width: 100%;
    text-align: center;
    transition: background 0.15s;
  }
  #cta:active { background: rgba(255,255,255,0.14); }

  .url-text {
    color: rgba(255,255,255,0.3);
    font-size: 0.8rem;
    font-family: monospace;
    margin-top: -0.5rem;
  }

  .hint {
    color: rgba(255,255,255,0.2);
    font-size: 0.78rem;
    line-height: 1.5;
  }
</style>
