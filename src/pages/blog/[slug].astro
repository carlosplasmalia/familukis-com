---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryRow from '../../components/CategoryRow.astro';
import { getCollection, render } from 'astro:content';
import { CATEGORIA_LABELS } from '../../content.config';

const MAGIC_URL = 'https://www.magichotelgroup.com/es?utm_source=embajadores&utm_medium=macroinfluencer&utm_campaign=MAGICLOSFAMILUKIS&cp=MAGICLOSFAMILUKI';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(a => ({ params: { slug: a.id }, props: { article: a } }));
}

const { article } = Astro.props;
const { data } = article;
const { Content } = await render(article);

const allVideos = (await getCollection('videos')).filter(v => !v.data.hidden);
const allArticles = await getCollection('articles');

// Vídeo principal del artículo
const mainVideoId = data.relatedVideoIds?.[0];
const mainVideo = mainVideoId ? allVideos.find(v => v.data.videoId === mainVideoId) : null;
const thumbUrl = mainVideoId
  ? `https://img.youtube.com/vi/${mainVideoId}/maxresdefault.jpg`
  : undefined;

// Vídeos relacionados (misma categoría)
const relatedVideos = allVideos
  .filter(v => v.data.categoria === data.categoria)
  .sort((a, b) => (b.data.views ?? 0) - (a.data.views ?? 0))
  .slice(0, 12)
  .map(v => ({ videoId: v.data.videoId, title: v.data.title, duracion: v.data.duracion, views: v.data.views, slug: v.id }));

// Artículos relacionados (misma categoría, excluye el actual)
const relatedArticles = allArticles
  .filter(a => a.data.categoria === data.categoria && a.id !== article.id)
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);

const catLabel = CATEGORIA_LABELS[data.categoria];

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": data.title,
  "description": data.description,
  "datePublished": data.date,
  "dateModified": data.date,
  "image": thumbUrl ?? `https://familukis.com/og-default.jpg`,
  "author": { "@type": "Person", "name": "Carlos Zamorano Rodriguez", "url": "https://familukis.com" },
  "publisher": { "@type": "Organization", "name": "Familukis", "url": "https://familukis.com",
    "logo": { "@type": "ImageObject", "url": "https://familukis.com/favicon.svg" } },
  "mainEntityOfPage": { "@type": "WebPage", "@id": Astro.url.href },
};
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={thumbUrl}
  type="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <article class="article-page">
    <div class="wrap">

      <nav class="breadcrumb" aria-label="Ruta de navegación">
        <a href="/">Inicio</a><span aria-hidden="true">›</span>
        <a href="/blog">Blog</a><span aria-hidden="true">›</span>
        <a href={`/categoria/${data.categoria}`}>{catLabel}</a>
      </nav>

      <header class="article-header">
        <a href={`/categoria/${data.categoria}`} class="acat">{catLabel}</a>
        <h1 data-pagefind-meta="title">{data.title}</h1>
        <p class="aleadin">{data.description}</p>
        <time class="adate" datetime={data.date}>
          {new Date(data.date).toLocaleDateString('es-ES', { year:'numeric', month:'long', day:'numeric' })}
        </time>
      </header>

      {/* ── VÍDEO PRINCIPAL ── */}
      {mainVideoId && (
        <div class="main-video">
          <iframe
            src={`https://www.youtube.com/embed/${mainVideoId}?rel=0`}
            title={mainVideo?.data.title ?? data.title}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            loading="lazy"
          ></iframe>
          {mainVideo && (
            <a href={`/videos/${mainVideo.id}`} class="video-link">
              Ver también en Familukis: {mainVideo.data.title}
            </a>
          )}
        </div>
      )}

      {/* ── CUERPO + SIDEBAR ── */}
      <div class="article-body">
        <div class="prose" data-pagefind-body>
          <Content />
        </div>

        <aside class="article-side">

          {/* Navegación interna */}
          <div class="side-box side-nav">
            <h3>Explorar</h3>
            <a href={`/categoria/${data.categoria}`}>→ Todos los vídeos de {catLabel}</a>
            <a href="/blog">→ Blog de Familukis</a>
            <a href="/buscar">→ Buscador de planes</a>
          </div>

          {/* Afiliados */}
          {data.categoria === 'magic-world' && (
            <div class="side-box aff-box">
              <p>Reserva Magic World Resort con descuento exclusivo para familias.</p>
              <a href={MAGIC_URL} target="_blank" rel="sponsored noopener">
                🎡 Código <strong>MAGICLOSFAMILUKIS</strong>
              </a>
            </div>
          )}
          {data.categoria === 'parques-atracciones' && (
            <div class="side-box aff-box">
              <p>Entradas y actividades para parques con descuento.</p>
              <a href="https://www.civitatis.com/es/?aid=FAMILUKIS" target="_blank" rel="sponsored noopener">
                🎢 Ver en Civitatis
              </a>
            </div>
          )}
          {['vacaciones-familia','playas-costa','camping-naturaleza'].includes(data.categoria) && (
            <div class="side-box aff-box">
              <p>Los mejores alojamientos para familias con niños.</p>
              <a href="https://www.booking.com/?aid=FAMILUKIS" target="_blank" rel="sponsored noopener">
                🏨 Buscar en Booking
              </a>
            </div>
          )}

          {/* Artículos relacionados en sidebar */}
          {relatedArticles.length > 0 && (
            <div class="side-box side-related">
              <h3>Artículos relacionados</h3>
              {relatedArticles.map(a => (
                <a href={`/blog/${a.id}`} class="side-article">
                  <span class="side-article-title">{a.data.title}</span>
                </a>
              ))}
            </div>
          )}

          {/* Tags */}
          {data.tags.length > 0 && (
            <div class="atags">
              {data.tags.map(t => <span class="atag">#{t}</span>)}
            </div>
          )}

        </aside>
      </div>
    </div>

    {/* ── VÍDEOS RELACIONADOS ── */}
    {relatedVideos.length > 0 && (
      <div class="wrap related-wrap">
        <CategoryRow
          title={`Más vídeos de ${catLabel}`}
          href={`/categoria/${data.categoria}`}
          videos={relatedVideos}
        />
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .wrap { max-width:1300px; margin:0 auto; padding:0 2rem; }
  @media(max-width:640px){ .wrap{ padding:0 1.25rem; } }

  .article-page { padding-bottom:5rem; }

  /* BREADCRUMB */
  .breadcrumb { display:flex; align-items:center; gap:.4rem; flex-wrap:wrap;
    font-size:.78rem; color:var(--text-3); padding:1.5rem 0 0; }
  .breadcrumb a { color:var(--text-3); transition:color .15s; }
  .breadcrumb a:hover { color:var(--text); }

  /* HEADER */
  .article-header { margin:1.25rem 0 2rem; max-width:72ch; }
  .acat {
    display:inline-block; font-size:.68rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.09em; color:var(--accent); margin-bottom:.55rem;
    transition:opacity .15s;
  }
  .acat:hover { opacity:.75; }
  .article-header h1 {
    font-size:clamp(1.6rem,3vw,2.4rem); font-weight:800;
    letter-spacing:-.025em; line-height:1.18; margin-bottom:.6rem;
  }
  .aleadin { font-size:1.05rem; color:var(--text-2); line-height:1.6; margin-bottom:.6rem; }
  .adate { font-size:.78rem; color:var(--text-3); }

  /* VÍDEO PRINCIPAL */
  .main-video {
    margin-bottom:2.5rem;
    max-width:860px;
  }
  .main-video iframe {
    width:100%;
    aspect-ratio:16/9;
    border:0;
    border-radius:8px;
    background:#000;
    display:block;
  }
  .video-link {
    display:inline-block; margin-top:.6rem;
    font-size:.8rem; color:var(--text-3);
    transition:color .15s;
  }
  .video-link:hover { color:var(--accent); }

  /* BODY GRID */
  .article-body {
    display:grid; grid-template-columns:1fr 280px;
    gap:3rem; align-items:start;
  }
  @media(max-width:900px){ .article-body{ grid-template-columns:1fr; } }

  /* SIDEBAR */
  .article-side { position:sticky; top:80px; display:flex; flex-direction:column; gap:1rem; }

  .side-box {
    background:var(--surface); border:1px solid var(--border);
    border-radius:8px; padding:1.1rem 1.2rem;
  }
  .side-box h3 {
    font-size:.65rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.09em; color:var(--text-3); margin-bottom:.7rem;
  }

  .side-nav { display:flex; flex-direction:column; gap:0; }
  .side-nav a {
    font-size:.82rem; color:var(--text-2); padding:.35rem 0;
    border-bottom:1px solid var(--border); transition:color .15s;
  }
  .side-nav a:last-child { border-bottom:none; }
  .side-nav a:hover { color:var(--accent); }

  .aff-box p { font-size:.82rem; color:var(--text-2); margin-bottom:.6rem; line-height:1.5; }
  .aff-box a {
    display:block; text-align:center; font-size:.85rem; font-weight:600;
    color:#fff; background:var(--accent); border-radius:6px; padding:.5rem;
    transition:opacity .15s;
  }
  .aff-box a:hover { opacity:.85; }

  .side-related { display:flex; flex-direction:column; gap:0; }
  .side-article {
    display:block; padding:.5rem 0;
    border-bottom:1px solid var(--border);
  }
  .side-article:last-child { border-bottom:none; }
  .side-article-title {
    font-size:.82rem; color:var(--text-2); line-height:1.4;
    transition:color .15s;
  }
  .side-article:hover .side-article-title { color:var(--accent); }

  .atags { display:flex; flex-wrap:wrap; gap:6px; padding:.25rem 0; }
  .atag {
    font-size:.72rem; color:var(--text-2);
    background:var(--surface-2); padding:3px 9px; border-radius:99px;
  }

  .related-wrap { margin-top:3rem; padding-top:2rem; border-top:1px solid var(--border); }
</style>
