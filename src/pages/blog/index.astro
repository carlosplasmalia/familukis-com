---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIA_LABELS } from '../../content.config';

const articles = await getCollection('articles');
articles.sort((a, b) => b.data.date.localeCompare(a.data.date));

const featured = articles.filter(a => a.data.featured);
const rest     = articles.filter(a => !a.data.featured);

// Group non-featured articles by category and sort sections by count (desc)
const byCatMap = new Map<string, typeof rest>();
for (const a of rest) {
  const cat = a.data.categoria;
  if (!byCatMap.has(cat)) byCatMap.set(cat, []);
  byCatMap.get(cat)!.push(a);
}
const catSections = [...byCatMap.entries()]
  .sort((a, b) => b[1].length - a[1].length);

const useGrouped = catSections.length > 1;

// Helper to get first YouTube thumbnail from an article
function getThumb(a: typeof articles[number]): string | null {
  const id = a.data.relatedVideoIds?.[0];
  return id ? `https://img.youtube.com/vi/${id}/mqdefault.jpg` : null;
}

const CAT_COLORS: Record<string, string> = {
  'magic-world':        'linear-gradient(135deg,#1a0033,#3d0066)',
  'parques-atracciones':'linear-gradient(135deg,#001a33,#003366)',
  'parques-acuaticos':  'linear-gradient(135deg,#001a2e,#004466)',
  'camping-naturaleza': 'linear-gradient(135deg,#0a1a00,#1a3300)',
  'playas-costa':       'linear-gradient(135deg,#001433,#002966)',
  'vacaciones-familia': 'linear-gradient(135deg,#1a1000,#332000)',
  'halloween':          'linear-gradient(135deg,#1a0a00,#331500)',
  'navidad-regalos':    'linear-gradient(135deg,#001a00,#003300)',
  'retos-challenges':   'linear-gradient(135deg,#1a0000,#330000)',
  'para-ninos':         'linear-gradient(135deg,#1a0033,#280044)',
  'vlogs-familia':      'linear-gradient(135deg,#0d0d0d,#1a1a1a)',
  'senderismo-cascadas':'linear-gradient(135deg,#001a0d,#003319)',
  'montana-pirineos':   'linear-gradient(135deg,#0d0d1a,#1a1a33)',
  'actividades-casa':   'linear-gradient(135deg,#1a1a00,#333300)',
};
---

<BaseLayout
  title="Blog — Familukis"
  description="Artículos sobre planes en familia, actividades para niños, guías de parques, camping y mucho más. Todo desde nuestra experiencia real."
>
<div class="wrap">
  <header class="blog-header">
    <nav class="breadcrumb"><a href="/">Inicio</a><span>›</span><span>Blog</span></nav>
    <h1>Blog</h1>
    <p>Guías, ideas y experiencias reales para disfrutar en familia.</p>
  </header>

  {featured.length > 0 && (
    <section class="featured-section">
      <h2 class="section-title">Destacados</h2>
      <div class="featured-grid">
        {featured.map(a => {
          const thumb = getThumb(a);
          const bg = CAT_COLORS[a.data.categoria] ?? 'linear-gradient(135deg,#1a1a1a,#0d0d0d)';
          return (
            <a href={`/blog/${a.id}`} class="acard acard--featured">
              <div class="acard-thumb" style={!thumb ? `background:${bg}` : ''}>
                {thumb && <img src={thumb} alt={a.data.title} loading="lazy" />}
              </div>
              <div class="acard-body">
                <span class="acard-cat">{CATEGORIA_LABELS[a.data.categoria]}</span>
                <h3>{a.data.title}</h3>
                <p>{a.data.description}</p>
                <span class="acard-link">Leer artículo →</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {useGrouped ? (
    catSections.map(([cat, catArticles]) => (
      <section class="cat-section">
        <h2 class="section-title">{CATEGORIA_LABELS[cat as keyof typeof CATEGORIA_LABELS]}</h2>
        <div class="all-grid">
          {catArticles.map(a => {
            const thumb = getThumb(a);
            const bg = CAT_COLORS[a.data.categoria] ?? 'linear-gradient(135deg,#1a1a1a,#0d0d0d)';
            return (
              <a href={`/blog/${a.id}`} class="acard">
                <div class="acard-thumb" style={!thumb ? `background:${bg}` : ''}>
                  {thumb && <img src={thumb} alt={a.data.title} loading="lazy" />}
                </div>
                <div class="acard-body">
                  <span class="acard-cat">{CATEGORIA_LABELS[a.data.categoria]}</span>
                  <h3>{a.data.title}</h3>
                  <p>{a.data.description}</p>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))
  ) : rest.length > 0 && (
    <section class="all-section">
      <h2 class="section-title">Todos los artículos</h2>
      <div class="all-grid">
        {rest.map(a => {
          const thumb = getThumb(a);
          const bg = CAT_COLORS[a.data.categoria] ?? 'linear-gradient(135deg,#1a1a1a,#0d0d0d)';
          return (
            <a href={`/blog/${a.id}`} class="acard">
              <div class="acard-thumb" style={!thumb ? `background:${bg}` : ''}>
                {thumb && <img src={thumb} alt={a.data.title} loading="lazy" />}
              </div>
              <div class="acard-body">
                <span class="acard-cat">{CATEGORIA_LABELS[a.data.categoria]}</span>
                <h3>{a.data.title}</h3>
                <p>{a.data.description}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}
</div>
</BaseLayout>

<style>
  .wrap { max-width:1300px; margin:0 auto; padding:0 2rem 5rem; }
  @media(max-width:640px){ .wrap{padding:0 1.25rem 4rem;} }

  .blog-header { padding:2rem 0 2.5rem; }
  .blog-header h1 { font-size:clamp(2rem,4vw,3rem); font-weight:800; letter-spacing:-.03em; margin:.3rem 0 .4rem; }
  .blog-header p { color:var(--text-2); font-size:.95rem; }

  .section-title {
    font-size:.7rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.1em; color:var(--text-2); margin-bottom:1rem;
  }

  .featured-section { margin-bottom:3rem; }
  .cat-section { margin-bottom:3rem; }
  .all-section { margin-bottom:3rem; }

  .featured-grid {
    display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
    gap:12px;
  }

  .all-grid {
    display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
    gap:10px;
  }

  /* Card base */
  .acard {
    background:var(--surface); border:1px solid var(--border);
    border-radius:8px; overflow:hidden;
    display:flex; flex-direction:column;
    transition:border-color .2s, transform .18s;
  }
  .acard:hover { border-color:var(--border-2); transform:translateY(-2px); }

  .acard--featured {
    background:linear-gradient(135deg,var(--surface) 0%,#1c1c1c 100%);
    border-color:var(--border-2);
  }

  /* Thumbnail */
  .acard-thumb {
    width:100%; aspect-ratio:16/9; overflow:hidden;
    border-radius:8px 8px 0 0; flex-shrink:0;
  }
  .acard-thumb img {
    width:100%; height:100%; object-fit:cover; display:block;
  }

  /* Body */
  .acard-body {
    padding:1.25rem 1.4rem;
    display:flex; flex-direction:column; gap:.45rem;
    flex:1;
  }

  .acard-cat {
    font-size:.65rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.08em; color:var(--accent);
  }

  .acard h3 {
    font-size:.95rem; font-weight:700; line-height:1.35; color:var(--text);
  }

  .acard p { font-size:.82rem; color:var(--text-2); line-height:1.55; }

  .acard-link {
    font-size:.78rem; font-weight:600; color:var(--accent);
    margin-top:.25rem;
  }
</style>
