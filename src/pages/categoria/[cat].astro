---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryRow from '../../components/CategoryRow.astro';
import { getCollection } from 'astro:content';
import { CATEGORIA_LABELS } from '../../content.config';

const MAGIC_URL = 'https://www.magichotelgroup.com/es?utm_source=embajadores&utm_medium=macroinfluencer&utm_campaign=MAGICLOSFAMILUKIS&cp=MAGICLOSFAMILUKI';

export async function getStaticPaths() {
  const videos = (await getCollection('videos')).filter(v => !v.data.hidden);
  const cats = [...new Set(videos.map(v => v.data.categoria))];
  return cats.map(cat => {
    const catVideos = videos
      .filter(v => v.data.categoria === cat)
      .sort((a, b) => (b.data.views ?? 0) - (a.data.views ?? 0));
    return { params: { cat }, props: { label: CATEGORIA_LABELS[cat], catVideos } };
  });
}

interface Props { label: string; catVideos: any[] }
const { cat } = Astro.params;
const { label, catVideos } = Astro.props;
const isMagic = cat === 'magic-world';

function toRow(vids: any[]) {
  return vids.map(v => ({
    videoId: v.data.videoId, title: v.data.title,
    duracion: v.data.duracion, views: v.data.views, slug: v.id,
  }));
}

const EDITORIALES: Record<string, string> = {
  'magic-world':
    'Magic World Resort es el gran complejo vacacional familiar con hoteles en Oropesa del Mar (Castellón) y Benidorm (Alicante). En Familukis llevamos años visitándolo con nuestros hijos y documentando cada rincón: atracciones de agua, shows, zonas de juego para los más pequeños y los mejores trucos para aprovechar el día al máximo. Si estás planeando una escapada en familia a la costa mediterránea, aquí tienes todo lo que necesitas saber antes de ir.',
  'para-ninos':
    'Juguetes que de verdad entretienen, juegos para hacer en casa y actividades pensadas para niños de todas las edades. En Familukis ponemos a prueba los juguetes más populares, comparamos opciones y os mostramos cuáles merecen la pena. Desde slimes hasta construcciones, pasando por juegos de mesa y manualidades, encontrarás ideas para regalar o para disfrutar cualquier tarde en casa.',
  'retos-challenges':
    'Los retos en familia son uno de nuestros contenidos favoritos: nos sacan de la rutina, nos hacen reír y crean recuerdos que duran años. Aquí recopilamos todos los challenges que hemos probado con los Familukis: retos de comida, desafíos físicos, retos de habilidad y mucho más. Ideales para hacer en casa o en el jardín, sin necesidad de material especial.',
  'halloween':
    'Halloween es nuestra fiesta favorita del año. En Familukis te mostramos cómo organizarla en grande con niños: disfraces caseros originales, decoración terrorífica con poco presupuesto, juegos de Halloween para celebrar en casa y las mejores ideas para que los más pequeños lo pasen de miedo. Todo desde nuestra experiencia real como familia.',
  'camping-naturaleza':
    'El camping y la naturaleza con niños es una de las mejores experiencias que puedes darles. Hemos acampado en pinares, junto a ríos y en la montaña, y aquí te contamos qué llevar, dónde ir y cómo hacer que los más pequeños disfruten del aire libre sin dramas. Rutas fáciles, campings familiares y consejos prácticos para familias que quieren desconectar de verdad.',
  'navidad-regalos':
    'La Navidad en familia es magia pura. En Familukis compartimos nuestras tradiciones, los mejores regalos que hemos probado con nuestros hijos y ideas para hacer de las fiestas algo especial sin gastar una fortuna. Apertura de regalos, decoración navideña, recetas y los momentos más emotivos de nuestra familia en las fechas más bonitas del año.',
  'parques-acuaticos':
    'Los parques acuáticos son el plan perfecto para el verano en familia. Hemos visitado los mejores de España y te contamos cuáles merecen la pena, qué atracciones tienen para niños pequeños, cómo evitar colas y los trucos que usamos nosotros para que el día sea perfecto. Toboganes, piscinas de olas, ríos lentos y mucha diversión bajo el sol.',
  'vacaciones-familia':
    'Viajar en familia es una aventura que merece vivirse. En Familukis documentamos nuestras escapadas por España y más allá: destinos con niños, hoteles familiares, qué ver y qué hacer en cada lugar. Desde la playa hasta la montaña, pasando por ciudades con encanto, aquí tienes inspiración real para planificar vuestras próximas vacaciones.',
  'parques-atracciones':
    'Los parques de atracciones son el destino favorito de los Familukis. Hemos visitado los grandes parques de España y te contamos todo: las atracciones imprescindibles, las que tienen mínimo de talla, cómo organizar el día para no perderse nada y cuáles merecen el viaje. Experiencias reales para ayudarte a elegir el mejor parque para tu familia.',
  'playas-costa':
    'Las playas y la costa española tienen mucho que ofrecer a las familias. Hemos recorrido calas, playas urbanas y pueblos costeros con nuestros hijos, y aquí compartimos los mejores rincones: aguas tranquilas para los peques, servicios para familias, chiringuitos y todo lo que necesitas para unas jornadas perfectas junto al mar.',
  'vlogs-familia':
    'El día a día de los Familukis: cumpleaños, sorpresas, viajes improvisados y momentos especiales que merecen ser guardados. Estos vlogs son una ventana a nuestra vida familiar real, con todo lo bueno y lo caótico que eso implica. Si quieres conocernos un poco mejor o simplemente disfrutar de contenido familiar auténtico, este es tu sitio.',
  'senderismo-cascadas':
    'El senderismo con niños es más fácil de lo que parece si eliges bien la ruta. En Familukis hemos caminado hasta cascadas espectaculares, pozas de agua cristalina y miradores con vistas increíbles, todo con niños de distintas edades. Aquí encontrarás rutas sencillas y de dificultad media pensadas para familias que quieren descubrir la naturaleza a pie.',
  'montana-pirineos':
    'La montaña y los Pirineos ofrecen algunos de los paisajes más impresionantes de España, y son perfectamente disfrutables en familia. Hemos subido a miradores, cruzado valles y disfrutado de la nieve con los Familukis, y aquí te contamos cómo preparar el viaje, qué ropa llevar y cuáles son los rincones que más nos han emocionado.',
  'actividades-casa':
    'Cuando el tiempo no acompaña o simplemente apetece quedarse en casa, siempre hay un plan Familukis. Manualidades, experimentos caseros, juegos de mesa, retos y actividades creativas que entretienen a niños de todas las edades sin necesidad de salir ni gastar. Aquí tienes nuestra selección de los mejores planes para disfrutar en familia sin moverte del sofá.',
};

const editorial = EDITORIALES[cat ?? ''] ?? '';

const top      = toRow(catVideos.slice(0, 20));
const recientes = toRow([...catVideos].sort((a,b) => b.data.publishedAt.localeCompare(a.data.publishedAt)).slice(0, 20));
const mas      = toRow(catVideos.slice(20, 60));
const aun      = toRow(catVideos.slice(60));

const hero = catVideos[0];
const heroThumb = hero ? `https://img.youtube.com/vi/${hero.data.videoId}/maxresdefault.jpg` : '';
---

<BaseLayout
  title={`${label} en familia — Familukis`}
  description={`Los mejores vídeos de ${label.toLowerCase()} para familias. Experiencias reales con niños por toda España.`}
  image={heroThumb}
>
  {hero && (
    <section class="cat-hero" style={`--img:url('${heroThumb}')`}>
      <div class="cat-hero-bg"></div>
      <div class="cat-hero-content wrap">
        <nav class="breadcrumb">
          <a href="/">Inicio</a><span>›</span><span>{label}</span>
        </nav>
        <h1>{label}</h1>
        <p class="cat-sub">{catVideos.length} vídeos · experiencias reales en familia</p>
        <div class="cat-actions">
          <a href={`/videos/${hero.id}`} class="btn-play">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M8 5v14l11-7z"/></svg>
            Reproducir
          </a>
          {isMagic && (
            <a href={MAGIC_URL} target="_blank" rel="sponsored noopener" class="btn-info">
              🎡 Reservar con descuento
            </a>
          )}
        </div>
      </div>
    </section>
  )}

  {isMagic && (
    <div class="wrap"><a href={MAGIC_URL} target="_blank" rel="sponsored noopener" class="magic-strip">
      <div class="ms-left">
        <span class="ms-tag">Código exclusivo</span>
        <strong>Reserva en Magic World Resort con descuento</strong>
        <span class="ms-desc">Usa el código <em>MAGICLOSFAMILUKIS</em> al reservar</span>
      </div>
      <span class="ms-cta">Reservar ahora →</span>
    </a></div>
  )}

  {editorial && (
    <div class="wrap">
      <p class="cat-editorial">{editorial}</p>
    </div>
  )}

  <div class="wrap cat-rows">
    {top.length > 0 && <CategoryRow title="Más vistos" videos={top} />}
    {recientes.length > 0 && <CategoryRow title="Más recientes" videos={recientes} />}
    {mas.length > 0 && <CategoryRow title="Todos los vídeos" videos={mas} />}
    {aun.length > 0 && <CategoryRow title="Aún más" videos={aun} />}
  </div>
</BaseLayout>

<style>
  .wrap { max-width:1300px; margin:0 auto; padding:0 2rem; }
  @media(max-width:640px){ .wrap{padding:0 1.25rem;} }

  .cat-hero {
    position:relative; height:clamp(260px,42vh,420px);
    display:flex; align-items:flex-end; overflow:hidden;
  }
  .cat-hero-bg {
    position:absolute; inset:0;
    background-image:var(--img); background-size:cover; background-position:center 20%;
    filter:brightness(0.65);
  }
  .cat-hero::after {
    content:''; position:absolute; inset:0;
    background:
      linear-gradient(to right,rgba(20,20,20,.88) 0%,rgba(20,20,20,.42) 50%,transparent 100%),
      linear-gradient(to top,rgba(20,20,20,.95) 0%,transparent 48%);
  }
  .cat-hero-content { position:relative; z-index:1; padding-bottom:2.5rem; }
  .cat-hero-content h1 {
    font-size:clamp(1.8rem,4vw,2.8rem); font-weight:800;
    letter-spacing:-.03em; margin:.3rem 0 .25rem;
  }
  .cat-sub { font-size:.875rem; color:var(--text-2); margin-bottom:1.1rem; }
  .cat-actions { display:flex; gap:.75rem; flex-wrap:wrap; }

  .btn-play {
    display:inline-flex; align-items:center; gap:8px;
    background:#fff; color:#000; font-weight:700; font-size:.875rem;
    padding:.55rem 1.3rem; border-radius:4px; transition:background .15s;
  }
  .btn-play:hover { background:rgba(255,255,255,.8); }

  .btn-info {
    display:inline-flex; align-items:center; gap:8px;
    background:rgba(255,255,255,.15); backdrop-filter:blur(4px);
    color:#fff; font-weight:600; font-size:.875rem;
    padding:.55rem 1.3rem; border-radius:4px; transition:background .15s;
  }
  .btn-info:hover { background:rgba(255,255,255,.25); }

  .magic-strip {
    display:flex; align-items:center; justify-content:space-between; gap:1rem;
    background:linear-gradient(90deg,#1a0000,#250000);
    border:1px solid rgba(229,9,20,.3); border-radius:6px;
    padding:1rem 1.5rem; margin-top:1.75rem; transition:border-color .2s;
  }
  .magic-strip:hover { border-color:rgba(229,9,20,.65); }
  .ms-left { display:flex; flex-direction:column; gap:2px; }
  .ms-tag { font-size:.65rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--accent); }
  .ms-left strong { font-size:.9rem; color:#fff; }
  .ms-desc { font-size:.8rem; color:var(--text-2); }
  .ms-desc em { font-style:normal; color:var(--accent); font-weight:800; }
  .ms-cta { font-size:.85rem; font-weight:700; color:var(--accent); flex-shrink:0; white-space:nowrap; }

  .cat-editorial {
    font-size:.92rem; color:var(--text-2); line-height:1.75;
    max-width:72ch; margin:1.75rem 0 0;
    border-left:3px solid rgba(229,9,20,.35);
    padding-left:1.1rem;
  }

  .cat-rows { padding-top:.5rem; padding-bottom:5rem; }

  @media(max-width:640px){
    .magic-strip { flex-direction:column; align-items:flex-start; }
    .ms-cta { display:none; }
  }
</style>
