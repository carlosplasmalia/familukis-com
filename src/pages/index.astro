---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryRow from '../components/CategoryRow.astro';
import Top10Row from '../components/Top10Row.astro';
import ProductRow from '../components/ProductRow.astro';
import LeadCapture from '../components/LeadCapture.astro';
import { getCollection } from 'astro:content';
import { CATEGORIA_LABELS } from '../content.config';

// Productos Amazon (afiliados)
const PRODUCTOS = [
  {
    title: 'Los Familukis y el poder de los Slimeris',
    badge: 'Libro',
    image: 'https://m.media-amazon.com/images/I/71+VadQF4zL._SL300_.jpg',
    url: 'https://amzn.to/44tMP0P',
  },
  {
    title: 'Lorien, el elfo que brillaba distinto',
    badge: 'Libro',
    image: 'https://m.media-amazon.com/images/I/61wko4YykAL._SL300_.jpg',
    url: 'https://amzn.to/4oL0M3M',
  },
  {
    title: 'MANDALAS La Mancha con Humor',
    badge: 'Libro',
    image: 'https://m.media-amazon.com/images/I/71FLOLsp87L._SL300_.jpg',
    url: 'https://amzn.to/4esSxpM',
  },
  {
    title: 'Libro de Colorear Familukis',
    badge: 'Libro',
    image: 'https://m.media-amazon.com/images/I/71Bn0ZwidfL._SL300_.jpg',
    url: 'https://amzn.to/4oYns0H',
  },
  {
    title: 'Camiseta Familukis — Viajeros',
    badge: 'Moda',
    image: 'https://m.media-amazon.com/images/I/B1cRsgg-hzL._CLa%7C2140%2C2000%7C91u9L9GVO8L.png%7C0%2C0%2C2140%2C2000%2B0.0%2C0.0%2C2140.0%2C2000.0_AC_SL400_.png',
    url: 'https://amzn.to/4gG9Y7y',
  },
  {
    title: 'Camiseta Madres Empoderadas',
    badge: 'Moda',
    image: 'https://m.media-amazon.com/images/I/B1EzU8uSCAL._CLa%7C2140%2C2000%7C81cz8xC8JRL.png%7C0%2C0%2C2140%2C2000%2B0.0%2C0.0%2C2140.0%2C2000.0_AC_SL400_.png',
    url: 'https://amzn.to/43WZZmV',
  },
  {
    title: 'Camiseta Marino Animales Piratas',
    badge: 'Moda',
    image: 'https://m.media-amazon.com/images/I/B1pppR4gVKL._CLa%7C2140%2C2000%7C819Bn3wD2tL.png%7C0%2C0%2C2140%2C2000%2B0.0%2C0.0%2C2140.0%2C2000.0_AC_SL400_.png',
    url: 'https://amzn.to/4g7nnW7',
  },
];

// Top 10 nostálgicos — portadas verticales generadas con Magnific Nano Banana
const TOP10 = [
  { rank:1,  videoId:'0FKc5N6OZdY', slug:'squishy-vs-real-food-vs-gominola-familukis',                             title:'SQUISHY vs Real Food vs GOMINOLA',         cover:'/covers/top1-squishy.webp' },
  { rank:2,  videoId:'56mIaEvoe-c', slug:'4-bromas-faciles-para-hacer-en-casa-juegos-y-juguetes-en-fam',           title:'4 Bromas Fáciles Para Hacer en Casa',       cover:'/covers/top2-bromas.webp' },
  { rank:3,  videoId:'aQ-euuK_H1c', slug:'24-horas-solos-en-la-jungla-sin-padres',                                 title:'24 Horas SOLOS en la JUNGLA sin Padres',   cover:'/covers/top3-jungla.webp' },
  { rank:4,  videoId:'PrmdEXsMRAk', slug:'retos-divertidos-con-amigos-invitada-especial-los-familukis',             title:'Retos Divertidos con Amigos',              cover:'/covers/top4-amigos.webp' },
  { rank:5,  videoId:'wgq0_onzOGk', slug:'tenemos-un-hermanito-chiquitito-vamos-bebe',                              title:'TENEMOS UN HERMANITO CHIQUITITO',          cover:'/covers/top5-hermanito.webp' },
  { rank:6,  videoId:'ShfxkD_dz50', slug:'familukis-fiesta-del-millon-en-mansion-de-los-juguetes-de-ar',            title:'Fiesta del MILLÓN en MANSIÓN de Juguetes', cover:'/covers/top6-millon.webp' },
  { rank:7,  videoId:'gv9pXFc7ke8', slug:'un-hacker-misterioso-entra-a-nuestra-casa-el-enigma-del-homb',            title:'UN HACKER Misterioso ENTRA a Nuestra CASA',cover:'/covers/top7-hacker.webp' },
  { rank:8,  videoId:'wgoWorcM1Rw', slug:'chocolate-vs-real-familukis',                                             title:'CHOCOLATE vs REAL',                        cover:'/covers/top8-chocolate.webp' },
  { rank:9,  videoId:'yrePQ0r_5GE', slug:'mi-padre-se-cuela-en-el-gimnasio-olimpico-super-saltos-los-f',            title:'Mi Padre se CUELA en el Gimnasio Olímpico',cover:'/covers/top9-gimnasio.webp' },
  { rank:10, videoId:'aj-yHtBd3T8', slug:'drink-slime-vs-real-drink-vs-pica-pica-bebida-real-vs-bebida',            title:'DRINK SLIME vs REAL DRINK vs PICA PICA',  cover:'/covers/top10-slime.webp' },
];

const allVideos = (await getCollection('videos')).filter(v => !v.data.hidden);
const byViews = [...allVideos].sort((a, b) => (b.data.views ?? 0) - (a.data.views ?? 0));

// Hero: mejor vídeo visual — no magic-world ni para-ninos (interiores)
const HERO_CATS = ['parques-atracciones','camping-naturaleza','vacaciones-familia',
                   'playas-costa','parques-acuaticos','vlogs-familia','retos-challenges'];
const hero = byViews.find(v => HERO_CATS.includes(v.data.categoria)) ?? byViews[0];
const heroThumb = `https://img.youtube.com/vi/${hero.data.videoId}/maxresdefault.jpg`;

function toRow(vids: typeof allVideos) {
  return vids.slice(0, 16).map(v => ({
    videoId: v.data.videoId, title: v.data.title,
    duracion: v.data.duracion, views: v.data.views, slug: v.id,
  }));
}

const byCat = (cat: string) => byViews.filter(v => v.data.categoria === cat);

function formatViews(n: number) {
  if (n >= 1_000_000) return `${(n/1_000_000).toFixed(1)}M vistas`;
  if (n >= 1_000) return `${Math.round(n/1_000)}K vistas`;
  return `${n} vistas`;
}
---

<BaseLayout
  title="Familukis — Canal de YouTube y blog de la familia"
  description="Somos los Familukis: familia numerosa con canal de YouTube. Aquí tienes todos nuestros vídeos, artículos y guías de parques, retos, escapadas y aventuras en familia."
  image={heroThumb}
>

<!-- HERO -->
<section class="hero" style={`--bg:url('${heroThumb}')`}>
  <div class="hero-bg"></div>
  <div class="hero-body wrap">
    <h1 class="sr-only">Familukis — Planes y actividades en familia: parques, retos, naturaleza y viajes con niños</h1>
    <span class="htag">Más visto</span>
    <h2 class="hero-title">{hero.data.title}</h2>
    {hero.data.description && <p>{hero.data.description.slice(0, 120).trim()}…</p>}
    <div class="hero-btns">
      <a href={`/videos/${hero.id}`} class="hbtn-play">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M8 5v14l11-7z"/></svg>
        Reproducir
      </a>
      <a href="/blog" class="hbtn-more">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
        Explorar
      </a>
    </div>
    {hero.data.views > 0 && <span class="hviews">{formatViews(hero.data.views)}</span>}
  </div>
</section>

<!-- FILAS -->
<div class="wrap rows">

  {byCat('magic-world').length > 0 && (
    <CategoryRow title="✨ Magic World Resort" href="/categoria/magic-world" videos={toRow(byCat('magic-world'))} />
  )}

  {byCat('retos-challenges').length > 0 && (
    <CategoryRow title="Retos y Challenges" href="/categoria/retos-challenges" videos={toRow(byCat('retos-challenges'))} />
  )}

  <Top10Row title="Para los más nostálgicos 🏆" items={TOP10} />

  <!-- Lead capture -->
  <LeadCapture />

  {byCat('parques-atracciones').length > 0 && (
    <CategoryRow title="Parques de Atracciones" href="/categoria/parques-atracciones" videos={toRow(byCat('parques-atracciones'))} />
  )}

  {byCat('para-ninos').length > 0 && (
    <CategoryRow title="Para Niños — Juegos y Juguetes" href="/categoria/para-ninos" videos={toRow(byCat('para-ninos'))} />
  )}

  {byCat('halloween').length > 0 && (
    <CategoryRow title="🎃 Halloween" href="/categoria/halloween" videos={toRow(byCat('halloween'))} />
  )}

  {byCat('camping-naturaleza').length > 0 && (
    <CategoryRow title="Camping y Naturaleza" href="/categoria/camping-naturaleza" videos={toRow(byCat('camping-naturaleza'))} />
  )}

  {byCat('navidad-regalos').length > 0 && (
    <CategoryRow title="🎄 Navidad y Regalos" href="/categoria/navidad-regalos" videos={toRow(byCat('navidad-regalos'))} />
  )}

  {byCat('parques-acuaticos').length > 0 && (
    <CategoryRow title="Parques Acuáticos" href="/categoria/parques-acuaticos" videos={toRow(byCat('parques-acuaticos'))} />
  )}

  {byCat('vacaciones-familia').length > 0 && (
    <CategoryRow title="Vacaciones en Familia" href="/categoria/vacaciones-familia" videos={toRow(byCat('vacaciones-familia'))} />
  )}

  {byCat('playas-costa').length > 0 && (
    <CategoryRow title="Playas y Costa" href="/categoria/playas-costa" videos={toRow(byCat('playas-costa'))} />
  )}

  {byCat('vlogs-familia').length > 0 && (
    <CategoryRow title="Vlogs de Familia" href="/categoria/vlogs-familia" videos={toRow(byCat('vlogs-familia'))} />
  )}

  <!-- Productos Amazon -->
  <ProductRow title="Nuestra tienda" products={PRODUCTOS} />

  <!-- Blog teaser -->
  <section class="blog-teaser">
    <div class="blog-teaser-hd">
      <h2>Del blog</h2>
      <a href="/blog" class="see-all">Ver todos los artículos <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
    </div>
    <div class="blog-grid">
      <a href="/blog/juegos-y-retos-para-hacer-en-casa-con-ninos" class="blog-card">
        <span class="blog-cat">Para niños</span>
        <h3>Juegos y retos para hacer en casa con niños</h3>
        <p>Las mejores ideas de juegos para entretener a los niños en casa sin gastar casi nada.</p>
      </a>
      <a href="/blog/halloween-con-ninos-ideas-disfraces-y-actividades" class="blog-card">
        <span class="blog-cat">Halloween</span>
        <h3>Halloween con niños: disfraces caseros e ideas</h3>
        <p>Cómo celebrar Halloween en familia con disfraces fáciles y actividades que funcionan de verdad.</p>
      </a>
      <a href="/blog/parque-warner-madrid-con-ninos-guia-completa" class="blog-card">
        <span class="blog-cat">Parques</span>
        <h3>Parque Warner Madrid con niños: guía completa</h3>
        <p>Todo lo que necesitas saber antes de ir: qué ver, cómo organizarlo y si merece la pena.</p>
      </a>
    </div>
  </section>

</div>
</BaseLayout>

<style>
  .wrap { max-width:1300px; margin:0 auto; padding:0 2rem; }
  @media(max-width:640px){ .wrap{padding:0 1.25rem;} }

  /* HERO */
  .hero {
    position:relative; min-height:min(68vh,580px);
    display:flex; align-items:flex-end; overflow:hidden;
  }
  .hero-bg {
    position:absolute; inset:0;
    background-image:var(--bg); background-size:cover; background-position:center 20%;
    filter:brightness(0.68); transform:scale(1.02);
  }
  .hero::after {
    content:''; position:absolute; inset:0;
    background:
      linear-gradient(to right,rgba(20,20,20,.88) 0%,rgba(20,20,20,.45) 50%,transparent 100%),
      linear-gradient(to top,rgba(20,20,20,.95) 0%,transparent 45%);
  }
  .hero-body {
    position:relative; z-index:1;
    padding-bottom:2rem; padding-top:2rem; max-width:560px;
  }
  .htag {
    display:inline-block; background:var(--accent); color:#fff;
    font-size:.68rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.08em; padding:3px 10px; border-radius:3px; margin-bottom:.6rem;
  }
  .sr-only {
    position:absolute; width:1px; height:1px; padding:0;
    overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0;
  }
  .hero-title {
    font-size:clamp(1.5rem,3.2vw,2.5rem); font-weight:800;
    line-height:1.15; letter-spacing:-.025em; margin-bottom:.7rem;
    text-shadow:0 2px 10px rgba(0,0,0,.5);
  }
  .hero-body p {
    font-size:.9rem; color:rgba(255,255,255,.68);
    line-height:1.65; margin-bottom:1.4rem; max-width:48ch;
  }
  .hero-btns { display:flex; gap:.65rem; flex-wrap:wrap; }
  .hbtn-play {
    display:inline-flex; align-items:center; gap:7px;
    background:#fff; color:#000; font-weight:700; font-size:.875rem;
    padding:.55rem 1.3rem; border-radius:4px; transition:background .15s;
  }
  .hbtn-play:hover { background:rgba(255,255,255,.82); }
  .hbtn-more {
    display:inline-flex; align-items:center; gap:7px;
    background:rgba(109,109,110,.7); color:#fff; font-weight:600; font-size:.875rem;
    padding:.55rem 1.3rem; border-radius:4px; transition:background .15s;
  }
  .hbtn-more:hover { background:rgba(109,109,110,.9); }
  .hviews { display:block; margin-top:.85rem; font-size:.75rem; color:rgba(255,255,255,.38); }

  /* ROWS */
  .rows { padding-top:.25rem; padding-bottom:4rem; }

  /* BLOG TEASER */
  .blog-teaser { padding:2rem 0 1rem; }
  .blog-teaser-hd {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:1rem;
  }
  .blog-teaser-hd h2 { font-size:1.05rem; font-weight:700; }
  .see-all {
    display:flex; align-items:center; gap:4px;
    font-size:.75rem; font-weight:600; color:var(--text-2); transition:color .15s;
  }
  .see-all:hover { color:var(--accent); }

  .blog-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; }
  @media(max-width:800px){ .blog-grid{grid-template-columns:1fr 1fr;} }
  @media(max-width:500px){ .blog-grid{grid-template-columns:1fr;} }

  .blog-card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:8px; padding:1.25rem;
    transition:border-color .2s, transform .2s;
    display:flex; flex-direction:column; gap:.4rem;
  }
  .blog-card:hover { border-color:var(--border-2); transform:translateY(-2px); }
  .blog-cat {
    font-size:.65rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.08em; color:var(--accent);
  }
  .blog-card h3 {
    font-size:.9rem; font-weight:700; line-height:1.35; color:var(--text);
  }
  .blog-card p { font-size:.8rem; color:var(--text-2); line-height:1.55; }
</style>
