---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryRow from '../components/CategoryRow.astro';
import { getCollection } from 'astro:content';
import { CATEGORIA_LABELS } from '../content.config';

const allVideos = await getCollection('videos');
const byViews = [...allVideos].sort((a, b) => (b.data.views ?? 0) - (a.data.views ?? 0));

const hero = byViews[0];
const heroThumb = `https://img.youtube.com/vi/${hero?.data.videoId}/maxresdefault.jpg`;

const PRIORITY = [
  'magic-world',
  'parques-atracciones',
  'vacaciones-familia',
  'camping-naturaleza',
  'parques-acuaticos',
  'montana-pirineos',
  'playas-costa',
  'senderismo-cascadas',
  'actividades-casa',
] as const;

const rows = PRIORITY.map(cat => ({
  cat,
  label: CATEGORIA_LABELS[cat],
  videos: byViews.filter(v => v.data.categoria === cat).slice(0, 14).map(v => ({
    videoId: v.data.videoId,
    title: v.data.title,
    duracion: v.data.duracion,
    views: v.data.views,
    slug: v.id,
  })),
})).filter(r => r.videos.length > 0);

function formatViews(n: number) {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M vistas`;
  if (n >= 1_000) return `${Math.round(n / 1_000)}K vistas`;
  return `${n} vistas`;
}
---

<BaseLayout
  title="Familukis — Planes y actividades en familia"
  description="Descubre los mejores planes con niños en España: parques de atracciones, camping, playas, rutas y mucho más. Experiencias reales de una familia española."
  image={heroThumb}
>

  <!-- ── HERO ─────────────────────────────────────── -->
  {hero && (
    <section class="hero" style={`--bg: url('${heroThumb}')`}>
      <div class="hero-bg"></div>
      <div class="hero-content wrap">
        <span class="tag tag-accent">Más visto</span>
        <h1>{hero.data.title}</h1>
        {hero.data.description && (
          <p>{hero.data.description.slice(0, 130).trim()}…</p>
        )}
        <div class="hero-actions">
          <a href={`/videos/${hero.id}`} class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Ver vídeo
          </a>
          <a href="/buscar" class="btn btn-ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            Buscar planes
          </a>
        </div>
        {hero.data.views > 0 && (
          <span class="hero-views">{formatViews(hero.data.views)}</span>
        )}
      </div>
    </section>
  )}

  <!-- ── MAGIC WORLD BANNER ────────────────────────── -->
  <div class="wrap">
    <a href="/categoria/magic-world" class="magic-banner">
      <div class="magic-icon">✨</div>
      <div class="magic-text">
        <strong>Magic World Resort · Código <em>Magiclosfamilukis</em></strong>
        <span>Descuento en entradas y estancias. Lo hemos probado, te contamos todo sin filtro.</span>
      </div>
      <div class="magic-cta">Ver experiencias →</div>
    </a>
  </div>

  <!-- ── FILAS DE CATEGORÍAS ───────────────────────── -->
  <div class="wrap rows-wrap">
    {rows.map(row => (
      <CategoryRow
        title={row.label}
        href={`/categoria/${row.cat}`}
        videos={row.videos}
      />
    ))}
  </div>

</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: min(68vh, 580px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: var(--bg);
    background-size: cover;
    background-position: center 20%;
    filter: brightness(0.55);
    transform: scale(1.02);
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.5) 55%, transparent 100%),
      linear-gradient(to top, rgba(10,10,10,1) 0%, transparent 45%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-bottom: 4.5rem;
    padding-top: 2rem;
    max-width: 580px;
  }

  .hero-content h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin: 0.6rem 0 0.8rem;
    text-shadow: 0 2px 12px rgba(0,0,0,0.4);
  }

  .hero-content p {
    font-size: 0.95rem;
    color: rgba(240,240,240,0.7);
    line-height: 1.65;
    margin-bottom: 1.5rem;
    max-width: 50ch;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-views {
    display: block;
    margin-top: 1rem;
    font-size: 0.78rem;
    color: rgba(240,240,240,0.4);
  }

  /* MAGIC BANNER */
  .magic-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: linear-gradient(135deg, #1a0000 0%, #200000 100%);
    border: 1px solid rgba(229,9,20,0.25);
    border-radius: var(--r-xl);
    padding: 1.1rem 1.5rem;
    margin-top: 2.5rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .magic-banner:hover {
    border-color: rgba(229,9,20,0.5);
    transform: translateY(-1px);
  }

  .magic-icon {
    font-size: 1.6rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .magic-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .magic-text strong {
    font-size: 0.95rem;
    color: var(--text);
  }

  .magic-text em {
    font-style: normal;
    color: var(--accent);
    font-weight: 800;
  }

  .magic-text span {
    font-size: 0.82rem;
    color: var(--text-3);
  }

  .magic-cta {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ROWS */
  .rows-wrap {
    padding-top: 0.5rem;
    padding-bottom: 4rem;
  }

  @media (max-width: 640px) {
    .hero { min-height: min(55vh, 400px); }
    .magic-cta { display: none; }
    .magic-banner { gap: 0.75rem; }
  }
</style>
