---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryRow from '../components/CategoryRow.astro';
import VideoCard from '../components/VideoCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIA_LABELS } from '../content.config';

const allVideos = await getCollection('videos');

// Ordenar por vistas
const byViews = [...allVideos].sort((a, b) => (b.data.views ?? 0) - (a.data.views ?? 0));

// Vídeo destacado (más vistas)
const hero = byViews[0];

// Categorías con más de 3 vídeos, ordenadas por relevancia manual
const PRIORITY_CATS = [
  'magic-world',
  'parques-atracciones',
  'vacaciones-familia',
  'camping-naturaleza',
  'parques-acuaticos',
  'actividades-casa',
  'montana-pirineos',
  'playas-costa',
  'senderismo-cascadas',
] as const;

const rows = PRIORITY_CATS.map(cat => {
  const vids = byViews
    .filter(v => v.data.categoria === cat)
    .slice(0, 12)
    .map(v => ({
      videoId: v.data.videoId,
      title: v.data.title,
      duracion: v.data.duracion,
      views: v.data.views,
      slug: v.id,
    }));
  return { cat, label: CATEGORIA_LABELS[cat], vids };
}).filter(r => r.vids.length > 0);

const heroThumb = `https://img.youtube.com/vi/${hero?.data.videoId}/maxresdefault.jpg`;
---

<BaseLayout
  title="Familukis — Planes y actividades en familia"
  description="Descubre los mejores planes con niños: parques de atracciones, camping, playas, rutas de senderismo y mucho más. Experiencias reales de una familia española."
>
  <!-- HERO -->
  {hero && (
    <section class="hero" style={`--hero-img: url('${heroThumb}')`}>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <span class="hero-tag">Más visto</span>
        <h1 class="hero-title">{hero.data.title}</h1>
        <p class="hero-desc">{hero.data.description?.slice(0, 120)}...</p>
        <div class="hero-actions">
          <a href={`/videos/${hero.id}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Ver vídeo
          </a>
          <a href="/buscar" class="btn-ghost">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            Buscar planes
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- MAGIC WORLD BANNER -->
  <div class="container">
    <a href="/categoria/magic-world" class="magic-banner">
      <div class="magic-banner-text">
        <span class="magic-tag">Código exclusivo</span>
        <strong>Magic World Resort — usa el código <em>Magiclosfamilukis</em></strong>
        <span>Descuento en entradas para familias. Lo probamos y te contamos todo.</span>
      </div>
      <div class="magic-banner-arrow">
        Ver experiencias →
      </div>
    </a>
  </div>

  <!-- FILAS DE CATEGORÍAS -->
  <div class="container rows-container">
    {rows.map((row, i) => (
      <CategoryRow
        title={row.label}
        href={`/categoria/${row.cat}`}
        videos={row.vids}
        accent={row.cat === 'magic-world'}
      />
    ))}
  </div>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    height: min(70vh, 560px);
    background-image: var(--hero-img);
    background-size: cover;
    background-position: center top;
    display: flex;
    align-items: flex-end;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(10,10,10,0.92) 0%,
      rgba(10,10,10,0.6) 50%,
      rgba(10,10,10,0.1) 100%
    ),
    linear-gradient(
      to top,
      rgba(10,10,10,1) 0%,
      transparent 40%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
    width: 100%;
    max-width: 600px;
    margin-left: max(1.5rem, calc((100vw - 1280px) / 2 + 1.5rem));
  }

  .hero-tag {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    line-height: 1.15;
    margin-bottom: 0.75rem;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }

  .hero-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    max-width: 48ch;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(4px);
    color: var(--text);
    font-weight: 600;
    padding: 0.7rem 1.5rem;
    border-radius: 8px;
    transition: background 0.2s;
    font-size: 0.95rem;
  }

  .btn-ghost:hover {
    background: rgba(255,255,255,0.18);
  }

  /* CONTAINER */
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* MAGIC BANNER */
  .magic-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: linear-gradient(135deg, #1a0d00, #2d1500);
    border: 1px solid rgba(255,107,0,0.3);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.75rem;
    margin: 2rem 0 0;
    transition: border-color 0.2s, transform 0.2s;
  }

  .magic-banner:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  .magic-banner-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .magic-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .magic-banner-text strong {
    font-size: 1rem;
    color: var(--text);
  }

  .magic-banner-text strong em {
    color: var(--accent);
    font-style: normal;
    font-weight: 800;
  }

  .magic-banner-text span {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .magic-banner-arrow {
    color: var(--accent);
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  /* ROWS */
  .rows-container {
    padding-top: 1rem;
    padding-bottom: 3rem;
  }

  @media (max-width: 640px) {
    .hero {
      height: min(55vh, 400px);
    }
    .hero-content {
      margin-left: 1.5rem;
    }
    .magic-banner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
