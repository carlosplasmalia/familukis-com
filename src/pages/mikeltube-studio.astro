function drawMuteBtn() {
  ctx.globalAlpha=0.75;
  ctx.fillStyle='rgba(0,0,10,0.5)';
  roundRect(W-44,6,38,30,7); ctx.fill();
  ctx.fillStyle='#fff'; ctx.font='16px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText(AudioMan.muted?'🔇':'🔊', W-25, 27);
  ctx.globalAlpha=1; ctx.textAlign='left';
}
function drawWorldBanner() {
  if (worldBanner<=0) return;
  const a = worldBanner>140 ? (170-worldBanner)/30 : worldBanner<30 ? worldBanner/30 : 1;
  ctx.save();
  ctx.globalAlpha=Math.min(1,a);
  ctx.fillStyle='rgba(0,0,25,0.72)';
  roundRect(W/2-260,H*0.30,520,110,16); ctx.fill();
  ctx.textAlign='center';
  ctx.fillStyle='#FFD700'; ctx.font='bold 40px "Baloo 2",sans-serif';
  ctx.fillText('MUNDO '+(world+1)+(lap>0?'  ·  VUELTA '+(lap+1):''), W/2, H*0.30+48);
  ctx.fillStyle='#fff'; ctx.font='bold 26px "Baloo 2",sans-serif';
  ctx.fillText(WORLDS[world].nombre, W/2, H*0.30+82);
  ctx.font='15px system-ui,sans-serif'; ctx.fillStyle='#aaddff';
  ctx.fillText(WORLDS[world].sub, W/2, H*0.30+104);
  ctx.restore();
  ctx.textAlign='left';
}
function drawHUD() {
  ctx.textAlign='left';
  ctx.fillStyle='rgba(0,0,10,0.55)';
  roundRect(10,10,210,40,9); ctx.fill();
  ctx.fillStyle='#fff'; ctx.font='bold 21px system-ui,sans-serif';
  ctx.fillText('SCORE  '+score.toLocaleString(), 20, 38);
  if (recordBeaten) {
    ctx.globalAlpha=0.7+Math.sin(gframe*0.15)*0.3;
    ctx.font='19px system-ui,sans-serif';
    ctx.fillText('🏆', 228, 37);
    ctx.globalAlpha=1;
  }

  if (fever>0 && state===ST.PLAYING) {
    const fa=0.22+0.14*Math.sin(gframe*0.2);
    ctx.strokeStyle=`rgba(255,180,0,${fa})`; ctx.lineWidth=16;
    ctx.strokeRect(8,8,W-16,H-16); ctx.lineWidth=1;
    ctx.textAlign='center';
    ctx.font='bold 22px "Baloo 2",sans-serif';
    ctx.lineWidth=4; ctx.strokeStyle='rgba(0,0,0,0.55)';
    ctx.strokeText('🔥 FIEBRE ×2  ·  '+Math.ceil(fever/60)+'s', W/2, 70);
    ctx.fillStyle='#FFDC00';
    ctx.fillText('🔥 FIEBRE ×2  ·  '+Math.ceil(fever/60)+'s', W/2, 70);
    ctx.lineWidth=1; ctx.textAlign='left';
  }

  const eb=gi('ebar'+Math.min(3,gems));
  if (eb) ctx.drawImage(eb, 10, 56, 150, 24);
  else {
    ctx.fillStyle='rgba(0,0,10,0.5)'; roundRect(10,58,150,14,7); ctx.fill();
    ctx.fillStyle='#44ff88'; roundRect(12,60,146*(gems/GEMS_FOR_TURBO),10,5); ctx.fill();
  }

  const ci=gi('c0');
  if (ci) ctx.drawImage(ci, W-166,11,28,28);
  ctx.fillStyle='#FFD700'; ctx.font='bold 21px system-ui,sans-serif';
  ctx.fillText('×'+coins, W-133, 34);

  if (combo>=5 && state===ST.PLAYING) {
    const mult=1+Math.floor(combo/5);
    const pulse=1+Math.sin(performance.now()*0.012)*0.08;
    ctx.save();
    ctx.translate(115,140); ctx.scale(pulse,pulse);
    ctx.textAlign='center';
    ctx.font='bold 26px "Baloo 2",sans-serif';
    ctx.lineWidth=5; ctx.strokeStyle='rgba(0,0,0,0.6)';
    ctx.strokeText('COMBO ×'+mult,0,0);
    ctx.fillStyle='#FFD700';
    ctx.fillText('COMBO ×'+mult,0,0);
    ctx.restore();
    ctx.fillStyle='rgba(0,0,10,0.5)'; ctx.fillRect(45,150,140,7);
    ctx.fillStyle='#FFD700'; ctx.fillRect(45,150,140*(comboT/180),7);
    ctx.textAlign='left';
  }

  // progreso del mundo: MUNDO N + barra hasta el jefe
  ctx.fillStyle='rgba(0,0,10,0.42)';
  roundRect(W/2-140,10,280,32,7); ctx.fill();
  ctx.fillStyle='#aaddff'; ctx.font='bold 13px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText('MUNDO '+(world+1)+' · '+WORLDS[world].nombre+(lap>0?' · V'+(lap+1):''), W/2, 24);
  const prog=Math.min(1, worldDist/WORLDS[world].len);
  ctx.fillStyle='rgba(255,255,255,0.18)'; roundRect(W/2-128,28,256,9,4); ctx.fill();
  ctx.fillStyle=prog>0.9?'#ff5544':'#7CFC00'; roundRect(W/2-128,28,256*prog,9,4); ctx.fill();
  // calaverita = jefe al final
  ctx.font='11px sans-serif';
  ctx.fillText('💀', W/2+134, 38);
  ctx.textAlign='left';

  const hi2=gi('heart');
  for (let i=0;i<LIVES;i++) {
    const hx=W-96-i*34;
    ctx.globalAlpha=i<lives?1:0.22;
    if (hi2) ctx.drawImage(hi2,hx,48,28,28);
    else { ctx.fillStyle='#e74c3c'; ctx.font='22px sans-serif'; ctx.fillText('♥',hx,70); }
  }
  ctx.globalAlpha=1;

  if (P.shielded>0 && state!==ST.BOSS) {
    ctx.fillStyle='rgba(0,0,10,0.5)'; ctx.fillRect(10,86,150,10);
    ctx.fillStyle='#44aaff'; ctx.fillRect(10,86,150*(P.shielded/420),10);
  }
  if (P.cat>0) {
    ctx.fillStyle='rgba(0,0,10,0.5)'; ctx.fillRect(10,100,150,10);
    ctx.fillStyle='#ffb060'; ctx.fillRect(10,100,150*(P.cat/480),10);
  }
  if (P.boosted>0) {
    ctx.fillStyle='rgba(255,140,0,0.88)'; ctx.font='bold 16px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.fillText('⚡  TURBO  ⚡', W/2, H-18);
    ctx.textAlign='left';
  }
  drawMuteBtn();
}

