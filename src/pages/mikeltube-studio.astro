// ═══════════════════════════════════════════════════════
//  IMAGE LOADING
// ═══════════════════════════════════════════════════════
const IMG = {};
let loaded = 0;
const TOTAL = Object.keys(ASSETS).length;
function preload() {
  return new Promise(resolve => {
    for (const [k, url] of Object.entries(ASSETS)) {
      const img = new Image();
      img.onload = img.onerror = () => { IMG[k] = img; if (++loaded >= TOTAL) resolve(); };
      img.src = url;
    }
  });
}
function gi(k) { const i = IMG[k]; return (i && i.naturalWidth) ? i : null; }
function di(k, x, y, w, h) { const i = gi(k); if (i) ctx.drawImage(i, x, y, w, h); }
function tileH(k, y, h, offsetX) {
  const i = gi(k); if (!i) return;
  const scale = h / i.naturalHeight;
  const tw = i.naturalWidth * scale;
  const off = -((offsetX % tw) + tw) % tw;
  for (let x = off - tw; x < W + tw; x += tw) ctx.drawImage(i, x, y, tw, h);
}

// ═══════════════════════════════════════════════════════
//  AUDIO (Web Audio — clips m4a extraídos del juego original)
// ═══════════════════════════════════════════════════════
const AUDIO_FILES = ['coin','gema','powerup-turbo','powerup-escudo','powerup-explosion',
  'bruja-aparece','bruja-carga','bruja-dispara','bruja-desaparece',
  'robot-aparece','robot-carga','robot-rayo','perro-ataque',
  'soldado-aviso','soldado-embiste','muerte','mikel-corre',
  'nave-aparece','nave-carga','nave-lanza','nave-disparo',
  'musica-menu','musica-ingame','ui-click','ui-back','ui-play','cannon'];

const AudioMan = {
  ctx:null, buffers:{}, musicSrc:null, musicName:null, runSrc:null,
  musicGain:null, sfxGain:null, unlocked:false,
  muted: localStorage.getItem('mk_mute')==='1',
  init() {
    if (this.ctx) return;
    const AC = window.AudioContext || window.webkitAudioContext;
    if (!AC) return;
    this.ctx = new AC();
    this.musicGain = this.ctx.createGain();
    this.sfxGain   = this.ctx.createGain();
    this.musicGain.connect(this.ctx.destination);
    this.sfxGain.connect(this.ctx.destination);
    this.applyMute();
    for (const n of AUDIO_FILES) {
      fetch(AU+n+'.m4a')
        .then(r => r.ok ? r.arrayBuffer() : Promise.reject())
        .then(ab => this.ctx.decodeAudioData(ab))
        .then(buf => {
          this.buffers[n] = buf;
          if (n===this.musicName && !this.musicSrc) this.music(n);
        })
        .catch(()=>{});
    }
  },
  unlock() {
    this.init();
    if (this.ctx && this.ctx.state==='suspended') this.ctx.resume();
    this.unlocked = true;
  },
  applyMute() {
    if (!this.ctx) return;
    this.musicGain.gain.value = this.muted ? 0 : 0.45;
    this.sfxGain.gain.value   = this.muted ? 0 : 0.9;
  },
  toggleMute() {
    this.muted = !this.muted;
    localStorage.setItem('mk_mute', this.muted?'1':'0');
    this.applyMute();
  },
  sfx(n, {vol=1, rate=1, loop=false}={}) {
    if (!this.ctx || !this.buffers[n]) return null;
    const src = this.ctx.createBufferSource();
    src.buffer = this.buffers[n];
    src.loop = loop;
    src.playbackRate.value = rate;
    const g = this.ctx.createGain();
    g.gain.value = vol;
    src.connect(g); g.connect(this.sfxGain);
    src.start();
    return src;
  },
  music(n) {
    this.musicName = n;
    if (!this.ctx || !this.buffers[n]) return;
    this.stopMusic(false);
    const src = this.ctx.createBufferSource();
    src.buffer = this.buffers[n];
    src.loop = true;
    src.connect(this.musicGain);
    src.start();
    this.musicSrc = src;
  },
  stopMusic(clearName=true) {
    if (this.musicSrc) { try{this.musicSrc.stop();}catch(e){} this.musicSrc=null; }
    if (clearName) this.musicName=null;
  },
  startRun() {
    if (this.runSrc || !this.ctx || !this.buffers['mikel-corre']) return;
    const src = this.ctx.createBufferSource();
    src.buffer = this.buffers['mikel-corre'];
    src.loop = true;
    const g = this.ctx.createGain(); g.gain.value = 0.5;
    src.connect(g); g.connect(this.sfxGain);
    src.start();
    this.runSrc = src;
  },
  stopRun() { if (this.runSrc) { try{this.runSrc.stop();}catch(e){} this.runSrc=null; } },
};
document.addEventListener('visibilitychange', () => {
  if (!AudioMan.ctx) return;
  if (document.hidden) AudioMan.ctx.suspend();
  else if (AudioMan.unlocked) AudioMan.ctx.resume();
});

// ═══════════════════════════════════════════════════════
//  CONSTANTES / MUNDOS
// ═══════════════════════════════════════════════════════
const GROUND  = 415;
const PX      = 175;
const GRAVITY = 0.65;
const JUMP_VY = -15.5;
const PH      = 92, PW = 72;
const LIVES   = 3;
const GEMS_FOR_TURBO = 3;
const REVIVE_COST = 50;

// Historia oficial: Gunilda roba la Brújula del Destino y huye a Marte
const WORLDS = [
  { nombre:'EL LABORATORIO', sub:'¡Gunilda ha robado la brújula! ¡Persíguela!', len:7000 },
  { nombre:'LA ISLA PIRATA', sub:'El pirata Espárrago defiende la costa',       len:8000 },
  { nombre:'MARTE',          sub:'El reino de la emperatriz Gunilda',           len:9000 },
];

const ST = Object.freeze({ LOADING:0, TITLE:1, CHAR_SELECT:2, STORY:3, INTRO:4,
                           PLAYING:5, BOSS:6, BOARD:7, FLY:8, DUEL:9, VICTORY:10, DEAD:11 });

let state   = ST.LOADING;
let gframe  = 0;
let score = 0, coins = 0, dist = 0, speed = 4.5;
let lives   = LIVES;
let gems    = 0;
let hiScore = +(localStorage.getItem('mk_hi') || 0);
let selChar = 0;                 // 0=Mikel 1=Leo
let shakeF  = 0, deadF = 0, introF = 0;
let world = 0;                   // mundo actual (0-2)
let lap   = 0;                   // 0=historia, 1+=vueltas extra (más difícil)
let worldDist = 0;               // distancia dentro del mundo actual
let worldBanner = 0;             // frames restantes del cartel de mundo
let bossWarned = false;          // aviso "jefe a la vista"
let introShip = false;           // la intro actual es de desembarco en nave
let storyIdx = 0, storyF = 0;    // cinemática
let victF = 0;                   // frames en pantalla de victoria
let bossesKilled = 0;
let combo = 0, comboT = 0;
let dodgeStreak = 0;
let bonusPts = 0;
let floatTexts = [];
let bank = +(localStorage.getItem('mk_bank') || 0);
let banked = 0;
let fever = 0;
let feverNext = 12;
let recordBeaten = false;
let nextMile = 250;
let revived = false;
// snapshot al entrar al mundo (para reintentar el nivel)
let wSnap = { dist:0, coins:0, bonusPts:0, bossesKilled:0, gems:0 };

// ── Misiones persistentes ──────────────────────────────
const MIS_DEFS = {
  coin: { txt:'Recoge %d monedas',          base:30,   mul:1.6, rew:25 },
  dodge:{ txt:'Esquiva %d obstáculos',      base:20,   mul:1.6, rew:30 },
  jump: { txt:'Salta %d veces',             base:40,   mul:1.6, rew:20 },
  near: { txt:'Roza %d obstáculos',         base:8,    mul:1.5, rew:40 },
  boss: { txt:'Derrota %d jefe(s)',         base:1,    mul:2,   rew:60 },
  m:    { txt:'Corre %d metros',            base:500,  mul:1.5, rew:25 },
};
let missions = [];
try { missions = JSON.parse(localStorage.getItem('mk_mis')||'[]'); } catch(e) { missions=[]; }
if (!Array.isArray(missions) || missions.length!==3 || missions.some(m=>!MIS_DEFS[m.t])) {
  const mk = Object.keys(MIS_DEFS).sort(()=>Math.random()-0.5).slice(0,3);
  missions = mk.map(t=>({ t, lvl:1, goal:MIS_DEFS[t].base, p:0 }));
}
function saveMeta(){
  localStorage.setItem('mk_bank', bank);
  localStorage.setItem('mk_mis', JSON.stringify(missions));
}
function misTxt(m){ return MIS_DEFS[m.t].txt.replace('%d', m.goal); }
function misEvent(type, n=1) {
  for (const m of missions) {
    if (m.t!==type || m.p>=m.goal) continue;
    m.p+=n;
    if (m.p>=m.goal) {
      const rew=MIS_DEFS[m.t].rew*m.lvl;
      bank+=rew;
      popup(W/2, 150, '✔ ¡Misión cumplida! +'+rew+' 🪙', '#7CFC00', 26);
      AudioMan.sfx('gema');
      const d=MIS_DEFS[m.t];
      m.lvl++; m.goal=Math.round(d.base*Math.pow(d.mul, m.lvl-1)); m.p=0;
      saveMeta();
    }
  }
}

const P = { x:PX, y:GROUND, vy:0, jumps:0, anim:0, atimer:0,
            shielded:0, boosted:0, cat:0, ducking:false, invincible:0, dead:false };

// Jefes (uno por mundo, patrones propios)
let RB=null;   // Robot (mundo 1)
let FB=null;   // Bubeado la rana (mundo 2)
let GB=null;   // Gunilda a pie (mundo 3)
let D =null;   // Duelo aéreo final vs Gunilda
let BD=null;   // secuencia de embarque en la nave
let F =null;   // vuelo entre mundos

let obstacles=[], coinItems=[], gemItems=[], powerUps=[], particles=[], effects=[];
let robotEv = null;
let cameo   = null;              // Papa Gorila pasando de fondo
let clouds  = [];
let stars   = [];
let bgOff=0, mtnOff=0, waveOff=0;
let spawnT=0, coinT=0, gemT=0, pupT=0, eventT=0, skullT=0;

// ═══════════════════════════════════════════════════════
//  HELPERS
// ═══════════════════════════════════════════════════════
function roundRect(x,y,w,h,r) {
  ctx.beginPath();
  ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y);
  ctx.arcTo(x+w,y,x+w,y+r,r); ctx.lineTo(x+w,y+h-r);
  ctx.arcTo(x+w,y+h,x+w-r,y+h,r); ctx.lineTo(x+r,y+h);
  ctx.arcTo(x,y+h,x,y+h-r,r); ctx.lineTo(x,y+r);
  ctx.arcTo(x,y,x+r,y,r); ctx.closePath();
}
function overlaps(ax,ay,aw,ah, bx,by,bw,bh, shrink=10) {
  return ax+shrink < bx+bw-shrink && ax+aw-shrink > bx+shrink &&
         ay+shrink < by+bh-shrink && ay+ah-shrink > by+shrink;
}
function playerRect() {
  const dh = P.ducking ? Math.round(PH*0.55) : PH;
  return { x:P.x-PW*0.42, y:P.y-dh, w:PW*0.84, h:dh };
}
function burst(x,y,color,n=10) {
  for (let i=0;i<n;i++) {
    const a=Math.random()*Math.PI*2, sp=2+Math.random()*5;
    particles.push({ x,y, vx:Math.cos(a)*sp, vy:Math.sin(a)*sp-2.5,
                     life:1.0, r:2+Math.random()*5, color });
  }
}
function shake(f){ shakeF=Math.max(shakeF,f); }
function fx(type,x,y,extra){ effects.push(Object.assign({type,x,y,af:0,at:0},extra||{})); }
function popup(x,y,txt,color='#FFD700',size=22){ floatTexts.push({x,y,txt,color,size,life:1}); }
function tickFloatTexts(){
  for (let i=floatTexts.length-1;i>=0;i--) {
    const t=floatTexts[i];
    t.y-=1.1; t.life-=0.02;
    if (t.life<=0) floatTexts.splice(i,1);
  }
}
function drawFloatTexts(){
  for (const t of floatTexts) {
    ctx.save();
    ctx.globalAlpha=Math.min(1,t.life*1.6);
    ctx.font='bold '+t.size+'px "Baloo 2",sans-serif';
    ctx.textAlign='center';
    ctx.lineWidth=4; ctx.strokeStyle='rgba(0,0,0,0.55)';
    ctx.strokeText(t.txt,t.x,t.y);
    ctx.fillStyle=t.color;
    ctx.fillText(t.txt,t.x,t.y);
    ctx.restore();
  }
}
function initClouds() {
  clouds = [
    { k:'cloud1', x:90,   y:55, w:220, h:88, sp:0.18 },
    { k:'cloud2', x:380,  y:80, w:180, h:72, sp:0.23 },
    { k:'cloud3', x:640,  y:42, w:205, h:82, sp:0.15 },
    { k:'cloud4', x:860,  y:68, w:165, h:66, sp:0.21 },
    { k:'cloud1', x:1160, y:58, w:200, h:80, sp:0.19 },
    { k:'cloud2', x:1400, y:38, w:180, h:70, sp:0.17 },
  ];
}
function initStars() {
  stars=[];
  for (let i=0;i<90;i++)
    stars.push({ x:Math.random()*W, y:Math.random()*H, r:0.6+Math.random()*1.8, sp:0.6+Math.random()*3 });
}
function baseSpeed(){ return Math.min(13, 4.5 + world*0.7 + lap*1.2); }
function hardness(){ return Math.min(1, (world + lap*3)/5 + worldDist/WORLDS[world].len*0.35); }

// ═══════════════════════════════════════════════════════
//  FLUJO DE PARTIDA
// ═══════════════════════════════════════════════════════
function resetRun() {
  score=0; coins=0; dist=0; gems=0; lives=LIVES;
  combo=0; comboT=0; dodgeStreak=0; bonusPts=0; floatTexts=[];
  banked=0; fever=0; feverNext=12; recordBeaten=false; nextMile=250; revived=false;
  bossesKilled=0; lap=0;
}
function startWorld(w, {fromShip=false, keepSnap=false}={}) {
  world=w; worldDist=0; bossWarned=false;
  speed=baseSpeed();
  deadF=0; shakeF=0; bgOff=0; mtnOff=0; waveOff=0;
  obstacles=[]; coinItems=[]; gemItems=[]; powerUps=[]; particles=[]; effects=[];
  robotEv=null; cameo=null; RB=null; FB=null; GB=null; D=null; BD=null; F=null;
  spawnT=150; coinT=90; gemT=520; pupT=600; eventT=1200; skullT=1600+(Math.random()*900|0);
  P.x=PX; P.y=GROUND; P.vy=0; P.jumps=0; P.anim=0; P.atimer=0;
  P.shielded=0; P.boosted=0; P.cat=0; P.ducking=false; P.invincible=0; P.dead=false;
  initClouds(); initStars();
  if (!keepSnap) wSnap={ dist, coins, bonusPts, bossesKilled, gems };
  introShip=fromShip;
  introF=0; state=ST.INTRO;
  worldBanner=170;
  if (AudioMan.musicName!=='musica-ingame') AudioMan.music('musica-ingame');
}
function beginRun() {
  state=ST.PLAYING;
  AudioMan.startRun();
}
function retryWorld() {
  // reinicia el mundo actual desde su comienzo (checkpoint de nivel)
  dist=wSnap.dist; coins=wSnap.coins; bonusPts=wSnap.bonusPts;
  bossesKilled=wSnap.bossesKilled; gems=wSnap.gems;
  banked=coins; lives=LIVES; revived=false;
  combo=0; comboT=0; fever=0;
  startWorld(world, {fromShip:world>0, keepSnap:true});
  AudioMan.sfx('ui-play');
}
function killPlayer() {
  P.dead=true; state=ST.DEAD; deadF=0;
  AudioMan.stopRun();
  AudioMan.stopMusic();
  AudioMan.sfx('muerte');
  fx('explosion', P.x, P.y-PH*0.4);
  burst(P.x, P.y-PH*0.5, '#ff3300', 24);
  shake(20);
  if (score>hiScore) { hiScore=score; localStorage.setItem('mk_hi',hiScore); }
  bank += coins - banked; banked = coins;
  saveMeta();
}
function reviveNow() {
  bank -= REVIVE_COST; saveMeta();
  revived=true; lives=1; P.dead=false;
  P.x=PX; P.y=GROUND; P.vy=0; P.jumps=0; P.ducking=false;
  P.invincible=240;
  combo=0; comboT=0; fever=0; shakeF=0;
  obstacles=[]; robotEv=null;
  // si murió contra un jefe, el jefe se reinicia con vida completa
  if (RB) startBossRobot();
  else if (FB) startBossFrog();
  else if (GB) startBossGunilda();
  else if (D) startDuel();
  else if (F) startFly();
  else state=ST.PLAYING;
  popup(P.x, P.y-PH-30, '¡SIGUE CORRIENDO!', '#7CFC00', 28);
  AudioMan.sfx('gema');
  AudioMan.music('musica-ingame');
  if (state===ST.PLAYING||state===ST.BOSS) AudioMan.startRun();
}
function playerHit() {
  if (P.invincible>0 || P.boosted>0) return;
  if (P.shielded>0) {
    P.shielded=0;
    fx('hit', P.x, P.y-PH*0.5);
    burst(P.x, P.y-PH*0.5, '#88ddff', 14);
    shake(8); P.invincible=45; return;
  }
  lives--;
  combo=0; comboT=0; dodgeStreak=0;
  shake(12);
  fx('hit', P.x, P.y-PH*0.5);
  burst(P.x, P.y-PH*0.5, '#ff5533', 16);
  if (lives<=0) { killPlayer(); return; }
  P.invincible=120;
}
function activateTurbo() {
  P.boosted=240;
  speed=Math.min(13,speed+2.5);
  burst(P.x,P.y-PH*0.5,'#ffaa44',14);
  AudioMan.sfx('powerup-turbo');
}
function calcScore(){ score = Math.floor(dist/80)+coins*7+bossesKilled*250+bonusPts; }

// ¿el jugador cae encima? (estómpalo estilo Mario)
function tryStomp(bx,by,bw,bh) {
  const pr=playerRect();
  if (!overlaps(pr.x,pr.y,pr.w,pr.h, bx,by,bw,bh, 6)) return 0;
  if (P.vy>1.5) return (P.y - by) < bh*0.55 ? 1 : -1;   // cayendo: pisotón o choque
  if (P.vy<-0.5) return 0;                              // subiendo lo atraviesas sin daño
  return (P.y - by) < bh*0.55 ? 0 : -1;                 // parado: solo daña de frente
}
function stompBounce() {
  P.vy=-13; P.jumps=1;
  AudioMan.sfx('coin',{rate:0.7});
  shake(8);
}

// ═══════════════════════════════════════════════════════
//  INPUT
// ═══════════════════════════════════════════════════════
const keys = {};
document.addEventListener('keydown', e => {
  keys[e.code]=true;
  AudioMan.unlock();
  if (e.code==='Space'||e.code==='ArrowUp') { e.preventDefault(); handleAction(); }
  if (e.code==='ArrowDown'||e.code==='KeyS') { e.preventDefault(); P.ducking=true; }
  if (e.code==='KeyM') AudioMan.toggleMute();
});
document.addEventListener('keyup', e => {
  keys[e.code]=false;
  if (e.code==='ArrowDown'||e.code==='KeyS') P.ducking=false;
});

let pointerDown=false, pointerY=H/2;
canvas.addEventListener('pointerdown', e => {
  e.preventDefault();
  AudioMan.unlock();
  const rect=canvas.getBoundingClientRect();
  const cx=(e.clientX-rect.left)*(W/rect.width);
  const cy=(e.clientY-rect.top)*(H/rect.height);
  pointerDown=true; pointerY=cy;
  if (cx>W-46 && cy<40) { AudioMan.toggleMute(); return; }
  if (state===ST.CHAR_SELECT) { handleCharSelect(cx); return; }
  if (state===ST.DEAD && deadF>50) { handleDeadButtons(cx,cy); return; }
  if (state===ST.VICTORY && victF>60) { handleVictoryButtons(cx,cy); return; }
  handleAction();
});
canvas.addEventListener('pointermove', e => {
  const rect=canvas.getBoundingClientRect();
  pointerY=(e.clientY-rect.top)*(H/rect.height);
});
canvas.addEventListener('pointerup',    () => pointerDown=false);
canvas.addEventListener('pointercancel',() => pointerDown=false);

function handleAction() {
  if (state===ST.LOADING) return;
  if (state===ST.TITLE)   { AudioMan.sfx('ui-click'); state=ST.CHAR_SELECT; return; }
  if (state===ST.STORY)   { advanceStory(); return; }
  if (state===ST.FLY || state===ST.DUEL || state===ST.BOARD) return; // nave: mover con puntero/flechas
  if (state===ST.BOSS && FB) return;   // contra Bubeado pilotas la nave, no saltas
  if ((state===ST.PLAYING || state===ST.BOSS) && !P.dead && P.jumps<2) {
    P.vy = JUMP_VY - P.jumps*1.8;
    P.jumps++;
    misEvent('jump');
    AudioMan.stopRun();
  }
}
function handleCharSelect(cx) {
  const newSel = cx < W/2 ? 0 : 1;
  if (newSel===selChar) {
    AudioMan.sfx('ui-play');
    resetRun();
    storyIdx=0; storyF=0; state=ST.STORY;
    return;
  }
  selChar=newSel;
  AudioMan.sfx('ui-click');
}
function advanceStory() {
  AudioMan.sfx('ui-click');
  storyIdx++; storyF=0;
  if (storyIdx>=3) startWorld(0);
}
function handleDeadButtons(cx,cy) {
  const ry=H/2+104;
  if (!revived && bank>=REVIVE_COST && cy>ry-22 && cy<ry+22 && cx>W/2-135 && cx<W/2+135) {
    reviveNow(); return;
  }
  const by=H/2+150;
  if (cy>by-34 && cy<by+34) {
    if (cx>W/2-120 && cx<W/2-40) { retryWorld(); return; }
    if (cx>W/2+40 && cx<W/2+120) {
      AudioMan.sfx('ui-back');
      state=ST.TITLE;
      AudioMan.music('musica-menu');
      return;
    }
  }
}
function handleVictoryButtons(cx,cy) {
  const by=H-90;
  if (cy>by-30 && cy<by+30) {
    if (cx>W/2-260 && cx<W/2-20) {
      // Otra vuelta: más rápido y más difícil, conservando puntuación
      lap++;
      lives=LIVES; revived=false;
      AudioMan.sfx('ui-play');
      startWorld(0, {fromShip:true});
      return;
    }
    if (cx>W/2+20 && cx<W/2+260) {
      AudioMan.sfx('ui-back');
      if (score>hiScore) { hiScore=score; localStorage.setItem('mk_hi',hiScore); }
      bank += coins - banked; banked=coins; saveMeta();
      state=ST.TITLE;
      AudioMan.music('musica-menu');
      return;
    }
  }
}

