  const rbi=gi('bgRed');
  if (rbi) ctx.drawImage(rbi,0,0,W,H);
  else { const g=ctx.createLinearGradient(0,0,0,H); g.addColorStop(0,'#1a0010'); g.addColorStop(1,'#440020'); ctx.fillStyle=g; ctx.fillRect(0,0,W,H); }

  const li=gi('logo');
  if (li) {
    const lw=Math.min(520,W*0.56), lh=lw*li.naturalHeight/li.naturalWidth;
    const fl=Math.sin(gframe*0.03)*8;
    ctx.drawImage(li,(W-lw)/2,H*0.06+fl,lw,lh);
  } else {
    ctx.fillStyle='#fff'; ctx.font='bold 52px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.fillText('MIKELTUBE ADVENTURES', W/2, H*0.3);
  }
  ctx.fillStyle='#FFDC00'; ctx.font='bold 24px "Baloo 2",sans-serif'; ctx.textAlign='center';
  ctx.shadowColor='#000'; ctx.shadowBlur=10;
  ctx.fillText('— LA BRÚJULA DEL DESTINO —', W/2, H*0.52);
  ctx.shadowBlur=0;

  if (Math.sin(gframe*0.07)>-0.4) {
    ctx.globalAlpha=0.7+Math.sin(gframe*0.07)*0.3;
    ctx.fillStyle='#fff'; ctx.font='bold 25px system-ui,sans-serif';
    ctx.shadowColor='#000'; ctx.shadowBlur=14;
    ctx.fillText('✦  TOCA PARA EMPEZAR  ✦', W/2, H*0.70);
    ctx.shadowBlur=0; ctx.globalAlpha=1;
  }
  ctx.fillStyle='rgba(255,255,255,0.55)'; ctx.font='15px system-ui,sans-serif';
  ctx.fillText('ESPACIO / ↑ = Saltar (doble salto)   ·   ↓ / S = Agachar   ·   M = Silencio', W/2, H*0.80);
