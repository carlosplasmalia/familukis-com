let delayedObs=[];
function setTimeoutObs(ob, frames){ delayedObs.push({ob, t:frames}); }
function tickDelayedObs(){
  for (let i=delayedObs.length-1;i>=0;i--) {
    if (--delayedObs[i].t<=0) {
      obstacles.push(delayedObs[i].ob);
      AudioMan.sfx('cannon',{vol:0.6});
      delayedObs.splice(i,1);
    }
  }
}
function spawnRobot() {
  const doubleBeam = hardness()>0.35;
  robotEv = { x:W-105, y:-220, phase:'enter', pt:0, af:0,
              beams:[], plan: doubleBeam ? (Math.random()<0.5?['low','high']:['high','low'])
                                         : [Math.random()<0.5?'low':'high'] };
  AudioMan.sfx('robot-aparece');
}
function makeCball(sx,sy) {
  const tx=P.x+30, ty=P.y-18;
  const N=68, g=GRAVITY*0.4;
  const vx=(tx-sx)/N;
  const vy=(ty-sy)/N - 0.5*g*(N-1);
  return { type:'cball', x:sx, y:sy, w:28, h:28, vx, vy, grav:g, af:0, at:0 };
}

// ═══════════════════════════════════════════════════════
//  JEFES — uno por mundo, patrones distintos
// ═══════════════════════════════════════════════════════
function bossHp(base){ return base + lap*6; }

// ── MUNDO 1: ROBOT GUARDIÁN (en tierra: saltar/agacharse bajo sus rayos,
//    se aturde al lanzar la onda de choque → estómpalo) ──
function startBossRobot() {
  state=ST.BOSS;
  RB={ phase:'enter', t:0, x:W+180, y:GROUND-170, hp:bossHp(3), maxHp:bossHp(3),
       af:0, beams:[], stun:0, hitFlash:0 };
  FB=null; GB=null;
  obstacles=[]; coinItems=[]; gemItems=[]; powerUps=[]; robotEv=null;
  AudioMan.sfx('robot-aparece');
}
function updateBossRobot() {
  const R=RB; R.t++;
  if (R.t%6===0) R.af=(R.af+1)%8;
  if (R.hitFlash>0) R.hitFlash--;
  runnerPhysics();

  if (R.phase==='enter') {
    R.x += (W-190-R.x)*0.06;
    R.y += (GROUND-170-R.y)*0.08;
    if (Math.abs(R.x-(W-190))<5) { R.phase='hover'; R.t=0; }
  }
  else if (R.phase==='hover') {
    R.y = GROUND-170+Math.sin(R.t*0.05)*26;
    if (R.t>70) {
      R.phase='charge'; R.t=0;
      R.plan = Math.random()<0.5 ? 'low' : 'high';
      AudioMan.sfx('robot-carga');
    }
  }
  else if (R.phase==='charge') {
    if (R.t>=50) {
      R.phase='fire'; R.t=0;
      R.beams=[{ h:R.plan, t:0 }];
      AudioMan.sfx('robot-rayo');
    }
  }
  else if (R.phase==='fire') {
    for (const b of R.beams) b.t++;
    const pr=playerRect();
    for (const b of R.beams) {
      if (b.t<20||b.t>75) continue;
      const by = b.h==='low' ? GROUND-50 : GROUND-148;
      if (overlaps(pr.x,pr.y,pr.w,pr.h, 0,by,R.x-40,52, 6)) playerHit();
    }
    if (R.beams[0].t>90) {
      R.beams=[];
      // tras disparar cae al suelo y patina hacia ti → sáltale encima
      R.phase='stunned'; R.t=0; R.stun=220;
      R.groundY=GROUND-55;
    }
  }
  else if (R.phase==='stunned') {
    R.y += (R.groundY-R.y)*0.2;
    if (R.t===12) popup(R.x, R.y-130, '¡AHORA! ¡SALTA ENCIMA!', '#FFDC00', 24);
    if (R.t>30) R.x -= 5.2+lap*0.8;   // patina hacia ti: esquívalo o písalo
    if (R.x < P.x-100 || --R.stun<=0) { R.phase='enter'; R.t=0; }
    const st=tryStomp(R.x-60, R.y-55, 120, 110);
    if (st===1) {
      stompBounce();
      R.hp--; R.hitFlash=10;
      burst(R.x, R.y-40, '#66eaff', 16);
      popup(R.x, R.y-90, '¡GOLPE!', '#7CFC00', 26);
      if (R.hp<=0) { R.phase='dying'; R.t=0; AudioMan.sfx('powerup-explosion'); return; }
      R.phase='enter'; R.t=0;
    } else if (st===-1) playerHit();
  }
  else if (R.phase==='dying') {
    if (R.t%8===0) { fx('explosion', R.x-60+Math.random()*120, R.y-60+Math.random()*120); shake(6); }
    if (R.t>70) { bossDefeated(); return; }
  }
  bossCommonTick();
}

// ── MUNDO 2: BUBEADO LA RANA (duelo naval — te subes al cañón del barco;
//    apunta con el puntero, esquiva sus burbujas y su láser) ──
function startBossFrog() {
  state=ST.BOSS;
  FB={ phase:'enter', t:0, x:W+220, y:210, hp:bossHp(8), maxHp:bossHp(8),
       af:0, laserT:0, laserY:0, flash:0,
       shipY:260, shipTargetY:260, fireT:0, bullets:[], bubbles:[] };
  RB=null; GB=null;
  obstacles=[]; coinItems=[]; gemItems=[]; powerUps=[]; robotEv=null;
  P.jumps=0; P.vy=0; P.ducking=false;
  AudioMan.stopRun();
  AudioMan.sfx('nave-aparece');
}
function updateBossFrog() {
  const B=FB; B.t++;
  if (pointerDown) B.shipTargetY=Math.max(90,Math.min(GROUND-40,pointerY));
  if (keys['ArrowUp'])   B.shipTargetY=Math.max(90, B.shipTargetY-7);
  if (keys['ArrowDown']) B.shipTargetY=Math.min(GROUND-40, B.shipTargetY+7);
  B.shipY += (B.shipTargetY-B.shipY)*0.14;

  bgOff+=speed*0.08; mtnOff+=speed*0.45; waveOff+=speed;
  for (const cl of clouds) { cl.x-=cl.sp*speed*0.55; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*200; }

  if (B.phase==='enter') {
    B.x += (W-190-B.x)*0.05;
    if (Math.abs(B.x-(W-190))<4) { B.phase='fight'; B.t=0; }
  }
  else if (B.phase==='fight') {
    B.y = 210 + Math.sin(B.t*0.023)*115;
    if (B.t%9===0) B.af=(B.af+1)%11;
    // burbujas flotantes que persiguen suavemente
    if (B.t%110===0) {
      B.bubbles.push({ x:B.x-70, y:B.y, vx:-2.6, vy:0, t:0 });
      AudioMan.sfx('bruja-dispara',{rate:1.4,vol:0.6});
    }
    B.laserT++;
    const cycle = Math.max(150, 260-lap*30);
    if (B.laserT===cycle-60) AudioMan.sfx('nave-carga');
    if (B.laserT>=cycle) { B.phase='laser'; B.t=0; B.laserY=B.y; AudioMan.sfx('nave-lanza'); }
    if (++B.fireT>=26) { B.fireT=0; B.bullets.push({ x:200, y:B.shipY+6, vx:11 }); AudioMan.sfx('nave-disparo',{vol:0.7}); }
  }
  else if (B.phase==='laser') {
    if (B.t>75) { B.phase='fight'; B.laserT=0; B.t=0; }
    else if (B.t>20) {
      if (Math.abs(B.shipY-B.laserY)<42 && P.invincible<=0) hitInShip(B.shipY);
    }
    if (++B.fireT>=26) { B.fireT=0; B.bullets.push({ x:200, y:B.shipY+6, vx:11 }); AudioMan.sfx('nave-disparo',{vol:0.7}); }
  }
  else if (B.phase==='dying') {
    if (B.t%9===0) { fx('explosion', B.x-70+Math.random()*160, B.y-60+Math.random()*130); shake(6); }
    if (B.t>80) { bossDefeated(); return; }
  }

  B.bubbles=B.bubbles.filter(bu=>{
    bu.t++;
    bu.vy += ((B.shipY-bu.y)>0?0.06:-0.06);
    bu.vy = Math.max(-2.2, Math.min(2.2, bu.vy));
    bu.x+=bu.vx; bu.y+=bu.vy;
    if (B.phase!=='dying' && P.invincible<=0 &&
        overlaps(bu.x-22,bu.y-22,44,44, 150-46,B.shipY-30,92,60, 4)) {
      hitInShip(B.shipY);
      burst(bu.x,bu.y,'#a8e6ff',10);
      return false;
    }
    return bu.x>-60 && bu.t<600;
  });

  if (P.invincible>0) P.invincible--;
  if (P.shielded>0)   P.shielded--;

  B.bullets = B.bullets.filter(b => {
    b.x+=b.vx;
    if (B.phase!=='dying' &&
        overlaps(b.x-14,b.y-7,28,14, B.x-80,B.y-55,160,120, 0)) {
      B.hp--; B.flash=8;
      burst(b.x,b.y,'#aaffcc',6);
      AudioMan.sfx('coin',{rate:0.6,vol:0.5});
      if (B.hp<=0) {
        B.phase='dying'; B.t=0;
        AudioMan.sfx('powerup-explosion');
        AudioMan.sfx('bruja-desaparece');
      }
      return false;
    }
    return b.x<W+40;
  });
  if (B.flash>0) B.flash--;

  tickEffects(); tickParticles(); tickFloatTexts();
  if (shakeF>0) shakeF--;
  calcScore();
}
function hitInShip(sy) {
  if (P.shielded>0) { P.shielded=0; fx('hit',160,sy); P.invincible=60; shake(8); return; }
  lives--; shake(12); fx('hit',160,sy);
  burst(160,sy,'#ff5533',16);
  if (lives<=0) { killPlayer(); return; }
  P.invincible=90;
}

// ── MUNDO 3: GUNILDA (teletransporte + magia; solo es vulnerable
//    justo después de lanzar su hechizo triple) ──
function startBossGunilda() {
  state=ST.BOSS;
  GB={ phase:'enter', t:0, x:W+160, y:180, hp:bossHp(4), maxHp:bossHp(4),
       af:0, alpha:1, hitFlash:0, spot:0, shots:0, vulnT:0 };
  RB=null; FB=null;
  obstacles=[]; coinItems=[]; gemItems=[]; powerUps=[]; robotEv=null;
  AudioMan.sfx('bruja-aparece');
}
const GUN_SPOTS=[ {x:W-180,y:170},{x:W-320,y:250},{x:W-140,y:300},{x:W-420,y:160} ];
function updateBossGunilda() {
  const G=GB; G.t++;
  if (G.t%7===0) G.af=(G.af+1)%3;
  if (G.hitFlash>0) G.hitFlash--;
  runnerPhysics();

  if (G.phase==='enter') {
    G.x += (GUN_SPOTS[0].x-G.x)*0.06;
    G.y = 180+Math.sin(G.t*0.05)*14;
    if (Math.abs(G.x-GUN_SPOTS[0].x)<6) { G.phase='taunt'; G.t=0; }
  }
  else if (G.phase==='taunt') {
    G.y += Math.sin(G.t*0.08)*0.8;
    if (G.t>55) { G.phase='cast'; G.t=0; G.shots=0; AudioMan.sfx('bruja-carga'); }
  }
  else if (G.phase==='cast') {
    G.y += Math.sin(G.t*0.08)*0.5;
    if (G.t>40 && G.t%26===0 && G.shots<3) {
      G.shots++;
      AudioMan.sfx('bruja-dispara');
      const dx=P.x-G.x, dy=(P.y-PH*0.5)-G.y;
      const d=Math.hypot(dx,dy)||1, sp2=5.2+lap*0.8;
      obstacles.push({ type:'bola', x:G.x, y:G.y+40, w:34, h:34,
                       vx:dx/d*sp2, vy:dy/d*sp2, af:0, at:0, homing:40 });
    }
    if (G.shots>=3 && G.t>140) {
      // agotada: baja y es vulnerable un rato
      G.phase='tired'; G.t=0; G.vulnT=150;
      G.targetY=GROUND-165;   // a la altura justa de un salto, sin rozar al jugador parado
      popup(G.x, G.y-70, '¡AHORA! ¡SALTA SOBRE ELLA!', '#FFDC00', 22);
    }
  }
  else if (G.phase==='tired') {
    G.y += (G.targetY-G.y)*0.12;
    G.x += (P.x+30-G.x)*0.06;   // agotada, flota hasta ponerse a tu alcance
    if (--G.vulnT<=0) {
      G.phase='blink'; G.t=0; AudioMan.sfx('bruja-desaparece');
    }
    const st=tryStomp(G.x-50, G.y-40, 100, 105);
    if (st===1) {
      stompBounce();
      G.hp--; G.hitFlash=10;
      burst(G.x, G.y, '#dd66ff', 16);
      popup(G.x, G.y-80, '¡GOLPE!', '#7CFC00', 26);
      if (G.hp<=0) { G.phase='dying'; G.t=0; AudioMan.sfx('powerup-explosion'); return; }
      G.phase='blink'; G.t=0;
      AudioMan.sfx('bruja-desaparece');
    } else if (st===-1) playerHit();
  }
  else if (G.phase==='blink') {
    G.alpha-=0.06;
    if (G.alpha<=0) {
      G.spot=(G.spot+1)%GUN_SPOTS.length;
      const s=GUN_SPOTS[G.spot];
      G.x=s.x; G.y=s.y; G.alpha=0.01; G.phase='appear';
      AudioMan.sfx('bruja-aparece');
    }
  }
  else if (G.phase==='appear') {
    G.alpha=Math.min(1,G.alpha+0.07);
    if (G.alpha>=1) { G.phase='taunt'; G.t=0; }
  }
  else if (G.phase==='dying') {
    G.alpha=Math.max(0,G.alpha-0.012);
    if (G.t%8===0) { fx('explosion', G.x-50+Math.random()*100, G.y-40+Math.random()*90); shake(5); }
    if (G.t>80) { bossDefeated(); return; }
  }
  bossCommonTick();
}

// física del corredor durante jefes en tierra (Robot y Gunilda)
function runnerPhysics() {
  bgOff+=speed*0.08; mtnOff+=speed*0.45; waveOff+=speed;
  for (const cl of clouds) { cl.x-=cl.sp*speed*0.55; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*200; }
  if (P.invincible>0) P.invincible--;
  if (P.shielded>0)  P.shielded--;
  if (P.boosted>0)  { P.boosted--; if (!P.boosted) speed=Math.max(baseSpeed(),speed-2.5); }
  const wasAir=P.y<GROUND-1;
  P.vy+=GRAVITY; P.y+=P.vy;
  if (P.y>=GROUND) { P.y=GROUND; P.vy=0; P.jumps=0; if (wasAir) AudioMan.startRun(); }
  if (P.y>=GROUND-1) {
    P.atimer+=speed*0.034;
    if (P.atimer>=1) { P.atimer=0; P.anim=(P.anim+1)%6; }
  }
  // bolas mágicas residuales durante el jefe
  updateObstacles();
  checkCollisions();
}
function bossCommonTick() {
  tickEffects(); tickParticles(); tickFloatTexts();
  if (shakeF>0) shakeF--;
  calcScore();
}

function bossDefeated() {
  bossesKilled++;
  misEvent('boss');
  RB=null; FB=null; GB=null;
  coins+=25;
  gems=Math.min(GEMS_FOR_TURBO-1,gems+1);
  if (lives<LIVES) lives++;
  P.y=GROUND; P.vy=0;
  if (world<2) {
    // secuencia: la nave aterriza, el héroe corre y SE MONTA
    startBoarding();
  } else {
    // Gunilda huye en su escoba → duelo aéreo final
    startDuel();
  }
}

// ═══════════════════════════════════════════════════════
//  EMBARQUE — la nave aterriza delante y el héroe se sube
// ═══════════════════════════════════════════════════════
function startBoarding() {
  state=ST.BOARD;
  BD={ t:0, shipX:W+160, shipY:80, phase:'land' };
  AudioMan.stopRun();
  AudioMan.sfx('nave-aparece');
  popup(W/2, 140, '¡Tu nave ha llegado!', '#7FDBFF', 28);
}
function updateBoarding() {
  const b=BD; b.t++;
  bgOff+=2; mtnOff+=3; waveOff+=4;
  for (const cl of clouds) { cl.x-=cl.sp*2; if (cl.x+cl.w<-20) cl.x=W+cl.w; }
  if (b.phase==='land') {
    b.shipX += (P.x+260-b.shipX)*0.06;
    b.shipY += (GROUND-46-b.shipY)*0.06;
    if (Math.abs(b.shipY-(GROUND-46))<3 && Math.abs(b.shipX-(P.x+260))<6) {
      b.phase='run'; b.t=0;
      AudioMan.startRun();
    }
  } else if (b.phase==='run') {
    // el héroe corre hacia la nave
    P.x += 3.4;
    P.atimer+=0.16;
    if (P.atimer>=1){ P.atimer=0; P.anim=(P.anim+1)%6; }
    if (P.x >= b.shipX-30) {
      b.phase='hop'; b.t=0;
      P.vy=-11;
      AudioMan.stopRun();
    }
  } else if (b.phase==='hop') {
    // saltito para montarse
    P.vy+=GRAVITY*0.9;
    P.y+=P.vy;
    P.x+=2.2;
    if (P.y>=GROUND-40) {
      b.phase='takeoff'; b.t=0;
      burst(b.shipX, GROUND-20, '#7FDBFF', 14);
      AudioMan.sfx('nave-carga');
    }
  } else if (b.phase==='takeoff') {
    b.shipY -= b.t*0.14;
    b.shipX += b.t*0.10;
    if (b.t%5===0) particles.push({ x:b.shipX-40, y:b.shipY+26, vx:-3-Math.random()*2, vy:1+Math.random(),
                                    life:0.9, r:3+Math.random()*4, color:'#9adcff' });
    if (b.shipY<-140) { startFly(); return; }
  }
  tickEffects(); tickParticles(); tickFloatTexts();
}

// ═══════════════════════════════════════════════════════
//  VUELO ENTRE MUNDOS — minifase pilotando la nave
// ═══════════════════════════════════════════════════════
function startFly() {
  state=ST.FLY;
  F={ t:0, y:H/2, targetY:H/2, rocks:[], coins:[], spT:50, dur:640 };
  initStars();
  AudioMan.sfx('powerup-turbo');
}
function updateFly() {
  const f=F; f.t++;
  if (pointerDown) f.targetY=Math.max(70,Math.min(H-70,pointerY));
  if (keys['ArrowUp'])   f.targetY=Math.max(70, f.targetY-7);
  if (keys['ArrowDown']) f.targetY=Math.min(H-70, f.targetY+7);
  f.y += (f.targetY-f.y)*0.12;

  for (const s of stars) { s.x-=s.sp*2.2; if (s.x<-4){ s.x=W+4; s.y=Math.random()*H; } }

  if (--f.spT<=0) {
    f.spT=Math.max(26, 46-Math.floor(f.t/120));
    if (Math.random()<0.62) {
      f.rocks.push({ x:W+60, y:60+Math.random()*(H-120), r:20+Math.random()*26, rot:Math.random()*Math.PI, vr:(Math.random()-0.5)*0.06 });
    } else {
      const y0=70+Math.random()*(H-160);
      for (let i=0;i<5;i++) f.coins.push({ x:W+60+i*48, y:y0+Math.sin(i*0.8)*26, af:i%7, at:0 });
    }
  }
  f.rocks=f.rocks.filter(r=>{
    r.x-=7.5; r.rot+=r.vr;
    if (P.invincible<=0 && Math.hypot(r.x-170, r.y-f.y)<r.r+30) {
      if (P.shielded>0){ P.shielded=0; P.invincible=45; fx('hit',170,f.y); shake(8); }
      else {
        lives--; shake(12); fx('hit',170,f.y); burst(170,f.y,'#ff5533',14);
        if (lives<=0){ killPlayer(); return false; }
        P.invincible=80;
      }
      return false;
    }
    return r.x>-70;
  });
  f.coins=f.coins.filter(c=>{
    c.x-=7.5; c.at++;
    if (c.at%5===0) c.af=(c.af+1)%7;
    if (Math.hypot(c.x-170,c.y-f.y)<44) {
      coins++; bonusPts+=5;
      burst(c.x,c.y,'#FFD700',6);
      AudioMan.sfx('coin',{vol:0.7});
      return false;
    }
    return c.x>-40;
  });
  if (P.invincible>0) P.invincible--;
  if (P.shielded>0)   P.shielded--;

  if (f.t>=f.dur) {
    // aterrizaje en el siguiente mundo
    startWorld(world+1, {fromShip:true});
    return;
  }
  tickEffects(); tickParticles(); tickFloatTexts();
  if (shakeF>0) shakeF--;
  calcScore();
}

// ═══════════════════════════════════════════════════════
//  DUELO FINAL — nave vs Gunilda en escoba, cielo de Marte
// ═══════════════════════════════════════════════════════
function startDuel() {
  state=ST.DUEL;
  D={ t:0, y:H/2, targetY:H/2, bullets:[], bolas:[],
      gx:W-170, gy:H/2, gvy:1.6, hp:bossHp(12), maxHp:bossHp(12),
      flash:0, fireT:0, castT:0, phase:'fight' };
  initStars();
  AudioMan.stopRun();
  AudioMan.sfx('bruja-aparece');
  popup(W/2, 130, '¡GUNILDA HUYE! ¡DERRÍBALA!', '#FF4136', 30);
}
function updateDuel() {
  const d=D; d.t++;
  if (pointerDown) d.targetY=Math.max(70,Math.min(H-70,pointerY));
  if (keys['ArrowUp'])   d.targetY=Math.max(70, d.targetY-7);
  if (keys['ArrowDown']) d.targetY=Math.min(H-70, d.targetY+7);
  d.y += (d.targetY-d.y)*0.12;

  for (const s of stars) { s.x-=s.sp*1.6; if (s.x<-4){ s.x=W+4; s.y=Math.random()*H; } }

  if (d.phase==='fight') {
    // Gunilda serpentea, a veces se lanza en picado hacia tu columna
    d.gy += d.gvy;
    if (d.gy<90||d.gy>H-90) d.gvy*=-1;
    if (d.t%160===120) d.gvy = (d.y>d.gy?1:-1)*(2.4+lap*0.5);
    if (d.t%160===0)   d.gvy = d.gvy>0?1.6:-1.6;

    if (++d.fireT>=24) { d.fireT=0; d.bullets.push({ x:210, y:d.y+4, vx:11.5 }); AudioMan.sfx('nave-disparo',{vol:0.65}); }
    if (++d.castT>=Math.max(70,110-lap*15)) {
      d.castT=0;
      AudioMan.sfx('bruja-dispara');
      const dy=(d.y-d.gy), dd=Math.hypot(-520,dy)||1;
      d.bolas.push({ x:d.gx-40, y:d.gy, vx:-520/dd*6.2, vy:dy/dd*6.2, af:0, at:0 });
    }
  }
  else if (d.phase==='dying') {
    d.gy += 2.4; d.gx += Math.sin(d.t*0.3)*3;
    if (d.t%7===0) { fx('explosion', d.gx-40+Math.random()*80, d.gy-30+Math.random()*60); shake(5); }
    if (d.t>110) { startVictory(); return; }
  }

  d.bullets=d.bullets.filter(b=>{
    b.x+=b.vx;
    if (d.phase==='fight' && overlaps(b.x-14,b.y-7,28,14, d.gx-55,d.gy-55,110,110, 0)) {
      d.hp--; d.flash=8;
      burst(b.x,b.y,'#dd66ff',6);
      AudioMan.sfx('coin',{rate:0.6,vol:0.5});
      if (d.hp<=0) { d.phase='dying'; d.t=0; AudioMan.sfx('powerup-explosion'); AudioMan.sfx('bruja-desaparece'); }
      return false;
    }
    return b.x<W+40;
  });
  d.bolas=d.bolas.filter(bo=>{
    bo.x+=bo.vx; bo.y+=bo.vy; bo.at++;
    if (bo.at%4===0) bo.af=(bo.af+1)%3;
    if (P.invincible<=0 && Math.hypot(bo.x-170,bo.y-d.y)<40) {
      if (P.shielded>0){ P.shielded=0; P.invincible=45; fx('hit',170,d.y); shake(8); }
      else {
        lives--; shake(12); fx('hit',170,d.y); burst(170,d.y,'#ff5533',14);
        if (lives<=0){ killPlayer(); return false; }
        P.invincible=80;
      }
      return false;
    }
    return bo.x>-60 && bo.y>-60 && bo.y<H+60;
  });
  if (d.flash>0) d.flash--;
  if (P.invincible>0) P.invincible--;
  if (P.shielded>0)   P.shielded--;

  tickEffects(); tickParticles(); tickFloatTexts();
  if (shakeF>0) shakeF--;
  calcScore();
}
function startVictory() {
  state=ST.VICTORY; victF=0;
  bonusPts+=1000;
  calcScore();
  if (score>hiScore) { hiScore=score; localStorage.setItem('mk_hi',hiScore); }
  bank += coins - banked; banked=coins; saveMeta();
  AudioMan.stopMusic();
  AudioMan.sfx('gema');
  AudioMan.sfx('powerup-turbo');
}

// ═══════════════════════════════════════════════════════
//  UPDATE (runner)
// ═══════════════════════════════════════════════════════
function update() {
  if (state===ST.TITLE || state===ST.CHAR_SELECT) {
    for (const cl of clouds) { cl.x-=cl.sp*3.2; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*100; }
    return;
  }
  if (state===ST.STORY)   { storyF++; if (storyF>420) advanceStory(); return; }
  if (state===ST.DEAD) {
    deadF++;
    if (shakeF>0) shakeF--;
    tickEffects(); tickParticles();
    for (const cl of clouds) { cl.x-=cl.sp*speed*0.5; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*200; }
    return;
  }
  if (state===ST.BOSS) {
    if (RB) updateBossRobot();
    else if (FB) updateBossFrog();
    else if (GB) updateBossGunilda();
    return;
  }
  if (state===ST.BOARD)   { updateBoarding(); return; }
  if (state===ST.FLY)     { updateFly(); return; }
  if (state===ST.DUEL)    { updateDuel(); return; }
  if (state===ST.VICTORY) { victF++; tickParticles(); tickFloatTexts();
    if (victF%12===0) burst(Math.random()*W, 80+Math.random()*250, ['#FFD700','#FF4136','#7FDBFF','#7CFC00'][victF/12%4|0], 8);
    return; }

  if (state===ST.INTRO) {
    introF++;
    bgOff+=1.2; mtnOff+=2; waveOff+=3;
    for (const cl of clouds) { cl.x-=cl.sp*2; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*100; }
    if (introShip) {
      // desembarco: la nave desciende, el héroe salta de ella
      if (introF<55) {
        P.shipX = W*0.42 - (introF*1.2);
        P.shipY = -80 + introF*((GROUND-120+80)/55);
      }
      if (introF===55) { AudioMan.sfx('nave-carga'); }
      if (introF>=55 && introF<95) {
        const t=(introF-55)/40;
        P.x = (P.shipX||W*0.35) + (PX-(P.shipX||W*0.35))*t;
        P.y = (GROUND-110) + (GROUND-(GROUND-110))*t*t;
      }
      if (introF===95) { burst(P.x,GROUND-10,'#9adcff',12); shake(4); }
      if (introF>=95) { P.x=PX; P.y=GROUND; beginRun(); }
    } else {
      // arranque mundo 1: sale disparado de la cápsula del laboratorio
      if (introF===45) { AudioMan.sfx('cannon'); shake(10); fx('explosion', 105, GROUND-105); }
      if (introF>=45 && introF<90) {
        const t=(introF-45)/45;
        P.x = 70+(PX-70)*t;
        P.y = GROUND-40 - Math.sin(t*Math.PI)*190 + 40*t;
      }
      if (introF>=90) { P.x=PX; P.y=GROUND; beginRun(); }
    }
    tickEffects(); tickParticles();
    if (shakeF>0) shakeF--;
    return;
  }

  if (state!==ST.PLAYING) return;

  // ── PLAYING ──────────────────────────────────────────
  dist+=speed; worldDist+=speed;
  speed=Math.min(13, speed+0.0018);
  calcScore();
  if (comboT>0 && --comboT===0) combo=0;
  tickFloatTexts();
  tickDelayedObs();
  if (worldBanner>0) worldBanner--;

  misEvent('m', speed/80);
  if (fever>0) {
    fever--;
    if (gframe%2===0) particles.push({
      x:P.x-24+Math.random()*14, y:P.y-Math.random()*PH,
      vx:-2-Math.random()*2, vy:(Math.random()-0.5)*1.6,
      life:0.8, r:3+Math.random()*4, color:`hsl(${(gframe*12)%360},95%,60%)`
    });
  }
  if (Math.floor(dist/80)>=nextMile) {
    const bono=25*(nextMile/250);
    bonusPts+=bono;
    popup(W/2, 120, '🏁 ¡'+nextMile.toLocaleString()+' m!  +'+bono, '#7FDBFF', 30);
    AudioMan.sfx('gema');
    nextMile+=250;
  }
  if (!recordBeaten && hiScore>0 && score>hiScore) {
    recordBeaten=true;
    popup(W/2, 165, '🏆 ¡NUEVO RÉCORD!', '#FFD700', 36);
    burst(P.x, P.y-PH, '#FFD700', 22);
    AudioMan.sfx('gema');
    shake(5);
  }

  const wl=WORLDS[world].len;
  // aviso de jefe cerca del final del mundo
  if (!bossWarned && worldDist>=wl-700) {
    bossWarned=true;
    popup(W/2, 150, '⚠ ¡'+(world===0?'ROBOT GUARDIÁN':world===1?'BUBEADO':'GUNILDA')+' A LA VISTA!', '#FF4136', 30);
    AudioMan.sfx('soldado-aviso');
  }
  if (worldDist>=wl && !robotEv) {
    if (world===0) startBossRobot();
    else if (world===1) startBossFrog();
    else startBossGunilda();
    return;
  }

  bgOff+=speed*0.08; mtnOff+=speed*0.45; waveOff+=speed;
  if (world===2) for (const s of stars) { s.x-=s.sp*0.5; if (s.x<-4){ s.x=W+4; s.y=Math.random()*(GROUND-60); } }

  if (P.invincible>0) P.invincible--;
  if (P.shielded>0)  P.shielded--;
  if (P.cat>0)       P.cat--;
  if (P.boosted>0)  { P.boosted--; if (!P.boosted) speed=Math.max(baseSpeed(),speed-2.5); }

  const wasAir = P.y<GROUND-1;
  P.vy+=GRAVITY;
  P.y+=P.vy;
  if (P.y>=GROUND) {
    P.y=GROUND; P.vy=0; P.jumps=0;
    if (wasAir) AudioMan.startRun();
  }
  if (P.y>=GROUND-1) {
    P.atimer+=speed*0.034;
    if (P.atimer>=1) { P.atimer=0; P.anim=(P.anim+1)%6; }
  }

  for (const cl of clouds) { cl.x-=cl.sp*speed*0.55; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*200; }
  if (cameo) { cameo.x-=speed*1.4; cameo.at++; if (cameo.x<-200) cameo=null; }

  if (!robotEv && worldDist<wl-500) {
    if (--spawnT<=0)   { spawnObstacle(); spawnT=Math.max(48,150-Math.floor(hardness()*90)); }
    if (--coinT<=0)    { spawnCoins();    coinT=Math.max(62,140-Math.floor(dist/3000)); }
    if (--gemT<=0)     { spawnGem();      gemT=420+(Math.random()*380|0); }
    if (--pupT<=0)     { spawnPowerUp();  pupT=460+(Math.random()*420|0); }
    if (--skullT<=0)   { spawnSkull();    skullT=1400+(Math.random()*1100|0); }
    if (--eventT<=0)   { spawnWorldEvent(); eventT=900+(Math.random()*700|0); }
  }

  updateRobot();
  updateObstacles();
  updateCollectibles();
  checkCollisions();

  tickEffects(); tickParticles();
  if (shakeF>0) shakeF--;
}

// ── Evento robot (mundo 1) ─────────────────────────────
function updateRobot() {
  if (!robotEv) return;
  const R=robotEv;
  R.pt++;
  if (R.pt%6===0) R.af=(R.af+1)%8;

  if (R.phase==='enter') {
    R.y += (GROUND-170-R.y)*0.07;
    if (Math.abs(R.y-(GROUND-170))<4) { R.phase='charge'; R.pt=0; AudioMan.sfx('robot-carga'); }
  }
  else if (R.phase==='charge') {
    if (R.pt>=55) {
      R.phase='fire'; R.pt=0;
      R.beams.push({ h:R.plan.shift(), t:0 });
      AudioMan.sfx('robot-rayo');
    }
  }
  else if (R.phase==='fire') {
    for (const b of R.beams) b.t++;
    R.beams=R.beams.filter(b=>b.t<95);
    const pr=playerRect();
    for (const b of R.beams) {
      if (b.t<20||b.t>80) continue;
      const by = b.h==='low' ? GROUND-50 : GROUND-148;
      if (overlaps(pr.x,pr.y,pr.w,pr.h, 0,by,R.x-30,52, 6)) playerHit();
    }
    if (R.beams.length===0) {
      if (R.plan.length>0) { R.phase='charge'; R.pt=30; AudioMan.sfx('robot-carga'); }
      else { R.phase='exit'; R.pt=0; }
    }
  }
  else if (R.phase==='exit') {
    R.y-=6;
    if (R.y<-260) robotEv=null;
  }
}

// ── Obstáculos ─────────────────────────────────────────
function updateObstacles() {
  const nextObs=[];
  for (const ob of obstacles) {
    if (ob.type!=='soldier') ob.x-=speed;
    if (ob.x<-380) continue;

    if (ob.type==='espar') {
      ob.at++;
      ob.x-=speed*0.16;
      const ph=(ob.at%46)/46;
      ob.hop = ph<0.5 ? Math.sin(ph*2*Math.PI*0.5)*26 : 0;
    }

    else if (ob.type==='parachute') {
      ob.at++;
      if (ob.at%12===0) ob.af^=1;
      if (!ob.landed) {
        ob.vy=Math.min(3.2,ob.vy+0.05);
        ob.y+=ob.vy;
        ob.x+=Math.sin(ob.at*0.08)*0.9;
        if (ob.y>=GROUND) {
          ob.y=GROUND; ob.landed=true; ob.landTimer=0;
          fx('hit', ob.x, GROUND-40);
          burst(ob.x, GROUND-30, '#c8a468', 10);
          shake(3);
        }
      } else ob.landTimer++;
    }

    else if (ob.type==='mina') {
      ob.at++;
      ob.bob=Math.sin(ob.at*0.1)*3;
    }

    else if (ob.type==='lowball') {
      ob.x+=ob.vx-(-speed);   // compensa el scroll: velocidad propia
      ob.at++;
      if (ob.at%4===0) ob.af=(ob.af+1)%3;
    }

    else if (ob.type==='missile') {
      ob.at++;
      if (ob.warn>0) { ob.warn--; }
      else {
        ob.vy=Math.min(11, ob.vy+0.5);
        ob.y+=ob.vy;
        if (ob.y>=GROUND) {
          fx('explosion', ob.x, GROUND-40);
          shake(8);
          AudioMan.sfx('cannon',{vol:0.6,rate:1.3});
          if (Math.abs(P.x-ob.x)<80 && P.y>GROUND-70) playerHit();
          continue;
        }
      }
    }

    else if (ob.type==='raycol') {
      ob.at++;
      if (ob.warn>0) ob.warn--;
      else if (ob.at>140) continue;
    }

    else if (ob.type==='gunilda-cameo') {
      ob.at++;
      ob.x-=speed*0.6;
      ob.y+=Math.sin(ob.at*0.07)*1.1;
      if (!ob.dropped && ob.x<W*0.72) {
        ob.dropped=true;
        AudioMan.sfx('bruja-dispara');
        const dx=P.x-ob.x, dy=(P.y-PH*0.5)-ob.y;
        const dd=Math.hypot(dx,dy)||1, sp2=5.5;
        nextObs.push({ type:'bola', x:ob.x, y:ob.y+40, w:34, h:34,
                       vx:dx/dd*sp2, vy:dy/dd*sp2, af:0, at:0, homing:45 });
      }
    }

    else if (ob.type==='witch') {
      ob.at++;
      if (ob.at%5===0) ob.af=(ob.af+1)%6;
      ob.pt++;
      ob.y += Math.sin(ob.at*0.06)*0.8;
      if (ob.phase==='enter' && ob.x<W*0.78) { ob.phase='charge'; ob.pt=0; AudioMan.sfx('bruja-carga'); }
      else if (ob.phase==='charge' && ob.pt>=50) {
        ob.phase='shot'; ob.pt=0;
        AudioMan.sfx('bruja-dispara');
        const ty = ob.lowShot ? GROUND-24 : P.y-PH*0.5;
        const dx=P.x-ob.x, dy=ty-ob.y;
        const d=Math.hypot(dx,dy)||1, sp2=5.5;
        nextObs.push({ type:'bola', x:ob.x, y:ob.y+50, w:34, h:34,
                       vx:dx/d*sp2, vy:dy/d*sp2, af:0, at:0, homing:ob.lowShot?0:45 });
      }
      else if (ob.phase==='shot' && ob.pt>=45) { ob.phase='fade'; ob.pt=0; AudioMan.sfx('bruja-desaparece'); }
      else if (ob.phase==='fade') {
        ob.alpha-=0.04;
        if (ob.alpha<=0) continue;
      }
    }

    else if (ob.type==='bola') {
      if (ob.homing>0) {
        ob.homing--;
        const dx=P.x-ob.x, dy=(P.y-PH*0.5)-ob.y, d=Math.hypot(dx,dy)||1;
        ob.vx+= (dx/d*5.5-ob.vx)*0.04;
        ob.vy+= (dy/d*5.5-ob.vy)*0.04;
      }
      ob.x+=ob.vx; ob.y+=ob.vy; ob.at++;
      if (ob.at%4===0) ob.af=(ob.af+1)%3;
      if (ob.x<-80||ob.y>H+60) continue;
    }

    else if (ob.type==='dog' || ob.type==='minibot') {
      ob.at++;
      if (ob.at%6===0) ob.af=(ob.af+1)%(ob.type==='dog'?5:8);
      if (!ob.fired && ob.x-P.x<400) {
        ob.fired=true; ob.attacking=60;
        AudioMan.sfx(ob.type==='dog' ? 'perro-ataque' : 'robot-rayo');
      }
      if (ob.attacking>0) ob.attacking--;
    }

    else if (ob.type==='bomb') {
      ob.at++;
      if (ob.at%5===0) ob.af=(ob.af+1)%4;
      ob.y += Math.sin(ob.at*0.08)*0.6;
    }

    else if (ob.type==='soldier') {
      ob.pt++; ob.at++;
      if (ob.at%5===0) ob.af^=1;
      if (ob.phase==='warn') {
        if (ob.pt>=70) { ob.phase='charge'; AudioMan.sfx('soldado-embiste'); }
      } else {
        ob.x -= speed*2.6;
      }
    }

    else if (ob.type==='cball') {
      ob.vy+=ob.grav; ob.x+=ob.vx; ob.y+=ob.vy; ob.at++;
      if (ob.at%4===0) ob.af=(ob.af+1)%3;
      if (ob.y>GROUND+8) { fx('splash',ob.x,GROUND); continue; }
    }

    nextObs.push(ob);
  }
  obstacles=nextObs;
}

// ── Coleccionables ─────────────────────────────────────
function updateCollectibles() {
  const pr=playerRect();
  const magnetOn = P.cat>0 || fever>0;
  coinItems=coinItems.filter(c=>{
    c.x-=speed; c.at++;
    if (c.at%5===0) c.af=(c.af+1)%7;
    if (magnetOn) {
      const dx=P.x-c.x, dy=(P.y-PH*0.5)-c.y, d=Math.hypot(dx,dy)||1;
      if (d<260) { c.x+=dx/d*9; c.y+=dy/d*9; }
    }
    if (overlaps(pr.x,pr.y,pr.w,pr.h, c.x-16,c.y-16,32,32, 2)) {
      coins++;
      combo++; comboT=180;
      misEvent('coin');
      const mult=(1+Math.floor(combo/5))*(fever>0?2:1);
      bonusPts+=5*mult;
      popup(c.x,c.y-14,'+'+(5*mult)+(mult>1?' ×'+mult:''),fever>0?'#FF851B':'#FFD700',mult>1?26:20);
      burst(c.x,c.y,'#FFD700',8);
      AudioMan.sfx('coin',{vol:0.8,rate:1+Math.min(0.6,combo*0.03)});
      if (combo>=feverNext) {
        fever=420; feverNext=combo+12;
        popup(P.x, P.y-PH-44, '🔥 ¡FIEBRE DE MONEDAS! ×2', '#FF4136', 30);
        burst(P.x, P.y-PH*0.5, '#FF851B', 18);
        AudioMan.sfx('powerup-turbo');
      }
      return false;
    }
    return c.x>-60;
  });
  gemItems=gemItems.filter(gm=>{
    gm.x-=speed; gm.at++;
    if (gm.at%6===0) gm.af=(gm.af+1)%4;
    if (overlaps(pr.x,pr.y,pr.w,pr.h, gm.x-20,gm.y-20,40,40, 2)) {
      gems++;
      burst(gm.x,gm.y,'#44ff88',10);
      AudioMan.sfx('gema');
      if (gems>=GEMS_FOR_TURBO) { gems=0; activateTurbo(); }
      return false;
    }
    return gm.x>-60;
  });
  powerUps=powerUps.filter(pu=>{
    pu.x-=speed; pu.at++;
    if (pu.at%6===0) pu.af=(pu.af+1)%8;
    if (pu.type==='skull') {
      // Eufrasio bota por el suelo
      pu.vy+=GRAVITY*0.55;
      pu.y+=pu.vy;
      if (pu.y>=GROUND-26) { pu.y=GROUND-26; pu.vy=-7; }
    }
    if (overlaps(pr.x,pr.y,pr.w,pr.h, pu.x-24,pu.y-24,48,48, 2)) {
      if (pu.type==='shield') {
        P.shielded=420;
        burst(P.x,P.y-PH*0.5,'#88ddff',16);
        AudioMan.sfx('powerup-escudo');
      } else if (pu.type==='boost') {
        activateTurbo();
      } else if (pu.type==='cat') {
        P.cat=480;
        burst(P.x,P.y-PH*0.5,'#ffb060',14);
        popup(P.x, P.y-PH-30, '¡BILLS HUELE MONEDAS!', '#ffb060', 24);
        AudioMan.sfx('powerup-escudo',{rate:1.3});
      } else if (pu.type==='skull') {
        bonusPts+=100; coins+=5;
        popup(pu.x, pu.y-30, '💀 ¡EUFRASIO! +100', '#ffee88', 26);
        burst(pu.x,pu.y,'#ffee88',14);
        AudioMan.sfx('gema',{rate:0.8});
      } else {
        AudioMan.sfx('powerup-explosion');
        shake(14);
        for (const ob of obstacles) {
          if (ob.x>-100 && ob.x<W+150) fx('explosion', ob.x, ob.y-(ob.h||60)*0.5);
        }
        obstacles=[];
      }
      return false;
    }
    return pu.x>-80;
  });
}

// ── Colisiones jugador/obstáculo ───────────────────────
function checkCollisions() {
  const pr=playerRect();
  for (const ob of obstacles) {
    if (ob.x<-200) continue;
    let bx,by,bw,bh;
    switch(ob.type) {
      case 'espar':     bx=ob.x-ob.w*0.5; by=ob.y-ob.h-(ob.hop||0); bw=ob.w; bh=ob.h; break;
      case 'parachute': if (ob.landed){bx=ob.x-36;by=ob.y-72;bw=72;bh=72;}
                        else {bx=ob.x-35;by=ob.y-60;bw=70;bh=60;} break;
      case 'mina':      bx=ob.x-28; by=ob.y-58; bw=56; bh=58; break;
      case 'lowball':   bx=ob.x-15; by=ob.y-15; bw=30; bh=30; break;
      case 'missile':   if (ob.warn>0) continue;
                        bx=ob.x-20; by=ob.y-ob.h*0.5; bw=40; bh=ob.h; break;
      case 'raycol':    if (ob.warn>0 || ob.at>125) continue;
                        bx=ob.x-ob.w*0.5; by=0; bw=ob.w; bh=GROUND; break;
      case 'cball':     bx=ob.x-13; by=ob.y-13; bw=26; bh=26; break;
      case 'bola':      bx=ob.x-14; by=ob.y-14; bw=28; bh=28; break;
      case 'bomb':      bx=ob.x-26; by=ob.y-26; bw=52; bh=52; break;
      case 'soldier':   if (ob.phase!=='charge') continue;
                        bx=ob.x-44; by=ob.y-ob.h; bw=ob.w; bh=ob.h; break;
      case 'minibot':
      case 'dog':
        bx=ob.x-38; by=ob.y-ob.h; bw=ob.w; bh=ob.h;
        if (ob.attacking>10 && ob.attacking<55) {
          if (overlaps(pr.x,pr.y,pr.w,pr.h, ob.x-190,GROUND-58,155,58, 6)) {
            playerHit();
            if (state===ST.DEAD) return;
          }
        }
        break;
      default: continue;
    }
    if (overlaps(pr.x,pr.y,pr.w,pr.h, bx,by,bw,bh)) {
      if (P.boosted>0) { fx('explosion', ob.x, ob.y-(ob.h||50)*0.5); ob.x=-999; shake(6); continue; }
      // Espárrago y pirata se pueden estompar desde arriba
      if ((ob.type==='espar'||ob.type==='parachute') && P.vy>1.5 && (P.y-by)<bh*0.6) {
        stompBounce();
        fx('hit', ob.x, by);
        burst(ob.x, by, '#ffcc44', 12);
        bonusPts+=30;
        popup(ob.x, by-20, '¡PISOTÓN! +30', '#FFDC00', 24);
        ob.x=-999;
        continue;
      }
      ob.x=-999;
      playerHit();
      if (state===ST.DEAD) return;
    } else if (!ob.grazed && overlaps(pr.x,pr.y,pr.w,pr.h, bx-24,by-24,bw+48,bh+48)) {
      ob.grazed=true;
      bonusPts+=15;
      misEvent('near');
      popup(P.x,P.y-PH-16,'¡Casi! +15','#7FDBFF',20);
    }
    if (!ob.dodged && bx+bw<pr.x) {
      ob.dodged=true;
      dodgeStreak++;
      misEvent('dodge');
      if (dodgeStreak%10===0) {
        popup(P.x,P.y-PH-38,'¡RACHA ×'+dodgeStreak+'!','#FF851B',30);
        AudioMan.sfx('gema');
        for (let i=0;i<7;i++) {
          coinItems.push({ x:P.x+160+i*46, y:GROUND-150-Math.sin(i/6*Math.PI)*70, at:0, af:i%7 });
        }
      }
    }
  }
}

function tickEffects() {
  effects=effects.filter(ef=>{
    ef.at++;
    if (ef.type==='explosion') { if (ef.at%3===0) ef.af++; return ef.af<12; }
    if (ef.type==='splash')    { if (ef.at%4===0) ef.af++; return ef.af<6;  }
    if (ef.type==='hit')       { if (ef.at%5===0) ef.af++; return ef.af<3;  }
    if (ef.type==='warning')   { ef.life--; if (ef.at%5===0) ef.af=(ef.af+1)%6; return ef.life>0; }
    return false;
  });
}
function tickParticles() {
  particles=particles.filter(p=>{
    p.x+=p.vx; p.y+=p.vy; p.vy+=0.22; p.life-=0.028; return p.life>0;
  });
}

// ═══════════════════════════════════════════════════════
//  DRAW — FONDOS (uno por mundo)
// ═══════════════════════════════════════════════════════
function drawBg() {
  if (world===2) {
    const sk=gi('marsSky');
    if (sk) ctx.drawImage(sk,0,0,W,GROUND);
    else { ctx.fillStyle='#f5b98a'; ctx.fillRect(0,0,W,GROUND); }
    ctx.fillStyle='rgba(255,255,255,0.7)';
    for (const s of stars) { if (s.y<GROUND-60) { ctx.globalAlpha=0.4; ctx.beginPath(); ctx.arc(s.x,s.y*0.5,s.r*0.7,0,Math.PI*2); ctx.fill(); } }
    ctx.globalAlpha=1;
    return;
  }
  if (world===0) {
    // laboratorio: pared modular en mosaico con luz fría
    const g=ctx.createLinearGradient(0,0,0,GROUND);
    g.addColorStop(0,'#2a3a58'); g.addColorStop(1,'#8fb4cc');
    ctx.fillStyle=g; ctx.fillRect(0,0,W,GROUND);
    const li=gi('lab');
    if (li) {
      const lh=GROUND*0.94, lw=li.naturalWidth*(lh/li.naturalHeight);
      const off=((bgOff*2.2)%lw+lw)%lw;
      ctx.globalAlpha=0.85;
      for (let x=-off; x<W+lw; x+=lw-4) ctx.drawImage(li,x,GROUND-lh,lw,lh);
      ctx.globalAlpha=1;
    }
    return;
  }
  const g=ctx.createLinearGradient(0,0,0,GROUND);
  g.addColorStop(0,'#0d3a7a'); g.addColorStop(0.5,'#1a6dcc'); g.addColorStop(1,'#5fc8e8');
  ctx.fillStyle=g; ctx.fillRect(0,0,W,GROUND);
  const bi=gi('bg');
  if (bi) {
    const scale=GROUND/bi.naturalHeight;
    const bw=bi.naturalWidth*scale;
    const bx=-((bgOff%bw)+bw)%bw;
    ctx.globalAlpha=0.78;
    ctx.drawImage(bi,bx,0,bw,GROUND);
    if (bx+bw<W) ctx.drawImage(bi,bx+bw,0,bw,GROUND);
    ctx.globalAlpha=1;
  }
}
function drawClouds() {
  if (world===0) return;
  for (const cl of clouds) {
    const i=gi(cl.k); if (!i) continue;
    ctx.globalAlpha=world===2?0.35:0.9;
    ctx.drawImage(i,cl.x,cl.y,cl.w,cl.h);
    ctx.globalAlpha=1;
  }
}
function drawMountains() {
  if (world===0) return;
  if (world===2) {
    const layers=[['mars3',0.35,220,0.55],['mars2',0.62,150,0.75],['mars1',1.0,120,1]];
    for (const [k,par,h,al] of layers) {
      const m=gi(k); if (!m) continue;
      const w=m.naturalWidth*(h/m.naturalHeight);
      const off=((mtnOff*par)%w+w)%w;
      ctx.globalAlpha=al;
      for (let x=-off-w;x<W+w;x+=w-2) ctx.drawImage(m,x,GROUND-h,w,h);
      ctx.globalAlpha=1;
    }
    return;
  }
  const m1=gi('mtn1');
  if (m1) {
    const h1=148, w1=m1.naturalWidth*(h1/m1.naturalHeight);
    const off1=((mtnOff*0.42)%w1+w1)%w1;
    ctx.globalAlpha=0.68;
    for (let x=-off1-w1;x<W+w1;x+=w1+6) ctx.drawImage(m1,x,GROUND-h1,w1,h1);
    ctx.globalAlpha=1;
  }
  const m2=gi('mtn2');
  if (m2) {
    const h2=192, w2=m2.naturalWidth*(h2/m2.naturalHeight);
    const off2=((mtnOff*0.88)%w2+w2)%w2;
    ctx.globalAlpha=0.84;
    for (let x=-off2-w2;x<W+w2;x+=w2+4) ctx.drawImage(m2,x,GROUND-h2,w2,h2);
    ctx.globalAlpha=1;
  }
}
function drawOcean() {
  if (world===0) {
    // suelo metálico del laboratorio
    const og=ctx.createLinearGradient(0,GROUND,0,H);
    og.addColorStop(0,'#4a5a74'); og.addColorStop(1,'#141c2c');
    ctx.fillStyle=og; ctx.fillRect(0,GROUND,W,H-GROUND);
    ctx.fillStyle='#98b0c8'; ctx.fillRect(0,GROUND,W,5);
    ctx.strokeStyle='rgba(160,190,220,0.25)'; ctx.lineWidth=2;
    const seg=90, off=(waveOff%seg+seg)%seg;
    for (let x=-off;x<W;x+=seg) { ctx.beginPath(); ctx.moveTo(x,GROUND+6); ctx.lineTo(x-24,H); ctx.stroke(); }
    ctx.lineWidth=1;
    return;
  }
  if (world===2) {
    const og=ctx.createLinearGradient(0,GROUND,0,H);
    og.addColorStop(0,'#a94a30'); og.addColorStop(1,'#4a1608');
    ctx.fillStyle=og; ctx.fillRect(0,GROUND,W,H-GROUND);
    tileH('wood', GROUND+5, 40, waveOff*0.88);
    ctx.fillStyle='#d4703f'; ctx.fillRect(0,GROUND,W,5);
    return;
  }
  const og=ctx.createLinearGradient(0,GROUND,0,H);
  og.addColorStop(0,'#1888d8'); og.addColorStop(1,'#072560');
  ctx.fillStyle=og; ctx.fillRect(0,GROUND,W,H-GROUND);
  tileH('wave', GROUND-22, 58, waveOff);
  tileH('wood', GROUND+5, 40, waveOff*0.88);
  ctx.fillStyle='#c89840'; ctx.fillRect(0,GROUND,W,5);
}
function drawScene(){ drawBg(); drawClouds(); drawMountains(); drawOcean(); }

// ═══════════════════════════════════════════════════════
//  DRAW — JUGADOR
// ═══════════════════════════════════════════════════════
function charFilter() { return selChar===1 ? 'hue-rotate(120deg) saturate(1.15)' : 'none'; }

function drawRunFrame(x, y) {
  const ri=gi((selChar===1?'lr':'r')+(P.anim|0));
  if (!ri) { ctx.fillStyle='#3498db'; ctx.fillRect(x-PW*0.5,y-PH,PW,PH); return; }
  const w=PH*ri.naturalWidth/ri.naturalHeight;
  ctx.drawImage(ri, x-w*0.5, y-PH, w, PH);
}
function drawCatBuddy() {
  if (P.cat<=0) return;
  const cf=gi('g'+(Math.floor(gframe/4)%5));
  if (cf) {
    ctx.globalAlpha = P.cat<90 ? (Math.floor(gframe/5)%2?0.4:0.9) : 1;
    ctx.drawImage(cf, P.x-118, GROUND-34, 66, 30);
    ctx.globalAlpha = 1;
  }
}
function drawPlayer() {
  const pr=playerRect();
  const onGround=P.y>=GROUND-2;
  const isDuck=P.ducking&&onGround;
  const flicker=P.invincible>0 && Math.floor(gframe/4)%2===1;

  drawCatBuddy();
  if (flicker) ctx.globalAlpha=0.3;

  if (P.boosted>0) {
    const wf=gi('wind'+(Math.floor(gframe/4)%4));
    if (wf) {
      const oldA=ctx.globalAlpha;
      ctx.globalAlpha=Math.min(oldA,0.8);
      ctx.drawImage(wf, P.x-115, P.y-PH-8, 100, PH+16);
      ctx.globalAlpha=oldA;
    }
  }

  if (P.shielded>0) {
    const si=gi('shield'+(Math.floor(gframe/4)%9));
    if (si) {
      const oldA=ctx.globalAlpha;
      ctx.globalAlpha=Math.min(oldA,0.55);
      ctx.drawImage(si, pr.x-22, pr.y-14, pr.w+44, pr.h+28);
      ctx.globalAlpha=oldA;
    }
  }

  if (state===ST.DEAD) {
    di('splat', P.x-55, P.y-PH-18, 96, PH+40);
  } else if (state===ST.INTRO && !introShip && introF>=45 && introF<90) {
    const ji=gi(selChar===1?'ljump':'mjump');
    ctx.save();
    ctx.translate(P.x,P.y-PH*0.5);
    ctx.rotate(((introF-45)/45)*Math.PI*2);
    if (ji) {
      const jw=PH*ji.naturalWidth/ji.naturalHeight;
      ctx.drawImage(ji,-jw*0.5,-PH*0.5,jw,PH);
    }
    ctx.restore();
  } else if (!onGround) {
    const ji=gi(selChar===1?'ljump':'mjump');
    if (ji) {
      const jw=PH*ji.naturalWidth/ji.naturalHeight;
      ctx.drawImage(ji, P.x-jw*0.5, P.y-PH, jw, PH);
    } else drawRunFrame(P.x,P.y);
  } else if (isDuck) {
    ctx.save();
    ctx.translate(P.x,P.y);
    ctx.scale(1,0.55);
    drawRunFrame(0,0);
    ctx.restore();
  } else if (P.boosted>0) {
    const ti=gi('tur'+(Math.floor(gframe/4)%2));
    if (ti) {
      if (ctx.filter!==undefined) ctx.filter=charFilter();
      ctx.drawImage(ti, P.x-PW*0.62, P.y-PH-4, PW*1.3, PH+4);
      if (ctx.filter!==undefined) ctx.filter='none';
    }
    else drawRunFrame(P.x,P.y);
  } else {
    drawRunFrame(P.x,P.y);
  }

  if (ctx.filter!==undefined) ctx.filter='none';
  ctx.globalAlpha=1;
}

// ═══════════════════════════════════════════════════════
//  DRAW — OBSTÁCULOS / ROBOT / CAMEO
// ═══════════════════════════════════════════════════════
function drawBeamH(imgKey, frame, y, xEnd, thick, alpha) {
  const ri=gi(imgKey+frame);
  ctx.globalAlpha=alpha;
  if (ri) {
    const tw=thick*ri.naturalHeight/ri.naturalWidth;
    for (let x=0; x<xEnd; x+=tw*0.85) {
      ctx.save();
      ctx.translate(x+tw*0.5, y);
      ctx.rotate(-Math.PI/2);
      ctx.drawImage(ri, -thick*0.5, -tw*0.5, thick, tw);
      ctx.restore();
    }
  } else {
    ctx.fillStyle='#8feaff';
    ctx.fillRect(0, y-thick*0.5, xEnd, thick);
  }
  ctx.globalAlpha=1;
}

function drawRobot() {
  if (!robotEv) return;
  const R=robotEv;
  for (const b of R.beams) {
    const by = (b.h==='low' ? GROUND-50 : GROUND-148) + 26;
    const active = b.t>=20 && b.t<=80;
    const alpha = active ? 0.95 : (b.t<20 ? 0.3+0.2*Math.sin(b.t) : Math.max(0,(95-b.t)/15));
    drawBeamH('rayo', Math.floor(b.t/3)%3, by, R.x-30, active?52:14, alpha);
  }
  const rb=gi('robot'+R.af);
  if (rb) {
    const rh=180, rw=rh*rb.naturalWidth/rb.naturalHeight;
    ctx.save();
    if (R.phase==='charge') { ctx.shadowColor='#66eaff'; ctx.shadowBlur=18+Math.sin(R.pt*0.4)*10; }
    ctx.drawImage(rb, R.x-rw*0.5, R.y-rh*0.5, rw, rh);
    ctx.restore();
  }
}
function drawCameo() {
  if (!cameo) return;
  const g2=gi('gorilla');
  if (g2) {
    const bob=Math.sin(cameo.at*0.3)*2;
    ctx.drawImage(g2, cameo.x-48, GROUND-88+bob, 96, 88);
    if (!cameo.said && cameo.x<W-160) {
      cameo.said=true;
      popup(cameo.x, GROUND-110, '¡Papa Gorila al rescate!', '#ffcc88', 20);
    }
  }
}

function drawObstacles() {
  for (const ob of obstacles) {
    if (ob.x<-380||ob.x>W+320) continue;

    if (ob.type==='espar') {
      const ei=gi('espar');
      if (ei) {
        const hop=ob.hop||0;
        const stretch = hop>2 ? 1.08 : (ob.at%46)>40 ? 0.9 : 1;
        ctx.save();
        ctx.translate(ob.x, ob.y-hop);
        ctx.rotate(Math.sin(ob.at*0.14)*0.07);
        ctx.scale(-(2-stretch), stretch);   // volteado: corre mirando al jugador
        ctx.drawImage(ei, -ob.w*0.5, -ob.h, ob.w, ob.h);
        ctx.restore();
      }
    }
    else if (ob.type==='parachute') {
      const pi=gi(ob.af===0?'pirata0':'pirata1');
      if (pi) {
        if (ob.landed) {
          const sy=pi.naturalHeight*0.46, sh=pi.naturalHeight*0.54;
          const dh=78;
          ctx.save();
          ctx.translate(ob.x, ob.y);
          ctx.rotate(Math.sin(ob.landTimer*0.15)*0.06);
          ctx.drawImage(pi, 0, sy, pi.naturalWidth, sh, -42, -dh, 84, dh);
          ctx.restore();
        } else {
          ctx.save();
          ctx.translate(ob.x, ob.y-ob.h*0.5);
          ctx.rotate(Math.sin(ob.at*0.08)*0.12);
          ctx.drawImage(pi, -45, -ob.h*0.5, ob.w, ob.h);
          ctx.restore();
        }
      }
    }
    else if (ob.type==='mina') {
      // bomba pinchuda varada en la arena
      const mi=gi('bomb'+(Math.floor(ob.at/6)%4));
      const bob=ob.bob||0;
      if (mi) ctx.drawImage(mi, ob.x-32, ob.y-64+bob, 64, 64);
      else { ctx.fillStyle='#333'; ctx.beginPath(); ctx.arc(ob.x,ob.y-30+bob,26,0,Math.PI*2); ctx.fill(); }
    }
    else if (ob.type==='lowball') {
      const bi=gi('cb'+ob.af);
      if (bi) {
        ctx.save();
        ctx.translate(ob.x,ob.y);
        ctx.rotate(Math.PI/2);
        ctx.drawImage(bi,-14,-22,28,44);
        ctx.restore();
      } else { ctx.fillStyle='#222'; ctx.beginPath(); ctx.arc(ob.x,ob.y,15,0,Math.PI*2); ctx.fill(); }
    }
    else if (ob.type==='missile') {
      if (ob.warn>0) {
        if (Math.floor(ob.at/6)%2===0) {
          ctx.save();
          ctx.fillStyle='rgba(255,60,40,0.8)';
          ctx.beginPath();
          ctx.moveTo(ob.x,GROUND-34); ctx.lineTo(ob.x-16,GROUND-6); ctx.lineTo(ob.x+16,GROUND-6);
          ctx.closePath(); ctx.fill();
          ctx.fillStyle='#fff'; ctx.font='bold 20px sans-serif'; ctx.textAlign='center';
          ctx.fillText('!', ob.x, GROUND-12);
          ctx.restore();
          ctx.textAlign='left';
        }
      } else {
        const mi=gi('missile');
        if (mi) {
          ctx.save();
          ctx.translate(ob.x, ob.y);
          ctx.rotate(Math.PI);
          ctx.drawImage(mi, -ob.w*0.5, -ob.h*0.5, ob.w, ob.h);
          ctx.restore();
        }
      }
    }
    else if (ob.type==='raycol') {
      if (ob.warn>0) {
        if (Math.floor(ob.at/6)%2===0) {
          ctx.fillStyle='rgba(221,102,255,0.35)';
          ctx.fillRect(ob.x-ob.w*0.5, 0, ob.w, GROUND);
        }
      } else {
        const a = ob.at>125 ? Math.max(0,(140-ob.at)/15) : 0.92;
        const mf=gi('magia'+(Math.floor(ob.at/3)%6));
        ctx.globalAlpha=a;
        if (mf) {
          for (let y=0;y<GROUND;y+=90) ctx.drawImage(mf, ob.x-ob.w*0.65, y, ob.w*1.3, 92);
        } else {
          ctx.fillStyle='#dd66ff';
          ctx.fillRect(ob.x-ob.w*0.5, 0, ob.w, GROUND);
        }
        ctx.globalAlpha=1;
      }
    }
    else if (ob.type==='gunilda-cameo') {
      const gf=gi('gun'+(Math.floor(ob.at/6)%3));
      if (gf) {
        const gh=86, gw=gh*gf.naturalWidth/gf.naturalHeight;
        ctx.save();
        ctx.translate(ob.x, ob.y);
        ctx.rotate(Math.sin(ob.at*0.05)*0.08);
        ctx.scale(-1,1);
        ctx.drawImage(gf, -gw*0.5, -gh*0.5, gw, gh);
        ctx.restore();
      }
    }
    else if (ob.type==='witch') {
      ctx.globalAlpha=Math.max(0, ob.alpha);
      const wi=gi('bruja'+ob.af);
      if (wi) {
        ctx.save();
        if (ob.phase==='charge') { ctx.shadowColor='#dd66ff'; ctx.shadowBlur=16+Math.sin(ob.pt*0.4)*8; }
        ctx.drawImage(wi, ob.x-41, ob.y, 82, 100);
        ctx.restore();
      }
      ctx.globalAlpha=1;
    }
    else if (ob.type==='bola') {
      const bi=gi('bola'+ob.af);
      if (bi) ctx.drawImage(bi, ob.x-19, ob.y-19, 38, 38);
      else { ctx.fillStyle='#cc2244'; ctx.beginPath(); ctx.arc(ob.x,ob.y,14,0,Math.PI*2); ctx.fill(); }
    }
    else if (ob.type==='dog') {
      const dgi=gi('dog'+ob.af);
      if (dgi) ctx.drawImage(dgi, ob.x-41, ob.y-ob.h, 82, ob.h);
      if (ob.attacking>10 && ob.attacking<55) {
        const fi=gi('fuego'+(Math.floor(ob.at/4)%3));
        if (fi) ctx.drawImage(fi, ob.x-205, ob.y-72, 175, 76);
      }
    }
    else if (ob.type==='minibot') {
      const ri=gi('robot'+ob.af);
      if (ri) ctx.drawImage(ri, ob.x-38, ob.y-ob.h-4+Math.sin(ob.at*0.15)*3, 76, ob.h);
      if (ob.attacking>10 && ob.attacking<55) {
        const li=gi('flaser'+(Math.floor(ob.at/4)%5));
        if (li) {
          const th=34, tw2=th*li.naturalHeight/li.naturalWidth;
          for (let lx=ob.x-205; lx<ob.x-35; lx+=tw2*0.85) {
            ctx.save(); ctx.translate(lx+tw2*0.5, GROUND-40); ctx.rotate(-Math.PI/2);
            ctx.drawImage(li, -th*0.5, -tw2*0.5, th, tw2); ctx.restore();
          }
        } else { ctx.fillStyle='#8feaff'; ctx.fillRect(ob.x-205, GROUND-56, 175, 30); }
      }
    }
    else if (ob.type==='bomb') {
      const bi=gi('bomb'+ob.af);
      if (bi) ctx.drawImage(bi, ob.x-31, ob.y-31, 62, 62);
    }
    else if (ob.type==='soldier') {
      if (ob.phase==='warn') {
        const wi=gi('soldierWarn');
        if (wi && Math.floor(ob.pt/7)%2===0) ctx.drawImage(wi, W-108, GROUND-176, 92, 88);
      } else {
        const mi=gi(ob.af===0?'moto0':'moto1');
        if (mi) ctx.drawImage(mi, ob.x-48, ob.y-ob.h, ob.w, ob.h);
      }
    }
    else if (ob.type==='cball') {
      const cbi=gi('cb'+ob.af);
      if (cbi) {
        ctx.save();
        ctx.translate(ob.x,ob.y);
        ctx.rotate(Math.atan2(ob.vy,ob.vx));
        ctx.drawImage(cbi,-14,-22,28,44);
        ctx.restore();
      }
    }
  }
}

// ═══════════════════════════════════════════════════════
//  DRAW — COLECCIONABLES / EFECTOS
// ═══════════════════════════════════════════════════════
function drawCollectibles() {
  for (const c of coinItems) {
    const ci=gi('c'+c.af);
    if (ci) ctx.drawImage(ci, c.x-18, c.y-18, 36, 36);
  }
  for (const gm of gemItems) {
    const g2=gi('gem'+gm.af);
    ctx.save();
    ctx.shadowColor='#44ff88'; ctx.shadowBlur=12;
    if (g2) ctx.drawImage(g2, gm.x-20, gm.y-20, 40, 40);
    ctx.restore();
  }
  for (const pu of powerUps) {
    const pulse=1+Math.sin(gframe*0.14)*0.06, sz=48*pulse;
    ctx.save();
    ctx.shadowColor = pu.type==='shield'?'#44aaff':pu.type==='boost'?'#ffaa22':pu.type==='cat'?'#ffb060':pu.type==='skull'?'#ffee88':'#ff5533';
    ctx.shadowBlur=16+Math.sin(gframe*0.12)*6;
    if (pu.type==='shield') {
      const ei=gi('escudo'+pu.af);
      if (ei) ctx.drawImage(ei, pu.x-sz*0.5, pu.y-sz*0.6, sz, sz*1.3);
    } else if (pu.type==='boost') {
      const bi2=gi('boost'+(pu.af%5));
      if (bi2) ctx.drawImage(bi2, pu.x-sz*0.5, pu.y-sz*0.5, sz, sz);
    } else if (pu.type==='cat') {
      const cf=gi('g'+(Math.floor(gframe/5)%5));
      if (cf) ctx.drawImage(cf, pu.x-sz*0.6, pu.y-sz*0.35, sz*1.2, sz*0.7);
    } else if (pu.type==='skull') {
      const sk=gi('skull');
      if (sk) {
        ctx.save();
        ctx.translate(pu.x,pu.y);
        ctx.rotate(Math.sin(pu.at*0.15)*0.25);
        ctx.drawImage(sk, -sz*0.55, -sz*0.45, sz*1.1, sz*0.8);
        ctx.restore();
      }
    } else {
      const ex=gi('exp2');
      if (ex) ctx.drawImage(ex, pu.x-sz*0.5, pu.y-sz*0.5, sz, sz);
    }
    if (pu.type!=='skull') {
      const bu=gi('burb'+(Math.floor(gframe/5)%14));
      if (bu) { ctx.globalAlpha=0.45; ctx.drawImage(bu, pu.x-sz*0.75, pu.y-sz*0.75, sz*1.5, sz*1.5); ctx.globalAlpha=1; }
    }
    ctx.restore();
  }
}
function drawEffects() {
  for (const ef of effects) {
    if (ef.type==='explosion') {
      const ei2=gi('exp'+Math.min(11,ef.af));
      if (ei2) ctx.drawImage(ei2, ef.x-50, ef.y-50, 100, 100);
    } else if (ef.type==='splash') {
      const si=gi('splash'+Math.min(5,ef.af));
      if (si) ctx.drawImage(si, ef.x-24, ef.y-48, 48, 50);
    } else if (ef.type==='hit') {
      const hi=gi('hit'+Math.min(2,ef.af));
      if (hi) { ctx.globalAlpha=0.88; ctx.drawImage(hi, ef.x-44, ef.y-50, 88, 104); ctx.globalAlpha=1; }
    } else if (ef.type==='warning') {
      const wf=gi('warn'+ef.af);
      ctx.globalAlpha=Math.min(1, ef.life/18);
      if (wf) ctx.drawImage(wf, ef.x-26, ef.y-32, 52, 52);
      ctx.globalAlpha=1;
    }
  }
}
function drawParticles() {
  for (const p of particles) {
    ctx.globalAlpha=Math.max(0,p.life);
    ctx.fillStyle=p.color;
    ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2); ctx.fill();
  }
  ctx.globalAlpha=1;
}

