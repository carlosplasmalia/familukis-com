---
// Mikeltube Adventures — HTML5 Game (noindex)
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
  <meta name="robots" content="noindex, nofollow"/>
  <title>Mikeltube Adventures</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    html,body { width:100%; height:100%; background:#0a1020; overflow:hidden; touch-action:none; }
    body { display:flex; align-items:center; justify-content:center; }
    canvas { display:block; image-rendering:pixelated; image-rendering:crisp-edges; cursor:pointer; }
  </style>
</head>
<body>
<canvas id="c"></canvas>
<script>
'use strict';

// ═══════════════════════════════════════════════════
//  CANVAS & SCALE
// ═══════════════════════════════════════════════════
const canvas = document.getElementById('c');
const ctx    = canvas.getContext('2d');
const W = 960, H = 540;
canvas.width = W; canvas.height = H;

function resize() {
  const s = Math.min(window.innerWidth / W, window.innerHeight / H);
  canvas.style.width  = Math.floor(W * s) + 'px';
  canvas.style.height = Math.floor(H * s) + 'px';
}
window.addEventListener('resize', resize);
resize();

// ═══════════════════════════════════════════════════
//  ASSETS
// ═══════════════════════════════════════════════════
const S  = '/mk-studio/sprites/';
const TX = '/mk-studio/textures/';

const ASSET_LIST = {
  // UI / title
  logo:     S + 'MikelTubeLogo_2.png',
  titleBg:  S + 'MIKELTUBE TITLE BG.png',
  heart:    S + 'health.png',
  // Background layers
  bg:       S + 'BACKGROUND.png',
  cloud1:   S + 'cloud1.png',
  cloud2:   S + 'cloud 2.png',
  cloud3:   S + 'cloud 3.png',
  cloud4:   S + 'cloud 4.png',
  mtn1:     S + 'montain big1.png',
  mtn2:     S + 'montain big2.png',
  wave:     S + 'ONE SINGLE WAVE_2.png',
  ship:     TX + 'Barco.png',
  wood:     TX + 'madera.png',
  // Character — run cycle (9 frames)
  r0: S+'RUNCYCLE_MIKEL_PWERSUIT_atlas_0.png',
  r1: S+'RUNCYCLE_MIKEL_PWERSUIT_atlas_1.png',
  r2: S+'RUNCYCLE_MIKEL_PWERSUIT_atlas_2.png',
  r3: S+'RUNCYCLE_MIKEL_PWERSUIT_atlas_3.png',
  r4: S+'RUNCYCLE_MIKEL_PWERSUIT_atlas_4.png',
  r5: S+'RUNCYCLE_MIKEL_PWERSUIT_atlas_5.png',
  r6: S+'RUNCYCLE_MIKEL_PWERSUIT_atlas_6.png',
  r7: S+'RUNCYCLE_MIKEL_PWERSUIT_atlas_7.png',
  r8: S+'RUNCYCLE_MIKEL_PWERSUIT_atlas_8.png',
  jump: S + 'MIKeL AIRBORNE.png',
  dead: S + 'MIKEL SPLAT BASE.png',
  // Obstacles
  cannon:   S + 'cannon.png',
  cb0: S + 'cannonball ATLAS_0.png',
  cb1: S + 'cannonball ATLAS_1.png',
  cb2: S + 'cannonball ATLAS_2.png',
  pirate:   S + 'PIRATE.png',
  pirateAir:S + 'PIRATE AIRBORNE.png',
  warn0: S + 'ATLAS_CANNONBALL_WARNING_0.png',
  warn1: S + 'ATLAS_CANNONBALL_WARNING_1.png',
  warn2: S + 'ATLAS_CANNONBALL_WARNING_2.png',
  // Coins
  c0: S+'SPECIAL COIN ATLAS_0.png',
  c1: S+'SPECIAL COIN ATLAS_1.png',
  c2: S+'SPECIAL COIN ATLAS_2.png',
  c3: S+'SPECIAL COIN ATLAS_3.png',
  c4: S+'SPECIAL COIN ATLAS_4.png',
  c5: S+'SPECIAL COIN ATLAS_5.png',
  c6: S+'SPECIAL COIN ATLAS_6.png',
  // Power-up
  shield0: S + 'escudo atlas_0.png',
  shield1: S + 'escudo atlas_1.png',
  shield2: S + 'escudo atlas_2.png',
  shield3: S + 'escudo atlas_3.png',
  shieldPU: S + 'shield.png',
  boost0: S + 'BOOST atlas_0.png',
  boost1: S + 'BOOST atlas_1.png',
  boost2: S + 'BOOST atlas_2.png',
};

const IMG = {};
let loaded = 0;
const TOTAL = Object.keys(ASSET_LIST).length;

function preload() {
  return new Promise(res => {
    for (const [k, url] of Object.entries(ASSET_LIST)) {
      const img = new Image();
      img.onload = img.onerror = () => { IMG[k] = img; loaded++; if (loaded === TOTAL) res(); };
      img.src = url;
    }
  });
}

// ═══════════════════════════════════════════════════
//  GAME CONSTANTS
// ═══════════════════════════════════════════════════
const GROUND  = 415;     // y-coordinate of feet
const PX      = 160;     // player fixed X
const GRAVITY = 0.62;
const JUMP_VY = -15.0;
const RUN_FPS = 11;      // animation frames per second

// ═══════════════════════════════════════════════════
//  GAME STATE
// ═══════════════════════════════════════════════════
const ST = { TITLE:0, PLAY:1, DEAD:2 };
let state, score, coins, dist, speed, gframe;
let hiScore = +(localStorage.getItem('mk_hi')||0);

// Player
const P = { x:PX, y:GROUND, vy:0, jumps:0, anim:0, atimer:0, h:88, w:60, shielded:0 };

// Entity arrays
let obstacles, coinItems, pups, particles, clouds, warns;

// Spawn timing
let spawnT, coinT, pupT;

// ═══════════════════════════════════════════════════
//  INIT / RESET
// ═══════════════════════════════════════════════════
function reset() {
  state = ST.PLAY;
  score = coins = dist = gframe = 0;
  speed = 4.2;
  obstacles = []; coinItems = []; pups = []; particles = []; warns = [];
  spawnT = 120; coinT = 80; pupT = 600;
  P.y = GROUND; P.vy = 0; P.jumps = 0; P.anim = 0; P.atimer = 0; P.shielded = 0;

  // Initial clouds spread across screen
  clouds = [
    {k:'cloud1', x:100,  y:55,  w:220, h:90,  sp:0.18},
    {k:'cloud2', x:380,  y:80,  w:180, h:75,  sp:0.22},
    {k:'cloud3', x:630,  y:45,  w:200, h:80,  sp:0.15},
    {k:'cloud4', x:860,  y:70,  w:160, h:65,  sp:0.20},
    {k:'cloud1', x:1150, y:60,  w:200, h:85,  sp:0.19},
    {k:'cloud3', x:1380, y:40,  w:180, h:72,  sp:0.16},
  ];
}

// ═══════════════════════════════════════════════════
//  INPUT
// ═══════════════════════════════════════════════════
function onJump() {
  if (state === ST.TITLE) { reset(); return; }
  if (state === ST.DEAD)  { reset(); return; }
  if (P.jumps < 2) { P.vy = JUMP_VY - (P.jumps * 1.5); P.jumps++; }
}

document.addEventListener('keydown', e => {
  if (e.code === 'Space' || e.code === 'ArrowUp') { e.preventDefault(); onJump(); }
});
canvas.addEventListener('pointerdown', e => { e.preventDefault(); onJump(); });

// ═══════════════════════════════════════════════════
//  SPAWN
// ═══════════════════════════════════════════════════
function spawnObstacle() {
  const r = Math.random();
  if (r < 0.45) {
    // Cannon on ground + fires cannonball after delay
    const cx = W + 80;
    const cy = GROUND - 44;
    obstacles.push({ type:'cannon', x:cx, y:cy, w:80, h:80, fireIn:55, fired:false });
  } else if (r < 0.80) {
    // Pirate(s)
    obstacles.push({ type:'pirate', x:W+50,  y:GROUND, w:52, h:88, af:0, at:0 });
    if (r > 0.65) obstacles.push({ type:'pirate', x:W+155, y:GROUND, w:52, h:88, af:0, at:0 });
  } else {
    // Cannon + pirate immediately after
    obstacles.push({ type:'cannon', x:W+80,  y:GROUND-44, w:80, h:80, fireIn:55, fired:false });
    obstacles.push({ type:'pirate', x:W+260, y:GROUND,    w:52, h:88, af:0, at:0 });
  }
}

function spawnCoins() {
  const heights = [GROUND-30, GROUND-80, GROUND-140];
  const y = heights[Math.floor(Math.random()*3)];
  const n = 3 + Math.floor(Math.random()*4);
  for (let i = 0; i < n; i++)
    coinItems.push({ x: W + 50 + i*58, y, af:0, at:0, got:false });
}

function spawnPowerUp() {
  const type = Math.random() < 0.6 ? 'shield' : 'boost';
  pups.push({ type, x:W+50, y:GROUND-110, af:0, at:0, got:false });
}

// ═══════════════════════════════════════════════════
//  PHYSICS / COLLISION
// ═══════════════════════════════════════════════════
function overlaps(ax,ay,aw,ah, bx,by,bw,bh, shrink=12) {
  return ax+shrink < bx+bw-shrink &&
         ax+aw-shrink > bx+shrink &&
         ay+shrink < by+bh-shrink &&
         ay+ah-shrink > by+shrink;
}

function playerTop()  { return P.y - P.h; }
function playerLeft() { return P.x - P.w/2; }

function calcCannonBall(sx, sy, tx, ty) {
  const N = 75;
  const g = GRAVITY * 0.38;
  const vx = (tx - sx) / N;
  const vy = (ty - sy) / N - 0.5 * g * (N - 1);
  return { vx, vy, grav: g };
}

// ═══════════════════════════════════════════════════
//  PARTICLES
// ═══════════════════════════════════════════════════
function burst(x, y, color, n=10) {
  for (let i=0; i<n; i++) {
    const a = Math.random() * Math.PI * 2;
    const sp = Math.random() * 5 + 1.5;
    particles.push({ x, y, vx:Math.cos(a)*sp, vy:Math.sin(a)*sp - 2, life:1, r:Math.random()*5+2, color });
  }
}

// ═══════════════════════════════════════════════════
//  UPDATE
// ═══════════════════════════════════════════════════
function update() {
  if (state !== ST.PLAY) { gframe++; return; }
  gframe++; dist += speed;
  speed += 0.0016;
  score = Math.floor(dist/80) + coins*7;

  // — Player physics —
  P.vy += GRAVITY;
  P.y  += P.vy;
  if (P.y >= GROUND) { P.y = GROUND; P.vy = 0; P.jumps = 0; }

  // — Run animation —
  if (P.y === GROUND) {
    P.atimer += speed * 0.55;
    if (P.atimer >= 1) { P.atimer = 0; P.anim = (P.anim + 1) % 9; }
  }

  // — Shield tick —
  if (P.shielded > 0) P.shielded--;

  // — Clouds —
  for (const cl of clouds) {
    cl.x -= cl.sp * speed * 0.6;
    if (cl.x + cl.w < -20) cl.x = W + cl.w + Math.random()*200;
  }

  // — Spawn —
  if (--spawnT <= 0) { spawnObstacle(); spawnT = Math.max(55, 160 - Math.floor(dist/1800)); }
  if (--coinT  <= 0) { spawnCoins();    coinT  = Math.max(70, 140 - Math.floor(dist/2500)); }
  if (--pupT   <= 0) { spawnPowerUp();  pupT   = 500 + Math.random()*400 | 0; }

  // — Obstacles —
  for (const ob of obstacles) {
    ob.x -= speed;

    if (ob.type === 'cannon') {
      ob.fireIn--;
      if (ob.fireIn === 0 && !ob.fired) {
        ob.fired = true;
        // Warning sign above cannon
        warns.push({ x:ob.x, y:ob.y - 50, life:40 });
        // Cannonball aimed at where player will be in ~40 frames
        const tx = P.x + 20;
        const ty = P.y - 30;
        const { vx, vy, grav } = calcCannonBall(ob.x - 10, ob.y - 30, tx, ty);
        obstacles.push({ type:'cball', x:ob.x-10, y:ob.y-30, w:32, h:32, vx, vy, grav, af:0, at:0 });
      }
    }

    if (ob.type === 'cball') {
      ob.vy += ob.grav;
      ob.x  += ob.vx;
      ob.y  += ob.vy;
      ob.at++;
      if (ob.at % 4 === 0) ob.af = (ob.af + 1) % 3;
      if (ob.y > H + 50) ob.x = -999;
    }

    if (ob.type === 'pirate') {
      ob.at++;
      if (ob.at % 10 === 0) ob.af = (ob.af + 1) % 2;
    }
  }

  // — Coins —
  for (const c of coinItems) {
    c.x -= speed;
    c.at++;
    if (c.at % 5 === 0) c.af = (c.af + 1) % 7;
    if (!c.got && overlaps(playerLeft(), playerTop(), P.w, P.h, c.x-16, c.y-16, 32, 32, 6)) {
      c.got = true; coins++;
      burst(c.x, c.y, '#FFD700', 8);
    }
  }

  // — Power-ups —
  for (const pu of pups) {
    pu.x -= speed;
    pu.at++;
    if (pu.at % 6 === 0) pu.af = (pu.af + 1) % 3;
    if (!pu.got && overlaps(playerLeft(), playerTop(), P.w, P.h, pu.x-22, pu.y-22, 44, 44, 4)) {
      pu.got = true;
      if (pu.type === 'shield') { P.shielded = 300; burst(P.x, P.y-P.h/2, '#88ddff', 16); }
      if (pu.type === 'boost')  { speed += 1.5; burst(P.x, P.y-P.h/2, '#ffaa44', 12); }
    }
  }

  // — Collision player vs obstacles —
  for (const ob of obstacles) {
    if (ob.x < -200) continue;
    let bx, by, bw, bh;
    if (ob.type === 'cball')  { bx=ob.x-ob.w/2; by=ob.y-ob.h/2; bw=ob.w; bh=ob.h; }
    else if (ob.type === 'pirate') { bx=ob.x-ob.w/2; by=ob.y-ob.h;   bw=ob.w; bh=ob.h; }
    else continue;
    if (overlaps(playerLeft(), playerTop(), P.w, P.h, bx, by, bw, bh)) {
      if (P.shielded > 0) {
        P.shielded = 0;
        burst(ob.x, ob.y, '#aaccff', 14);
        ob.x = -999;
      } else {
        die(); return;
      }
    }
  }

  // — Warns —
  for (const w of warns) { w.x -= speed; w.life--; }

  // — Particles —
  for (const p of particles) { p.x+=p.vx; p.y+=p.vy; p.vy+=0.18; p.life-=0.03; }

  // — Cleanup —
  obstacles = obstacles.filter(o => o.x > -300);
  coinItems = coinItems.filter(c => c.x > -60);
  pups      = pups.filter(p => p.x > -80);
  particles = particles.filter(p => p.life > 0);
  warns     = warns.filter(w => w.life > 0 && w.x > -100);
}

function die() {
  state = ST.DEAD; gframe = 0;
  if (score > hiScore) { hiScore = score; localStorage.setItem('mk_hi', hiScore); }
  burst(P.x, P.y - P.h/2, '#ff4444', 20);
}

// ═══════════════════════════════════════════════════
//  DRAW HELPERS
// ═══════════════════════════════════════════════════
function img(k)  { const i=IMG[k]; return (i && i.naturalWidth) ? i : null; }
function di(k, x, y, w, h) { const i=img(k); if(i) ctx.drawImage(i, x, y, w, h); }

function tileX(k, y, h, spd) {
  const i = img(k); if (!i) return;
  const ratio = h / i.naturalHeight;
  const tw    = i.naturalWidth * ratio || h;
  const off   = -(gframe * spd * speed * 0.9) % tw;
  for (let x = off - tw; x < W + tw; x += tw) ctx.drawImage(i, x, y, tw, h);
}

// ═══════════════════════════════════════════════════
//  DRAW SCENE
// ═══════════════════════════════════════════════════
function drawSky() {
  const g = ctx.createLinearGradient(0,0,0,GROUND);
  g.addColorStop(0,'#0d2a6e');
  g.addColorStop(0.5,'#1a5db5');
  g.addColorStop(1,'#5fb8d8');
  ctx.fillStyle = g;
  ctx.fillRect(0,0,W,GROUND);

  const bi = img('bg');
  if (bi) {
    ctx.globalAlpha = 0.7;
    ctx.drawImage(bi, 0, 0, W, GROUND);
    ctx.globalAlpha = 1;
  }
}

function drawClouds() {
  for (const cl of clouds) {
    const i = img(cl.k); if (!i) continue;
    ctx.globalAlpha = 0.88;
    ctx.drawImage(i, cl.x, cl.y, cl.w, cl.h);
    ctx.globalAlpha = 1;
  }
}

function drawMountains() {
  const keys = ['mtn2','mtn1'];
  const spds = [0.35, 0.55];
  const heights = [160, 190];
  const offs  = [0, 480];

  for (let m=0; m<2; m++) {
    const i = img(keys[m]); if (!i) continue;
    const h = heights[m];
    const ratio = h / i.naturalHeight;
    const w = i.naturalWidth * ratio;
    const scroll = (gframe * spds[m] * speed * 0.8) % (w + 10);
    const sx = offs[m] - scroll;
    ctx.globalAlpha = 0.85;
    for (let x = sx - w; x < W + w; x += w + 10)
      ctx.drawImage(i, x, GROUND - h, w, h);
    ctx.globalAlpha = 1;
  }
}

function drawOcean() {
  const og = ctx.createLinearGradient(0, GROUND, 0, H);
  og.addColorStop(0,'#1870c5');
  og.addColorStop(1,'#09285e');
  ctx.fillStyle = og;
  ctx.fillRect(0, GROUND, W, H - GROUND);
  // wave foam strip
  tileX('wave', GROUND - 18, 55, 1.1);
  // wood deck
  tileX('wood', GROUND + 2, 38, 1.0);
  // deck edge
  ctx.fillStyle = '#b8893a';
  ctx.fillRect(0, GROUND, W, 5);
}

function drawObstacles() {
  for (const ob of obstacles) {
    if (ob.x < -200) continue;

    if (ob.type === 'cannon') {
      di('cannon', ob.x - 40, ob.y - 40, 80, 80);
    }

    if (ob.type === 'cball') {
      const cbImg = img('cb' + ob.af);
      if (cbImg) {
        ctx.save();
        ctx.translate(ob.x, ob.y);
        ctx.rotate(gframe * 0.25);
        ctx.drawImage(cbImg, -16, -16, 32, 32);
        ctx.restore();
      } else {
        ctx.fillStyle = '#444';
        ctx.beginPath(); ctx.arc(ob.x, ob.y, 14, 0, Math.PI*2); ctx.fill();
      }
    }

    if (ob.type === 'pirate') {
      const pi = ob.af === 0 ? img('pirate') : img('pirateAir');
      if (pi) ctx.drawImage(pi, ob.x - 26, ob.y - 88, 52, 88);
      else { ctx.fillStyle='#c0392b'; ctx.fillRect(ob.x-22, ob.y-82, 44, 82); }
    }
  }
}

function drawWarnings() {
  for (const w of warns) {
    const wf = Math.floor(gframe/4) % 3;
    const wi = img('warn' + wf);
    if (!wi) continue;
    const a = Math.min(1, w.life / 15);
    ctx.globalAlpha = a;
    ctx.drawImage(wi, w.x - 20, w.y - 24, 40, 40);
    ctx.globalAlpha = 1;
  }
}

function drawCoins() {
  for (const c of coinItems) {
    if (c.got) continue;
    const ci = img('c' + c.af);
    if (ci) ctx.drawImage(ci, c.x-18, c.y-18, 36, 36);
    else { ctx.fillStyle='#FFD700'; ctx.beginPath(); ctx.arc(c.x,c.y,14,0,Math.PI*2); ctx.fill(); }
  }
}

function drawPowerUps() {
  for (const pu of pups) {
    if (pu.got) continue;
    // Glow
    ctx.save();
    ctx.shadowColor = pu.type === 'shield' ? '#88ddff' : '#ffbb44';
    ctx.shadowBlur = 18 + Math.sin(gframe*0.12)*6;
    if (pu.type === 'shield') {
      const si = img('shield' + (pu.af % 4));
      if (si) ctx.drawImage(si, pu.x-22, pu.y-22, 44, 44);
    } else {
      const bi2 = img('boost' + pu.af);
      if (bi2) ctx.drawImage(bi2, pu.x-22, pu.y-22, 44, 44);
    }
    ctx.restore();
  }
}

function drawPlayer() {
  let pk;
  if (state === ST.DEAD)            pk = 'dead';
  else if (P.y < GROUND - 2)       pk = 'jump';
  else                              pk = 'r' + Math.floor(P.anim);

  const pi2 = img(pk);
  const pw = 82, ph = P.h;

  // Shield aura
  if (P.shielded > 0) {
    const saf = Math.floor(gframe/5) % 4;
    const sai = img('shield' + saf);
    if (sai) {
      ctx.globalAlpha = 0.7;
      ctx.drawImage(sai, P.x - 44, P.y - ph - 10, 88, ph + 20);
      ctx.globalAlpha = 1;
    }
    ctx.save();
    ctx.strokeStyle = `hsla(${(gframe*4)%360},80%,70%,0.6)`;
    ctx.lineWidth = 3;
    ctx.beginPath(); ctx.arc(P.x+6, P.y - ph*0.45, 56, 0, Math.PI*2); ctx.stroke();
    ctx.restore();
  }

  if (pi2) ctx.drawImage(pi2, P.x - pw/2 + 8, P.y - ph, pw, ph);
  else {
    ctx.fillStyle = state === ST.DEAD ? '#e74c3c' : '#3498db';
    ctx.fillRect(P.x - 20, P.y - ph, 40, ph);
  }
}

function drawParticles() {
  for (const p of particles) {
    ctx.globalAlpha = Math.max(0, p.life);
    ctx.fillStyle = p.color;
    ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI*2); ctx.fill();
  }
  ctx.globalAlpha = 1;
}

function drawHUD() {
  // Score pill
  ctx.fillStyle = 'rgba(0,0,0,0.5)';
  roundRect(10, 10, 180, 38, 8); ctx.fill();
  ctx.fillStyle = '#fff';
  ctx.font = 'bold 20px system-ui,sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText('SCORE  ' + score.toLocaleString(), 20, 34);

  // Coins
  const ci = img('c0');
  if (ci) ctx.drawImage(ci, W-115, 12, 28, 28);
  ctx.fillStyle = '#FFD700';
  ctx.font = 'bold 20px system-ui,sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText('×' + coins, W-83, 32);

  // Best
  ctx.fillStyle = 'rgba(0,0,0,0.4)';
  roundRect(W/2-90, 10, 180, 28, 6); ctx.fill();
  ctx.fillStyle = '#aaddff';
  ctx.font = '13px system-ui,sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('MEJOR  ' + hiScore.toLocaleString(), W/2, 28);

  // Shield timer bar
  if (P.shielded > 0) {
    const pct = P.shielded / 300;
    ctx.fillStyle = 'rgba(0,0,0,0.45)';
    ctx.fillRect(10, 56, 160, 10);
    ctx.fillStyle = '#44aaff';
    ctx.fillRect(10, 56, 160 * pct, 10);
    ctx.fillStyle = '#aaddff';
    ctx.font = '11px system-ui,sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText('ESCUDO', 14, 66);
  }
}

function roundRect(x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x+r, y);
  ctx.lineTo(x+w-r, y);
  ctx.arcTo(x+w, y, x+w, y+r, r);
  ctx.lineTo(x+w, y+h-r);
  ctx.arcTo(x+w, y+h, x+w-r, y+h, r);
  ctx.lineTo(x+r, y+h);
  ctx.arcTo(x, y+h, x, y+h-r, r);
  ctx.lineTo(x, y+r);
  ctx.arcTo(x, y, x+r, y, r);
  ctx.closePath();
}

// ═══════════════════════════════════════════════════
//  TITLE / DEAD SCREENS
// ═══════════════════════════════════════════════════
function drawTitle() {
  // BG
  const tbi = img('titleBg');
  if (tbi) { ctx.globalAlpha=0.8; ctx.drawImage(tbi,0,0,W,H); ctx.globalAlpha=1; }
  else { const g=ctx.createLinearGradient(0,0,0,H); g.addColorStop(0,'#0a1a40'); g.addColorStop(1,'#1a4a8a'); ctx.fillStyle=g; ctx.fillRect(0,0,W,H); }

  // Logo
  const li = img('logo');
  if (li) {
    const lw = Math.min(480, W*0.5);
    const lh = lw * li.naturalHeight / li.naturalWidth;
    ctx.drawImage(li, (W-lw)/2, H*0.12, lw, lh);
  } else {
    ctx.fillStyle='#fff'; ctx.font='bold 44px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.shadowColor='#000'; ctx.shadowBlur=12;
    ctx.fillText('MIKELTUBE ADVENTURES', W/2, H*0.28);
    ctx.shadowBlur=0;
  }

  // Blink prompt
  if (Math.sin(gframe * 0.07) > 0) {
    ctx.fillStyle='#fff'; ctx.font='bold 22px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.shadowColor='#000'; ctx.shadowBlur=10;
    ctx.fillText('TOCA O PULSA ESPACIO PARA JUGAR', W/2, H*0.72);
    ctx.shadowBlur=0;
  }

  // Controls hint
  ctx.fillStyle='rgba(255,255,255,0.55)';
  ctx.font='15px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText('ESPACIO / TAP → Saltar  ·  Doble salto disponible', W/2, H*0.82);

  if (hiScore > 0) {
    ctx.fillStyle='#FFD700'; ctx.font='18px system-ui,sans-serif';
    ctx.fillText('🏆 Mejor puntuación: ' + hiScore.toLocaleString(), W/2, H*0.90);
  }
}

function drawDead() {
  ctx.fillStyle='rgba(0,0,0,0.68)'; ctx.fillRect(0,0,W,H);
  ctx.textAlign='center';

  ctx.fillStyle='#ff3333'; ctx.font='bold 56px system-ui,sans-serif';
  ctx.shadowColor='#000'; ctx.shadowBlur=24;
  ctx.fillText('GAME OVER', W/2, H/2 - 70);
  ctx.shadowBlur=0;

  ctx.fillStyle='#fff'; ctx.font='bold 28px system-ui,sans-serif';
  ctx.fillText('Puntuación: ' + score.toLocaleString(), W/2, H/2 - 10);

  if (coins > 0) {
    ctx.fillStyle='#FFD700'; ctx.font='20px system-ui,sans-serif';
    ctx.fillText('Monedas: ' + coins, W/2, H/2 + 30);
  }

  if (score >= hiScore && score > 0) {
    ctx.fillStyle='#FFD700'; ctx.font='bold 22px system-ui,sans-serif';
    ctx.fillText('🏆 ¡NUEVO RÉCORD!', W/2, H/2 + 65);
  }

  if (gframe > 40 && Math.sin(gframe*0.08) > 0) {
    ctx.fillStyle='#fff'; ctx.font='20px system-ui,sans-serif';
    ctx.fillText('TOCA PARA REINICIAR', W/2, H/2 + 115);
  }
}

// ═══════════════════════════════════════════════════
//  MAIN LOOP
// ═══════════════════════════════════════════════════
function draw() {
  ctx.clearRect(0,0,W,H);

  if (state === ST.TITLE) {
    drawSky(); drawClouds(); drawMountains(); drawOcean();
    drawTitle();
    return;
  }

  drawSky();
  drawClouds();
  drawMountains();
  drawOcean();
  drawWarnings();
  drawPowerUps();
  drawObstacles();
  drawCoins();
  drawParticles();
  drawPlayer();
  drawHUD();

  if (state === ST.DEAD) drawDead();
}

function loop() {
  update();
  draw();
  requestAnimationFrame(loop);
}

// ═══════════════════════════════════════════════════
//  LOADING SCREEN → BOOT
// ═══════════════════════════════════════════════════
function drawLoading() {
  ctx.fillStyle='#0a1020'; ctx.fillRect(0,0,W,H);
  ctx.fillStyle='#fff'; ctx.font='bold 22px system-ui,sans-serif';
  ctx.textAlign='center';
  ctx.fillText('Cargando Mikeltube Adventures…', W/2, H/2 - 30);
  const pct = loaded / TOTAL;
  ctx.fillStyle='#1a2a50'; roundRect(W/2-160, H/2, 320, 18, 9); ctx.fill();
  ctx.fillStyle='#FFD700'; roundRect(W/2-160, H/2, 320*pct, 18, 9); ctx.fill();
  ctx.fillStyle='#aaa'; ctx.font='13px sans-serif';
  ctx.fillText(Math.round(pct*100) + '%', W/2, H/2 + 36);
  if (loaded < TOTAL) requestAnimationFrame(drawLoading);
}

// Init title state clouds
clouds = [
  {k:'cloud1', x:80,  y:55, w:220, h:90, sp:0.18},
  {k:'cloud2', x:350, y:80, w:180, h:75, sp:0.22},
  {k:'cloud3', x:620, y:45, w:200, h:80, sp:0.15},
  {k:'cloud4', x:850, y:70, w:160, h:65, sp:0.20},
];
obstacles=[]; coinItems=[]; pups=[]; particles=[]; warns=[];
state = ST.TITLE; gframe = 0; score=0; coins=0; dist=0; speed=4.2;

drawLoading();
preload().then(() => {
  loop();
});
</script>
</body>
