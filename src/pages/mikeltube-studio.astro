<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
  <meta name="robots" content="noindex, nofollow"/>
  <title>Mikeltube Adventures</title>
  <style is:inline>
    * { margin:0; padding:0; box-sizing:border-box; }
    html, body { width:100%; height:100%; background:#060d1a; overflow:hidden; touch-action:none; font-family:system-ui, sans-serif; }
    body { display:flex; align-items:center; justify-content:center; }
    canvas { display:block; cursor:pointer; image-rendering:pixelated; image-rendering:crisp-edges; }
  </style>
