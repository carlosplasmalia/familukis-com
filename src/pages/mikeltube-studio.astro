function spawnObstacle() {
  const re = W+120;
  const r = Math.random();
  const hard = hardness();

  if (world===0) {
    // LABORATORIO: robot de seguridad, bomba eléctrica, moto de seguridad
    if (r < 0.38) {
      obstacles.push({ type:'minibot', x:re, y:GROUND, w:76, h:70, af:0, at:0, attacking:0, fired:false });
      if (hard>0.5 && Math.random()<0.35)
        obstacles.push({ type:'bomb', x:re+230, y:GROUND-112, w:62, h:62, af:0, at:0 });
    } else if (r < 0.66) {
      obstacles.push({ type:'bomb', x:re, y:GROUND-112, w:62, h:62, af:0, at:0 });
      if (Math.random()<0.4)
        obstacles.push({ type:'bomb', x:re+120, y:GROUND-52, w:62, h:62, af:0, at:0 });
    } else {
      obstacles.push({ type:'soldier', x:W+140, y:GROUND, w:96, h:76, af:0, at:0, phase:'warn', pt:0 });
      AudioMan.sfx('soldado-aviso');
    }
  }
  else if (world===1) {
    // ISLA PIRATA: Espárrago, pirata paracaidista, mina, bala rasante
    if (r < 0.30) {
      obstacles.push({ type:'espar', x:re, y:GROUND, w:70, h:88, at:0 });
      if (hard>0.5 && Math.random()<0.35) obstacles.push({ type:'mina', x:re+190, y:GROUND, w:64, h:64, at:0 });
    } else if (r < 0.52) {
      const px = W+80+Math.random()*280;
      obstacles.push({ type:'parachute', x:px, y:-150, w:90, h:130, vy:1.5, af:0, at:0, landed:false, landTimer:0 });
    } else if (r < 0.78) {
      obstacles.push({ type:'mina', x:re, y:GROUND, w:64, h:64, at:0 });
      if (hard>0.4 && Math.random()<0.4) obstacles.push({ type:'mina', x:re+130, y:GROUND, w:64, h:64, at:0 });
    } else {
      // bala rasante a la altura de la cabeza: ¡agáchate!
      fx('warning', W-60, GROUND-125, {life:50});
      obstacles.push({ type:'lowball', x:W+340, y:GROUND-118, w:34, h:34, vx:-(speed+6), af:0, at:0 });
      AudioMan.sfx('cannon',{vol:0.5,rate:1.2});
    }
  }
  else {
    // MARTE: bruja aprendiza, misil, guerrero lobo de Gunilda, columnas de magia
    if (r < 0.30) {
      const wy = 170+Math.random()*110;
      obstacles.push({ type:'witch', x:re+80, y:wy, w:82, h:100, af:0, at:0, phase:'enter', pt:0, alpha:1,
                       lowShot: Math.random()<0.4 });
      AudioMan.sfx('bruja-aparece');
    } else if (r < 0.54) {
      obstacles.push({ type:'missile', x:re+60, y:-160, w:52, h:80, vy:0, warn:55, at:0 });
      if (hard>0.5 && Math.random()<0.4)
        obstacles.push({ type:'missile', x:re+240, y:-160, w:52, h:80, vy:0, warn:80, at:0 });
    } else if (r < 0.74) {
      obstacles.push({ type:'dog', x:re, y:GROUND, w:82, h:74, af:0, at:0, attacking:0, fired:false });
    } else if (r < 0.88) {
      obstacles.push({ type:'bomb', x:re, y:GROUND-112, w:62, h:62, af:0, at:0 });
    } else {
      // columna de magia que cae del cielo con aviso
      obstacles.push({ type:'raycol', x:re, y:0, w:46, at:0, warn:55 });
    }
  }
}
