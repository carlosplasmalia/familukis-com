  ctx.textAlign='left';
  drawMuteBtn();
}

function drawCharSelect() {
  const g=ctx.createLinearGradient(0,0,0,H);
  g.addColorStop(0,'#040c20'); g.addColorStop(1,'#0a2050');
  ctx.fillStyle=g; ctx.fillRect(0,0,W,H);

  ctx.fillStyle='#fff'; ctx.font='bold 34px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.shadowColor='#0055ff'; ctx.shadowBlur=22;
  ctx.fillText('ELIGE TU PERSONAJE', W/2, 62);
  ctx.shadowBlur=0;

  const cw=200, ch=255, my=H/2-ch/2+6;
  const cards=[{x:W/2-190,pose:'mikelPose',name:'nameMikel',label:'MIKEL'},
               {x:W/2+30, pose:'leoPose', name:'nameLeo', label:'LEO'}];
  cards.forEach((c,i)=>{
    const sel=selChar===i;
    ctx.fillStyle=sel?'rgba(255,220,0,0.18)':'rgba(255,255,255,0.06)';
    roundRect(c.x-12,my-12,cw+24,ch+84,14); ctx.fill();
    if (sel) {
      ctx.strokeStyle='#FFD700'; ctx.lineWidth=3;
      roundRect(c.x-12,my-12,cw+24,ch+84,14); ctx.stroke(); ctx.lineWidth=1;
    }
    di(c.pose,c.x,my,cw,ch);
    const ni=gi(c.name);
    if (ni) {
      const nw=150, nh=nw*ni.naturalHeight/ni.naturalWidth;
      ctx.drawImage(ni, c.x+cw/2-nw/2, my+ch+14, nw, nh);
    } else {
      ctx.fillStyle=sel?'#FFD700':'#ccc'; ctx.font='bold 23px system-ui,sans-serif'; ctx.textAlign='center';
      ctx.fillText(c.label, c.x+cw/2, my+ch+44);
    }
    if (sel) {
      ctx.fillStyle='#fff'; ctx.font='14px system-ui,sans-serif'; ctx.textAlign='center';
      ctx.fillText('¡SELECCIONADO!', c.x+cw/2, my+ch+72);
    }
  });

  ctx.globalAlpha=0.7+Math.sin(gframe*0.08)*0.3;
  ctx.fillStyle='#fff'; ctx.font='bold 17px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText('Toca un personaje  ·  Toca de nuevo para jugar', W/2, H-22);
  ctx.globalAlpha=1;
  ctx.textAlign='left';
  drawMuteBtn();
}

// Cinemática de 3 viñetas: el robo de la brújula
const STORY=[
  { who:'gunilda', txt1:'¡Ja, ja, ja! ¡La Brújula del Destino es MÍA!',
    txt2:'La bruja Gunilda ha asaltado el laboratorio...' },
  { who:'brujula', txt1:'Sin la brújula, ¡las aventuras se perderán para siempre!',
    txt2:'Gunilda huye hacia su reino... ¡en MARTE!' },
  { who:'hero',    txt1:'¡Tranquilos! ¡Yo la recuperaré!',
    txt2:'Cruza el laboratorio, la isla pirata y Marte. ¡Corre!' },
];
function drawStory() {
  const g=ctx.createLinearGradient(0,0,0,H);
  g.addColorStop(0,'#050512'); g.addColorStop(1,'#141033');
  ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
  ctx.fillStyle='#fff';
  for (const s of stars) { ctx.globalAlpha=0.5; ctx.beginPath(); ctx.arc(s.x,s.y,s.r*0.8,0,Math.PI*2); ctx.fill(); }
  ctx.globalAlpha=1;

  const sc=STORY[Math.min(storyIdx,2)];
  const t=storyF;
  const fade=Math.min(1,t/20);
  ctx.globalAlpha=fade;

  const cy=H*0.42;
  if (sc.who==='gunilda') {
    const bi=gi('brunilda');
    if (bi) {
      const gh=230, gw=gh*bi.naturalWidth/bi.naturalHeight;
      const fl=Math.sin(t*0.05)*10;
      ctx.drawImage(bi, W/2-gw/2, cy-gh/2+fl, gw, gh);
    }
    // la brújula robada brillando en su mano
    const bj=gi('bruj'+(Math.floor(t/6)%4));
    if (bj) {
      ctx.save(); ctx.shadowColor='#FFD700'; ctx.shadowBlur=24;
      ctx.drawImage(bj, W/2+80, cy-40+Math.sin(t*0.05)*10, 62, 68);
      ctx.restore();
    }
  } else if (sc.who==='brujula') {
    const bj=gi('bruj'+(Math.floor(t/6)%4));
    if (bj) {
      ctx.save(); ctx.shadowColor='#FFD700'; ctx.shadowBlur=34;
      const bw2=120+Math.sin(t*0.06)*8;
      ctx.drawImage(bj, W/2-bw2/2, cy-bw2/2, bw2, bw2*1.1);
      ctx.restore();
    }
    const sk=gi('marsSky');
    if (sk) {
      ctx.save();
      roundRect(W/2+120, cy-70, 210, 140, 14); ctx.clip();
      ctx.drawImage(sk, W/2+120, cy-70, 210, 140);
      const mt=gi('mars1');
      if (mt) { const mh=90; ctx.drawImage(mt, W/2+110, cy+70-mh, 240, mh); }
      ctx.restore();
      ctx.strokeStyle='#ff8855'; ctx.lineWidth=3;
      roundRect(W/2+120, cy-70, 210, 140, 14); ctx.stroke();
      ctx.fillStyle='#ffb08a'; ctx.font='bold 15px "Baloo 2",sans-serif'; ctx.textAlign='center';
      ctx.fillText('MARTE', W/2+225, cy+92);
      ctx.textAlign='left';
    }
  } else {
    const pi=gi(selChar===1?'leoPose':'mikelPose');
    if (pi) {
      const phh=250, pw2=phh*pi.naturalWidth/pi.naturalHeight;
      ctx.drawImage(pi, W/2-pw2/2, cy-phh/2+10, pw2, phh);
    }
    const sf=gi('shine'+(Math.floor(t/5)%6));
    if (sf) { ctx.globalAlpha=fade*0.8; ctx.drawImage(sf, W/2-160, cy-120, 60, 60); ctx.drawImage(sf, W/2+100, cy-60, 46, 46); ctx.globalAlpha=fade; }
  }

  // bocadillo
  ctx.fillStyle='rgba(255,255,255,0.95)';
  roundRect(W/2-330,H*0.72,660,52,14); ctx.fill();
  ctx.fillStyle='#1a1a2e'; ctx.font='bold 21px "Baloo 2",sans-serif'; ctx.textAlign='center';
  ctx.fillText(sc.txt1, W/2, H*0.72+33);
  ctx.fillStyle='#aaddff'; ctx.font='16px system-ui,sans-serif';
  ctx.fillText(sc.txt2, W/2, H*0.72+80);

  ctx.globalAlpha=0.6+Math.sin(t*0.1)*0.3;
  ctx.fillStyle='#fff'; ctx.font='14px system-ui,sans-serif';
  ctx.fillText('— toca para continuar ('+(storyIdx+1)+'/3) —', W/2, H-18);
  ctx.globalAlpha=1;
  ctx.textAlign='left';
  drawMuteBtn();
}

function drawVictory() {
  const g=ctx.createLinearGradient(0,0,0,H);
  g.addColorStop(0,'#1a0a30'); g.addColorStop(1,'#3a1055');
  ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
  ctx.fillStyle='#fff';
  for (const s of stars) { ctx.globalAlpha=0.6; ctx.beginPath(); ctx.arc(s.x,s.y,s.r,0,Math.PI*2); ctx.fill(); }
  ctx.globalAlpha=1;
  drawParticles();

  const sc2=Math.min(1, victF/30);
  ctx.save();
  ctx.translate(W/2, H*0.16); ctx.scale(sc2,sc2);
  ctx.fillStyle='#FFD700'; ctx.font='bold 56px "Baloo 2",sans-serif'; ctx.textAlign='center';
  ctx.shadowColor='#ff8800'; ctx.shadowBlur=26;
  ctx.fillText('¡BRÚJULA RECUPERADA!', 0, 0);
  ctx.restore(); ctx.shadowBlur=0;

  // héroe con la brújula
  const pi=gi(selChar===1?'leoPose':'mikelPose');
  if (pi) {
    const phh=200, pw2=phh*pi.naturalWidth/pi.naturalHeight;
    ctx.drawImage(pi, W/2-pw2/2-60, H*0.24, pw2, phh);
  }
  const bj=gi('bruj'+(Math.floor(victF/6)%4));
  if (bj) {
    ctx.save(); ctx.shadowColor='#FFD700'; ctx.shadowBlur=30;
    ctx.drawImage(bj, W/2+40, H*0.30+Math.sin(victF*0.06)*8, 84, 92);
    ctx.restore();
  }

  ctx.textAlign='center';
  ctx.fillStyle='#fff'; ctx.font='bold 28px system-ui,sans-serif';
  ctx.fillText('Puntuación: '+score.toLocaleString(), W/2, H*0.62);
  ctx.fillStyle='#FFD700'; ctx.font='20px system-ui,sans-serif';
  ctx.fillText('Monedas: ×'+coins+'   ·   Jefes: '+bossesKilled+(lap>0?'   ·   Vueltas: '+(lap+1):''), W/2, H*0.62+32);
  if (score>=hiScore && score>0) {
    ctx.fillStyle='#7CFC00'; ctx.font='bold 22px system-ui,sans-serif';
    ctx.fillText('🏆 ¡NUEVO RÉCORD!', W/2, H*0.62+62);
  }

  if (victF>60) {
    const by=H-90;
    ctx.fillStyle='rgba(255,70,50,0.9)';
    roundRect(W/2-260,by-30,240,60,14); ctx.fill();
    ctx.fillStyle='#fff'; ctx.font='bold 19px "Baloo 2",sans-serif';
    ctx.fillText('🔥 VUELTA '+(lap+2)+' (+difícil)', W/2-140, by+7);
    ctx.fillStyle='rgba(60,120,255,0.9)';
    roundRect(W/2+20,by-30,240,60,14); ctx.fill();
    ctx.fillStyle='#fff';
    ctx.fillText('🏠 MENÚ', W/2+140, by+7);
  }
  ctx.textAlign='left';
  drawMuteBtn();
}

function drawDead() {
  drawScene();
  drawEffects(); drawParticles(); drawPlayer();

  ctx.fillStyle=`rgba(0,0,0,${Math.min(0.72,deadF/60*0.72)})`;
  ctx.fillRect(0,0,W,H);
  if (deadF<18) return;

  ctx.textAlign='center';
  const goy=H/2-95+Math.max(0,(50-deadF)*3);
  ctx.fillStyle='#ff2222'; ctx.font='bold 64px system-ui,sans-serif';
  ctx.shadowColor='#000'; ctx.shadowBlur=30;
  ctx.fillText('GAME OVER', W/2, goy); ctx.shadowBlur=0;

  ctx.fillStyle='#fff'; ctx.font='bold 30px system-ui,sans-serif';
  ctx.fillText('Puntuación: '+score.toLocaleString(), W/2, H/2-18);
  ctx.fillStyle='#FFD700'; ctx.font='22px system-ui,sans-serif';
  ctx.fillText('Mundo '+(world+1)+' · '+WORLDS[world].nombre+'   ·   Monedas ×'+coins, W/2, H/2+22);

  if (score>=hiScore && score>0) {
    const p2=1+Math.sin(deadF*0.14)*0.08;
    ctx.save(); ctx.translate(W/2,H/2+62); ctx.scale(p2,p2);
    ctx.fillStyle='#FFD700'; ctx.font='bold 26px system-ui,sans-serif';
    ctx.shadowColor='#ff8800'; ctx.shadowBlur=18;
    ctx.fillText('🏆  ¡NUEVO RÉCORD!',0,0); ctx.shadowBlur=0; ctx.restore();
  }

  if (deadF>50) {
    if (!revived && bank>=REVIVE_COST) {
      const ry=H/2+104;
      const pulse=0.85+Math.sin(deadF*0.12)*0.15;
      ctx.fillStyle=`rgba(220,40,40,${pulse})`;
      roundRect(W/2-135,ry-22,270,44,12); ctx.fill();
      ctx.strokeStyle='#fff'; ctx.lineWidth=2;
      roundRect(W/2-135,ry-22,270,44,12); ctx.stroke(); ctx.lineWidth=1;
      ctx.fillStyle='#fff'; ctx.font='bold 20px system-ui,sans-serif'; ctx.textAlign='center';
      ctx.fillText('❤ REVIVIR  —  '+REVIVE_COST+' 🪙', W/2, ry+7);
    }
    const by=H/2+150;
    const br=gi('btnReplay'), bh2=gi('btnHome');
    if (br) ctx.drawImage(br, W/2-114, by-30, 68, 62);
    else { ctx.fillStyle='#44cc44'; roundRect(W/2-120,by-30,80,60,10); ctx.fill(); ctx.fillStyle='#fff'; ctx.font='bold 30px sans-serif'; ctx.fillText('↻',W/2-80,by+11); }
    if (bh2) ctx.drawImage(bh2, W/2+46, by-30, 68, 62);
    else { ctx.fillStyle='#4488ee'; roundRect(W/2+40,by-30,80,60,10); ctx.fill(); ctx.fillStyle='#fff'; ctx.font='bold 26px sans-serif'; ctx.fillText('⌂',W/2+80,by+10); }
    ctx.fillStyle='#aaddff'; ctx.font='13px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.fillText('reintentar mundo', W/2-80, by+48);
    ctx.fillText('menú', W/2+80, by+48);
  }

  if (deadF>30) {
    ctx.textAlign='left';
    ctx.fillStyle='rgba(0,0,25,0.62)';
    roundRect(16,74,306,124,10); ctx.fill();
    ctx.fillStyle='#FFD700'; ctx.font='bold 16px system-ui,sans-serif';
    ctx.fillText('MISIONES   ·   Banco: '+bank+' 🪙', 30, 98);
    missions.forEach((m,i)=>{
      const my2=118+i*26;
      const done=Math.min(1, m.p/m.goal);
      ctx.fillStyle='rgba(255,255,255,0.14)'; roundRect(30,my2,200,8,4); ctx.fill();
      ctx.fillStyle=done>=1?'#7CFC00':'#FFD700'; roundRect(30,my2,200*done,8,4); ctx.fill();
      ctx.fillStyle='#fff'; ctx.font='12px system-ui,sans-serif';
      ctx.fillText(misTxt(m), 30, my2+21);
      ctx.fillStyle='#aaddff'; ctx.textAlign='right';
      ctx.fillText(Math.floor(m.p)+'/'+m.goal, 306, my2+7);
      ctx.textAlign='left';
    });
  }
  drawMuteBtn();
}

function drawIntro() {
  drawScene();
  if (introShip) {
    // la nave desciende y suelta al héroe
    const shi=gi('ship');
    if (shi && introF<100) {
      const sw2=130, sh2=sw2*shi.naturalHeight/shi.naturalWidth;
      const sx=P.shipX||W*0.4, sy=P.shipY||-80;
      if (introF<55) {
        ctx.drawImage(shi, sx-sw2*0.5, sy-sh2*0.5, sw2, sh2);
      } else {
        drawShipEmpty(sx-sw2*0.5, sy-sh2*0.5, sw2);   // el héroe ya ha saltado
      }
    }
    if (introF>=55) { drawEffects(); drawParticles(); drawPlayer(); }
  } else {
    const ci=gi('capsule');
    if (ci) {
      ctx.save();
      ctx.translate(95, GROUND-30);
      ctx.rotate(0.62);
      ctx.drawImage(ci, -45, -110, 95, 120);
      ctx.restore();
    }
    if (introF<45) {
      const ri=gi('ready');
      if (ri) {
        const rw2=260, rh2=rw2*ri.naturalHeight/ri.naturalWidth;
        const sc=1+Math.sin(introF*0.2)*0.05;
        ctx.save(); ctx.translate(W/2,H*0.36); ctx.scale(sc,sc);
        ctx.drawImage(ri,-rw2/2,-rh2/2,rw2,rh2); ctx.restore();
      }
    } else {
      drawEffects(); drawParticles(); drawPlayer();
      if (introF>72) {
        const gg=gi('go');
        if (gg) {
          const gw2=230, gh2=gw2*gg.naturalHeight/gg.naturalWidth;
          ctx.drawImage(gg, W/2-gw2/2, H*0.36-gh2/2, gw2, gh2);
        }
      }
    }
  }
  drawWorldBanner();
  drawHUD();
}

function drawLoadingScreen() {
  ctx.fillStyle='#060d1a'; ctx.fillRect(0,0,W,H);
  const li=gi('logo');
  if (li) {
    const lw=350, lh=lw*li.naturalHeight/li.naturalWidth;
    ctx.globalAlpha=0.9; ctx.drawImage(li,(W-lw)/2,H*0.1,lw,lh); ctx.globalAlpha=1;
  } else {
    ctx.fillStyle='#fff'; ctx.font='bold 30px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.fillText('MIKELTUBE ADVENTURES', W/2, H*0.3);
  }
  ctx.fillStyle='#fff'; ctx.font='18px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText('Cargando…', W/2, H/2+18);
  const pct=TOTAL>0?loaded/TOTAL:0;
  ctx.fillStyle='#1a2a50'; roundRect(W/2-185,H/2+38,370,22,11); ctx.fill();
  if (pct>0) { ctx.fillStyle='#FFD700'; roundRect(W/2-185,H/2+38,370*pct,22,11); ctx.fill(); }
  ctx.fillStyle='#888'; ctx.font='13px sans-serif';
  ctx.fillText(Math.round(pct*100)+'%', W/2, H/2+86);
  ctx.textAlign='left';
}

// ═══════════════════════════════════════════════════════
//  MAIN LOOP
// ═══════════════════════════════════════════════════════
function draw() {
  let didShake=false;
  if (shakeF>0) {
    const mag=shakeF*0.55;
    ctx.save();
    ctx.translate((Math.random()*2-1)*mag,(Math.random()*2-1)*mag*0.7);
    didShake=true;
  }
  ctx.clearRect(-12,-12,W+24,H+24);

  switch(state) {
    case ST.LOADING: drawLoadingScreen(); break;
    case ST.TITLE:   drawTitle(); break;
    case ST.CHAR_SELECT: drawCharSelect(); break;
    case ST.STORY:   drawStory(); break;
    case ST.INTRO:   drawIntro(); break;
    case ST.PLAYING:
      drawScene();
      drawCameo();
      drawEffects(); drawCollectibles(); drawObstacles(); drawRobot();
      drawParticles(); drawPlayer(); drawFloatTexts();
      drawWorldBanner();
      drawHUD();
      break;
    case ST.BOSS:
      drawScene();
      drawEffects(); drawCollectibles(); drawObstacles();
      if (RB) drawBossRobot();
      else if (FB) drawBossFrog();
      else if (GB) drawBossGunilda();
      drawParticles();
      if (RB||GB) drawPlayer();
      drawFloatTexts(); drawHUD();
      break;
    case ST.BOARD:   drawBoarding(); break;
    case ST.FLY:     drawFly(); break;
    case ST.DUEL:    drawDuel(); break;
    case ST.VICTORY: drawVictory(); break;
    case ST.DEAD:    drawDead(); break;
  }
  if (didShake) ctx.restore();
}

function loop() {
  update();
  draw();
  gframe++;
  requestAnimationFrame(loop);
}

// ═══════════════════════════════════════════════════════
//  BOOT
// ═══════════════════════════════════════════════════════
initClouds();
initStars();
AudioMan.init();

function bootDraw() {
  drawLoadingScreen();
  if (loaded<TOTAL) requestAnimationFrame(bootDraw);
}
bootDraw();

preload().then(()=>{
  state=ST.TITLE;
  AudioMan.music('musica-menu');
  requestAnimationFrame(loop);
});
</script>
</body>
</html>
