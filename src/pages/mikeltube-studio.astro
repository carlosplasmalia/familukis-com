//  DRAW — HUD / PANTALLAS
// ═══════════════════════════════════════════════════════
function drawMuteBtn() {
  ctx.globalAlpha=0.75;
  ctx.fillStyle='rgba(0,0,10,0.5)';
  roundRect(W-44,6,38,30,7); ctx.fill();
  ctx.fillStyle='#fff'; ctx.font='16px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText(AudioMan.muted?'🔇':'🔊', W-25, 27);
  ctx.globalAlpha=1; ctx.textAlign='left';
}
function drawHUD() {
  ctx.textAlign='left';
  ctx.fillStyle='rgba(0,0,10,0.55)';
  roundRect(10,10,210,40,9); ctx.fill();
  ctx.fillStyle='#fff'; ctx.font='bold 21px system-ui,sans-serif';
  ctx.fillText('SCORE  '+score.toLocaleString(), 20, 38);

  // Barra de gemas (energybar del original: 3 gemas = turbo)
  const eb=gi('ebar'+Math.min(3,gems));
  if (eb) ctx.drawImage(eb, 10, 56, 150, 24);
  else {
    ctx.fillStyle='rgba(0,0,10,0.5)'; roundRect(10,58,150,14,7); ctx.fill();
    ctx.fillStyle='#44ff88'; roundRect(12,60,146*(gems/GEMS_FOR_TURBO),10,5); ctx.fill();
  }

  const ci=gi('c0');
  if (ci) ctx.drawImage(ci, W-166,11,28,28);
  ctx.fillStyle='#FFD700'; ctx.font='bold 21px system-ui,sans-serif';
  ctx.fillText('×'+coins, W-133, 34);

  ctx.fillStyle='rgba(0,0,10,0.42)';
  roundRect(W/2-100,10,200,30,7); ctx.fill();
  ctx.fillStyle='#aaddff'; ctx.font='14px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText('MEJOR  '+hiScore.toLocaleString(), W/2, 30);
  ctx.textAlign='left';

  const hi2=gi('heart');
  for (let i=0;i<LIVES;i++) {
    const hx=W-96-i*34;
    ctx.globalAlpha=i<lives?1:0.22;
    if (hi2) ctx.drawImage(hi2,hx,48,28,28);
    else { ctx.fillStyle='#e74c3c'; ctx.font='22px sans-serif'; ctx.fillText('♥',hx,70); }
  }
  ctx.globalAlpha=1;

  if (P.shielded>0 && state!==ST.BOSS) {
    ctx.fillStyle='rgba(0,0,10,0.5)'; ctx.fillRect(10,86,150,10);
    ctx.fillStyle='#44aaff'; ctx.fillRect(10,86,150*(P.shielded/420),10);
  }
  if (P.magnet>0) {
    ctx.fillStyle='rgba(0,0,10,0.5)'; ctx.fillRect(10,100,150,10);
    ctx.fillStyle='#ffee55'; ctx.fillRect(10,100,150*(P.magnet/480),10);
  }
  if (P.boosted>0) {
    ctx.fillStyle='rgba(255,140,0,0.88)'; ctx.font='bold 16px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.fillText('⚡  TURBO  ⚡', W/2, H-18);
    ctx.textAlign='left';
  }
  drawMuteBtn();
}

function drawTitle() {
  const rbi=gi('bgRed');
  if (rbi) ctx.drawImage(rbi,0,0,W,H);
  else { const g=ctx.createLinearGradient(0,0,0,H); g.addColorStop(0,'#1a0010'); g.addColorStop(1,'#440020'); ctx.fillStyle=g; ctx.fillRect(0,0,W,H); }

  ctx.globalAlpha=0.15;
  drawBg(); drawClouds(); drawMountains(); drawOcean();
  ctx.globalAlpha=1;

  const li=gi('logo');
  if (li) {
    const lw=Math.min(520,W*0.56), lh=lw*li.naturalHeight/li.naturalWidth;
    const fl=Math.sin(gframe*0.03)*8;
    ctx.drawImage(li,(W-lw)/2,H*0.08+fl,lw,lh);
  } else {
    ctx.fillStyle='#fff'; ctx.font='bold 52px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.fillText('MIKELTUBE ADVENTURES', W/2, H*0.3);
  }

  if (Math.sin(gframe*0.07)>-0.4) {
    ctx.globalAlpha=0.7+Math.sin(gframe*0.07)*0.3;
    ctx.fillStyle='#fff'; ctx.font='bold 25px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.shadowColor='#000'; ctx.shadowBlur=14;
    ctx.fillText('✦  TOCA PARA EMPEZAR  ✦', W/2, H*0.72);
    ctx.shadowBlur=0; ctx.globalAlpha=1;
  }
  ctx.fillStyle='rgba(255,255,255,0.55)'; ctx.font='15px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText('ESPACIO / ↑ = Saltar (doble salto)   ·   ↓ / S = Agachar   ·   M = Silencio', W/2, H*0.82);
  if (hiScore>0) {
    ctx.fillStyle='#FFD700'; ctx.font='bold 20px system-ui,sans-serif';
    ctx.fillText('🏆  Récord: '+hiScore.toLocaleString(), W/2, H*0.91);
  }
  drawMuteBtn();
}

function drawCharSelect() {
  const g=ctx.createLinearGradient(0,0,0,H);
  g.addColorStop(0,'#040c20'); g.addColorStop(1,'#0a2050');
  ctx.fillStyle=g; ctx.fillRect(0,0,W,H);

  ctx.fillStyle='#fff'; ctx.font='bold 34px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.shadowColor='#0055ff'; ctx.shadowBlur=22;
  ctx.fillText('ELIGE TU PERSONAJE', W/2, 62);
  ctx.shadowBlur=0;

  const cw=200, ch=255, my=H/2-ch/2+6;
  const cards=[{x:W/2-190,pose:'mikelPose',name:'nameMikel',label:'MIKEL'},
               {x:W/2+30, pose:'leoPose', name:'nameLeo', label:'LEO'}];
  cards.forEach((c,i)=>{
    const sel=selChar===i;
    ctx.fillStyle=sel?'rgba(255,220,0,0.18)':'rgba(255,255,255,0.06)';
    roundRect(c.x-12,my-12,cw+24,ch+84,14); ctx.fill();
    if (sel) {
      ctx.strokeStyle='#FFD700'; ctx.lineWidth=3;
      roundRect(c.x-12,my-12,cw+24,ch+84,14); ctx.stroke(); ctx.lineWidth=1;
    }
    di(c.pose,c.x,my,cw,ch);
    const ni=gi(c.name);
    if (ni) {
      const nw=150, nh=nw*ni.naturalHeight/ni.naturalWidth;
      ctx.drawImage(ni, c.x+cw/2-nw/2, my+ch+14, nw, nh);
    } else {
      ctx.fillStyle=sel?'#FFD700':'#ccc'; ctx.font='bold 23px system-ui,sans-serif'; ctx.textAlign='center';
      ctx.fillText(c.label, c.x+cw/2, my+ch+44);
    }
    if (sel) {
      ctx.fillStyle='#fff'; ctx.font='14px system-ui,sans-serif'; ctx.textAlign='center';
      ctx.fillText('¡SELECCIONADO!', c.x+cw/2, my+ch+72);
    }
  });

  ctx.globalAlpha=0.7+Math.sin(gframe*0.08)*0.3;
  ctx.fillStyle='#fff'; ctx.font='bold 17px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText('Toca un personaje  ·  Toca de nuevo para jugar', W/2, H-22);
  ctx.globalAlpha=1;
  drawMuteBtn();
}

function drawIntro() {
  drawBg(); drawClouds(); drawMountains(); drawOcean();
  const ci=gi('cannonBig');
  if (ci) {
    ctx.save();
    ctx.translate(95, GROUND-30);
    ctx.rotate(-0.62);
    ctx.drawImage(ci, -45, -110, 95, 120);
    ctx.restore();
  }
  if (introF<45) {
    const ri=gi('ready');
    if (ri) {
      const rw2=260, rh2=rw2*ri.naturalHeight/ri.naturalWidth;
      const sc=1+Math.sin(introF*0.2)*0.05;
      ctx.save(); ctx.translate(W/2,H*0.36); ctx.scale(sc,sc);
      ctx.drawImage(ri,-rw2/2,-rh2/2,rw2,rh2); ctx.restore();
    }
  } else {
    drawEffects(); drawParticles(); drawPlayer();
    if (introF>72) {
      const gg=gi('go');
      if (gg) {
        const gw2=230, gh2=gw2*gg.naturalHeight/gg.naturalWidth;
        ctx.drawImage(gg, W/2-gw2/2, H*0.36-gh2/2, gw2, gh2);
      }
    }
  }
  drawHUD();
}

function drawDead() {
  drawBg(); drawClouds(); drawMountains(); drawOcean();
  drawEffects(); drawParticles(); drawPlayer();

  ctx.fillStyle=`rgba(0,0,0,${Math.min(0.72,deadF/60*0.72)})`;
  ctx.fillRect(0,0,W,H);
  if (deadF<18) return;

  ctx.textAlign='center';
  const goy=H/2-95+Math.max(0,(50-deadF)*3);
  ctx.fillStyle='#ff2222'; ctx.font='bold 64px system-ui,sans-serif';
  ctx.shadowColor='#000'; ctx.shadowBlur=30;
  ctx.fillText('GAME OVER', W/2, goy); ctx.shadowBlur=0;

  ctx.fillStyle='#fff'; ctx.font='bold 30px system-ui,sans-serif';
  ctx.fillText('Puntuación: '+score.toLocaleString(), W/2, H/2-18);
  ctx.fillStyle='#FFD700'; ctx.font='22px system-ui,sans-serif';
  ctx.fillText('Monedas: ×'+coins + (bossesKilled>0?'   ·   Jefes: '+bossesKilled:''), W/2, H/2+22);

  if (score>=hiScore && score>0) {
    const p2=1+Math.sin(deadF*0.14)*0.08;
    ctx.save(); ctx.translate(W/2,H/2+62); ctx.scale(p2,p2);
    ctx.fillStyle='#FFD700'; ctx.font='bold 26px system-ui,sans-serif';
    ctx.shadowColor='#ff8800'; ctx.shadowBlur=18;
    ctx.fillText('🏆  ¡NUEVO RÉCORD!',0,0); ctx.shadowBlur=0; ctx.restore();
  }

  if (deadF>50) {
    const by=H/2+150;
    const br=gi('btnReplay'), bh2=gi('btnHome');
    if (br) ctx.drawImage(br, W/2-114, by-30, 68, 62);
    else { ctx.fillStyle='#44cc44'; roundRect(W/2-120,by-30,80,60,10); ctx.fill(); ctx.fillStyle='#fff'; ctx.font='bold 30px sans-serif'; ctx.fillText('↻',W/2-80,by+11); }
    if (bh2) ctx.drawImage(bh2, W/2+46, by-30, 68, 62);
    else { ctx.fillStyle='#4488ee'; roundRect(W/2+40,by-30,80,60,10); ctx.fill(); ctx.fillStyle='#fff'; ctx.font='bold 26px sans-serif'; ctx.fillText('⌂',W/2+80,by+10); }
  }
  drawMuteBtn();
}

function drawLoadingScreen() {
  ctx.fillStyle='#060d1a'; ctx.fillRect(0,0,W,H);
  const li=gi('logo');
  if (li) {
    const lw=350, lh=lw*li.naturalHeight/li.naturalWidth;
    ctx.globalAlpha=0.9; ctx.drawImage(li,(W-lw)/2,H*0.1,lw,lh); ctx.globalAlpha=1;
  } else {
    ctx.fillStyle='#fff'; ctx.font='bold 30px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.fillText('MIKELTUBE ADVENTURES', W/2, H*0.3);
  }
  ctx.fillStyle='#fff'; ctx.font='18px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText('Cargando…', W/2, H/2+18);
  const pct=TOTAL>0?loaded/TOTAL:0;
  ctx.fillStyle='#1a2a50'; roundRect(W/2-185,H/2+38,370,22,11); ctx.fill();
  if (pct>0) { ctx.fillStyle='#FFD700'; roundRect(W/2-185,H/2+38,370*pct,22,11); ctx.fill(); }
  ctx.fillStyle='#888'; ctx.font='13px sans-serif';
  ctx.fillText(Math.round(pct*100)+'%', W/2, H/2+86);
}

// ═══════════════════════════════════════════════════════
//  MAIN LOOP
// ═══════════════════════════════════════════════════════
function draw() {
  let didShake=false;
  if (shakeF>0) {
    const mag=shakeF*0.55;
    ctx.save();
    ctx.translate((Math.random()*2-1)*mag,(Math.random()*2-1)*mag*0.7);
    didShake=true;
  }
  ctx.clearRect(-12,-12,W+24,H+24);

  switch(state) {
    case ST.LOADING: drawLoadingScreen(); break;
    case ST.TITLE:
      drawBg(); drawClouds(); drawMountains(); drawOcean();
      drawTitle(); break;
    case ST.CHAR_SELECT: drawCharSelect(); break;
    case ST.INTRO: drawIntro(); break;
    case ST.PLAYING:
      drawBg(); drawClouds(); drawMountains(); drawOcean();
      drawEffects(); drawCollectibles(); drawObstacles(); drawRobot();
      drawParticles(); drawPlayer(); drawHUD();
      break;
    case ST.BOSS:
      drawBg(); drawClouds(); drawMountains(); drawOcean();
      drawEffects(); drawBoss(); drawParticles(); drawHUD();
      break;
    case ST.DEAD: drawDead(); break;
  }
  if (didShake) ctx.restore();
}

function loop() {
  update();
  draw();
  gframe++;
  requestAnimationFrame(loop);
}

// ═══════════════════════════════════════════════════════
//  BOOT
// ═══════════════════════════════════════════════════════
initClouds();
AudioMan.init();   // decodifica en segundo plano; el contexto se desbloquea al primer toque

function bootDraw() {
  drawLoadingScreen();
  if (loaded<TOTAL) requestAnimationFrame(bootDraw);
}
bootDraw();

preload().then(()=>{
  state=ST.TITLE;
  AudioMan.music('musica-menu');
  requestAnimationFrame(loop);
});
</script>
</body>
</html>
