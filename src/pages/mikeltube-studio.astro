function drawBossBar(x,y,hp,maxHp,name) {
  const bw2=220, bx2=x-bw2*0.5, by2=y;
  ctx.fillStyle='rgba(0,0,0,0.55)'; roundRect(bx2,by2,bw2,13,6); ctx.fill();
  ctx.fillStyle='#ff5544'; roundRect(bx2+2,by2+2,(bw2-4)*Math.max(0,hp/maxHp),9,4); ctx.fill();
  if (name) {
    ctx.fillStyle='#fff'; ctx.font='bold 13px system-ui,sans-serif'; ctx.textAlign='center';
    ctx.fillText(name, x, by2-5);
    ctx.textAlign='left';
  }
}
function drawBossRobot() {
  const R=RB;
  for (const b of R.beams) {
    const by = (b.h==='low' ? GROUND-50 : GROUND-148) + 26;
    const active = b.t>=20 && b.t<=75;
    const alpha = active ? 0.95 : (b.t<20 ? 0.3+0.2*Math.sin(b.t) : Math.max(0,(90-b.t)/15));
    drawBeamH('rayo', Math.floor(b.t/3)%3, by, R.x-40, active?52:14, alpha);
  }
  const rb=gi('robot'+R.af);
  if (rb) {
    const rh=180, rw=rh*rb.naturalWidth/rb.naturalHeight;
    ctx.save();
    if (R.phase==='charge') { ctx.shadowColor='#66eaff'; ctx.shadowBlur=18+Math.sin(R.t*0.4)*10; }
    if (R.phase==='stunned') { ctx.shadowColor='#ffee55'; ctx.shadowBlur=14; }
    if (R.hitFlash>0 && ctx.filter!==undefined) ctx.filter='brightness(2.2)';
    ctx.drawImage(rb, R.x-rw*0.5, R.y-rh*0.5, rw, rh);
    ctx.restore();
    if (ctx.filter!==undefined) ctx.filter='none';
  }
  if (R.phase==='stunned' && Math.floor(gframe/8)%2===0) {
    ctx.fillStyle='#FFDC00'; ctx.font='bold 22px "Baloo 2",sans-serif'; ctx.textAlign='center';
    ctx.fillText('¡SALTA ENCIMA!', R.x, R.y-110);
    ctx.textAlign='left';
  }
  drawBossBar(R.x, R.y-140, R.hp, R.maxHp, 'ROBOT GUARDIÁN');
}
function drawBossFrog() {
  const B=FB;
  if (B.phase==='laser') {
    const active=B.t>20;
    drawBeamH('flaser', Math.floor(B.t/3)%5, B.laserY, B.x-70,
              active?58:14, active?0.95:0.3+0.2*Math.sin(B.t*0.8));
  }
  if (B.phase==='fight') {
    const cycle=Math.max(150,260-lap*30);
    if (B.laserT>cycle-60) {
      ctx.save();
      ctx.shadowColor='#ff4444'; ctx.shadowBlur=20;
      ctx.fillStyle=`rgba(255,80,80,${0.4+0.3*Math.sin(B.laserT*0.5)})`;
      ctx.beginPath(); ctx.arc(B.x-95, B.y, 16, 0, Math.PI*2); ctx.fill();
      ctx.restore();
    }
  }
  for (const bu of B.bubbles) {
    const bimg=gi('burb'+(Math.floor(bu.t/4)%14));
    if (bimg) ctx.drawImage(bimg, bu.x-26, bu.y-26, 52, 52);
    else { ctx.strokeStyle='#a8e6ff'; ctx.beginPath(); ctx.arc(bu.x,bu.y,22,0,Math.PI*2); ctx.stroke(); }
  }
  if (B.phase!=='dying' || B.t<60) {
    const fi=gi('frog'+B.af);
    ctx.save();
    if (B.flash>0 && ctx.filter!==undefined) ctx.filter='brightness(2.2)';
    if (fi) {
      const fh=150, fw=fh*fi.naturalWidth/fi.naturalHeight;
      ctx.translate(B.x, B.y);
      ctx.drawImage(fi, -fw*0.5, -fh*0.5, fw, fh);
    }
    ctx.restore();
    if (ctx.filter!==undefined) ctx.filter='none';
    drawBossBar(B.x, B.y-105, B.hp, B.maxHp, 'BUBEADO');
  }
  for (const b of B.bullets) {
    const bi=gi('bullet');
    if (bi) ctx.drawImage(bi, b.x-16, b.y-8, 32, 16);
    else { ctx.fillStyle='#aaffcc'; ctx.fillRect(b.x-12,b.y-4,24,8); }
  }
  drawPlayerShip(B.shipY);
}
function drawPlayerShip(sy) {
  const shi=gi('ship');
  if (shi) {
    const sw2=120, sh2=sw2*shi.naturalHeight/shi.naturalWidth;
    if (P.invincible>0 && Math.floor(gframe/4)%2===1) ctx.globalAlpha=0.35;
    ctx.drawImage(shi, 150-sw2*0.5, sy-sh2*0.5, sw2, sh2);
    ctx.globalAlpha=1;
  }
  if (P.shielded>0) {
    const si=gi('shield'+(Math.floor(gframe/4)%9));
    if (si) { ctx.globalAlpha=0.5; ctx.drawImage(si, 150-70, sy-58, 140, 116); ctx.globalAlpha=1; }
  }
}
function drawBossGunilda() {
  const G=GB;
  ctx.globalAlpha=Math.max(0,G.alpha);
  const gf = G.phase==='tired' ? gi('brunilda') : gi('gun'+G.af);
  if (gf) {
    const gh=G.phase==='tired'?115:110, gw=gh*gf.naturalWidth/gf.naturalHeight;
    ctx.save();
    if (G.phase==='cast') { ctx.shadowColor='#dd66ff'; ctx.shadowBlur=18+Math.sin(G.t*0.4)*8; }
    if (G.phase==='tired') { ctx.shadowColor='#ffee55'; ctx.shadowBlur=12; }
    if (G.hitFlash>0 && ctx.filter!==undefined) ctx.filter='brightness(2.2)';
    ctx.translate(G.x, G.y);
    ctx.scale(-1,1);
    ctx.drawImage(gf, -gw*0.5, -gh*0.5, gw, gh);
    ctx.restore();
    if (ctx.filter!==undefined) ctx.filter='none';
  }
  // chispas mágicas alrededor mientras lanza
  if (G.phase==='cast' && gframe%3===0) {
    const sf=gi('shine'+(Math.floor(gframe/4)%6));
    if (sf) { ctx.globalAlpha=0.75; ctx.drawImage(sf, G.x-70+Math.random()*140-20, G.y-70+Math.random()*140-20, 40, 40); }
  }
  ctx.globalAlpha=1;
  drawBossBar(G.x, G.y-92, G.hp, G.maxHp, 'GUNILDA');
}

// ═══════════════════════════════════════════════════════
//  DRAW — EMBARQUE / VUELO / DUELO
// ═══════════════════════════════════════════════════════
function drawShipEmpty(x0, y0, w2) {
  // el sprite de la nave trae al piloto pintado: recortamos el casco
  // y tapamos la cabina con una cúpula de cristal opaca
  const shi=gi('ship'); if (!shi) return;
  const h2=w2*shi.naturalHeight/shi.naturalWidth;
  ctx.save();
  ctx.beginPath(); ctx.rect(x0, y0+h2*0.40, w2, h2*0.60); ctx.clip();
  ctx.drawImage(shi, x0, y0, w2, h2);
  ctx.restore();
  const dg=ctx.createLinearGradient(0, y0-h2*0.05, 0, y0+h2*0.66);
  dg.addColorStop(0,'#dcf3ff'); dg.addColorStop(1,'#569fd2');
  ctx.beginPath();
  ctx.ellipse(x0+w2*0.42, y0+h2*0.30, w2*0.27, h2*0.34, 0, 0, Math.PI*2);
  ctx.fillStyle=dg; ctx.fill();
  ctx.strokeStyle='#2a6a9a'; ctx.lineWidth=3; ctx.stroke();
  ctx.beginPath();
  ctx.ellipse(x0+w2*0.34, y0+h2*0.16, w2*0.06, h2*0.10, -0.5, 0, Math.PI*2);
  ctx.fillStyle='rgba(255,255,255,0.8)'; ctx.fill();
}
function drawBoarding() {
  drawScene();
  drawEffects(); drawParticles();
  const b=BD;
  const shi=gi('ship');
  if (shi) {
    const sw2=130, sh2=sw2*shi.naturalHeight/shi.naturalWidth;
    const wob=b.phase==='land'||b.phase==='takeoff' ? Math.sin(b.t*0.2)*3 : 0;
    const sx0=b.shipX-sw2*0.5, sy0=b.shipY-sh2*0.5+wob;
    if (b.phase==='takeoff') {
      ctx.drawImage(shi, sx0, sy0, sw2, sh2);   // el piloto del sprite ES el héroe a bordo
    } else {
      drawShipEmpty(sx0, sy0, sw2);
    }
  }
  if (b.phase!=='takeoff') drawPlayer();
  drawFloatTexts();
  drawHUD();
  if (b.phase==='run'||b.phase==='land') {
    ctx.fillStyle='rgba(0,0,20,0.55)'; roundRect(W/2-190,64,380,36,10); ctx.fill();
    ctx.fillStyle='#7FDBFF'; ctx.font='bold 19px "Baloo 2",sans-serif'; ctx.textAlign='center';
    ctx.fillText('¡Corre a la nave y sube a bordo!', W/2, 88);
    ctx.textAlign='left';
  }
}
function drawSpaceBg(mode) {
  // mode 0 = espacio (vuelo), 1 = cielo de Marte (duelo)
  if (mode===1) {
    const sk=gi('marsSky');
    if (sk) ctx.drawImage(sk,0,0,W,H);
    else { ctx.fillStyle='#7a2810'; ctx.fillRect(0,0,W,H); }
    ctx.fillStyle='rgba(30,6,2,0.35)'; ctx.fillRect(0,0,W,H);
  } else {
    const g=ctx.createLinearGradient(0,0,0,H);
    g.addColorStop(0,'#020208'); g.addColorStop(1,'#0a1030');
    ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
  }
  ctx.fillStyle='#fff';
  for (const s of stars) {
    ctx.globalAlpha=mode===1?0.35:0.9;
    ctx.beginPath(); ctx.arc(s.x,s.y,s.r,0,Math.PI*2); ctx.fill();
  }
  ctx.globalAlpha=1;
}
function drawFly() {
  drawSpaceBg(0);
  const f=F;
  for (const r of f.rocks) {
    ctx.save();
    ctx.translate(r.x,r.y); ctx.rotate(r.rot);
    ctx.fillStyle='#8a7362';
    ctx.beginPath();
    for (let i=0;i<7;i++) {
      const a=i/7*Math.PI*2, rr=r.r*(0.8+((i*7)%3)*0.12);
      i?ctx.lineTo(Math.cos(a)*rr,Math.sin(a)*rr):ctx.moveTo(Math.cos(a)*rr,Math.sin(a)*rr);
    }
    ctx.closePath(); ctx.fill();
    ctx.fillStyle='rgba(0,0,0,0.25)';
    ctx.beginPath(); ctx.arc(-r.r*0.25,-r.r*0.2,r.r*0.3,0,Math.PI*2); ctx.fill();
    ctx.restore();
  }
  for (const c of f.coins) {
    const ci=gi('c'+c.af);
    if (ci) ctx.drawImage(ci, c.x-18, c.y-18, 36, 36);
  }
  // estela de la nave
  if (gframe%2===0) particles.push({ x:110, y:f.y+8, vx:-4-Math.random()*2, vy:(Math.random()-0.5)*1.4,
                                     life:0.7, r:2.5+Math.random()*3.5, color:'#9adcff' });
  drawParticles();
  drawPlayerShip(f.y);
  drawEffects(); drawFloatTexts();
  drawHUD();
  // destino
  const prog=f.t/f.dur;
  ctx.fillStyle='rgba(0,0,20,0.55)'; roundRect(W/2-160,H-46,320,30,9); ctx.fill();
  ctx.fillStyle='rgba(255,255,255,0.2)'; roundRect(W/2-150,H-38,300,14,7); ctx.fill();
  ctx.fillStyle='#7FDBFF'; roundRect(W/2-150,H-38,300*prog,14,7); ctx.fill();
  ctx.fillStyle='#fff'; ctx.font='bold 13px system-ui,sans-serif'; ctx.textAlign='center';
  ctx.fillText('RUMBO A '+WORLDS[world+1].nombre, W/2, H-52);
  ctx.textAlign='left';
}
function drawDuel() {
  drawSpaceBg(1);
  const d=D;
  // Gunilda en escoba
  if (d.phase!=='dying' || d.t<80) {
    const be=gi('BRUJAESCOBA')||gi('gun'+(Math.floor(d.t/6)%3));
    const bimg=gi('brunilda');
    ctx.save();
    if (d.flash>0 && ctx.filter!==undefined) ctx.filter='brightness(2.2)';
    ctx.translate(d.gx, d.gy);
    const tilt=d.phase==='dying'?d.t*0.05:Math.sin(d.t*0.05)*0.12;
    ctx.rotate(tilt);
    ctx.scale(-1,1);
    if (bimg) {
      const gh=120, gw=gh*bimg.naturalWidth/bimg.naturalHeight;
      ctx.drawImage(bimg, -gw*0.5, -gh*0.5, gw, gh);
    }
    ctx.restore();
    if (ctx.filter!==undefined) ctx.filter='none';
    drawBossBar(d.gx, d.gy-95, d.hp, d.maxHp, 'GUNILDA — ¡RECUPERA LA BRÚJULA!');
  }
  for (const b of d.bullets) {
    const bi=gi('bullet');
    if (bi) ctx.drawImage(bi, b.x-16, b.y-8, 32, 16);
  }
  for (const bo of d.bolas) {
    const bi=gi('bola'+bo.af);
    if (bi) ctx.drawImage(bi, bo.x-19, bo.y-19, 38, 38);
  }
  if (gframe%2===0) particles.push({ x:110, y:d.y+8, vx:-4-Math.random()*2, vy:(Math.random()-0.5)*1.4,
                                     life:0.7, r:2.5+Math.random()*3.5, color:'#ffd27a' });
  drawParticles();
  drawPlayerShip(d.y);
  drawEffects(); drawFloatTexts();
  drawHUD();
}

