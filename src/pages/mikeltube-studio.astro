---
// Mikeltube Adventures — Asset Studio
// URL privada: /mikeltube-studio  (noindex)
const title = "Mikeltube Studio — Asset Viewer";
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="robots" content="noindex, nofollow"/>
  <title>{title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0f1117;
      --bg2: #1a1d2e;
      --bg3: #252840;
      --accent: #6c63ff;
      --accent2: #ff6b6b;
      --text: #e0e0f0;
      --text2: #9898b8;
      --border: #2d2f4a;
      --card: #1e2035;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, sans-serif;
      font-size: 14px;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* HEADER */
    header {
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      padding: 0 20px;
      height: 54px;
      display: flex;
      align-items: center;
      gap: 16px;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    header h1 {
      font-size: 16px;
      font-weight: 700;
      color: var(--accent);
      white-space: nowrap;
    }
    header h1 span { color: var(--accent2); }

    #search {
      flex: 1;
      max-width: 400px;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 7px 12px;
      color: var(--text);
      font-size: 13px;
      outline: none;
    }
    #search::placeholder { color: var(--text2); }
    #search:focus { border-color: var(--accent); }

    .header-stats { color: var(--text2); font-size: 12px; margin-left: auto; white-space: nowrap; }

    /* LAYOUT */
    .layout {
      display: flex;
      flex: 1;
      overflow: hidden;
      height: calc(100vh - 54px);
    }

    /* SIDEBAR */
    nav {
      width: 200px;
      min-width: 200px;
      background: var(--bg2);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding: 12px 0;
    }

    .nav-section { padding: 6px 16px 2px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text2); }

    .nav-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      width: 100%;
      padding: 8px 16px;
      background: none;
      border: none;
      color: var(--text2);
      cursor: pointer;
      font-size: 13px;
      text-align: left;
      border-left: 3px solid transparent;
      transition: all 0.15s;
    }
    .nav-btn:hover { background: var(--bg3); color: var(--text); }
    .nav-btn.active { background: var(--bg3); color: var(--accent); border-left-color: var(--accent); }
    .nav-btn .count {
      margin-left: auto;
      font-size: 11px;
      background: var(--bg);
      padding: 1px 6px;
      border-radius: 10px;
      color: var(--text2);
    }

    /* MAIN CONTENT */
    main {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
    }

    /* TABS */
    .tab-bar {
      display: flex;
      gap: 4px;
      margin-bottom: 20px;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0;
    }
    .tab {
      padding: 8px 16px;
      background: none;
      border: none;
      color: var(--text2);
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
    }
    .tab.active { color: var(--accent); border-bottom-color: var(--accent); }
    .tab:hover:not(.active) { color: var(--text); }

    /* GRID */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 10px;
    }
    .grid.large { grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); }
    .grid.list { grid-template-columns: 1fr; gap: 4px; }

    .asset-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      cursor: pointer;
      transition: all 0.15s;
      position: relative;
    }
    .asset-card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(108,99,255,0.2); }

    .asset-thumb {
      width: 100%;
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      background: repeating-conic-gradient(#1a1d2e 0% 25%, #252840 0% 50%) 0 0 / 16px 16px;
      overflow: hidden;
      position: relative;
    }
    .asset-thumb img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      image-rendering: pixelated;
    }
    .asset-label {
      padding: 6px 8px;
      font-size: 10px;
      color: var(--text2);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      border-top: 1px solid var(--border);
    }

    /* ANIM BADGE */
    .atlas-badge {
      position: absolute;
      top: 4px;
      right: 4px;
      background: var(--accent);
      color: white;
      font-size: 9px;
      font-weight: 700;
      padding: 2px 5px;
      border-radius: 4px;
    }

    /* VIEW CONTROLS */
    .view-controls {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
      align-items: center;
    }
    .view-controls span { color: var(--text2); font-size: 12px; }
    .icon-btn {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 5px;
      padding: 5px 10px;
      color: var(--text2);
      cursor: pointer;
      font-size: 12px;
    }
    .icon-btn.active, .icon-btn:hover { background: var(--accent); color: white; border-color: var(--accent); }

    /* MODAL */
    #modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.85);
      z-index: 1000;
      align-items: center;
      justify-content: center;
    }
    #modal.open { display: flex; }
    .modal-inner {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 12px;
      max-width: 90vw;
      max-height: 90vh;
      overflow: auto;
      padding: 24px;
      position: relative;
      min-width: 400px;
    }
    .modal-close {
      position: absolute;
      top: 12px;
      right: 12px;
      background: var(--bg3);
      border: none;
      color: var(--text);
      width: 30px;
      height: 30px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 16px;
    }
    .modal-img {
      max-width: 70vw;
      max-height: 70vh;
      object-fit: contain;
      display: block;
      margin: 0 auto 12px;
      image-rendering: pixelated;
      background: repeating-conic-gradient(#1a1d2e 0% 25%, #252840 0% 50%) 0 0 / 20px 20px;
      border-radius: 6px;
    }
    .modal-title { font-size: 14px; font-weight: 600; text-align: center; color: var(--text); margin-bottom: 4px; }
    .modal-meta { font-size: 12px; color: var(--text2); text-align: center; }
    .modal-nav { display: flex; justify-content: center; gap: 12px; margin-top: 16px; }
    .modal-nav button {
      background: var(--bg3);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 6px 20px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 13px;
    }
    .modal-nav button:hover { border-color: var(--accent); color: var(--accent); }

    /* ANIM PLAYER */
    .anim-player {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 16px;
    }
    .anim-player h3 { font-size: 13px; color: var(--text2); margin-bottom: 12px; }
    .anim-canvas-wrap {
      background: repeating-conic-gradient(#1a1d2e 0% 25%, #252840 0% 50%) 0 0 / 20px 20px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 200px;
      margin-bottom: 12px;
      overflow: hidden;
    }
    #animCanvas { image-rendering: pixelated; }
    .anim-controls { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
    .anim-controls label { font-size: 12px; color: var(--text2); }
    .anim-controls input[type=range] { flex: 1; min-width: 100px; }

    /* ANIM LIST */
    .anim-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 8px; }
    .anim-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 12px;
      cursor: pointer;
      transition: border-color 0.15s;
    }
    .anim-item:hover { border-color: var(--accent); }
    .anim-item.active { border-color: var(--accent); background: var(--bg3); }
    .anim-item-name { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
    .anim-item-meta { font-size: 11px; color: var(--text2); }

    /* SPRITE ANIMATOR for atlas */
    .frame-strip {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-top: 12px;
    }
    .frame-thumb {
      width: 60px;
      height: 60px;
      background: repeating-conic-gradient(#1a1d2e 0% 25%, #252840 0% 50%) 0 0 / 10px 10px;
      border-radius: 4px;
      border: 1px solid var(--border);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }
    .frame-thumb img { max-width: 100%; max-height: 100%; object-fit: contain; image-rendering: pixelated; }
    .frame-thumb.active-frame { border-color: var(--accent); }

    /* LEVEL BUILDER */
    #levelBuilder { display: none; }
    #levelBuilder.active { display: block; }
    .builder-top { display: flex; gap: 16px; height: calc(100vh - 160px); }
    .builder-canvas-wrap {
      flex: 1;
      background: #1a2a4a;
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      position: relative;
    }
    #levelCanvas { display: block; cursor: crosshair; }
    .builder-panel {
      width: 200px;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow-y: auto;
      padding: 12px;
    }
    .builder-panel h3 { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text2); margin-bottom: 10px; }
    .palette-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px;
      border-radius: 5px;
      cursor: pointer;
      margin-bottom: 2px;
    }
    .palette-item:hover, .palette-item.selected { background: var(--bg3); }
    .palette-item img { width: 36px; height: 36px; object-fit: contain; image-rendering: pixelated; }
    .palette-item span { font-size: 11px; color: var(--text2); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .builder-tools { display: flex; gap: 6px; margin-bottom: 12px; }
    .tool-btn {
      padding: 5px 10px;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 5px;
      color: var(--text2);
      cursor: pointer;
      font-size: 11px;
    }
    .tool-btn.active { background: var(--accent); color: white; border-color: var(--accent); }

    /* EMPTY STATE */
    .empty { text-align: center; padding: 60px 20px; color: var(--text2); }
    .empty .icon { font-size: 48px; margin-bottom: 16px; }
    .empty p { font-size: 14px; }

    /* SCROLLBAR */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

    /* LOADING */
    .loading { text-align: center; padding: 40px; color: var(--text2); }
    .spin { display: inline-block; width: 24px; height: 24px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 12px; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>

<header>
  <h1>🎮 Mikeltube <span>Studio</span></h1>
  <input id="search" type="search" placeholder="Buscar assets…" autocomplete="off"/>
  <div class="header-stats" id="statsBar">Cargando…</div>
</header>

<div class="layout">
  <nav id="sidebar">
    <div class="nav-section">Categorías</div>
    <button class="nav-btn active" data-cat="all">📦 Todos <span class="count" id="cnt-all">—</span></button>
    <button class="nav-btn" data-cat="characters">🧑 Personajes <span class="count" id="cnt-characters">—</span></button>
    <button class="nav-btn" data-cat="backgrounds">🏔️ Fondos <span class="count" id="cnt-backgrounds">—</span></button>
    <button class="nav-btn" data-cat="obstacles">💣 Obstáculos <span class="count" id="cnt-obstacles">—</span></button>
    <button class="nav-btn" data-cat="effects">✨ Efectos <span class="count" id="cnt-effects">—</span></button>
    <button class="nav-btn" data-cat="collectibles">⭐ Coleccionables <span class="count" id="cnt-collectibles">—</span></button>
    <button class="nav-btn" data-cat="ui">🖼️ UI <span class="count" id="cnt-ui">—</span></button>
    <button class="nav-btn" data-cat="atlases">🗂️ Atlas <span class="count" id="cnt-atlases">—</span></button>
    <button class="nav-btn" data-cat="other">📂 Otros <span class="count" id="cnt-other">—</span></button>

    <div class="nav-section" style="margin-top:12px">Herramientas</div>
    <button class="nav-btn" data-tool="animator">🎬 Animador</button>
    <button class="nav-btn" data-tool="level">🗺️ Level Builder</button>
  </nav>

  <main id="mainContent">
    <div class="loading"><div class="spin"></div><br>Cargando assets…</div>
  </main>
</div>

<!-- MODAL -->
<div id="modal">
  <div class="modal-inner">
    <button class="modal-close" id="modalClose">✕</button>
    <img class="modal-img" id="modalImg" src="" alt=""/>
    <div class="modal-title" id="modalTitle"></div>
    <div class="modal-meta" id="modalMeta"></div>
    <div class="modal-nav">
      <button id="modalPrev">← Anterior</button>
      <a id="modalDownload" download style="
        background: var(--accent);
        color: white;
        border: none;
        padding: 6px 20px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 13px;
        text-decoration: none;
        display: flex;
        align-items: center;
      ">⬇ Descargar</a>
      <button id="modalNext">Siguiente →</button>
    </div>
  </div>
</div>

<script>
const BASE = '/mk-studio';
let INDEX = null;
let currentAssets = [];
let currentIdx = 0;
let viewMode = 'grid'; // grid | large | list
let currentCategory = 'all';
let searchQuery = '';
let currentTool = null;

// Build flat asset list from index
function buildAssets(index) {
  const list = [];
  for (const [type, files] of [['sprites', index.sprites], ['textures', index.textures]]) {
    for (const f of files) {
      const cat = categorize(f);
      list.push({ type, file: f, cat, url: `${BASE}/${type}/${encodeURIComponent(f)}` });
    }
  }
  return list;
}

function categorize(name) {
  const n = name.toLowerCase();
  if (/mikel|leo|pirate|pirata|witch|bruja|bubeado|robot|soldier|soldado|gato|dog|gorilla|beerus|brunilda|gunilda|eufrasio/.test(n)) return 'characters';
  if (/^bg|background|fondo|cloud|mountain|montain|mars|sky|ocean|wave|water|foam|coral|isla|rocks/.test(n)) return 'backgrounds';
  if (/cannon|shark|esparrago|mina|obstacle|bullet|missile|rayo|bola|bomb|laser/.test(n)) return 'obstacles';
  if (/coin|gold|silver|bronze|gem|gema|token|star|estrella|score|point/.test(n)) return 'collectibles';
  if (/button|btn|ui|window|bar|popup|store|icon|logo|title|text|arrow|check|close|back|go\.|ready|new\.|cancel|delete|compras|vibrat|marcador|scores|vertical|standard|fondo barra/.test(n)) return 'ui';
  if (/explosion|hit|splash|smoke|shine|boost|turbo|wind|trail|effect|shield|escudo|energy|shine|sparkle/.test(n)) return 'effects';
  if (/atlas/.test(n)) return 'atlases';
  return 'other';
}

function getFiltered() {
  let items = currentAssets;
  if (currentCategory !== 'all') items = items.filter(a => a.cat === currentCategory);
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    items = items.filter(a => a.file.toLowerCase().includes(q));
  }
  return items;
}

function renderGrid() {
  const items = getFiltered();
  const main = document.getElementById('mainContent');

  let modeClass = 'grid';
  if (viewMode === 'large') modeClass = 'grid large';
  if (viewMode === 'list') modeClass = 'grid list';

  const controls = `
    <div class="view-controls">
      <span>${items.length} assets</span>
      <button class="icon-btn ${viewMode==='grid'?'active':''}" onclick="setView('grid')">⊞ Grid</button>
      <button class="icon-btn ${viewMode==='large'?'active':''}" onclick="setView('large')">⊟ Grande</button>
      <button class="icon-btn ${viewMode==='list'?'active':''}" onclick="setView('list')">☰ Lista</button>
    </div>`;

  if (!items.length) {
    main.innerHTML = controls + `<div class="empty"><div class="icon">🔍</div><p>No se encontraron assets</p></div>`;
    return;
  }

  const cards = items.map((a, i) => {
    const isAtlas = a.file.toLowerCase().includes('atlas') || /_\d+\.png$/.test(a.file);
    const badge = isAtlas ? `<span class="atlas-badge">ATLAS</span>` : '';
    if (viewMode === 'list') {
      return `<div class="asset-card" style="display:flex;align-items:center;gap:12px;padding:8px" onclick="openModal(${i})" data-idx="${i}">
        <img src="${a.url}" style="width:40px;height:40px;object-fit:contain;image-rendering:pixelated;flex-shrink:0" loading="lazy"/>
        <span style="font-size:12px;color:var(--text)">${a.file}</span>
        <span style="margin-left:auto;font-size:10px;color:var(--text2)">${a.type}</span>
      </div>`;
    }
    return `<div class="asset-card" onclick="openModal(${i})" data-idx="${i}">
      <div class="asset-thumb">
        ${badge}
        <img src="${a.url}" loading="lazy" decoding="async" alt="${a.file}"/>
      </div>
      <div class="asset-label" title="${a.file}">${a.file.replace(/\.png$/i,'')}</div>
    </div>`;
  }).join('');

  main.innerHTML = controls + `<div class="${modeClass}">${cards}</div>`;
  currentAssets = currentAssets; // keep reference
  // store filtered list for modal navigation
  window._filteredAssets = items;
}

window.setView = function(mode) { viewMode = mode; renderGrid(); };

function openModal(idx) {
  const items = window._filteredAssets || getFiltered();
  currentIdx = idx;
  const a = items[idx];
  const modal = document.getElementById('modal');
  const img = document.getElementById('modalImg');
  img.src = a.url;
  document.getElementById('modalTitle').textContent = a.file;
  document.getElementById('modalMeta').textContent = `Categoría: ${a.cat} · Tipo: ${a.type}`;
  document.getElementById('modalDownload').href = a.url;
  document.getElementById('modalDownload').download = a.file;
  modal.classList.add('open');
}
window.openModal = openModal;

document.getElementById('modalClose').onclick = () => document.getElementById('modal').classList.remove('open');
document.getElementById('modal').onclick = (e) => { if (e.target === e.currentTarget) e.currentTarget.classList.remove('open'); };

document.getElementById('modalPrev').onclick = () => {
  const items = window._filteredAssets || [];
  if (currentIdx > 0) openModal(currentIdx - 1);
};
document.getElementById('modalNext').onclick = () => {
  const items = window._filteredAssets || [];
  if (currentIdx < items.length - 1) openModal(currentIdx + 1);
};

document.addEventListener('keydown', e => {
  const modal = document.getElementById('modal');
  if (!modal.classList.contains('open')) return;
  if (e.key === 'Escape') modal.classList.remove('open');
  if (e.key === 'ArrowLeft') document.getElementById('modalPrev').click();
  if (e.key === 'ArrowRight') document.getElementById('modalNext').click();
});

// ANIMATOR VIEW
function renderAnimator() {
  const main = document.getElementById('mainContent');

  // Atlas groups: files with _N suffix
  const allSprites = currentAssets.filter(a => a.type === 'sprites');
  const atlasGroups = {};
  for (const a of allSprites) {
    const match = a.file.match(/^(.+?)_(\d+)\.png$/i);
    if (match) {
      const base = match[1];
      if (!atlasGroups[base]) atlasGroups[base] = [];
      atlasGroups[base].push(a);
    }
  }
  // Sort frames
  for (const k of Object.keys(atlasGroups)) {
    atlasGroups[k].sort((a,b) => {
      const na = parseInt(a.file.match(/_(\d+)\.png$/)[1]);
      const nb = parseInt(b.file.match(/_(\d+)\.png$/)[1]);
      return na - nb;
    });
  }

  const groupKeys = Object.keys(atlasGroups).sort();

  main.innerHTML = `
    <div style="display:flex;gap:20px;height:calc(100vh - 100px)">
      <div style="width:280px;overflow-y:auto">
        <div class="anim-list" style="display:block">
          ${groupKeys.map((k,i) => `
            <div class="anim-item" onclick="loadAtlas('${k}')" id="anim-${k.replace(/[^a-z0-9]/gi,'_')}">
              <div class="anim-item-name">${k}</div>
              <div class="anim-item-meta">${atlasGroups[k].length} frames</div>
            </div>`).join('')}
        </div>
      </div>
      <div style="flex:1">
        <div class="anim-player">
          <h3>🎬 Reproductor de Atlas</h3>
          <div class="anim-canvas-wrap" id="animWrap">
            <p style="color:var(--text2);font-size:13px">Selecciona un atlas de la lista →</p>
          </div>
          <div class="anim-controls" id="animControls" style="display:none">
            <button class="icon-btn active" id="playBtn" onclick="togglePlay()">⏸ Pausar</button>
            <label>FPS: <input type="range" id="fpsSlider" min="1" max="30" value="8" oninput="document.getElementById('fpsVal').textContent=this.value;setFps(+this.value)"/></label>
            <span id="fpsVal" style="font-size:12px;color:var(--text2)">8</span>
            <span id="frameLabel" style="font-size:12px;color:var(--text2)"></span>
          </div>
        </div>
        <div class="frame-strip" id="frameStrip"></div>
      </div>
    </div>`;

  window._atlasGroups = atlasGroups;
}

let _animInterval = null;
let _animFrames = [];
let _animFrame = 0;
let _animFps = 8;
let _animPlaying = true;

window.loadAtlas = function(key) {
  const frames = window._atlasGroups[key];
  if (!frames) return;
  _animFrames = frames;
  _animFrame = 0;

  document.querySelectorAll('.anim-item').forEach(el => el.classList.remove('active'));
  const id = 'anim-' + key.replace(/[^a-z0-9]/gi,'_');
  const el = document.getElementById(id);
  if (el) { el.classList.add('active'); el.scrollIntoView({ block:'nearest' }); }

  const wrap = document.getElementById('animWrap');
  wrap.innerHTML = `<img id="animImg" style="max-width:100%;max-height:300px;object-fit:contain;image-rendering:pixelated" src="${frames[0].url}"/>`;

  document.getElementById('animControls').style.display = 'flex';
  const strip = document.getElementById('frameStrip');
  strip.innerHTML = frames.map((f,i) => `
    <div class="frame-thumb ${i===0?'active-frame':''}" id="ft-${i}" onclick="jumpFrame(${i})">
      <img src="${f.url}" loading="lazy"/>
    </div>`).join('');

  clearInterval(_animInterval);
  _animPlaying = true;
  document.getElementById('playBtn').textContent = '⏸ Pausar';
  startAnim();
};

function startAnim() {
  clearInterval(_animInterval);
  _animInterval = setInterval(() => {
    if (!_animPlaying) return;
    _animFrame = (_animFrame + 1) % _animFrames.length;
    updateAnimFrame();
  }, 1000 / _animFps);
}

function updateAnimFrame() {
  const img = document.getElementById('animImg');
  if (img) img.src = _animFrames[_animFrame].url;
  document.getElementById('frameLabel').textContent = `Frame ${_animFrame+1}/${_animFrames.length}`;
  document.querySelectorAll('.frame-thumb').forEach((el,i) => {
    el.classList.toggle('active-frame', i === _animFrame);
  });
}

window.jumpFrame = function(i) { _animFrame = i; updateAnimFrame(); };
window.togglePlay = function() {
  _animPlaying = !_animPlaying;
  document.getElementById('playBtn').textContent = _animPlaying ? '⏸ Pausar' : '▶ Play';
};
window.setFps = function(fps) { _animFps = fps; startAnim(); };

// LEVEL BUILDER
function renderLevelBuilder() {
  const main = document.getElementById('mainContent');
  main.innerHTML = `
    <div class="builder-top">
      <div style="flex:1;display:flex;flex-direction:column;gap:8px">
        <div class="builder-tools">
          <button class="tool-btn active" id="toolPlace" onclick="setTool('place')">📦 Colocar</button>
          <button class="tool-btn" id="toolSelect" onclick="setTool('select')">🖱️ Seleccionar</button>
          <button class="tool-btn" id="toolDelete" onclick="setTool('delete')">🗑️ Borrar</button>
          <button class="tool-btn" onclick="clearCanvas()" style="margin-left:auto">🧹 Limpiar</button>
          <button class="tool-btn" onclick="exportLevel()">📋 Exportar JSON</button>
        </div>
        <div class="builder-canvas-wrap" id="canvasWrap">
          <canvas id="levelCanvas"></canvas>
        </div>
        <div style="font-size:11px;color:var(--text2);padding:4px 8px" id="levelStatus">
          Selecciona un sprite del panel y haz clic en el canvas para colocar.
        </div>
      </div>
      <div class="builder-panel">
        <h3>Sprites</h3>
        <input type="search" placeholder="Filtrar…" style="width:100%;padding:5px;background:var(--bg);border:1px solid var(--border);border-radius:4px;color:var(--text);font-size:12px;margin-bottom:8px" oninput="filterPalette(this.value)"/>
        <div id="palette"></div>
      </div>
    </div>`;

  initLevelCanvas();
  renderPalette('');
}

let _levelTool = 'place';
let _levelSprite = null;
let _levelObjects = [];
let _levelImages = {};

window.setTool = function(t) {
  _levelTool = t;
  document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tool'+t.charAt(0).toUpperCase()+t.slice(1)).classList.add('active');
  document.getElementById('levelCanvas').style.cursor = t === 'delete' ? 'not-allowed' : t === 'select' ? 'default' : 'crosshair';
};

window.filterPalette = function(q) { renderPalette(q); };

function renderPalette(q) {
  const ql = q.toLowerCase();
  const items = currentAssets.filter(a => !ql || a.file.toLowerCase().includes(ql)).slice(0, 80);
  document.getElementById('palette').innerHTML = items.map((a,i) =>
    `<div class="palette-item" onclick="selectPalette('${encodeURIComponent(a.url)}','${encodeURIComponent(a.file)}')" id="pal-${i}">
      <img src="${a.url}" onerror="this.style.display='none'"/>
      <span>${a.file.replace(/\.png$/i,'')}</span>
    </div>`).join('');
}

window.selectPalette = function(url, name) {
  _levelSprite = { url: decodeURIComponent(url), name: decodeURIComponent(name) };
  document.querySelectorAll('.palette-item').forEach(el => el.classList.remove('selected'));
  document.getElementById('levelStatus').textContent = `Sprite activo: ${decodeURIComponent(name)}`;
  setTool('place');
};

function initLevelCanvas() {
  const wrap = document.getElementById('canvasWrap');
  const canvas = document.getElementById('levelCanvas');
  canvas.width = wrap.clientWidth || 800;
  canvas.height = wrap.clientHeight || 500;

  // Draw grid
  const ctx = canvas.getContext('2d');
  drawGrid(ctx, canvas.width, canvas.height);

  canvas.onclick = function(e) {
    const rect = canvas.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    if (_levelTool === 'place' && _levelSprite) {
      _levelObjects.push({ url: _levelSprite.url, name: _levelSprite.name, x, y, w: 64, h: 64 });
      redrawLevel(ctx, canvas);
    } else if (_levelTool === 'delete') {
      _levelObjects = _levelObjects.filter(o => !(x >= o.x-o.w/2 && x <= o.x+o.w/2 && y >= o.y-o.h/2 && y <= o.y+o.h/2));
      redrawLevel(ctx, canvas);
    }
  };
}

function drawGrid(ctx, w, h) {
  ctx.clearRect(0,0,w,h);
  ctx.strokeStyle = 'rgba(255,255,255,0.05)';
  ctx.lineWidth = 0.5;
  for (let x = 0; x < w; x += 32) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,h); ctx.stroke(); }
  for (let y = 0; y < h; y += 32) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(w,y); ctx.stroke(); }
}

function redrawLevel(ctx, canvas) {
  drawGrid(ctx, canvas.width, canvas.height);
  for (const obj of _levelObjects) {
    if (!_levelImages[obj.url]) {
      const img = new Image();
      img.src = obj.url;
      img.onload = () => { _levelImages[obj.url] = img; redrawLevel(ctx, canvas); };
      _levelImages[obj.url] = img;
    } else {
      ctx.drawImage(_levelImages[obj.url], obj.x - obj.w/2, obj.y - obj.h/2, obj.w, obj.h);
    }
  }
}

window.clearCanvas = function() {
  _levelObjects = [];
  const canvas = document.getElementById('levelCanvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    drawGrid(ctx, canvas.width, canvas.height);
  }
};

window.exportLevel = function() {
  const json = JSON.stringify({ objects: _levelObjects.map(o => ({ name: o.name, x: Math.round(o.x), y: Math.round(o.y), w: o.w, h: o.h })) }, null, 2);
  const blob = new Blob([json], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'level.json';
  a.click();
};

// INIT
async function init() {
  const res = await fetch(`${BASE}/index.json`);
  INDEX = await res.json();
  currentAssets = buildAssets(INDEX);

  // Update counts
  const cats = ['characters','backgrounds','obstacles','effects','collectibles','ui','atlases','other'];
  document.getElementById('cnt-all').textContent = currentAssets.length;
  for (const c of cats) {
    const el = document.getElementById(`cnt-${c}`);
    if (el) el.textContent = currentAssets.filter(a => a.cat === c).length;
  }

  document.getElementById('statsBar').textContent = `${currentAssets.length} assets · ${INDEX.animations.length} animaciones`;
  window._filteredAssets = currentAssets;

  renderGrid();
}

// NAV
document.querySelectorAll('.nav-btn[data-cat]').forEach(btn => {
  btn.onclick = () => {
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentCategory = btn.dataset.cat;
    currentTool = null;
    searchQuery = document.getElementById('search').value;
    renderGrid();
  };
});

document.querySelectorAll('.nav-btn[data-tool]').forEach(btn => {
  btn.onclick = () => {
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentTool = btn.dataset.tool;
    if (currentTool === 'animator') renderAnimator();
    else if (currentTool === 'level') renderLevelBuilder();
  };
});

document.getElementById('search').addEventListener('input', e => {
  searchQuery = e.target.value;
  if (!currentTool) renderGrid();
});

init();
</script>
</body>
</html>
