<body>
<canvas id="c"></canvas>
<script is:inline>
'use strict';

// ═══════════════════════════════════════════════════════
//  CANVAS
// ═══════════════════════════════════════════════════════
const canvas = document.getElementById('c');
const ctx    = canvas.getContext('2d');
const W = 960, H = 540;
canvas.width = W; canvas.height = H;
function resize() {
  const s = Math.min(window.innerWidth / W, window.innerHeight / H);
  canvas.style.width  = Math.floor(W * s) + 'px';
  canvas.style.height = Math.floor(H * s) + 'px';
}
window.addEventListener('resize', resize);
resize();

// ═══════════════════════════════════════════════════════
//  ASSET MANIFEST
// ═══════════════════════════════════════════════════════
const S  = '/mk-studio/sprites/';
const TX = '/mk-studio/textures/';
const AU = '/mk-studio/audio/';

const ASSETS = {
  logo:      S+'MikelTubeLogo_2.png',
  bgRed:     S+'BG.png',
  heart:     S+'health.png',
  mikelPose: S+'MIKEL V POSE.png',
  leoPose:   S+'LEO V POSE.png',
  nameMikel: S+'bar name MIKEL.png',
  nameLeo:   S+'bar name LEO.png',
  ready:     S+'ready.png',
  go:        S+'go.png',
  btnReplay: S+'button_replay.png',
  btnHome:   S+'button_home.png',
  bg:        S+'BACKGROUND.png',
  cloud1:    S+'cloud1.png',
  cloud2:    S+'cloud 2.png',
  cloud3:    S+'cloud 3.png',
  cloud4:    S+'cloud 4.png',
  mtn1:      S+'montain big1.png',
  mtn2:      S+'montain big2.png',
  wave:      S+'ONE SINGLE WAVE_2.png',
  wood:      TX+'madera.png',
  jump:      S+'MIKeL AIRBORNE.png',
  splat:     S+'MIKEL SPLAT BASE.png',
  cannonBig: S+'cannon.png',
  espar:     S+'ESPARRAGO.png',
  pirata0:   S+'ATLAS PIRATA_0.png',
  pirata1:   S+'ATLAS PIRATA_1.png',
  soldierWarn: S+'soldier warning.png',
  moto0:     S+'soldado moto ATLAS v2_0.png',
  moto1:     S+'soldado moto ATLAS v2_1.png',
  ship:      S+'little spaceship.png',
  bullet:    S+'little spacechip SHOOT bullet.png',
};
function series(prefix, file, n) {
  for (let i=0;i<n;i++) ASSETS[prefix+i] = S+file.replace('%d', i);
}
series('r',      'RUNCYCLE_MIKEL_PWERSUIT_atlas_%d.png', 9);
series('tur',    'mikel turbo ATLAS_%d.png', 2);
series('wind',   'turbo wind fx ATLAS_%d.png', 4);
series('g',      'GATO run cycle ATLAS_%d.png', 5);
series('bruja',  'ATLAS BRUJA_%d.png', 6);
series('bola',   'BOLA obstaculo bruja ATLAS_%d.png', 3);
series('rayo',   'RAYO obstaculo bruja ATLAS_%d.png', 3);
series('robot',  'ATLAS ROBOT_%d.png', 8);
series('dog',    'dogdark atlas_%d.png', 5);
series('fuego',  'FUEGO dogdark atlas_%d.png', 3);
series('bomb',   'spiky bomb electric_%d.png', 4);
series('cannonF','ATLAS CANNON_%d.png', 9);
series('cb',     'cannonball ATLAS_%d.png', 3);
series('warn',   'ATLAS_CANNONBALL_WARNING_%d.png', 6);
series('exp',    'ATLAS EXPLOSION_%d.png', 12);
series('hit',    'ATLAS HIT_%d.png', 3);
series('splash', 'ATLAS CANNONBALL SPLASH_%d.png', 6);
series('c',      'SPECIAL COIN ATLAS_%d.png', 7);
series('gem',    'GEMA VERDE atlas_%d.png', 4);
series('ebar',   'energybar-3_%d.png', 4);
series('escudo', 'escudo atlas_%d.png', 8);
series('shield', 'SHIELD ATLAS_%d.png', 9);
series('boost',  'BOOST atlas_%d.png', 5);
series('bruj',   'brujula powerup ATLAS_%d.png', 4);
series('burb',   'burbuja ATLAS_%d.png', 14);
series('frog',   'bubeado atlas_%d.png', 11);
series('flaser', 'laser bubeado atlas 1_%d.png', 5);

// ═══════════════════════════════════════════════════════
//  IMAGE LOADING
// ═══════════════════════════════════════════════════════
const IMG = {};
let loaded = 0;
const TOTAL = Object.keys(ASSETS).length;
function preload() {
  return new Promise(resolve => {
    for (const [k, url] of Object.entries(ASSETS)) {
      const img = new Image();
      img.onload = img.onerror = () => { IMG[k] = img; if (++loaded >= TOTAL) resolve(); };
      img.src = url;
    }
  });
}
function gi(k) { const i = IMG[k]; return (i && i.naturalWidth) ? i : null; }
function di(k, x, y, w, h) { const i = gi(k); if (i) ctx.drawImage(i, x, y, w, h); }
function tileH(k, y, h, offsetX) {
  const i = gi(k); if (!i) return;
  const scale = h / i.naturalHeight;
  const tw = i.naturalWidth * scale;
  const off = -((offsetX % tw) + tw) % tw;
  for (let x = off - tw; x < W + tw; x += tw) ctx.drawImage(i, x, y, tw, h);
}

// ═══════════════════════════════════════════════════════
//  AUDIO (Web Audio — clips m4a extraídos del juego original)
// ═══════════════════════════════════════════════════════
const AUDIO_FILES = ['coin','gema','powerup-turbo','powerup-escudo','powerup-explosion',
  'bruja-aparece','bruja-carga','bruja-dispara','bruja-desaparece',
  'robot-aparece','robot-carga','robot-rayo','perro-ataque',
  'soldado-aviso','soldado-embiste','muerte','mikel-corre',
  'nave-aparece','nave-carga','nave-lanza','nave-disparo',
  'musica-menu','musica-ingame','ui-click','ui-back','ui-play','cannon'];

const AudioMan = {
  ctx:null, buffers:{}, musicSrc:null, musicName:null, runSrc:null,
  musicGain:null, sfxGain:null, unlocked:false,
  muted: localStorage.getItem('mk_mute')==='1',
  init() {
    if (this.ctx) return;
    const AC = window.AudioContext || window.webkitAudioContext;
    if (!AC) return;
    this.ctx = new AC();
    this.musicGain = this.ctx.createGain();
    this.sfxGain   = this.ctx.createGain();
    this.musicGain.connect(this.ctx.destination);
    this.sfxGain.connect(this.ctx.destination);
    this.applyMute();
    for (const n of AUDIO_FILES) {
      fetch(AU+n+'.m4a')
        .then(r => r.ok ? r.arrayBuffer() : Promise.reject())
        .then(ab => this.ctx.decodeAudioData(ab))
        .then(buf => {
          this.buffers[n] = buf;
          // si la música se pidió antes de terminar de decodificar, arrancarla ahora
          if (n===this.musicName && !this.musicSrc) this.music(n);
        })
        .catch(()=>{});
    }
  },
  unlock() {
    this.init();
    if (this.ctx && this.ctx.state==='suspended') this.ctx.resume();
    this.unlocked = true;
  },
  applyMute() {
    if (!this.ctx) return;
    this.musicGain.gain.value = this.muted ? 0 : 0.45;
    this.sfxGain.gain.value   = this.muted ? 0 : 0.9;
  },
  toggleMute() {
    this.muted = !this.muted;
    localStorage.setItem('mk_mute', this.muted?'1':'0');
    this.applyMute();
  },
  sfx(n, {vol=1, rate=1, loop=false}={}) {
    if (!this.ctx || !this.buffers[n]) return null;
    const src = this.ctx.createBufferSource();
    src.buffer = this.buffers[n];
    src.loop = loop;
    src.playbackRate.value = rate;
    const g = this.ctx.createGain();
    g.gain.value = vol;
    src.connect(g); g.connect(this.sfxGain);
    src.start();
    return src;
  },
  music(n) {
    this.musicName = n;
    if (!this.ctx || !this.buffers[n]) return;
    this.stopMusic(false);
    const src = this.ctx.createBufferSource();
    src.buffer = this.buffers[n];
    src.loop = true;
    src.connect(this.musicGain);
    src.start();
    this.musicSrc = src;
  },
  stopMusic(clearName=true) {
    if (this.musicSrc) { try{this.musicSrc.stop();}catch(e){} this.musicSrc=null; }
    if (clearName) this.musicName=null;
  },
  startRun() {
    if (this.runSrc || !this.ctx || !this.buffers['mikel-corre']) return;
    const src = this.ctx.createBufferSource();
    src.buffer = this.buffers['mikel-corre'];
    src.loop = true;
    const g = this.ctx.createGain(); g.gain.value = 0.5;
    src.connect(g); g.connect(this.sfxGain);
    src.start();
    this.runSrc = src;
  },
  stopRun() { if (this.runSrc) { try{this.runSrc.stop();}catch(e){} this.runSrc=null; } },
};
document.addEventListener('visibilitychange', () => {
  if (!AudioMan.ctx) return;
  if (document.hidden) AudioMan.ctx.suspend();
  else if (AudioMan.unlocked) AudioMan.ctx.resume();
});

// ═══════════════════════════════════════════════════════
//  CONSTANTS / STATE
// ═══════════════════════════════════════════════════════
const GROUND  = 415;
const PX      = 175;
const GRAVITY = 0.65;
const JUMP_VY = -15.5;
const PH      = 92, PW = 72;
const LIVES   = 3;
const GEMS_FOR_TURBO = 3;
const BOSS_EVERY = 2800;

const ST = Object.freeze({ LOADING:0, TITLE:1, CHAR_SELECT:2, INTRO:3, PLAYING:4, BOSS:5, DEAD:6 });

let state   = ST.LOADING;
let gframe  = 0;
let score = 0, coins = 0, dist = 0, speed = 4.5;
let lives   = LIVES;
let gems    = 0;
let hiScore = +(localStorage.getItem('mk_hi') || 0);
let selChar = 0;                 // 0=Mikel 1=Leo
let shakeF  = 0, deadF = 0, introF = 0;
let nextBossAt = BOSS_EVERY;
let bossesKilled = 0;

const P = { x:PX, y:GROUND, vy:0, jumps:0, anim:0, atimer:0,
            shielded:0, boosted:0, magnet:0, ducking:false, invincible:0, dead:false };

// Jefe FrogBoss (la rana "Bubeado" en su nave)
const BOSS = { active:false, phase:'', t:0, x:0, y:0, hp:0, maxHp:10,
               laserY:0, laserT:0, flash:0, af:0,
               shipY:GROUND-120, shipTargetY:GROUND-120, fireT:0, bullets:[] };

let obstacles=[], coinItems=[], gemItems=[], powerUps=[], particles=[], effects=[];
let robotEv = null;
let clouds  = [];
let bgOff=0, mtnOff=0, waveOff=0;
let spawnT=0, coinT=0, gemT=0, pupT=0, soldierT=0;

// ═══════════════════════════════════════════════════════
//  HELPERS
// ═══════════════════════════════════════════════════════
function roundRect(x,y,w,h,r) {
  ctx.beginPath();
  ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y);
  ctx.arcTo(x+w,y,x+w,y+r,r); ctx.lineTo(x+w,y+h-r);
  ctx.arcTo(x+w,y+h,x+w-r,y+h,r); ctx.lineTo(x+r,y+h);
  ctx.arcTo(x,y+h,x,y+h-r,r); ctx.lineTo(x,y+r);
  ctx.arcTo(x,y,x+r,y,r); ctx.closePath();
}
function overlaps(ax,ay,aw,ah, bx,by,bw,bh, shrink=10) {
  return ax+shrink < bx+bw-shrink && ax+aw-shrink > bx+shrink &&
         ay+shrink < by+bh-shrink && ay+ah-shrink > by+shrink;
}
function playerRect() {
  const dh = P.ducking ? Math.round(PH*0.55) : PH;
  return { x:P.x-PW*0.42, y:P.y-dh, w:PW*0.84, h:dh };
}
function burst(x,y,color,n=10) {
  for (let i=0;i<n;i++) {
    const a=Math.random()*Math.PI*2, sp=2+Math.random()*5;
    particles.push({ x,y, vx:Math.cos(a)*sp, vy:Math.sin(a)*sp-2.5,
                     life:1.0, r:2+Math.random()*5, color });
  }
}
function shake(f){ shakeF=Math.max(shakeF,f); }
function fx(type,x,y,extra){ effects.push(Object.assign({type,x,y,af:0,at:0},extra||{})); }

function initClouds() {
  clouds = [
    { k:'cloud1', x:90,   y:55, w:220, h:88, sp:0.18 },
    { k:'cloud2', x:380,  y:80, w:180, h:72, sp:0.23 },
    { k:'cloud3', x:640,  y:42, w:205, h:82, sp:0.15 },
    { k:'cloud4', x:860,  y:68, w:165, h:66, sp:0.21 },
    { k:'cloud1', x:1160, y:58, w:200, h:80, sp:0.19 },
    { k:'cloud2', x:1400, y:38, w:180, h:70, sp:0.17 },
  ];
}

// ═══════════════════════════════════════════════════════
//  GAME FLOW
// ═══════════════════════════════════════════════════════
function startIntro() {
  state=ST.INTRO; introF=0;
  score=0; coins=0; dist=0; gems=0; speed=4.5; lives=LIVES;
  deadF=0; shakeF=0; bgOff=0; mtnOff=0; waveOff=0;
  nextBossAt=BOSS_EVERY; bossesKilled=0;
  obstacles=[]; coinItems=[]; gemItems=[]; powerUps=[]; particles=[]; effects=[];
  robotEv=null; BOSS.active=false; BOSS.bullets=[];
  spawnT=140; coinT=90; gemT=520; pupT=600; soldierT=1500;
  P.x=PX; P.y=GROUND; P.vy=0; P.jumps=0; P.anim=0; P.atimer=0;
  P.shielded=0; P.boosted=0; P.magnet=0; P.ducking=false; P.invincible=0; P.dead=false;
  initClouds();
  AudioMan.music('musica-ingame');
}
function beginRun() {
  state=ST.PLAYING;
  AudioMan.startRun();
}
function killPlayer() {
  P.dead=true; state=ST.DEAD; deadF=0;
  AudioMan.stopRun();
  AudioMan.stopMusic();
  AudioMan.sfx('muerte');
  fx('explosion', P.x, P.y-PH*0.4);
  burst(P.x, P.y-PH*0.5, '#ff3300', 24);
  shake(20);
  if (score>hiScore) { hiScore=score; localStorage.setItem('mk_hi',hiScore); }
}
function playerHit() {
  if (P.invincible>0 || P.boosted>0) return;
  if (P.shielded>0) {
    P.shielded=0;
    fx('hit', P.x, P.y-PH*0.5);
    burst(P.x, P.y-PH*0.5, '#88ddff', 14);
    shake(8); return;
  }
  lives--;
  shake(12);
  fx('hit', P.x, P.y-PH*0.5);
  burst(P.x, P.y-PH*0.5, '#ff5533', 16);
  if (lives<=0) { killPlayer(); return; }
  P.invincible=120;
}
function activateTurbo() {
  P.boosted=240;
  speed=Math.min(13,speed+2.5);
  burst(P.x,P.y-PH*0.5,'#ffaa44',14);
  AudioMan.sfx('powerup-turbo');
}

// ═══════════════════════════════════════════════════════
//  INPUT
// ═══════════════════════════════════════════════════════
const keys = {};
document.addEventListener('keydown', e => {
  keys[e.code]=true;
  AudioMan.unlock();
  if (e.code==='Space'||e.code==='ArrowUp') { e.preventDefault(); handleAction(); }
  if (e.code==='ArrowDown'||e.code==='KeyS') { e.preventDefault(); P.ducking=true; }
  if (e.code==='KeyM') AudioMan.toggleMute();
});
document.addEventListener('keyup', e => {
  keys[e.code]=false;
  if (e.code==='ArrowDown'||e.code==='KeyS') P.ducking=false;
});

let pointerDown=false, pointerY=H/2;
canvas.addEventListener('pointerdown', e => {
  e.preventDefault();
  AudioMan.unlock();
  const rect=canvas.getBoundingClientRect();
  const cx=(e.clientX-rect.left)*(W/rect.width);
  const cy=(e.clientY-rect.top)*(H/rect.height);
  pointerDown=true; pointerY=cy;
  if (cx>W-46 && cy<40) { AudioMan.toggleMute(); return; }   // botón mute
  if (state===ST.CHAR_SELECT) { handleCharSelect(cx); return; }
  if (state===ST.DEAD && deadF>50) { handleDeadButtons(cx,cy); return; }
  handleAction();
});
canvas.addEventListener('pointermove', e => {
  const rect=canvas.getBoundingClientRect();
  pointerY=(e.clientY-rect.top)*(H/rect.height);
});
canvas.addEventListener('pointerup',    () => pointerDown=false);
canvas.addEventListener('pointercancel',() => pointerDown=false);

function handleAction() {
  if (state===ST.LOADING) return;
  if (state===ST.TITLE)   { AudioMan.sfx('ui-click'); state=ST.CHAR_SELECT; return; }
  if (state===ST.BOSS)    return;   // disparo automático; mover con puntero/flechas
  if (state===ST.PLAYING && !P.dead && P.jumps<2) {
    P.vy = JUMP_VY - P.jumps*1.8;
    P.jumps++;
    AudioMan.stopRun();
  }
}
function handleCharSelect(cx) {
  const newSel = cx < W/2 ? 0 : 1;
  if (newSel===selChar) { AudioMan.sfx('ui-play'); startIntro(); return; }
  selChar=newSel;
  AudioMan.sfx('ui-click');
}
function handleDeadButtons(cx,cy) {
  const by=H/2+150;
  if (cy>by-34 && cy<by+34) {
    if (cx>W/2-120 && cx<W/2-40) { AudioMan.sfx('ui-play'); startIntro(); return; }
    if (cx>W/2+40 && cx<W/2+120) {
      AudioMan.sfx('ui-back');
      state=ST.TITLE;
      AudioMan.music('musica-menu');
      return;
    }
  }
  AudioMan.sfx('ui-play'); startIntro();
}

// ═══════════════════════════════════════════════════════
//  SPAWNERS (runner)
// ═══════════════════════════════════════════════════════
function spawnObstacle() {
  const r = Math.random();
  const re = W+120;
  const hard = Math.min(1, dist/14000);

  if (r < 0.24) {
    obstacles.push({ type:'espar', x:re, y:GROUND, w:70, h:88, at:0 });
    if (Math.random()<0.4) obstacles.push({ type:'espar', x:re+145, y:GROUND, w:70, h:88, at:0 });
  } else if (r < 0.40) {
    const px = W+80+Math.random()*280;
    obstacles.push({ type:'parachute', x:px, y:-150, w:90, h:130, vy:1.5, af:0, at:0, landed:false, landTimer:0 });
  } else if (r < 0.56) {
    const n = 1+Math.floor(Math.random()*(2+hard*2));
    for (let i=0;i<n;i++) obstacles.push({ type:'cat', x:re+i*108, y:GROUND, w:72, h:32, af:0, at:0 });
  } else if (r < 0.68) {
    obstacles.push({ type:'cannon', x:re, y:GROUND, w:76, h:80, fireIn:65, fired:false, canAf:0, canAt:0 });
  } else if (r < 0.80) {
    // Bruja: aparece → carga → dispara bola guiada → desaparece
    const wy = 170+Math.random()*110;
    obstacles.push({ type:'witch', x:re+80, y:wy, w:82, h:100, af:0, at:0, phase:'enter', pt:0, alpha:1 });
    AudioMan.sfx('bruja-aparece');
  } else if (r < 0.90) {
    // Perro oscuro: al acercarse lanza aliento de fuego
    obstacles.push({ type:'dog', x:re, y:GROUND, w:82, h:74, af:0, at:0, attacking:0, fired:false });
  } else {
    // Bomba eléctrica flotante (agáchate)
    obstacles.push({ type:'bomb', x:re, y:GROUND-112, w:62, h:62, af:0, at:0 });
  }
}
function spawnCoins() {
  const ys=[GROUND-35, GROUND-100, GROUND-162];
  const y=ys[Math.floor(Math.random()*3)];
  const n=3+Math.floor(Math.random()*3);
  for (let i=0;i<n;i++) coinItems.push({ x:W+60+i*58, y, af:0, at:0 });
}
function spawnGem() {
  gemItems.push({ x:W+80, y:GROUND-70-Math.random()*100, af:0, at:0 });
}
function spawnPowerUp() {
  const r=Math.random();
  const type = r<0.4 ? 'shield' : r<0.65 ? 'boost' : r<0.85 ? 'magnet' : 'bomb';
  powerUps.push({ type, x:W+90, y:GROUND-125, af:0, at:0 });
}
function spawnSoldier() {
  obstacles.push({ type:'soldier', x:W+140, y:GROUND, w:96, h:76, af:0, at:0, phase:'warn', pt:0 });
  AudioMan.sfx('soldado-aviso');
}
function spawnRobot() {
  // Evento robot: cae, carga y lanza 1-2 rayos (salta el bajo, agáchate en el alto)
  const doubleBeam = bossesKilled>0 || dist>9000;
  robotEv = { x:W-105, y:-220, phase:'enter', pt:0, af:0,
              beams:[], plan: doubleBeam ? (Math.random()<0.5?['low','high']:['high','low'])
                                         : [Math.random()<0.5?'low':'high'] };
  AudioMan.sfx('robot-aparece');
}
function makeCball(sx,sy) {
  const tx=P.x+30, ty=P.y-18;
  const N=68, g=GRAVITY*0.4;
  const vx=(tx-sx)/N;
  const vy=(ty-sy)/N - 0.5*g*(N-1);
  return { type:'cball', x:sx, y:sy, w:28, h:28, vx, vy, grav:g, af:0, at:0 };
}

// ═══════════════════════════════════════════════════════
//  JEFE — NAVE RANA (FrogBoss del original)
// ═══════════════════════════════════════════════════════
function startBoss() {
  state=ST.BOSS;
  BOSS.active=true; BOSS.phase='enter'; BOSS.t=0;
  BOSS.x=W+220; BOSS.y=220;
  BOSS.hp=BOSS.maxHp=10+bossesKilled*4;
  BOSS.laserT=0; BOSS.flash=0; BOSS.af=0;
  BOSS.shipY=P.y-60; BOSS.shipTargetY=260; BOSS.fireT=0; BOSS.bullets=[];
  obstacles=[]; coinItems=[]; gemItems=[]; powerUps=[];
  robotEv=null;
  P.jumps=0; P.vy=0; P.ducking=false;
  AudioMan.stopRun();
  AudioMan.sfx('nave-aparece');
}
function endBoss() {
  bossesKilled++;
  BOSS.active=false;
  coins+=25;
  gems=Math.min(GEMS_FOR_TURBO-1,gems+1);
  if (lives<LIVES) lives++;            // healthAdd del original
  speed=Math.min(13, 4.5+bossesKilled*0.8);
  nextBossAt=dist+BOSS_EVERY+bossesKilled*600;
  state=ST.PLAYING;
  P.y=GROUND; P.vy=0;
  AudioMan.startRun();
}
function playerShipFire() {
  BOSS.bullets.push({ x:200, y:BOSS.shipY+6, vx:11 });
  AudioMan.sfx('nave-disparo',{vol:0.7});
}
function updateBoss() {
  BOSS.t++;
  if (pointerDown) BOSS.shipTargetY=Math.max(90,Math.min(GROUND-40,pointerY));
  if (keys['ArrowUp'])   BOSS.shipTargetY=Math.max(90, BOSS.shipTargetY-7);
  if (keys['ArrowDown']) BOSS.shipTargetY=Math.min(GROUND-40, BOSS.shipTargetY+7);
  BOSS.shipY += (BOSS.shipTargetY-BOSS.shipY)*0.14;

  bgOff+=speed*0.08; mtnOff+=speed*0.45; waveOff+=speed;
  for (const cl of clouds) { cl.x-=cl.sp*speed*0.55; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*200; }

  if (BOSS.phase==='enter') {
    BOSS.x += (W-190-BOSS.x)*0.05;
    if (Math.abs(BOSS.x-(W-190))<4) { BOSS.phase='fight'; BOSS.t=0; }
  }
  else if (BOSS.phase==='fight') {
    BOSS.y = 210 + Math.sin(BOSS.t*0.023)*115;
    if (BOSS.t%9===0) BOSS.af=(BOSS.af+1)%11;
    BOSS.laserT++;
    const cycle = Math.max(150, 260-bossesKilled*25);
    if (BOSS.laserT===cycle-60) AudioMan.sfx('nave-carga');
    if (BOSS.laserT>=cycle) {
      BOSS.phase='laser'; BOSS.t=0; BOSS.laserY=BOSS.y;
      AudioMan.sfx('nave-lanza');
    }
    if (++BOSS.fireT>=26) { BOSS.fireT=0; playerShipFire(); }
  }
  else if (BOSS.phase==='laser') {
    // 20f de aviso + rayo activo hasta el frame 75
    if (BOSS.t>75) { BOSS.phase='fight'; BOSS.laserT=0; BOSS.t=0; }
    else if (BOSS.t>20) {
      if (Math.abs(BOSS.shipY-BOSS.laserY)<42 && P.invincible<=0) {
        if (P.shielded>0) { P.shielded=0; fx('hit',160,BOSS.shipY); P.invincible=60; shake(8); }
        else {
          lives--; shake(12); fx('hit',160,BOSS.shipY);
          burst(160,BOSS.shipY,'#ff5533',16);
          if (lives<=0) { killPlayer(); return; }
          P.invincible=90;
        }
      }
    }
    if (++BOSS.fireT>=26) { BOSS.fireT=0; playerShipFire(); }
  }
  else if (BOSS.phase==='dying') {
    if (BOSS.t%9===0) {
      fx('explosion', BOSS.x-70+Math.random()*160, BOSS.y-60+Math.random()*130);
      shake(6);
    }
    if (BOSS.t>80) { endBoss(); return; }
  }

  if (P.invincible>0) P.invincible--;
  if (P.shielded>0)   P.shielded--;

  BOSS.bullets = BOSS.bullets.filter(b => {
    b.x+=b.vx;
    if (BOSS.phase!=='dying' &&
        overlaps(b.x-14,b.y-7,28,14, BOSS.x-80,BOSS.y-55,160,120, 0)) {
      BOSS.hp--; BOSS.flash=8;
      burst(b.x,b.y,'#aaffcc',6);
      AudioMan.sfx('coin',{rate:0.6,vol:0.5});
      if (BOSS.hp<=0) {
        BOSS.phase='dying'; BOSS.t=0;
        AudioMan.sfx('powerup-explosion');
        AudioMan.sfx('bruja-desaparece');
      }
      return false;
    }
    return b.x<W+40;
  });
  if (BOSS.flash>0) BOSS.flash--;

  tickEffects(); tickParticles();
  if (shakeF>0) shakeF--;
  score = Math.floor(dist/80)+coins*7+bossesKilled*250;
}

// ═══════════════════════════════════════════════════════
//  UPDATE (runner)
// ═══════════════════════════════════════════════════════
function update() {
  if (state===ST.TITLE || state===ST.CHAR_SELECT) {
    for (const cl of clouds) { cl.x-=cl.sp*3.2; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*100; }
    return;
  }
  if (state===ST.DEAD) {
    deadF++;
    if (shakeF>0) shakeF--;
    tickEffects(); tickParticles();
    for (const cl of clouds) { cl.x-=cl.sp*speed*0.5; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*200; }
    return;
  }
  if (state===ST.BOSS) { updateBoss(); return; }

  if (state===ST.INTRO) {
    introF++;
    bgOff+=1.2; mtnOff+=2; waveOff+=3;
    for (const cl of clouds) { cl.x-=cl.sp*2; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*100; }
    // 0-45: READY · 45: cañonazo · 45-90: vuelo parabólico · 90: GO! y a correr
    if (introF===45) { AudioMan.sfx('cannon'); shake(10); fx('explosion', 105, GROUND-105); }
    if (introF>=45 && introF<90) {
      const t=(introF-45)/45;
      P.x = 70+(PX-70)*t;
      P.y = GROUND-40 - Math.sin(t*Math.PI)*190 + 40*t;
    }
    if (introF>=90) { P.x=PX; P.y=GROUND; beginRun(); }
    tickEffects(); tickParticles();
    if (shakeF>0) shakeF--;
    return;
  }

  if (state!==ST.PLAYING) return;

  // ── PLAYING ──────────────────────────────────────────
  dist+=speed;
  speed=Math.min(13, speed+0.0018);
  score=Math.floor(dist/80)+coins*7+bossesKilled*250;

  if (dist>=nextBossAt && !robotEv) { startBoss(); return; }

  bgOff+=speed*0.08; mtnOff+=speed*0.45; waveOff+=speed;

  if (P.invincible>0) P.invincible--;
  if (P.shielded>0)  P.shielded--;
  if (P.magnet>0)    P.magnet--;
  if (P.boosted>0)  { P.boosted--; if (!P.boosted) speed=Math.max(4.5,speed-2.5); }

  const wasAir = P.y<GROUND-1;
  P.vy+=GRAVITY;
  P.y+=P.vy;
  if (P.y>=GROUND) {
    P.y=GROUND; P.vy=0; P.jumps=0;
    if (wasAir) AudioMan.startRun();
  }
  if (P.y>=GROUND-1) {
    P.atimer+=speed*0.48;
    if (P.atimer>=1) { P.atimer=0; P.anim=(P.anim+1)%9; }
  }

  for (const cl of clouds) { cl.x-=cl.sp*speed*0.55; if (cl.x+cl.w<-20) cl.x=W+cl.w+Math.random()*200; }

  if (!robotEv) {
    if (--spawnT<=0)   { spawnObstacle(); spawnT=Math.max(50,160-Math.floor(dist/2000)); }
    if (--coinT<=0)    { spawnCoins();    coinT=Math.max(62,140-Math.floor(dist/3000)); }
    if (--gemT<=0)     { spawnGem();      gemT=420+(Math.random()*380|0); }
    if (--pupT<=0)     { spawnPowerUp();  pupT=460+(Math.random()*420|0); }
    if (--soldierT<=0) {
      if (Math.random()<0.5 && dist>3500) spawnRobot();
      else spawnSoldier();
      soldierT=900+(Math.random()*700|0);
    }
  }

  updateRobot();
  updateObstacles();
  updateCollectibles();
  checkCollisions();

  tickEffects(); tickParticles();
  if (shakeF>0) shakeF--;
}

// ── Evento robot ───────────────────────────────────────
function updateRobot() {
  if (!robotEv) return;
  const R=robotEv;
  R.pt++;
  if (R.pt%6===0) R.af=(R.af+1)%8;

  if (R.phase==='enter') {
    R.y += (GROUND-170-R.y)*0.07;
    if (Math.abs(R.y-(GROUND-170))<4) { R.phase='charge'; R.pt=0; AudioMan.sfx('robot-carga'); }
  }
  else if (R.phase==='charge') {
    if (R.pt>=55) {
      R.phase='fire'; R.pt=0;
      R.beams.push({ h:R.plan.shift(), t:0 });
      AudioMan.sfx('robot-rayo');
    }
  }
  else if (R.phase==='fire') {
    for (const b of R.beams) b.t++;
    R.beams=R.beams.filter(b=>b.t<95);
    const pr=playerRect();
    for (const b of R.beams) {
      if (b.t<20||b.t>80) continue;
      const by = b.h==='low' ? GROUND-50 : GROUND-148;
      if (overlaps(pr.x,pr.y,pr.w,pr.h, 0,by,R.x-30,52, 6)) playerHit();
    }
    if (R.beams.length===0) {
      if (R.plan.length>0) { R.phase='charge'; R.pt=30; AudioMan.sfx('robot-carga'); }
      else { R.phase='exit'; R.pt=0; }
    }
  }
  else if (R.phase==='exit') {
    R.y-=6;
    if (R.y<-260) robotEv=null;
  }
}

// ── Obstáculos ─────────────────────────────────────────
function updateObstacles() {
  const nextObs=[];
  for (const ob of obstacles) {
    if (ob.type!=='soldier') ob.x-=speed;
    if (ob.x<-380) continue;

    if (ob.type==='espar') { ob.at++; ob.x-=speed*0.16; }

    else if (ob.type==='parachute') {
      ob.at++;
      if (ob.at%12===0) ob.af^=1;
      if (!ob.landed) {
        ob.vy=Math.min(4,ob.vy+0.06);
        ob.y+=ob.vy;
        if (ob.y>=GROUND) { ob.y=GROUND; ob.landed=true; ob.landTimer=0; fx('explosion',ob.x,GROUND-40); }
      } else if (++ob.landTimer>42) continue;
    }

    else if (ob.type==='cat') { ob.at++; if (ob.at%4===0) ob.af=(ob.af+1)%5; }

    else if (ob.type==='witch') {
      ob.at++;
      if (ob.at%5===0) ob.af=(ob.af+1)%6;
      ob.pt++;
      ob.y += Math.sin(ob.at*0.06)*0.8;
      if (ob.phase==='enter' && ob.x<W*0.78) { ob.phase='charge'; ob.pt=0; AudioMan.sfx('bruja-carga'); }
      else if (ob.phase==='charge' && ob.pt>=50) {
        ob.phase='shot'; ob.pt=0;
        AudioMan.sfx('bruja-dispara');
        const dx=P.x-ob.x, dy=(P.y-PH*0.5)-ob.y;
        const d=Math.hypot(dx,dy)||1, sp2=5.5;
        nextObs.push({ type:'bola', x:ob.x, y:ob.y+50, w:34, h:34,
                       vx:dx/d*sp2, vy:dy/d*sp2, af:0, at:0, homing:45 });
      }
      else if (ob.phase==='shot' && ob.pt>=45) { ob.phase='fade'; ob.pt=0; AudioMan.sfx('bruja-desaparece'); }
      else if (ob.phase==='fade') {
        ob.alpha-=0.04;
        if (ob.alpha<=0) continue;
      }
    }

    else if (ob.type==='bola') {
      if (ob.homing>0) {
        ob.homing--;
        const dx=P.x-ob.x, dy=(P.y-PH*0.5)-ob.y, d=Math.hypot(dx,dy)||1;
        ob.vx+= (dx/d*5.5-ob.vx)*0.04;
        ob.vy+= (dy/d*5.5-ob.vy)*0.04;
      }
      ob.x+=ob.vx; ob.y+=ob.vy; ob.at++;
      if (ob.at%4===0) ob.af=(ob.af+1)%3;
      if (ob.x<-80||ob.y>H+60) continue;
    }

    else if (ob.type==='dog') {
      ob.at++;
      if (ob.at%6===0) ob.af=(ob.af+1)%5;
      if (!ob.fired && ob.x-P.x<400) {
        ob.fired=true; ob.attacking=60;
        AudioMan.sfx('perro-ataque');
      }
      if (ob.attacking>0) ob.attacking--;
    }

    else if (ob.type==='bomb') {
      ob.at++;
      if (ob.at%5===0) ob.af=(ob.af+1)%4;
      ob.y += Math.sin(ob.at*0.08)*0.6;
    }

    else if (ob.type==='soldier') {
      ob.pt++; ob.at++;
      if (ob.at%5===0) ob.af^=1;
      if (ob.phase==='warn') {
        if (ob.pt>=70) { ob.phase='charge'; AudioMan.sfx('soldado-embiste'); }
      } else {
        ob.x -= speed*2.6;
      }
    }

    else if (ob.type==='cannon') {
      ob.at++; ob.canAt++;
      if (ob.canAt%4===0) ob.canAf=(ob.canAf+1)%9;
      if (!ob.fired && --ob.fireIn<=0) {
        ob.fired=true;
        AudioMan.sfx('cannon',{vol:0.7});
        fx('warning', P.x, GROUND-90, {life:55});
        nextObs.push(makeCball(ob.x-20, ob.y-62));
      }
    }

    else if (ob.type==='cball') {
      ob.vy+=ob.grav; ob.x+=ob.vx; ob.y+=ob.vy; ob.at++;
      if (ob.at%4===0) ob.af=(ob.af+1)%3;
      if (ob.y>GROUND+8) { fx('splash',ob.x,GROUND); continue; }
    }

    nextObs.push(ob);
  }
  obstacles=nextObs;
}

// ── Coleccionables ─────────────────────────────────────
function updateCollectibles() {
  const pr=playerRect();
  coinItems=coinItems.filter(c=>{
    c.x-=speed; c.at++;
    if (c.at%5===0) c.af=(c.af+1)%7;
    if (P.magnet>0) {
      const dx=P.x-c.x, dy=(P.y-PH*0.5)-c.y, d=Math.hypot(dx,dy)||1;
      if (d<260) { c.x+=dx/d*9; c.y+=dy/d*9; }
    }
    if (overlaps(pr.x,pr.y,pr.w,pr.h, c.x-16,c.y-16,32,32, 2)) {
      coins++;
      burst(c.x,c.y,'#FFD700',8);
      AudioMan.sfx('coin',{vol:0.8});
      return false;
    }
    return c.x>-60;
  });
  gemItems=gemItems.filter(gm=>{
    gm.x-=speed; gm.at++;
    if (gm.at%6===0) gm.af=(gm.af+1)%4;
    if (overlaps(pr.x,pr.y,pr.w,pr.h, gm.x-20,gm.y-20,40,40, 2)) {
      gems++;
      burst(gm.x,gm.y,'#44ff88',10);
      AudioMan.sfx('gema');
      if (gems>=GEMS_FOR_TURBO) { gems=0; activateTurbo(); }
      return false;
    }
    return gm.x>-60;
  });
  powerUps=powerUps.filter(pu=>{
    pu.x-=speed; pu.at++;
    if (pu.at%6===0) pu.af=(pu.af+1)%8;
    if (overlaps(pr.x,pr.y,pr.w,pr.h, pu.x-24,pu.y-24,48,48, 2)) {
      if (pu.type==='shield') {
        P.shielded=420;
        burst(P.x,P.y-PH*0.5,'#88ddff',16);
        AudioMan.sfx('powerup-escudo');
      } else if (pu.type==='boost') {
        activateTurbo();
      } else if (pu.type==='magnet') {
        P.magnet=480;
        burst(P.x,P.y-PH*0.5,'#ffee66',14);
        AudioMan.sfx('powerup-escudo',{rate:1.3});
      } else {
        // Bomba: limpia la pantalla (PowerUp Explosión del original)
        AudioMan.sfx('powerup-explosion');
        shake(14);
        for (const ob of obstacles) {
          if (ob.x>-100 && ob.x<W+150) fx('explosion', ob.x, ob.y-(ob.h||60)*0.5);
        }
        obstacles=[];
      }
      return false;
    }
    return pu.x>-80;
  });
}

// ── Colisiones jugador/obstáculo ───────────────────────
function checkCollisions() {
  const pr=playerRect();
  for (const ob of obstacles) {
    if (ob.x<-200) continue;
    let bx,by,bw,bh;
    switch(ob.type) {
      case 'espar':     bx=ob.x-ob.w*0.5; by=ob.y-ob.h; bw=ob.w; bh=ob.h; break;
      case 'parachute': if (ob.landed){bx=ob.x-38;by=ob.y-55;bw=76;bh=55;}
                        else {bx=ob.x-35;by=ob.y-60;bw=70;bh=60;} break;
      case 'cat':       bx=ob.x-36; by=ob.y-ob.h; bw=ob.w; bh=ob.h; break;
      case 'cball':     bx=ob.x-13; by=ob.y-13; bw=26; bh=26; break;
      case 'bola':      bx=ob.x-14; by=ob.y-14; bw=28; bh=28; break;
      case 'bomb':      bx=ob.x-26; by=ob.y-26; bw=52; bh=52; break;
      case 'soldier':   if (ob.phase!=='charge') continue;
                        bx=ob.x-44; by=ob.y-ob.h; bw=ob.w; bh=ob.h; break;
      case 'dog':
        bx=ob.x-38; by=ob.y-ob.h; bw=ob.w; bh=ob.h;
        if (ob.attacking>10 && ob.attacking<55) {
          if (overlaps(pr.x,pr.y,pr.w,pr.h, ob.x-190,GROUND-58,155,58, 6)) {
            playerHit();
            if (state===ST.DEAD) return;
          }
        }
        break;
      default: continue;
    }
    if (overlaps(pr.x,pr.y,pr.w,pr.h, bx,by,bw,bh)) {
      if (P.boosted>0) { fx('explosion', ob.x, ob.y-(ob.h||50)*0.5); ob.x=-999; shake(6); continue; }
      ob.x=-999;
      playerHit();
      if (state===ST.DEAD) return;
    }
  }
}

function tickEffects() {
  effects=effects.filter(ef=>{
    ef.at++;
    if (ef.type==='explosion') { if (ef.at%3===0) ef.af++; return ef.af<12; }
    if (ef.type==='splash')    { if (ef.at%4===0) ef.af++; return ef.af<6;  }
    if (ef.type==='hit')       { if (ef.at%5===0) ef.af++; return ef.af<3;  }
    if (ef.type==='warning')   { ef.life--; if (ef.at%5===0) ef.af=(ef.af+1)%6; return ef.life>0; }
    return false;
  });
}
function tickParticles() {
  particles=particles.filter(p=>{
    p.x+=p.vx; p.y+=p.vy; p.vy+=0.22; p.life-=0.028; return p.life>0;
  });
}

// ═══════════════════════════════════════════════════════
//  DRAW — FONDO
// ═══════════════════════════════════════════════════════
function drawBg() {
  const g=ctx.createLinearGradient(0,0,0,GROUND);
  g.addColorStop(0,'#0d3a7a'); g.addColorStop(0.5,'#1a6dcc'); g.addColorStop(1,'#5fc8e8');
  ctx.fillStyle=g; ctx.fillRect(0,0,W,GROUND);
  const bi=gi('bg');
  if (bi) {
    const scale=GROUND/bi.naturalHeight;
    const bw=bi.naturalWidth*scale;
    const bx=-((bgOff%bw)+bw)%bw;
    ctx.globalAlpha=0.78;
    ctx.drawImage(bi,bx,0,bw,GROUND);
    if (bx+bw<W) ctx.drawImage(bi,bx+bw,0,bw,GROUND);
    ctx.globalAlpha=1;
  }
}
function drawClouds() {
  for (const cl of clouds) {
    const i=gi(cl.k); if (!i) continue;
    ctx.globalAlpha=0.9;
    ctx.drawImage(i,cl.x,cl.y,cl.w,cl.h);
    ctx.globalAlpha=1;
  }
}
function drawMountains() {
  const m1=gi('mtn1');
  if (m1) {
    const h1=148, w1=m1.naturalWidth*(h1/m1.naturalHeight);
    const off1=((mtnOff*0.42)%w1+w1)%w1;
    ctx.globalAlpha=0.68;
    for (let x=-off1-w1;x<W+w1;x+=w1+6) ctx.drawImage(m1,x,GROUND-h1,w1,h1);
    ctx.globalAlpha=1;
  }
  const m2=gi('mtn2');
  if (m2) {
    const h2=192, w2=m2.naturalWidth*(h2/m2.naturalHeight);
    const off2=((mtnOff*0.88)%w2+w2)%w2;
    ctx.globalAlpha=0.84;
    for (let x=-off2-w2;x<W+w2;x+=w2+4) ctx.drawImage(m2,x,GROUND-h2,w2,h2);
    ctx.globalAlpha=1;
  }
}
function drawOcean() {
  const og=ctx.createLinearGradient(0,GROUND,0,H);
  og.addColorStop(0,'#1888d8'); og.addColorStop(1,'#072560');
  ctx.fillStyle=og; ctx.fillRect(0,GROUND,W,H-GROUND);
  tileH('wave', GROUND-22, 58, waveOff);
  tileH('wood', GROUND+5, 40, waveOff*0.88);
  ctx.fillStyle='#c89840'; ctx.fillRect(0,GROUND,W,5);
}

// ═══════════════════════════════════════════════════════
//  DRAW — JUGADOR
// ═══════════════════════════════════════════════════════
// Leo no tiene ciclo de carrera en los assets del APK: se distingue con un tinte
function charFilter() { return selChar===1 ? 'hue-rotate(120deg) saturate(1.15)' : 'none'; }

function drawPlayer() {
  const pr=playerRect();
  const onGround=P.y>=GROUND-2;
  const isDuck=P.ducking&&onGround;
  const flicker=P.invincible>0 && Math.floor(gframe/4)%2===1;

  if (flicker) ctx.globalAlpha=0.3;

  if (P.boosted>0) {
    const wf=gi('wind'+(Math.floor(gframe/4)%4));
    if (wf) {
      const oldA=ctx.globalAlpha;
      ctx.globalAlpha=Math.min(oldA,0.8);
      ctx.drawImage(wf, P.x-115, P.y-PH-8, 100, PH+16);
      ctx.globalAlpha=oldA;
    }
  }

  if (P.shielded>0) {
    const si=gi('shield'+(Math.floor(gframe/4)%9));
    if (si) {
      const oldA=ctx.globalAlpha;
      ctx.globalAlpha=Math.min(oldA,0.55);
      ctx.drawImage(si, pr.x-22, pr.y-14, pr.w+44, pr.h+28);
      ctx.globalAlpha=oldA;
    }
  }

  if (ctx.filter!==undefined) ctx.filter=charFilter();

  if (state===ST.DEAD) {
    if (ctx.filter!==undefined) ctx.filter='none';
    di('splat', P.x-55, P.y-PH-18, 96, PH+40);
  } else if (state===ST.INTRO && introF>=45 && introF<90) {
    const jw=PW*1.1;
    ctx.save();
    ctx.translate(P.x,P.y-PH*0.5);
    ctx.rotate(((introF-45)/45)*Math.PI*2);
    const ji=gi('jump');
    if (ji) ctx.drawImage(ji,-jw*0.5,-PH*0.5,jw,PH);
    ctx.restore();
  } else if (!onGround) {
    const jw=PW*1.1;
    di('jump', P.x-jw*0.5+5, P.y-PH, jw, PH);
  } else if (isDuck) {
    ctx.save();
    ctx.translate(P.x,P.y);
    ctx.scale(1,0.55);
    const ri=gi('r'+Math.floor(P.anim));
    if (ri) ctx.drawImage(ri,-PW*0.5+5,-PH,PW,PH);
    ctx.restore();
  } else if (P.boosted>0) {
    const ti=gi('tur'+(Math.floor(gframe/4)%2));
    if (ti) ctx.drawImage(ti, P.x-PW*0.62, P.y-PH-4, PW*1.3, PH+4);
    else { const ri=gi('r'+Math.floor(P.anim)); if (ri) ctx.drawImage(ri,P.x-PW*0.5+5,P.y-PH,PW,PH); }
  } else {
    const ri=gi('r'+Math.floor(P.anim));
    if (ri) ctx.drawImage(ri, P.x-PW*0.5+5, P.y-PH, PW, PH);
    else { ctx.fillStyle='#3498db'; ctx.fillRect(P.x-PW*0.5,P.y-PH,PW,PH); }
  }

  if (ctx.filter!==undefined) ctx.filter='none';
  ctx.globalAlpha=1;
}

// ═══════════════════════════════════════════════════════
//  DRAW — OBSTÁCULOS / ROBOT
// ═══════════════════════════════════════════════════════
function drawBeamH(imgKey, frame, y, xEnd, thick, alpha) {
  // dibuja un rayo horizontal en mosaico con un sprite vertical rotado -90°
  const ri=gi(imgKey+frame);
  ctx.globalAlpha=alpha;
  if (ri) {
    const tw=thick*ri.naturalHeight/ri.naturalWidth;
    for (let x=0; x<xEnd; x+=tw*0.85) {
      ctx.save();
      ctx.translate(x+tw*0.5, y);
      ctx.rotate(-Math.PI/2);
      ctx.drawImage(ri, -thick*0.5, -tw*0.5, thick, tw);
      ctx.restore();
    }
  } else {
    ctx.fillStyle='#8feaff';
    ctx.fillRect(0, y-thick*0.5, xEnd, thick);
  }
  ctx.globalAlpha=1;
}

function drawRobot() {
  if (!robotEv) return;
  const R=robotEv;
  for (const b of R.beams) {
    const by = (b.h==='low' ? GROUND-50 : GROUND-148) + 26;
    const active = b.t>=20 && b.t<=80;
    const alpha = active ? 0.95 : (b.t<20 ? 0.3+0.2*Math.sin(b.t) : Math.max(0,(95-b.t)/15));
    drawBeamH('rayo', Math.floor(b.t/3)%3, by, R.x-30, active?52:14, alpha);
  }
  const rb=gi('robot'+R.af);
  if (rb) {
    const rh=180, rw=rh*rb.naturalWidth/rb.naturalHeight;
    ctx.save();
    if (R.phase==='charge') { ctx.shadowColor='#66eaff'; ctx.shadowBlur=18+Math.sin(R.pt*0.4)*10; }
    ctx.drawImage(rb, R.x-rw*0.5, R.y-rh*0.5, rw, rh);
    ctx.restore();
  }
}

function drawObstacles() {
  for (const ob of obstacles) {
    if (ob.x<-380||ob.x>W+320) continue;

    if (ob.type==='espar') {
      const ei=gi('espar');
      if (ei) ctx.drawImage(ei, ob.x-ob.w*0.5, ob.y-ob.h, ob.w, ob.h);
    }
    else if (ob.type==='parachute') {
      const pi=gi(ob.af===0?'pirata0':'pirata1');
      if (pi) ctx.drawImage(pi, ob.x-45, ob.y-ob.h, ob.w, ob.h);
    }
    else if (ob.type==='cat') {
      const ci=gi('g'+ob.af);
      if (ci) ctx.drawImage(ci, ob.x-36, ob.y-ob.h, ob.w, ob.h);
    }
    else if (ob.type==='witch') {
      ctx.globalAlpha=Math.max(0, ob.alpha);
      const wi=gi('bruja'+ob.af);
      if (wi) {
        ctx.save();
        if (ob.phase==='charge') { ctx.shadowColor='#dd66ff'; ctx.shadowBlur=16+Math.sin(ob.pt*0.4)*8; }
        ctx.drawImage(wi, ob.x-41, ob.y, 82, 100);
        ctx.restore();
      }
      ctx.globalAlpha=1;
    }
    else if (ob.type==='bola') {
      const bi=gi('bola'+ob.af);
      if (bi) ctx.drawImage(bi, ob.x-19, ob.y-19, 38, 38);
      else { ctx.fillStyle='#cc2244'; ctx.beginPath(); ctx.arc(ob.x,ob.y,14,0,Math.PI*2); ctx.fill(); }
    }
    else if (ob.type==='dog') {
      const dgi=gi('dog'+ob.af);
      if (dgi) ctx.drawImage(dgi, ob.x-41, ob.y-ob.h, 82, ob.h);
      if (ob.attacking>10 && ob.attacking<55) {
        const fi=gi('fuego'+(Math.floor(ob.at/4)%3));
        if (fi) ctx.drawImage(fi, ob.x-205, ob.y-72, 175, 76);
      }
    }
    else if (ob.type==='bomb') {
      const bi=gi('bomb'+ob.af);
      if (bi) ctx.drawImage(bi, ob.x-31, ob.y-31, 62, 62);
    }
    else if (ob.type==='soldier') {
      if (ob.phase==='warn') {
        const wi=gi('soldierWarn');
        if (wi && Math.floor(ob.pt/7)%2===0) ctx.drawImage(wi, W-108, GROUND-176, 92, 88);
      } else {
        const mi=gi(ob.af===0?'moto0':'moto1');
        if (mi) ctx.drawImage(mi, ob.x-48, ob.y-ob.h, ob.w, ob.h);
      }
    }
    else if (ob.type==='cannon') {
      di('cannonBig', ob.x-38, ob.y-80, 76, 80);
      if (ob.fired) {
        const cf=gi('cannonF'+ob.canAf);
        if (cf) ctx.drawImage(cf, ob.x-55, ob.y-92, 104, 52);
      }
    }
    else if (ob.type==='cball') {
      const cbi=gi('cb'+ob.af);
      if (cbi) {
        ctx.save();
        ctx.translate(ob.x,ob.y);
        ctx.rotate(Math.atan2(ob.vy,ob.vx));
        ctx.drawImage(cbi,-14,-22,28,44);
        ctx.restore();
      }
    }
  }
}

// ═══════════════════════════════════════════════════════
//  DRAW — COLECCIONABLES / EFECTOS
// ═══════════════════════════════════════════════════════
function drawCollectibles() {
  for (const c of coinItems) {
    const ci=gi('c'+c.af);
    if (ci) ctx.drawImage(ci, c.x-18, c.y-18, 36, 36);
  }
  for (const gm of gemItems) {
    const g2=gi('gem'+gm.af);
    ctx.save();
    ctx.shadowColor='#44ff88'; ctx.shadowBlur=12;
    if (g2) ctx.drawImage(g2, gm.x-20, gm.y-20, 40, 40);
    ctx.restore();
  }
  for (const pu of powerUps) {
    const pulse=1+Math.sin(gframe*0.14)*0.06, sz=48*pulse;
    ctx.save();
    ctx.shadowColor = pu.type==='shield'?'#44aaff':pu.type==='boost'?'#ffaa22':pu.type==='magnet'?'#ffee55':'#ff5533';
    ctx.shadowBlur=16+Math.sin(gframe*0.12)*6;
    if (pu.type==='shield') {
      const ei=gi('escudo'+pu.af);
      if (ei) ctx.drawImage(ei, pu.x-sz*0.5, pu.y-sz*0.6, sz, sz*1.3);
    } else if (pu.type==='boost') {
      const bi2=gi('boost'+(pu.af%5));
      if (bi2) ctx.drawImage(bi2, pu.x-sz*0.5, pu.y-sz*0.5, sz, sz);
    } else if (pu.type==='magnet') {
      const bj=gi('bruj'+(pu.af%4));
      if (bj) ctx.drawImage(bj, pu.x-sz*0.5, pu.y-sz*0.55, sz, sz*1.1);
    } else {
      const ex=gi('exp2');
      if (ex) ctx.drawImage(ex, pu.x-sz*0.5, pu.y-sz*0.5, sz, sz);
    }
    const bu=gi('burb'+(Math.floor(gframe/5)%14));
    if (bu) { ctx.globalAlpha=0.45; ctx.drawImage(bu, pu.x-sz*0.75, pu.y-sz*0.75, sz*1.5, sz*1.5); ctx.globalAlpha=1; }
    ctx.restore();
  }
}
function drawEffects() {
  for (const ef of effects) {
    if (ef.type==='explosion') {
      const ei2=gi('exp'+Math.min(11,ef.af));
      if (ei2) ctx.drawImage(ei2, ef.x-50, ef.y-50, 100, 100);
    } else if (ef.type==='splash') {
      const si=gi('splash'+Math.min(5,ef.af));
      if (si) ctx.drawImage(si, ef.x-24, ef.y-48, 48, 50);
    } else if (ef.type==='hit') {
      const hi=gi('hit'+Math.min(2,ef.af));
      if (hi) { ctx.globalAlpha=0.88; ctx.drawImage(hi, ef.x-44, ef.y-50, 88, 104); ctx.globalAlpha=1; }
    } else if (ef.type==='warning') {
      const wf=gi('warn'+ef.af);
      ctx.globalAlpha=Math.min(1, ef.life/18);
      if (wf) ctx.drawImage(wf, ef.x-26, ef.y-32, 52, 52);
      ctx.globalAlpha=1;
    }
  }
}
function drawParticles() {
  for (const p of particles) {
    ctx.globalAlpha=Math.max(0,p.life);
    ctx.fillStyle=p.color;
    ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2); ctx.fill();
  }
  ctx.globalAlpha=1;
}

// ═══════════════════════════════════════════════════════
//  DRAW — JEFE
// ═══════════════════════════════════════════════════════
function drawBoss() {
  if (BOSS.phase==='laser') {
    const active=BOSS.t>20;
    drawBeamH('flaser', Math.floor(BOSS.t/3)%5, BOSS.laserY, BOSS.x-70,
              active?58:14, active?0.95:0.3+0.2*Math.sin(BOSS.t*0.8));
  }
  if (BOSS.phase==='fight') {
    const cycle=Math.max(150,260-bossesKilled*25);
    if (BOSS.laserT>cycle-60) {
      ctx.save();
      ctx.shadowColor='#ff4444'; ctx.shadowBlur=20;
      ctx.fillStyle=`rgba(255,80,80,${0.4+0.3*Math.sin(BOSS.laserT*0.5)})`;
      ctx.beginPath(); ctx.arc(BOSS.x-95, BOSS.y, 16, 0, Math.PI*2); ctx.fill();
      ctx.restore();
    }
  }
  if (BOSS.phase!=='dying' || BOSS.t<60) {
    const fi=gi('frog'+BOSS.af);
    ctx.save();
    if (BOSS.flash>0 && ctx.filter!==undefined) ctx.filter='brightness(2.2)';
    if (fi) {
      const fh=150, fw=fh*fi.naturalWidth/fi.naturalHeight;
      ctx.translate(BOSS.x, BOSS.y);
      ctx.drawImage(fi, -fw*0.5, -fh*0.5, fw, fh);
    }
    ctx.restore();
    if (ctx.filter!==undefined) ctx.filter='none';
    const bw2=220, bx2=BOSS.x-bw2*0.5, by2=BOSS.y-105;
    ctx.fillStyle='rgba(0,0,0,0.55)'; roundRect(bx2,by2,bw2,13,6); ctx.fill();
    ctx.fillStyle='#66ff44'; roundRect(bx2+2,by2+2,(bw2-4)*Math.max(0,BOSS.hp/BOSS.maxHp),9,4); ctx.fill();
  }
  for (const b of BOSS.bullets) {
    const bi=gi('bullet');
    if (bi) ctx.drawImage(bi, b.x-16, b.y-8, 32, 16);
    else { ctx.fillStyle='#aaffcc'; ctx.fillRect(b.x-12,b.y-4,24,8); }
  }
  const shi=gi('ship');
  if (ctx.filter!==undefined) ctx.filter=charFilter();
  if (shi) {
    const sw2=120, sh2=sw2*shi.naturalHeight/shi.naturalWidth;
    if (P.invincible>0 && Math.floor(gframe/4)%2===1) ctx.globalAlpha=0.35;
    ctx.drawImage(shi, 150-sw2*0.5, BOSS.shipY-sh2*0.5, sw2, sh2);
    ctx.globalAlpha=1;
  }
  if (ctx.filter!==undefined) ctx.filter='none';
  if (P.shielded>0) {
    const si=gi('shield'+(Math.floor(gframe/4)%9));
    if (si) { ctx.globalAlpha=0.5; ctx.drawImage(si, 150-70, BOSS.shipY-58, 140, 116); ctx.globalAlpha=1; }
  }
}

