---
const TARGET = "https://www.sinmaletas.com/";
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content={`0; url=${TARGET}`} />
  <meta name="robots" content="noindex, nofollow" />
  <title>Redirigiendo a Sinmaletas…</title>
  <script define:vars={{ TARGET }}>window.location.replace(TARGET);</script>
</head>
<body>
  <p>Redirigiendo… <a href={TARGET}>Haz clic aquí si no te redirige</a></p>
</body>
</html>
