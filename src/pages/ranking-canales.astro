---
import BaseLayout from '../layouts/BaseLayout.astro';
import ytData from '../data/channels_yt.json';

// ── Canal definitions ────────────────────────────────────────────────────────
const channelDefs = [
  { name: 'Los Polinesios',          handle: '@LosPolinesios',        emoji: '🌺', color: '#ff7675', era: '2013 – hoy',   status: 'activo',     cat: 'Familia & Vlogs',          desc: 'La familia youtuber más grande de habla hispana. Tres hermanos que convirtieron su vida en espectáculo.', quizInclude: true },
  { name: 'Rovi23',                  handle: '@Rovi23',               emoji: '🎮', color: '#a29bfe', era: '2013 – hoy',   status: 'activo',     cat: 'Gaming & Entretenimiento', desc: 'El referente del gaming familiar español. Retos, bromas y una energía que enganchaba a toda la familia.', quizInclude: true },
  { name: 'Los juguetes de Arantxa', handle: '@LosjuguetesdeArantxa', emoji: '🧸', color: '#fd79a8', era: '2016 – 2022',  status: 'inactivo',   cat: 'Juguetes',                 desc: 'Una niña de verdad abriendo sus juguetes. Auténtica y cercana, con una colección que daba envidia.', quizInclude: true },
  { name: 'The Crazy Haacks',        handle: '@TheCrazyHaacks',       emoji: '🧪', color: '#00cec9', era: '2017 – hoy',   status: 'activo',     cat: 'Ciencia & Experimentos',   desc: 'Experimentos imposibles que hacían rezar a los padres para que no los intentaras en casa.', quizInclude: true },
  { name: 'Jugando con Aby',         handle: '@JugandoconAby',        emoji: '🎀', color: '#e17055', era: '2014 – 2022',  status: 'esporádico', cat: 'Juguetes & Gaming',        desc: 'La reina del unboxing y los juguetes. Millones de niños se despertaban los sábados esperando su nuevo vídeo.', quizInclude: true },
  { name: 'Familia Carameluchi',     handle: '@FamiliaCarameluchi',   emoji: '🍬', color: '#fdcb6e', era: '2015 – hoy',   status: 'esporádico', cat: 'Familia',                  desc: 'La familia más dulce de YouTube. Rutinas, retos y momentos cotidianos que se sentían cercanos de verdad.', quizInclude: true },
  { name: 'Abreló Toys',             handle: 'AbrelóToys',            emoji: '🎁', color: '#6c5ce7', era: '2015 – 2021',  status: 'inactivo',   cat: 'Juguetes',                 desc: 'Unboxings épicos que hacían que todos los niños quisieran esos mismos juguetes en Navidad.', quizInclude: true },
  { name: 'Tremendig Girls',         handle: '@HermanosTremending',   emoji: '👯', color: '#fd79a8', era: '2016 – hoy',   status: 'activo',     cat: 'Familia & Hermanas',       desc: 'Las hermanas Tremending con sus challenges, vlogs y una energía que arrasó en toda España.', quizInclude: true },
  { name: 'Los Jaritos',             handle: '@losjaritos1023',        emoji: '🫙', color: '#55efc4', era: '2018 – hoy',   status: 'esporádico', cat: 'Familia & Vlogs',          desc: 'Una familia normal con una cámara y muchas ganas de compartir. La esencia del vlog familiar de barrio.', quizInclude: true },
  { name: 'La diversión de Martina', handle: '@MartinaDAntiochia',    emoji: '🌈', color: '#ff9ff3', era: '2015 – 2021',  status: 'inactivo',   cat: 'Familia',                  desc: 'Martina y su familia en vlogs, retos y momentos que parecían sacados de la familia perfecta.', quizInclude: true },
  { name: 'Las Ratitas pandilleras', handle: '@RatitasPandilleras',   emoji: '🐭', color: '#badc58', era: '2016 – 2023',  status: 'esporádico', cat: 'Familia & Hermanas',       desc: 'Tres hermanas, caos total y risas garantizadas. El caos familiar convertido en entretenimiento puro.', quizInclude: true },
  { name: 'Los Familukis',           handle: '@MagicExploradores',    emoji: '🌊', color: '#e50914', era: '2020 – hoy',   status: 'activo',     cat: 'Familia & Aventuras',      desc: '¡Ese somos nosotros! Parques, aventuras y momentos reales en familia. El relevo generacional está aquí 👋', quizInclude: false, isFamilukis: true, staticThumb: '/favicon-512x512.png' },
];

// ── Merge static definitions with YouTube API data ───────────────────────────
const channels = channelDefs.map(ch => {
  const yt = (ytData as any)[ch.name] ?? {};
  return {
    ...ch,
    id:   yt.channel_id ?? null,
    subs: yt.subscriber_count ?? null,
    // staticThumb (favicon) overrides API thumb for own channel
    thumb: (ch as any).staticThumb ?? yt.thumb ?? null,
  };
});

// Sort ranking by subs desc (unknown last)
const ranked = [...channels].sort((a, b) => {
  if (a.isFamilukis) return -1; // always first in CTA, exclude from rank
  if (b.isFamilukis) return 1;
  if (!a.subs && !b.subs) return 0;
  if (!a.subs) return 1;
  if (!b.subs) return -1;
  return (b.subs as number) - (a.subs as number);
});

const quizChannels = channels.filter(c => c.quizInclude);

function fmtSubs(n: number | null) {
  if (!n) return null;
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1).replace('.0','')}M`;
  if (n >= 1_000) return `${Math.round(n / 1_000)}K`;
  return String(n);
}

const statusLabel: Record<string,string> = {
  activo: 'Activo ✅',
  inactivo: 'Inactivo 💤',
  'esporádico': 'Esporádico 🔄',
};
---

<BaseLayout
  title="Ranking de canales YouTube familiares que marcaron una época"
  description="¿Cuántos de estos canales recuerdas? Jugando con Aby, Crazy Haacks, Las Ratitas, Los Jaritos... El ranking definitivo de los canales YouTube que marcaron la infancia de toda una generación."
>
  <main class="rk-main">

    <!-- INTRO -->
    <section id="rk-intro" class="rk-screen">
      <div class="rk-intro-inner">
        <p class="rk-eyebrow">📺 Ranking de nostalgia</p>
        <h1 class="rk-title">¿Cuántos recuerdas?</h1>
        <p class="rk-subtitle">
          Los canales de YouTube familiar en español que marcaron una época.<br>
          Comprueba cuántos recuerdas y descubre dónde están ahora.
        </p>
        <button id="btn-start" class="rk-btn-primary">
          Empezar el quiz
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </button>
        <p class="rk-hint">{quizChannels.length} canales · ~2 minutos</p>
      </div>
    </section>

    <!-- QUIZ -->
    <section id="rk-quiz" class="rk-screen hidden">
      <div class="rk-progress-wrap">
        <div class="rk-progress-bar">
          <div id="rk-progress-fill" class="rk-progress-fill" style="width:0%"></div>
        </div>
        <span id="rk-progress-text" class="rk-progress-text">1 / {quizChannels.length}</span>
      </div>

      <div id="rk-card" class="rk-card">
        <div id="rk-avatar-wrap" class="rk-avatar-wrap">
          <img id="rk-avatar-img" src="" alt="" class="rk-avatar-img hidden" />
          <div id="rk-avatar-fallback" class="rk-avatar-fallback">🎮</div>
        </div>
        <h2 id="rk-ch-name" class="rk-ch-name">Canal</h2>
        <p id="rk-ch-era" class="rk-ch-era">2014 – 2022</p>
        <p id="rk-ch-desc" class="rk-ch-desc">Descripción</p>
        <div class="rk-vote-btns">
          <button id="btn-yes" class="rk-btn-yes">❤️ ¡Lo recuerdo!</button>
          <button id="btn-no"  class="rk-btn-no">🤷 No lo conocía</button>
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section id="rk-results" class="rk-screen hidden">
      <div class="rk-results-inner">
        <div id="rk-result-emoji" class="rk-result-emoji">🏆</div>
        <h2 id="rk-result-title" class="rk-result-title">¡Leyenda!</h2>
        <p  id="rk-result-sub"   class="rk-result-sub">Recuerdas X de Y canales</p>

        <div class="rk-share">
          <button id="btn-share" class="rk-btn-share">📤 Compartir resultado</button>
          <button id="btn-retry" class="rk-btn-outline">🔄 Repetir</button>
        </div>

        <!-- CTA Familukis -->
        <div class="rk-cta-box">
          {channels.find(c => c.isFamilukis)?.thumb
            ? <img src={channels.find(c => c.isFamilukis)!.thumb!} alt="Magic Exploradores" class="rk-cta-avatar" />
            : <span class="rk-cta-emoji">🌊</span>
          }
          <div class="rk-cta-text">
            <p class="rk-cta-title">¿Ya sigues a Los Familukis?</p>
            <p class="rk-cta-desc">El canal de aventuras familiares en España que está escribiendo la próxima era. ¡Somos nosotros!</p>
          </div>
          <a href="https://www.youtube.com/@MagicExploradores" target="_blank" rel="noopener" class="rk-btn-red">Suscribirse</a>
        </div>

        <!-- Full ranking -->
        <h3 class="rk-ranking-title">📊 El ranking completo</h3>
        <div class="rk-ranking-list">
          {ranked.filter(c => !c.isFamilukis).map((ch, i) => (
            <a href={`https://www.youtube.com/${ch.handle.startsWith('@') ? ch.handle : 'c/' + ch.handle}`}
               target="_blank" rel="noopener" class="rk-rank-row">
              <span class="rk-rank-num">{i + 1}</span>
              {ch.thumb
                ? <img src={ch.thumb} alt={ch.name} class="rk-rank-avatar-img" />
                : <span class="rk-rank-avatar-emoji" style={`background:${ch.color}22;color:${ch.color}`}>{ch.emoji}</span>
              }
              <div class="rk-rank-info">
                <span class="rk-rank-name">{ch.name}</span>
                <span class="rk-rank-meta">
                  {ch.era} · {ch.cat}
                  {ch.subs && <> · <strong>{fmtSubs(ch.subs)} subs</strong></>}
                </span>
              </div>
              <span class={`rk-status rk-status--${ch.status === 'esporádico' ? 'esporadico' : ch.status}`}>
                {statusLabel[ch.status]}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<script define:vars={{ quizChannels }}>
  let current = 0;
  let remembered = 0;

  const screens = {
    intro:   document.getElementById('rk-intro'),
    quiz:    document.getElementById('rk-quiz'),
    results: document.getElementById('rk-results'),
  };

  function show(name) {
    Object.values(screens).forEach(s => { s.classList.add('hidden'); });
    screens[name].classList.remove('hidden');
    screens[name].classList.add('rk-fadein');
    setTimeout(() => screens[name].classList.remove('rk-fadein'), 400);
  }

  function updateCard() {
    const ch = quizChannels[current];
    const total = quizChannels.length;

    const img = document.getElementById('rk-avatar-img');
    const fallback = document.getElementById('rk-avatar-fallback');

    if (ch.thumb) {
      img.src = ch.thumb;
      img.alt = ch.name;
      img.classList.remove('hidden');
      fallback.classList.add('hidden');
    } else {
      img.classList.add('hidden');
      fallback.textContent = ch.emoji;
      fallback.style.background = ch.color + '22';
      fallback.style.color = ch.color;
      fallback.classList.remove('hidden');
    }

    document.getElementById('rk-ch-name').textContent = ch.name;
    document.getElementById('rk-ch-era').textContent = `${ch.era} · ${ch.cat}`;
    document.getElementById('rk-ch-desc').textContent = ch.desc;
    document.getElementById('rk-progress-fill').style.width = `${(current / total) * 100}%`;
    document.getElementById('rk-progress-text').textContent = `${current + 1} / ${total}`;

    const card = document.getElementById('rk-card');
    card.classList.remove('rk-slide-in');
    void card.offsetWidth;
    card.classList.add('rk-slide-in');
  }

  function vote(yes) {
    if (yes) remembered++;
    current++;
    current >= quizChannels.length ? showResults() : updateCard();
  }

  function showResults() {
    const total = quizChannels.length;
    const pct = remembered / total;
    let emoji, title;
    if (pct === 1)       { emoji = '🏆'; title = '¡Leyenda del YouTube familiar!'; }
    else if (pct >= 0.7) { emoji = '📺'; title = '¡Veterano de YouTube!'; }
    else if (pct >= 0.4) { emoji = '😊'; title = '¡Conoces el terreno!'; }
    else if (pct >= 0.1) { emoji = '🧐'; title = 'Algo has visto...'; }
    else                 { emoji = '👶'; title = '¡Eras demasiado pequeño!'; }

    document.getElementById('rk-result-emoji').textContent = emoji;
    document.getElementById('rk-result-title').textContent = title;
    document.getElementById('rk-result-sub').textContent = `Recuerdas ${remembered} de ${total} canales`;
    document.getElementById('rk-progress-fill').style.width = '100%';
    show('results');
  }

  document.getElementById('btn-start')?.addEventListener('click', () => { updateCard(); show('quiz'); });
  document.getElementById('btn-yes')?.addEventListener('click',  () => vote(true));
  document.getElementById('btn-no')?.addEventListener('click',   () => vote(false));
  document.getElementById('btn-retry')?.addEventListener('click', () => {
    current = 0; remembered = 0; updateCard(); show('quiz');
  });
  document.getElementById('btn-share')?.addEventListener('click', async () => {
    const text = `Recuerdo ${remembered} de ${quizChannels.length} canales del YouTube familiar en español 📺 ¿Y tú?\n→ https://familukis.com/ranking-canales`;
    if (navigator.share) {
      await navigator.share({ title: '¿Cuántos canales de YouTube recuerdas?', text, url: 'https://familukis.com/ranking-canales' });
    } else {
      await navigator.clipboard.writeText(text);
      const btn = document.getElementById('btn-share');
      btn.textContent = '✅ ¡Copiado!';
      setTimeout(() => { btn.textContent = '📤 Compartir resultado'; }, 2200);
    }
  });
</script>

<style>
  .rk-main {
    min-height: 100vh;
    background: #0f0f0f;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }
  .rk-screen { width: 100%; max-width: 560px; margin: 0 auto; }
  .hidden { display: none !important; }

  @keyframes fadein {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .rk-fadein { animation: fadein 0.35s ease; }

  @keyframes slidein {
    from { opacity: 0; transform: translateX(40px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .rk-slide-in { animation: slidein 0.28s ease; }

  /* INTRO */
  .rk-intro-inner { text-align: center; padding: 3rem 1.5rem; }
  .rk-eyebrow {
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: #e50914; margin-bottom: 1rem;
  }
  .rk-title {
    font-size: clamp(2rem, 5vw, 3rem); font-weight: 800;
    color: #fff; line-height: 1.1; margin-bottom: 1rem;
  }
  .rk-subtitle { font-size: 1rem; color: rgba(255,255,255,0.6); line-height: 1.6; margin-bottom: 2rem; }
  .rk-hint { margin-top: 0.875rem; font-size: 0.75rem; color: rgba(255,255,255,0.3); }

  /* PROGRESS */
  .rk-progress-wrap { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.75rem; }
  .rk-progress-bar { flex: 1; height: 4px; background: rgba(255,255,255,0.1); border-radius: 99px; overflow: hidden; }
  .rk-progress-fill { height: 100%; background: #e50914; border-radius: 99px; transition: width 0.4s ease; }
  .rk-progress-text { font-size: 0.72rem; font-weight: 600; color: rgba(255,255,255,0.35); white-space: nowrap; }

  /* CARD */
  .rk-card {
    background: #1a1a1a; border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px; padding: 2.5rem 2rem; text-align: center;
  }
  .rk-avatar-wrap { width: 96px; height: 96px; border-radius: 50%; margin: 0 auto 1.25rem; overflow: hidden; }
  .rk-avatar-img  { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .rk-avatar-fallback {
    width: 96px; height: 96px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.5rem;
  }
  .rk-ch-name  { font-size: 1.45rem; font-weight: 800; color: #fff; margin-bottom: 0.35rem; }
  .rk-ch-era   { font-size: 0.72rem; color: rgba(255,255,255,0.38); font-weight: 500; margin-bottom: 0.875rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .rk-ch-desc  { font-size: 0.88rem; color: rgba(255,255,255,0.55); line-height: 1.6; margin-bottom: 2rem; min-height: 3.2em; }
  .rk-vote-btns { display: flex; flex-direction: column; gap: 0.75rem; }

  /* BUTTONS */
  .rk-btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: #e50914; color: #fff; font-size: 1rem; font-weight: 700;
    padding: 0.875rem 2rem; border-radius: 8px; border: none; cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .rk-btn-primary:hover { background: #c40812; transform: scale(1.03); }

  .rk-btn-yes {
    background: #1db954; color: #fff; font-size: 1rem; font-weight: 700;
    padding: 0.875rem; border-radius: 10px; border: none; cursor: pointer;
    transition: background 0.2s, transform 0.12s;
  }
  .rk-btn-yes:hover  { background: #17a349; }
  .rk-btn-yes:active { transform: scale(0.97); }

  .rk-btn-no {
    background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.55);
    font-size: 1rem; font-weight: 600; padding: 0.875rem; border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.1); cursor: pointer; transition: background 0.2s;
  }
  .rk-btn-no:hover { background: rgba(255,255,255,0.12); }

  /* RESULTS */
  .rk-results-inner { text-align: center; padding: 1.5rem 0; }
  .rk-result-emoji  { font-size: 4rem; margin-bottom: 0.75rem; animation: fadein 0.4s ease; }
  .rk-result-title  { font-size: 1.75rem; font-weight: 800; color: #fff; margin-bottom: 0.5rem; }
  .rk-result-sub    { font-size: 1rem; color: rgba(255,255,255,0.45); margin-bottom: 1.5rem; }

  .rk-share { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem; }

  .rk-btn-share {
    background: #e50914; color: #fff; font-weight: 700; padding: 0.7rem 1.25rem;
    border-radius: 8px; border: none; cursor: pointer; font-size: 0.88rem;
    transition: background 0.2s;
  }
  .rk-btn-share:hover { background: #c40812; }

  .rk-btn-outline {
    background: transparent; color: rgba(255,255,255,0.55); font-weight: 600;
    padding: 0.7rem 1.25rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.18);
    cursor: pointer; font-size: 0.88rem; transition: border-color 0.2s, color 0.2s;
  }
  .rk-btn-outline:hover { border-color: rgba(255,255,255,0.45); color: #fff; }

  /* CTA */
  .rk-cta-box {
    display: flex; align-items: center; gap: 1rem;
    background: rgba(229,9,20,0.1); border: 1px solid rgba(229,9,20,0.3);
    border-radius: 12px; padding: 1.25rem; margin-bottom: 2.5rem; text-align: left;
  }
  .rk-cta-avatar { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
  .rk-cta-emoji  { font-size: 2rem; flex-shrink: 0; }
  .rk-cta-text   { flex: 1; }
  .rk-cta-title  { font-size: 0.92rem; font-weight: 700; color: #fff; margin-bottom: 0.2rem; }
  .rk-cta-desc   { font-size: 0.75rem; color: rgba(255,255,255,0.45); line-height: 1.4; }
  .rk-btn-red {
    flex-shrink: 0; background: #e50914; color: #fff; font-weight: 700;
    font-size: 0.8rem; padding: 0.55rem 0.9rem; border-radius: 6px;
    text-decoration: none; transition: background 0.2s; white-space: nowrap;
  }
  .rk-btn-red:hover { background: #c40812; }

  /* RANKING */
  .rk-ranking-title {
    font-size: 0.72rem; font-weight: 700; color: rgba(255,255,255,0.4);
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.875rem; text-align: left;
  }
  .rk-ranking-list { display: flex; flex-direction: column; gap: 0.45rem; margin-bottom: 3rem; }

  .rk-rank-row {
    display: flex; align-items: center; gap: 0.875rem;
    background: #1a1a1a; border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px; padding: 0.75rem 1rem;
    text-decoration: none; transition: background 0.2s, border-color 0.2s;
  }
  .rk-rank-row:hover { background: #222; border-color: rgba(255,255,255,0.13); }

  .rk-rank-num { font-size: 0.7rem; font-weight: 700; color: rgba(255,255,255,0.22); width: 1.1rem; text-align: center; flex-shrink: 0; }

  .rk-rank-avatar-img   { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
  .rk-rank-avatar-emoji { width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }

  .rk-rank-info { flex: 1; text-align: left; min-width: 0; }
  .rk-rank-name { display: block; font-size: 0.85rem; font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rk-rank-meta { display: block; font-size: 0.7rem; color: rgba(255,255,255,0.32); margin-top: 0.1rem; }
  .rk-rank-meta strong { color: rgba(255,255,255,0.6); font-weight: 600; }

  .rk-status { font-size: 0.65rem; font-weight: 600; padding: 0.22rem 0.55rem; border-radius: 99px; white-space: nowrap; flex-shrink: 0; }
  .rk-status--activo     { background: rgba(29,185,84,0.15); color: #1db954; }
  .rk-status--inactivo   { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.3); }
  .rk-status--esporadico { background: rgba(253,203,110,0.15); color: #fdcb6e; }

  @media (max-width: 480px) {
    .rk-card { padding: 2rem 1.25rem; }
    .rk-cta-box { flex-wrap: wrap; }
    .rk-btn-red { width: 100%; text-align: center; }
  }
</style>
