---
import BaseLayout from '../layouts/BaseLayout.astro';
import ytData from '../data/channels_yt.json';
import videos from '../data/nostalgia_videos.json';

const channelDefs = [
  { name: 'Los Polinesios',          handle: '@LosPolinesios',        emoji: '🌺', color: '#ff7675', era: '2013 – hoy',   status: 'activo',     cat: 'Familia & Vlogs',          desc: 'La familia youtuber más grande de habla hispana. Tres hermanos que convirtieron su vida en espectáculo.', quizInclude: true },
  { name: 'Rovi23',                  handle: '@Rovi23',               emoji: '🎮', color: '#a29bfe', era: '2013 – hoy',   status: 'activo',     cat: 'Gaming & Entretenimiento', desc: 'El referente del gaming familiar español. Retos, bromas y una energía que enganchaba a toda la familia.', quizInclude: true },
  { name: 'Los juguetes de Arantxa', handle: '@LosjuguetesdeArantxa', emoji: '🧸', color: '#fd79a8', era: '2016 – 2022',  status: 'inactivo',   cat: 'Juguetes',                 desc: 'Una niña de verdad abriendo sus juguetes. Auténtica y cercana, con una colección que daba envidia.', quizInclude: true },
  { name: 'The Crazy Haacks',        handle: '@TheCrazyHaacks',       emoji: '🧪', color: '#00cec9', era: '2017 – hoy',   status: 'activo',     cat: 'Ciencia & Experimentos',   desc: 'Experimentos imposibles que hacían rezar a los padres para que no los intentaras en casa.', quizInclude: true },
  { name: 'Jugando con Aby',         handle: '@JugandoconAby',        emoji: '🎀', color: '#e17055', era: '2014 – 2022',  status: 'esporádico', cat: 'Juguetes & Gaming',        desc: 'La reina del unboxing y los juguetes. Millones de niños se despertaban los sábados esperando su nuevo vídeo.', quizInclude: true },
  { name: 'Familia Carameluchi',     handle: '@FamiliaCarameluchi',   emoji: '🍬', color: '#fdcb6e', era: '2015 – hoy',   status: 'esporádico', cat: 'Familia',                  desc: 'La familia más dulce de YouTube. Rutinas, retos y momentos cotidianos que se sentían cercanos de verdad.', quizInclude: true },
  { name: 'Abreló Toys',             handle: 'AbrelóToys',            emoji: '🎁', color: '#6c5ce7', era: '2015 – 2021',  status: 'inactivo',   cat: 'Juguetes',                 desc: 'Unboxings épicos que hacían que todos los niños quisieran esos mismos juguetes en Navidad.', quizInclude: true },
  { name: 'Tremendig Girls',         handle: '@HermanosTremending',   emoji: '👯', color: '#fd79a8', era: '2016 – hoy',   status: 'activo',     cat: 'Familia & Hermanas',       desc: 'Las hermanas Tremending con sus challenges, vlogs y una energía que arrasó en toda España.', quizInclude: true },
  { name: 'Los Jaritos',             handle: '@losjaritos1023',        emoji: '🫙', color: '#55efc4', era: '2018 – hoy',   status: 'esporádico', cat: 'Familia & Vlogs',          desc: 'Una familia normal con una cámara y muchas ganas de compartir. La esencia del vlog familiar de barrio.', quizInclude: true },
  { name: 'La diversión de Martina', handle: '@MartinaDAntiochia',    emoji: '🌈', color: '#ff9ff3', era: '2015 – 2021',  status: 'inactivo',   cat: 'Familia',                  desc: 'Martina y su familia en vlogs, retos y momentos que parecían sacados de la familia perfecta.', quizInclude: true },
  { name: 'Las Ratitas pandilleras', handle: '@RatitasPandilleras',   emoji: '🐭', color: '#badc58', era: '2016 – 2023',  status: 'esporádico', cat: 'Familia & Hermanas',       desc: 'Tres hermanas, caos total y risas garantizadas. El caos familiar convertido en entretenimiento puro.', quizInclude: true },
  { name: 'Los Familukis',           handle: '@MagicExploradores',    emoji: '🌊', color: '#e50914', era: '2020 – hoy',   status: 'activo',     cat: 'Familia & Aventuras',      desc: '¡Ese somos nosotros! Parques, aventuras y momentos reales en familia. El relevo generacional está aquí 👋', quizInclude: false, isFamilukis: true, staticThumb: '/favicon-512x512.png' },
];

const channels = channelDefs.map(ch => {
  const yt = (ytData as any)[ch.name] ?? {};
  return { ...ch, id: yt.channel_id ?? null, subs: yt.subscriber_count ?? null, thumb: (ch as any).staticThumb ?? yt.thumb ?? null };
});

const ranked = [...channels].sort((a, b) => {
  if ((a as any).isFamilukis) return 1;
  if ((b as any).isFamilukis) return -1;
  if (!a.subs && !b.subs) return 0;
  if (!a.subs) return 1;
  if (!b.subs) return -1;
  return (b.subs as number) - (a.subs as number);
});

const quizChannels = channels.filter(c => c.quizInclude);
const familukis = channels.find(c => (c as any).isFamilukis);

const enriched = (videos as any[]).map(v => {
  const ch = channelDefs.find(c => c.name === v.channel);
  return { ...v, channelThumb: (ytData as any)[v.channel]?.thumb ?? null, color: ch?.color ?? '#e50914', emoji: ch?.emoji ?? '📺' };
});

function fmtSubs(n: number | null) {
  if (!n) return null;
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1).replace('.0', '')}M`;
  if (n >= 1_000) return `${Math.round(n / 1_000)}K`;
  return String(n);
}

const statusLabel: Record<string, string> = { activo: 'Activo ✅', inactivo: 'Inactivo 💤', 'esporádico': 'Esporádico 🔄' };
---

<BaseLayout
  title="¿Los recuerdas? Canales YouTube familiar en español — Jugando con Aby, Las Ratitas, Crazy Haacks"
  description="Quiz de nostalgia, ruleta de vídeos y ranking de los canales YouTube familiar en español que marcaron tu infancia: Jugando con Aby, Las Ratitas pandilleras, Los Polinesios, The Crazy Haacks, La diversión de Martina, Rovi23 y más. Solo vídeos de antes de 2021."
  canonicalUrl="https://familukis.com/ranking-canales"
>
  <slot name="head" slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "¿Qué canales de YouTube familiar marcaron los años 2015-2020?", "acceptedAnswer": { "@type": "Answer", "text": "Los canales más populares del YouTube familiar en español fueron: Jugando con Aby, Las Ratitas pandilleras, Los Polinesios, The Crazy Haacks, La diversión de Martina, Rovi23, Los juguetes de Arantxa, Familia Carameluchi, Abreló Toys, Tremendig Girls y Los Jaritos." } },
        { "@type": "Question", "name": "¿Dónde puedo ver vídeos de Jugando con Aby?", "acceptedAnswer": { "@type": "Answer", "text": "Jugando con Aby estuvo activo entre 2014 y 2022 en YouTube. Puedes explorar sus vídeos más populares en esta misma página con nuestra ruleta nostálgica." } },
        { "@type": "Question", "name": "¿Sigue activo el canal Las Ratitas pandilleras?", "acceptedAnswer": { "@type": "Answer", "text": "Las Ratitas pandilleras estuvo muy activo entre 2016 y 2023. Actualmente publican de forma esporádica." } }
      ]
    })} />
  </slot>

  <main class="rk-main">
    <div class="rk-container">

      <!-- HERO -->
      <header class="rk-hero">
        <p class="rk-eyebrow">📺 YouTube Familiar · Nostalgia</p>
        <h1 class="rk-h1">¿Los recuerdas?</h1>
        <p class="rk-hero-sub">
          Los canales de YouTube familiar en español que marcaron una generación.<br>
          <strong>Quiz · Ruleta · Ranking</strong>
        </p>
        <div class="rk-hero-tags">
          {quizChannels.slice(0,6).map(ch => (
            <span class="rk-tag" style={`--c:${ch.color}`}>{ch.emoji} {ch.name}</span>
          ))}
        </div>
      </header>

      <!-- ── MINIJUEGO 1: QUIZ ─────────────────────────────────── -->
      <section class="rk-section" id="sec-quiz" aria-label="Quiz de nostalgia">
        <div class="rk-sec-header">
          <h2 class="rk-sec-h2">🎯 Quiz de nostalgia</h2>
          <p class="rk-sec-p">Canal a canal — ¿cuántos recuerdas?</p>
        </div>

        <!-- Start panel -->
        <div id="qz-start" class="qz-start-panel">
          <button id="btn-start" class="rk-btn-primary">
            Empezar el quiz
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          </button>
          <p class="rk-hint">{quizChannels.length} canales · ~2 minutos</p>
        </div>

        <!-- Playing panel -->
        <div id="qz-playing" class="hidden">
          <div class="qz-progress-wrap">
            <div class="qz-progress-bar"><div id="qz-fill" class="qz-fill" style="width:0%"></div></div>
            <span id="qz-ptext" class="qz-ptext">1 / {quizChannels.length}</span>
          </div>
          <div id="qz-card" class="qz-card">
            <div class="qz-avatar-wrap">
              <img id="qz-avatar-img" src="" alt="" class="qz-avatar-img hidden" />
              <div id="qz-avatar-fb" class="qz-avatar-fb">🎮</div>
            </div>
            <h3 id="qz-name" class="qz-name">Canal</h3>
            <p id="qz-era" class="qz-era">2014 – 2022</p>
            <p id="qz-desc" class="qz-desc">Descripción</p>
            <div class="qz-vote-btns">
              <button id="btn-yes" class="qz-btn-yes">❤️ ¡Lo recuerdo!</button>
              <button id="btn-no"  class="qz-btn-no">🤷 No lo conocía</button>
            </div>
          </div>
        </div>

        <!-- Result panel -->
        <div id="qz-result" class="hidden qz-result-panel">
          <div id="qz-result-emoji" class="qz-result-emoji">🏆</div>
          <h3 id="qz-result-title" class="qz-result-title">¡Leyenda!</h3>
          <p  id="qz-result-sub"   class="qz-result-sub">Recuerdas X de Y canales</p>
          <div class="qz-result-btns">
            <button id="btn-share" class="rk-btn-primary">📤 Compartir</button>
            <button id="btn-retry" class="rk-btn-outline">🔄 Repetir</button>
          </div>
        </div>
      </section>

      <!-- ── MINIJUEGO 2: RULETA ───────────────────────────────── -->
      <section class="rk-section" id="sec-ruleta" aria-label="Ruleta nostálgica de YouTube">
        <div class="rk-sec-header">
          <h2 class="rk-sec-h2">📼 Ruleta nostálgica</h2>
          <p class="rk-sec-p">Gira y viaja a un vídeo aleatorio de antes de 2021.</p>
        </div>

        <!-- Slot ticker -->
        <div class="rl-slot-wrap">
          <div class="rl-slot-mask">
            <div id="rl-slot" class="rl-slot">
              {[...quizChannels, ...quizChannels, ...quizChannels].map(ch => (
                <div class="rl-slot-item" style={`--c:${ch.color}`}>
                  <span class="rl-slot-emoji">{ch.emoji}</span>
                  <span class="rl-slot-name">{ch.name}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="rl-slot-arrow rl-slot-arrow--l">◀</div>
          <div class="rl-slot-arrow rl-slot-arrow--r">▶</div>
        </div>

        <button id="rl-btn" class="rl-btn">
          <span id="rl-btn-text">¡Girar!</span>
          <svg id="rl-spinner" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="hidden">
            <path d="M12 4V2A10 10 0 0 0 2 12h2a8 8 0 0 1 8-8Z"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.7s" repeatCount="indefinite"/></path>
          </svg>
        </button>

        <!-- Video card -->
        <div id="rl-card" class="rl-card hidden">
          <div class="rl-tv">
            <div class="rl-tv-screen">
              <div class="rl-scanlines"></div>
              <img id="rl-thumb" src="" alt="" class="rl-thumb" />
              <a id="rl-play" href="#" target="_blank" rel="noopener" class="rl-play-btn" aria-label="Ver vídeo">
                <svg viewBox="0 0 24 24" fill="white" width="48" height="48"><path d="M8 5v14l11-7z"/></svg>
              </a>
            </div>
            <div class="rl-tv-base"></div>
            <div class="rl-tv-stand"></div>
          </div>
          <div class="rl-card-info">
            <div id="rl-ch-badge" class="rl-ch-badge">
              <img id="rl-ch-thumb" src="" alt="" class="rl-ch-avatar" />
              <span id="rl-ch-name" class="rl-ch-name">Canal</span>
            </div>
            <h3 id="rl-vid-title" class="rl-vid-title">Título del vídeo</h3>
            <p  id="rl-vid-year"  class="rl-vid-year">2018</p>
            <div class="rl-card-actions">
              <a id="rl-watch-btn" href="#" target="_blank" rel="noopener" class="rl-watch-btn">▶ Ver en YouTube</a>
              <button id="rl-otra-btn" class="rl-otra-btn">🎲 ¡Otra!</button>
            </div>
          </div>
        </div>

        <p class="rl-counter"><span id="rl-count">0</span> vídeos explorados · <strong>{enriched.length}</strong> en el archivo</p>
      </section>

      <!-- ── CTA FAMILUKIS ────────────────────────────────────── -->
      {familukis && (
        <div class="rk-cta-box">
          {familukis.thumb
            ? <img src={familukis.thumb} alt="Los Familukis" class="rk-cta-avatar" />
            : <span class="rk-cta-emoji">🌊</span>
          }
          <div class="rk-cta-text">
            <p class="rk-cta-title">¿Ya sigues a Los Familukis?</p>
            <p class="rk-cta-desc">El canal de aventuras en familia que está escribiendo la próxima era. ¡Somos nosotros!</p>
          </div>
          <a href="https://www.youtube.com/@MagicExploradores" target="_blank" rel="noopener" class="rk-btn-red">Suscribirse</a>
        </div>
      )}

      <!-- ── RANKING ────────────────────────────────────────── -->
      <section class="rk-section" id="sec-ranking" aria-label="Ranking canales YouTube familiar">
        <div class="rk-sec-header">
          <h2 class="rk-sec-h2">📊 El ranking completo</h2>
          <p class="rk-sec-p">Ordenado por suscriptores actuales · datos YouTube API</p>
        </div>
        <div class="rk-ranking-list">
          {ranked.filter(c => !(c as any).isFamilukis).map((ch, i) => (
            <a href={`https://www.youtube.com/${ch.handle.startsWith('@') ? ch.handle : 'c/' + ch.handle}`}
               target="_blank" rel="noopener" class="rk-rank-row">
              <span class="rk-rank-num">{i + 1}</span>
              {ch.thumb
                ? <img src={ch.thumb} alt={ch.name} class="rk-rank-avatar-img" />
                : <span class="rk-rank-avatar-emoji" style={`background:${ch.color}22;color:${ch.color}`}>{ch.emoji}</span>
              }
              <div class="rk-rank-info">
                <span class="rk-rank-name">{ch.name}</span>
                <span class="rk-rank-meta">
                  {ch.era} · {ch.cat}
                  {ch.subs && <> · <strong>{fmtSubs(ch.subs)} subs</strong></>}
                </span>
              </div>
              <span class={`rk-status rk-status--${ch.status === 'esporádico' ? 'esporadico' : ch.status}`}>
                {statusLabel[ch.status]}
              </span>
            </a>
          ))}
        </div>
      </section>

    </div>
  </main>
</BaseLayout>

<!-- ── QUIZ SCRIPT ─────────────────────────────────────────────── -->
<script define:vars={{ quizChannels }}>
  let current = 0;
  let remembered = 0;

  const panels = {
    start:   document.getElementById('qz-start'),
    playing: document.getElementById('qz-playing'),
    result:  document.getElementById('qz-result'),
  };

  function showPanel(name) {
    Object.entries(panels).forEach(([k, el]) => el.classList.toggle('hidden', k !== name));
  }

  function updateCard() {
    const ch = quizChannels[current];
    const total = quizChannels.length;
    const img = document.getElementById('qz-avatar-img');
    const fb  = document.getElementById('qz-avatar-fb');

    if (ch.thumb) {
      img.src = ch.thumb; img.alt = ch.name;
      img.classList.remove('hidden'); fb.classList.add('hidden');
    } else {
      img.classList.add('hidden');
      fb.textContent = ch.emoji;
      fb.style.background = ch.color + '22';
      fb.style.color = ch.color;
      fb.classList.remove('hidden');
    }

    document.getElementById('qz-name').textContent = ch.name;
    document.getElementById('qz-era').textContent  = `${ch.era} · ${ch.cat}`;
    document.getElementById('qz-desc').textContent = ch.desc;
    document.getElementById('qz-fill').style.width = `${(current / total) * 100}%`;
    document.getElementById('qz-ptext').textContent = `${current + 1} / ${total}`;

    const card = document.getElementById('qz-card');
    card.classList.remove('qz-slide-in');
    void card.offsetWidth;
    card.classList.add('qz-slide-in');
  }

  function vote(yes) {
    if (yes) remembered++;
    current++;
    current >= quizChannels.length ? showResults() : updateCard();
  }

  function showResults() {
    const total = quizChannels.length;
    const pct = remembered / total;
    let emoji, title;
    if (pct === 1)       { emoji = '🏆'; title = '¡Leyenda del YouTube familiar!'; }
    else if (pct >= 0.7) { emoji = '📺'; title = '¡Veterano de YouTube!'; }
    else if (pct >= 0.4) { emoji = '😊'; title = '¡Conoces el terreno!'; }
    else if (pct >= 0.1) { emoji = '🧐'; title = 'Algo has visto...'; }
    else                 { emoji = '👶'; title = '¡Eras demasiado pequeño!'; }

    document.getElementById('qz-result-emoji').textContent = emoji;
    document.getElementById('qz-result-title').textContent = title;
    document.getElementById('qz-result-sub').textContent   = `Recuerdas ${remembered} de ${total} canales`;
    document.getElementById('qz-fill').style.width = '100%';
    showPanel('result');
  }

  document.getElementById('btn-start')?.addEventListener('click', () => { updateCard(); showPanel('playing'); });
  document.getElementById('btn-yes')?.addEventListener('click',   () => vote(true));
  document.getElementById('btn-no')?.addEventListener('click',    () => vote(false));
  document.getElementById('btn-retry')?.addEventListener('click', () => { current = 0; remembered = 0; updateCard(); showPanel('playing'); });
  document.getElementById('btn-share')?.addEventListener('click', async () => {
    const text = `Recuerdo ${remembered} de ${quizChannels.length} canales del YouTube familiar en español 📺 ¿Y tú?\n→ https://familukis.com/ranking-canales`;
    if (navigator.share) {
      await navigator.share({ title: '¿Cuántos canales de YouTube recuerdas?', text, url: 'https://familukis.com/ranking-canales' });
    } else {
      await navigator.clipboard.writeText(text);
      const btn = document.getElementById('btn-share');
      btn.textContent = '✅ ¡Copiado!';
      setTimeout(() => { btn.textContent = '📤 Compartir'; }, 2200);
    }
  });
</script>

<!-- ── RULETA SCRIPT ────────────────────────────────────────────── -->
<script define:vars={{ enriched, quizChannels }}>
  const rlBtn     = document.getElementById('rl-btn');
  const rlBtnText = document.getElementById('rl-btn-text');
  const rlSpinner = document.getElementById('rl-spinner');
  const rlCard    = document.getElementById('rl-card');
  const rlSlot    = document.getElementById('rl-slot');
  const rlThumb   = document.getElementById('rl-thumb');
  const rlPlay    = document.getElementById('rl-play');
  const rlChThumb = document.getElementById('rl-ch-thumb');
  const rlChName  = document.getElementById('rl-ch-name');
  const rlVidTitle= document.getElementById('rl-vid-title');
  const rlVidYear = document.getElementById('rl-vid-year');
  const rlWatchBtn= document.getElementById('rl-watch-btn');
  const rlOtraBtn = document.getElementById('rl-otra-btn');
  const rlCounter = document.getElementById('rl-count');

  let rlSpinning = false;
  let explored = parseInt(localStorage.getItem('rl_explored') || '0');
  rlCounter.textContent = explored;

  const channelNames = quizChannels.map(c => c.name);
  const slotItems = rlSlot.querySelectorAll('.rl-slot-item');
  const itemW = 160;

  function spin() {
    if (rlSpinning) return;
    rlSpinning = true;
    rlCard.classList.add('hidden');
    rlBtnText.textContent = 'Girando...';
    rlSpinner.classList.remove('hidden');
    rlBtn.disabled = true;

    const video = enriched[Math.floor(Math.random() * enriched.length)];
    const targetIdx = channelNames.indexOf(video.channel);
    const totalItems = slotItems.length;
    const targetItem = Math.floor(totalItems / 3) + targetIdx;
    const targetOffset = targetItem * itemW;

    rlSlot.style.transition = 'none';
    rlSlot.style.transform = 'translateX(0)';

    setTimeout(() => {
      rlSlot.style.transition = 'transform 2s cubic-bezier(0.25, 0.46, 0.1, 1)';
      rlSlot.style.transform = `translateX(-${targetOffset}px)`;
    }, 50);

    setTimeout(() => {
      rlThumb.src = video.thumb || `https://img.youtube.com/vi/${video.id}/hqdefault.jpg`;
      rlThumb.alt = video.title;
      const ytUrl = `https://www.youtube.com/watch?v=${video.id}`;
      rlPlay.href = ytUrl;
      rlWatchBtn.href = ytUrl;

      if (video.channelThumb) {
        rlChThumb.src = video.channelThumb;
        rlChThumb.style.display = 'block';
      } else {
        rlChThumb.style.display = 'none';
      }
      rlChName.textContent   = video.channel;
      rlVidTitle.textContent = video.title;
      rlVidYear.textContent  = video.published ? video.published.slice(0, 4) : '';

      rlCard.classList.remove('hidden');
      rlCard.classList.add('rl-reveal');
      setTimeout(() => rlCard.classList.remove('rl-reveal'), 600);

      explored++;
      localStorage.setItem('rl_explored', explored);
      rlCounter.textContent = explored;

      rlSpinning = false;
      rlBtnText.textContent = '¡Girar de nuevo!';
      rlSpinner.classList.add('hidden');
      rlBtn.disabled = false;

      setTimeout(() => {
        rlSlot.style.transition = 'none';
        rlSlot.style.transform = 'translateX(0)';
      }, 500);
    }, 2200);
  }

  rlBtn.addEventListener('click', spin);
  rlOtraBtn.addEventListener('click', spin);
</script>

<style>
  /* ── Layout ── */
  .rk-main {
    background: #0f0f0f;
    min-height: 100vh;
    padding: 0 1rem 6rem;
  }
  .rk-container {
    max-width: 680px;
    margin: 0 auto;
  }
  .hidden { display: none !important; }

  /* ── Hero ── */
  .rk-hero {
    text-align: center;
    padding: 4rem 1rem 2.5rem;
  }
  .rk-eyebrow {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: #e50914; margin-bottom: 0.875rem;
  }
  .rk-h1 {
    font-size: clamp(2.4rem, 6vw, 3.5rem); font-weight: 800;
    color: #fff; line-height: 1.05; margin-bottom: 0.875rem;
  }
  .rk-hero-sub {
    font-size: 1rem; color: rgba(255,255,255,0.5);
    line-height: 1.6; margin-bottom: 1.5rem;
  }
  .rk-hero-sub strong { color: rgba(255,255,255,0.8); }
  .rk-hero-tags {
    display: flex; flex-wrap: wrap; gap: 0.45rem;
    justify-content: center;
  }
  .rk-tag {
